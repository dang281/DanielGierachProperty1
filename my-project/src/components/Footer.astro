---
const year = new Date().getFullYear();
---

<footer style="background:var(--color-surface-0);border-top:1px solid rgba(72,72,72,0.15);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12 py-16 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex flex-col leading-none mb-6">
          <span style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;font-style:italic;color:var(--color-text-primary);letter-spacing:0.04em;">
            Dan's
          </span>
          <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.28em;text-transform:uppercase;color:var(--color-gold);">
            Website
          </span>
        </div>
        <p style="font-size:0.825rem;line-height:1.75;color:var(--color-text-muted);max-width:24ch;">
          Realising the full potential of your home since 2005.
        </p>
        <div class="flex gap-5 mt-6">
          {[
            { label: 'Instagram', path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
            { label: 'Facebook', path: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
            { label: 'LinkedIn', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
          ].map(s => (
            <a href="#" aria-label={s.label} style="color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d={s.path}/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Services -->
      <div>
        <p class="eyebrow mb-6">Services</p>
        <ul class="flex flex-col gap-3">
          {['Buy a Property','Sell Your Home','Rental Appraisal','Property Management','Prestige Collection','Commercial'].map(item => (
            <li><a href="#" style="font-size:0.825rem;color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">{item}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="eyebrow mb-6">Company</p>
        <ul class="flex flex-col gap-3">
          {['Our Story','Meet the Team','Awards','News & Insights','Careers','Contact'].map(item => (
            <li><a href="#" style="font-size:0.825rem;color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">{item}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="eyebrow mb-6">Contact</p>
        <ul class="flex flex-col gap-5">
          <li>
            <p style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.3rem;">Address</p>
            <p style="font-size:0.825rem;color:var(--color-text-secondary);line-height:1.65;">Level 1, 42 Pacific Highway<br/>Sydney NSW 2000</p>
          </li>
          <li>
            <p style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.3rem;">Phone</p>
            <a href="tel:+61293339999" style="font-size:0.825rem;color:var(--color-text-secondary);">(02) 9333 9999</a>
          </li>
          <li>
            <p style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.3rem;">Email</p>
            <a href="mailto:dan@danswebsite.com.au" style="font-size:0.825rem;color:var(--color-text-secondary);">dan@danswebsite.com.au</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8" style="border-top:1px solid rgba(72,72,72,0.15);">
      <p style="font-size:0.7rem;color:var(--color-text-muted);letter-spacing:0.08em;text-transform:uppercase;">
        &copy; {year} Dan's Website. All rights reserved.
      </p>
      <div class="flex gap-6">
        {['Privacy Policy','Terms of Use','Sitemap'].map(item => (
          <a href="#" style="font-size:0.7rem;color:var(--color-text-muted);letter-spacing:0.08em;text-transform:uppercase;transition:color 0.2s;" onmouseover="this.style.color='var(--color-text-secondary)'" onmouseout="this.style.color='var(--color-text-muted)'">{item}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
