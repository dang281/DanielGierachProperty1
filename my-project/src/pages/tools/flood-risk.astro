---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { suburbs } from '../../data/suburbs';
---

<ToolLayout
  title="Flood Risk Checker"
  description="Understand flood risk, council zones, and insurance implications for Sydney suburbs before you buy."
  tool="Flood Risk"
  phase="Buyer Tools"
>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 pt-8">

    <!-- Inputs -->
    <div class="lg:col-span-3 flex flex-col gap-6">

      <!-- Suburb selector -->
      <div style="background:var(--color-surface-3);padding:2rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:1rem;">Select Suburb</label>
        <select id="suburb-select" class="obs-select" style="width:100%;">
          <option value="">Choose a suburb...</option>
          {suburbs.map(s => (
            <option value={s.slug}>{s.name} ({s.postcode})</option>
          ))}
        </select>
      </div>

      <!-- Risk display -->
      <div id="risk-panel" style="display:none;">
        <div id="risk-card" style="background:var(--color-surface-3);padding:2rem;">
          <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:1.5rem;">
            <div id="risk-icon" style="width:56px;height:56px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;"></div>
            <div>
              <p style="font-size:0.55rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-text-muted);">Flood Risk Rating</p>
              <p id="risk-level" style="font-family:var(--font-serif);font-size:2rem;font-weight:400;line-height:1.1;"></p>
            </div>
          </div>

          <div id="risk-detail" class="flex flex-col gap-3"></div>
        </div>

        <!-- What this means -->
        <div style="background:var(--color-surface-3);padding:2rem;margin-top:1.5rem;">
          <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:1rem;">What This Means for Buyers</label>
          <div id="implications" class="flex flex-col gap-3"></div>
        </div>
      </div>

      <!-- No selection state -->
      <div id="empty-state" style="background:var(--color-surface-3);padding:3rem 2rem;text-align:center;">
        <p style="font-size:2rem;margin-bottom:1rem;">🌊</p>
        <p style="font-size:0.85rem;color:var(--color-text-muted);line-height:1.7;">Select a suburb above to view flood risk information, insurance implications, and what to look out for before you buy.</p>
      </div>
    </div>

    <!-- Info panel -->
    <div class="lg:col-span-2">
      <div style="background:var(--color-surface-3);padding:2rem;margin-bottom:1.5rem;">
        <h3 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:var(--color-text-primary);margin-bottom:1.25rem;border-bottom:1px solid rgba(72,72,72,0.2);padding-bottom:0.75rem;">Risk Level Guide</h3>
        <div class="flex flex-col gap-3">
          {[
            { level: 'Low', color: '#a8e6a3', desc: 'Minimal flood history. Insurance standard rates.' },
            { level: 'Medium', color: '#ffdd79', desc: 'Some flood events on record. Insurance may be higher.' },
            { level: 'High', color: '#f4a261', desc: 'Regular flood events. Insurance premiums significantly elevated.' },
            { level: 'Very High', color: 'rgba(192,57,43,0.9)', desc: 'Significant flood risk. Specialist insurance required. Strata / council flood mapping essential.' },
          ].map(r => (
            <div style={`display:flex;gap:1rem;align-items:flex-start;padding:0.75rem;background:var(--color-surface-4);border-left:3px solid ${r.color};`}>
              <div>
                <p style={`font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:${r.color};margin-bottom:0.25rem;`}>{r.level}</p>
                <p style="font-size:0.75rem;color:var(--color-text-muted);line-height:1.6;">{r.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div style="background:var(--color-surface-3);padding:2rem;margin-bottom:1.5rem;">
        <h3 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:var(--color-text-primary);margin-bottom:1.25rem;border-bottom:1px solid rgba(72,72,72,0.2);padding-bottom:0.75rem;">Buyer Checklist</h3>
        <div class="flex flex-col gap-2">
          {[
            'Request Section 10.7 Planning Certificate from council',
            'Check NSW Flood Data (SEED platform)',
            'Review strata report flood history (if applicable)',
            'Get flood-specific insurance quotes before exchange',
            'Check if property has been raised or flood-proofed',
            'Ask about historical flood events from neighbours',
          ].map((item, i) => (
            <div style="display:flex;gap:0.75rem;align-items:flex-start;padding:0.5rem 0;border-bottom:1px solid rgba(72,72,72,0.1);">
              <span style="font-size:0.7rem;font-weight:700;color:var(--color-gold);flex-shrink:0;margin-top:0.1rem;">{String(i+1).padStart(2,'0')}</span>
              <span style="font-size:0.78rem;color:var(--color-text-secondary);line-height:1.5;">{item}</span>
            </div>
          ))}
        </div>
      </div>

      <a href="/appraisal" class="btn-gold" style="width:100%;justify-content:center;">
        Discuss Due Diligence →
      </a>
    </div>
  </div>
</ToolLayout>

<script>
  const RISK_CONFIG: Record<string, { color: string; bg: string; icon: string; details: string[]; implications: { icon: string; text: string }[] }> = {
    'Low': {
      color: '#a8e6a3',
      bg: 'rgba(168,230,163,0.06)',
      icon: '✅',
      details: [
        'No known flood planning controls',
        'Standard insurance rates apply',
        'No council flood overlay on most properties',
        'Low likelihood of overland or catchment flooding',
      ],
      implications: [
        { icon: '💰', text: 'Standard home and contents insurance available at normal market rates.' },
        { icon: '📋', text: 'Section 10.7 certificate unlikely to show flood constraints.' },
        { icon: '🏠', text: 'Lenders comfortable with standard LVR without flood conditions.' },
      ],
    },
    'Medium': {
      color: '#ffdd79',
      bg: 'rgba(255,221,121,0.06)',
      icon: '⚠️',
      details: [
        'Some recorded flood events in suburb history',
        'Parts of suburb may be in flood planning areas',
        'Insurance premiums 20–50% above average',
        'Council may impose conditions on development',
      ],
      implications: [
        { icon: '💰', text: 'Insurance premiums elevated — obtain quotes before exchange.' },
        { icon: '📋', text: 'Request Section 10.7 certificate and check for flood overlay.' },
        { icon: '🔍', text: 'Investigate specific street and property elevation, not just suburb.' },
      ],
    },
    'High': {
      color: '#f4a261',
      bg: 'rgba(244,162,97,0.06)',
      icon: '🔶',
      details: [
        'Regular flood events on record',
        'Council flood planning overlay on many properties',
        'Insurance 100–300% premium loading common',
        'Some lenders apply conditions or reduced LVR',
        'May affect future saleability and price growth',
      ],
      implications: [
        { icon: '💰', text: 'Specialist flood insurance likely required — budget for significant annual premiums.' },
        { icon: '📋', text: 'Section 10.7 almost certain to show flood constraints — review carefully.' },
        { icon: '🏦', text: 'Some lenders may require 30%+ deposit or decline entirely.' },
        { icon: '📉', text: 'Flood risk may suppress price growth and limit buyer pool at resale.' },
      ],
    },
    'Very High': {
      color: 'rgba(192,57,43,0.9)',
      bg: 'rgba(192,57,43,0.06)',
      icon: '🚨',
      details: [
        'Significant and recurring flood history',
        'Council flood maps show frequent inundation areas',
        'Some properties may be uninsurable at standard rates',
        'Development and renovation may be restricted',
        'Climate change increasing risk over time',
      ],
      implications: [
        { icon: '💰', text: 'Insurance may be unaffordable or unavailable — seek specialist brokers.' },
        { icon: '📋', text: 'Section 10.7 will show significant flood constraints — legal review essential.' },
        { icon: '🏦', text: 'Many mainstream lenders will decline or require very low LVR.' },
        { icon: '⚖️', text: 'Seek independent legal and building advice before proceeding.' },
        { icon: '📉', text: 'Resale may be difficult — significant impact on future value.' },
      ],
    },
  };

  const SUBURB_DATA: Record<string, { name: string; risk: string; notes: string }> = {
    'mosman':      { name: 'Mosman',      risk: 'Low',    notes: 'Elevated topography throughout most of the suburb. Some lower-lying pockets near Balmoral and harbour foreshore have minor risk.' },
    'double-bay':  { name: 'Double Bay',  risk: 'Low',    notes: 'Generally low flood risk. Some properties near Double Bay harbour foreshore may have minor coastal inundation risk in extreme weather events.' },
    'vaucluse':    { name: 'Vaucluse',    risk: 'Low',    notes: 'Elevated headland position with very low flood risk. Ocean-facing properties carry coastal erosion risk rather than flood risk.' },
    'cremorne':    { name: 'Cremorne',    risk: 'Low',    notes: 'Most of Cremorne is elevated. Some foreshore properties near Cremorne Point have minor harbour inundation risk during extreme weather.' },
    'neutral-bay': { name: 'Neutral Bay', risk: 'Low',    notes: 'Well-elevated suburb with low overall flood risk. Small portions near creek lines and the harbour foreshore may have minor localised risk.' },
    'paddington':  { name: 'Paddington',  risk: 'Low',    notes: 'Hilly terrain provides natural drainage. Low flood risk across most of the suburb. Some lower Oxford Street areas can experience minor stormwater issues.' },
    'surry-hills': { name: 'Surry Hills', risk: 'Medium', notes: 'Some areas adjacent to the old South Sydney drain network have recorded stormwater overflow events. Specific streets near Crown Street low points warrant investigation.' },
    'balmain':     { name: 'Balmain',     risk: 'Low',    notes: 'Peninsula position with good harbour drainage. Very low flood risk for most properties. Foreshore properties carry minor coastal weather risk.' },
  };

  document.getElementById('suburb-select')!.addEventListener('change', (e) => {
    const slug = (e.target as HTMLSelectElement).value;

    if (!slug) {
      document.getElementById('risk-panel')!.style.display = 'none';
      document.getElementById('empty-state')!.style.display = 'block';
      return;
    }

    const suburb = SUBURB_DATA[slug];
    if (!suburb) return;

    const cfg = RISK_CONFIG[suburb.risk];

    document.getElementById('risk-panel')!.style.display = 'block';
    document.getElementById('empty-state')!.style.display = 'none';

    const card = document.getElementById('risk-card')!;
    card.style.borderLeft = `4px solid ${cfg.color}`;
    card.style.background = `var(--color-surface-3)`;

    document.getElementById('risk-icon')!.textContent = cfg.icon;
    document.getElementById('risk-icon')!.style.background = cfg.bg;

    const levelEl = document.getElementById('risk-level')!;
    levelEl.textContent = suburb.risk;
    levelEl.style.color = cfg.color;

    document.getElementById('risk-detail')!.innerHTML = `
      <div style="padding:1rem;background:var(--color-surface-4);margin-bottom:0.5rem;">
        <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.5rem;">About ${suburb.name}</p>
        <p style="font-size:0.8rem;color:var(--color-text-secondary);line-height:1.7;">${suburb.notes}</p>
      </div>
      ${cfg.details.map(d => `
        <div style="display:flex;gap:0.75rem;align-items:flex-start;padding:0.5rem 0;border-bottom:1px solid rgba(72,72,72,0.1);">
          <span style="color:${cfg.color};font-size:0.7rem;flex-shrink:0;margin-top:0.15rem;">▸</span>
          <span style="font-size:0.8rem;color:var(--color-text-secondary);line-height:1.5;">${d}</span>
        </div>
      `).join('')}
    `;

    document.getElementById('implications')!.innerHTML = cfg.implications.map(imp => `
      <div style="display:flex;gap:0.75rem;align-items:flex-start;padding:0.75rem;background:var(--color-surface-4);">
        <span style="font-size:1rem;flex-shrink:0;">${imp.icon}</span>
        <span style="font-size:0.78rem;color:var(--color-text-secondary);line-height:1.6;">${imp.text}</span>
      </div>
    `).join('');
  });
</script>
