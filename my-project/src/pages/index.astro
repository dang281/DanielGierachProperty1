---
import Layout from '../layouts/Layout.astro';

const listings = [
  {
    id: 1,
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/025d-H3473905-192570098__1773729572-112408-SatinwoodCt11-1.jpg',
    suburb: 'Bardon',
    address: '11 Satinwood Court',
    street: 'Bardon QLD 4065',
    price: 'Best Offers by 16 April',
    beds: 5, baths: 6, cars: 4,
    tag: 'For Sale',
    size: 'large',
    href: 'https://raywhitebulimba.com.au/properties/residential-for-sale/qld/bardon-4065/house/3473905',
  },
  {
    id: 2,
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/8929-H3473633-192806009__1773800859-70111-0.png',
    suburb: 'Seven Hills',
    address: '20A Marshall Avenue',
    street: 'Seven Hills QLD 4170',
    price: 'Price By Negotiation',
    beds: 4, baths: 3, cars: 2,
    tag: 'For Sale',
    size: 'tall',
    href: 'https://raywhitebulimba.com.au/properties/residential-for-sale/qld/seven-hills-4170/house/3473633',
  },
  {
    id: 3,
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/1a0c-H3474693-192972192__1773876548-26815-Photo-2-Web.jpg',
    suburb: 'Norman Park',
    address: '154 Morehead Avenue',
    street: 'Norman Park QLD 4170',
    price: 'Best Offers by 22 April',
    beds: 3, baths: 1, cars: 2,
    tag: 'For Sale',
    size: 'square',
    href: 'https://raywhitebulimba.com.au/properties/residential-for-sale/qld/norman-park-4170/house/3474693',
  },
  {
    id: 4,
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/772d-H3473513-192064272__1773457507-13356-28VincentStreetAuchenflowerInternet01.jpg',
    suburb: 'Auchenflower',
    address: '28 Vincent Street',
    street: 'Auchenflower QLD 4066',
    price: 'Pre-Market Opportunity',
    beds: 3, baths: 2, cars: 2,
    tag: 'Pre-Market',
    size: 'square',
    href: 'https://raywhitebulimba.com.au/properties/residential-for-sale/qld/auchenflower-4066/house/3473513',
  },
];

const prestige = [
  {
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/b485-H3473001-192442478__1773707732-39332-6-print-70-longland-st-203.jpg',
    suburb: 'Newstead',
    address: '203/70 Longland Street',
    price: 'Auction 18 April — The Calile Hotel',
    beds: 2, baths: 2, cars: 1,
    desc: 'Engineered timber floors, Miele appliances and sweeping views over the historic Gasometer — a rare inner-city apartment of genuine architectural distinction.',
    tag: 'Forthcoming Auction',
    href: 'https://raywhitebulimba.com.au/properties/residential-for-sale/qld/newstead-4006/apartment/3473001',
  },
  {
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/e543-H3474534-192843678__1773807208-74050-IMG2700p.jpg',
    suburb: 'Bridgeman Downs',
    address: '5 Neville Road',
    price: 'For Sale by Negotiation',
    beds: 3, baths: 2, cars: 6,
    desc: 'An elevated 607m² hilltop allotment surrounded by multi-million-dollar acreage homes — a rare opportunity to landbank or rebuild in one of Brisbane\'s most prestigious pockets.',
    tag: 'Blue-Chip Land',
    href: 'https://raywhitebulimba.com.au/properties/residential-for-sale/qld/bridgeman-downs-4035/house/3474534',
  },
];

const stats = [
  { value: 2.4, suffix: 'B+', prefix: '$', label: 'In Sales' },
  { value: 18,  suffix: '',   prefix: '',  label: 'Years Experience' },
  { value: 4200, suffix: '+', prefix: '',  label: 'Properties Sold' },
  { value: 1,   suffix: '',   prefix: '#', label: 'Ranked Agency' },
];

const reasons = [
  { n: '01', title: 'Deep Local Knowledge', body: 'Born and raised in Brisbane, Daniel brings a decade of property economics expertise and hyper-local intelligence across the inner east and south — delivering insights no broad-market agency can match.' },
  { n: '02', title: 'Data-Driven Campaigns', body: 'Every campaign is grounded in data, detail and clear communication. From pricing strategy to buyer targeting, decisions are backed by market evidence — not gut feel.' },
  { n: '03', title: 'Access to 500,000+ Buyers', body: 'Through the Ray White Collective network, your property is exposed to Australia\'s largest active buyer database, ensuring maximum competition and the strongest possible result.' },
];

const toolPhaseColors: Record<string, string> = { Seller: '#ffdd79', Buyer: '#7ec8e3', Investor: '#a8e6a3', Market: '#c8c6c8' };

const showcaseTools = [
  { href: '/tools/selling-costs',    phase: 'Seller',   label: 'Selling Cost Calculator', desc: 'See your true net proceeds after all selling costs.' },
  { href: '/tools/stamp-duty',       phase: 'Buyer',    label: 'Stamp Duty Calculator',   desc: 'QLD stamp duty, FHB concessions & upfront costs.' },
  { href: '/tools/mortgage',         phase: 'Buyer',    label: 'Mortgage Calculator',     desc: 'Weekly or monthly repayments + amortisation chart.' },
  { href: '/tools/investment-yield', phase: 'Investor', label: 'Investment Yield',        desc: 'Net yield, cash flow & 10-year capital projection.' },
  { href: '/tools/renovation-roi',   phase: 'Seller',   label: 'Renovation ROI',          desc: 'Which upgrades add the most value before you sell.' },
  { href: '/tools/suburb-match',     phase: 'Buyer',    label: 'Suburb Match Quiz',       desc: 'Answer 8 questions to find your ideal Brisbane suburb.' },
  { href: '/tools/valuation',        phase: 'Seller',   label: 'Instant Valuation',       desc: 'Get an indicative property value in minutes.' },
  { href: '/tools/heatmap',          phase: 'Market',   label: 'Price Heatmap',           desc: 'Visual median price & growth map across Brisbane.' },
];
---

<Layout>

<!-- ════════════════════════════════════════════
     HERO
════════════════════════════════════════════ -->
<section class="relative min-h-dvh flex items-center overflow-hidden" style="background:var(--color-base);">

  <!-- Parallax bg -->
  <div class="absolute inset-0 z-0" id="hero-bg">
    <img
      src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1920&q=90"
      alt="Brisbane inner east property"
      class="w-full h-full object-cover"
      style="filter:grayscale(30%) brightness(0.38);"
      fetchpriority="high"
      width="1920" height="1080"
    />
    <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(14,14,14,0.7) 0%,rgba(14,14,14,0.3) 100%);"></div>
  </div>

  <!-- Glass card -->
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-8 lg:px-12 pt-28 pb-20">
    <div class="max-w-2xl" style="background:rgba(0,0,0,0.45);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(72,72,72,0.2);padding:3rem 3.5rem;">

      <span class="eyebrow mb-5 reveal" data-delay="0">Daniel Gierach Property · Ray White Bulimba</span>

      <h1 class="reveal" data-delay="80"
        style="font-family:var(--font-serif);font-size:clamp(2.8rem,6vw,5rem);font-weight:400;line-height:1.08;letter-spacing:-0.02em;color:var(--color-text-primary);margin-bottom:1.5rem;">
        Campaigns Built<br />
        on <em style="font-style:italic;color:var(--color-gold);">Data,</em><br />Delivered with Care
      </h1>

      <p class="reveal" data-delay="160"
        style="font-size:1rem;color:var(--color-text-secondary);line-height:1.8;max-width:42ch;margin-bottom:2.5rem;">
        Brisbane inner east and south specialist. From Bulimba to Woolloongabba, Daniel Gierach creates standout campaigns and meaningful conversations that lead to exceptional outcomes.
      </p>

      <div class="flex flex-wrap gap-4 reveal" data-delay="240">
        <a href="/listings" class="btn-gold">
          View Collection
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/appraisal" class="btn-ghost-light">Free Appraisal</a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mt-10 pt-8 reveal" data-delay="320"
        style="border-top:1px solid rgba(72,72,72,0.25);">
        {stats.map((s) => (
          <div>
            <p class="stat-counter" data-value={s.value} data-suffix={s.suffix} data-prefix={s.prefix}
              style="font-family:var(--font-serif);font-size:1.8rem;font-weight:400;color:var(--color-text-primary);line-height:1;letter-spacing:-0.02em;">
              {s.prefix}{s.value}{s.suffix}
            </p>
            <p style="font-size:0.62rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-text-muted);margin-top:0.4rem;">
              {s.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll nudge -->
  <div class="absolute bottom-8 right-12 hidden lg:flex flex-col items-center gap-2">
    <span style="font-size:0.55rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(161,161,161,0.4);writing-mode:vertical-rl;">Scroll</span>
    <div style="width:1px;height:48px;background:linear-gradient(to bottom,rgba(255,221,121,0.4),transparent);"></div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     MARQUEE RIBBON
════════════════════════════════════════════ -->
<div style="background:var(--color-surface-2);border-top:1px solid rgba(72,72,72,0.12);border-bottom:1px solid rgba(72,72,72,0.12);padding:1.1rem 0;overflow:hidden;">
  <div class="marquee-track">
    {[
      'Riverfront Properties',
      'Luxury Penthouses',
      'Heritage Estates',
      'Off-Market Exclusives',
      'Private Collection',
      'Auction Results',
      'Riverfront Properties',
      'Luxury Penthouses',
      'Heritage Estates',
      'Off-Market Exclusives',
      'Private Collection',
      'Auction Results',
    ].map((item, i) => (
      <span class="flex items-center gap-5 flex-shrink-0 px-10" style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-text-muted);">
        {item}
        <span style={`display:inline-block;width:4px;height:4px;background:${i % 2 === 0 ? 'var(--color-gold)' : 'rgba(72,72,72,0.5)'};`}></span>
      </span>
    ))}
  </div>
</div>


<!-- ════════════════════════════════════════════
     SEARCH WIDGET
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-1);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">

    <!-- Tabs -->
    <div class="flex" style="border-bottom:1px solid rgba(72,72,72,0.18);">
      {[
        { id: 'buy',      label: 'Buy' },
        { id: 'rent',     label: 'Rent' },
        { id: 'sold',     label: 'Sold' },
        { id: 'estimate', label: 'Estimate' },
      ].map((tab, i) => (
        <button class={`s-tab${i === 0 ? ' active' : ''}`} data-tab={tab.id}>{tab.label}</button>
      ))}
    </div>

    <!-- Buy panel -->
    <div id="panel-buy" class="search-panel py-6">
      <div class="flex flex-col lg:flex-row gap-3">
        <div class="flex-1 relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" placeholder="Search by suburb, street or postcode..." class="obs-input" style="padding-left:2.75rem;" />
        </div>
        <select class="obs-select" style="min-width:150px;">
          <option value="">Any Type</option>
          <option>House</option><option>Apartment</option><option>Townhouse</option><option>Land</option>
        </select>
        <select class="obs-select" style="min-width:130px;">
          <option value="">Any Beds</option>
          <option>1+</option><option>2+</option><option>3+</option><option>4+</option><option>5+</option>
        </select>
        <select class="obs-select" style="min-width:150px;">
          <option value="">Any Price</option>
          <option>Under $2M</option><option>$2M – $5M</option><option>$5M – $10M</option><option>$10M+</option>
        </select>
        <button class="btn-gold" style="white-space:nowrap;flex-shrink:0;">Search Properties</button>
      </div>
    </div>

    <!-- Rent panel -->
    <div id="panel-rent" class="search-panel py-6" style="display:none;">
      <div class="flex flex-col lg:flex-row gap-3">
        <div class="flex-1 relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" placeholder="Search suburb or postcode..." class="obs-input" style="padding-left:2.75rem;" />
        </div>
        <select class="obs-select" style="min-width:150px;">
          <option value="">Any Type</option>
          <option>House</option><option>Apartment</option><option>Townhouse</option>
        </select>
        <select class="obs-select" style="min-width:150px;">
          <option value="">Max Rent / wk</option>
          <option>$500</option><option>$750</option><option>$1,000</option><option>$1,500</option><option>$2,000+</option>
        </select>
        <button class="btn-gold" style="white-space:nowrap;flex-shrink:0;">Find Rentals</button>
      </div>
    </div>

    <!-- Sold panel -->
    <div id="panel-sold" class="search-panel py-6" style="display:none;">
      <div class="flex flex-col lg:flex-row gap-3">
        <div class="flex-1 relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" placeholder="Search recently sold by suburb..." class="obs-input" style="padding-left:2.75rem;" />
        </div>
        <select class="obs-select" style="min-width:170px;">
          <option>Last 12 months</option>
          <option>Last 3 months</option><option>Last 6 months</option><option>Last 2 years</option>
        </select>
        <button class="btn-gold" style="white-space:nowrap;flex-shrink:0;">View Sold Results</button>
      </div>
    </div>

    <!-- Estimate panel -->
    <div id="panel-estimate" class="search-panel py-7" style="display:none;">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <p style="font-family:var(--font-serif);font-size:1.4rem;font-weight:400;font-style:italic;color:var(--color-text-primary);margin-bottom:0.4rem;">
            What is your property worth?
          </p>
          <p style="font-size:0.8rem;color:var(--color-text-muted);line-height:1.6;max-width:44ch;">
            Get an instant digital property report — powered by Ray White, no obligation.
          </p>
        </div>
        <a
          href="https://raywhitecollective.com.au/property-report/my-property-value?da_email_id=DanielGierach"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-gold"
          style="flex-shrink:0;"
        >
          Get My Free Property Report
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

  </div>
</section>


<!-- ════════════════════════════════════════════
     CURATED LISTINGS
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-0);padding:6rem 0 7rem;">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14">
      <div class="reveal">
        <span class="eyebrow mb-4">Available Now</span>
        <h2 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,2.75rem);font-weight:400;color:var(--color-text-primary);letter-spacing:-0.01em;line-height:1.1;">
          Curated Listings
        </h2>
        <p style="font-size:0.875rem;color:var(--color-text-secondary);margin-top:0.75rem;max-width:46ch;line-height:1.75;">
          A handpicked selection of Sydney's most exceptional residences available for private viewing.
        </p>
      </div>
      <a href="/listings" class="reveal" data-delay="100"
        style="font-family:var(--font-sans);font-size:0.68rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);border-bottom:1px solid var(--color-gold);padding-bottom:2px;white-space:nowrap;transition:opacity 0.2s;flex-shrink:0;align-self:flex-end;">
        Explore All Properties
      </a>
    </div>

    <!-- Asymmetric grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- Large card col-8 -->
      <article class="prop-card md:col-span-8 reveal" data-delay="0">
        <div class="img-wrap" style="aspect-ratio:16/9;">
          <img src={listings[0].image} alt={listings[0].address} width="1200" height="675" loading="eager" />
          <div class="absolute top-5 left-5"><span class="gold-pill">{listings[0].tag}</span></div>
        </div>
        <div style="padding:1.5rem 0 0;">
          <div class="flex items-start justify-between gap-4 mb-2">
            <div>
              <span style="font-size:0.6rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);">{listings[0].suburb}</span>
              <h3 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;color:var(--color-text-primary);margin-top:0.2rem;">{listings[0].address}</h3>
              <p style="font-size:0.75rem;color:var(--color-text-muted);margin-top:0.2rem;">{listings[0].street}</p>
            </div>
            <span style="font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-gold);margin-top:0.5rem;white-space:nowrap;">
              {listings[0].price}
            </span>
          </div>
          <div style="display:flex;gap:1.25rem;margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid rgba(72,72,72,0.15);">
            <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">{listings[0].beds} Bed</span>
            <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">{listings[0].baths} Bath</span>
            <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">{listings[0].cars} Car</span>
          </div>
        </div>
      </article>

      <!-- Tall card col-4 -->
      <article class="prop-card md:col-span-4 reveal" data-delay="100">
        <div class="img-wrap" style="aspect-ratio:4/5;">
          <img src={listings[1].image} alt={listings[1].address} width="800" height="1000" loading="lazy" />
          <div class="absolute top-5 left-5"><span class="gold-pill">{listings[1].tag}</span></div>
        </div>
        <div style="padding:1.25rem 0 0;">
          <span style="font-size:0.6rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);">{listings[1].suburb}</span>
          <h3 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:var(--color-text-primary);margin-top:0.2rem;">{listings[1].address}</h3>
          <div style="display:flex;gap:1rem;margin-top:0.6rem;">
            <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">{listings[1].beds} Bed</span>
            <span style="font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">{listings[1].baths} Bath</span>
            <span style="font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-gold);">{listings[1].price}</span>
          </div>
        </div>
      </article>

      <!-- Square cards -->
      {listings.slice(2).map((p, i) => (
        <article class="prop-card md:col-span-4 reveal" data-delay={`${(i+1)*80}`}>
          <div class="img-wrap" style="aspect-ratio:1/1;">
            <img src={p.image} alt={p.address} width="600" height="600" loading="lazy" />
            <div class="absolute top-5 left-5"><span class="gold-pill">{p.tag}</span></div>
          </div>
          <div style="padding:1rem 0 0;">
            <span style="font-size:0.6rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);">{p.suburb}</span>
            <h3 style="font-family:var(--font-serif);font-size:1.15rem;font-weight:400;color:var(--color-text-primary);margin-top:0.2rem;">{p.address}</h3>
            <p style="font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-gold);margin-top:0.4rem;">{p.price}</p>
          </div>
        </article>
      ))}

      <!-- Off-market portal tile -->
      <div class="md:col-span-4 reveal" data-delay="240"
        style="background:var(--color-surface-3);border:1px solid rgba(72,72,72,0.18);display:flex;align-items:center;justify-content:center;padding:3rem 2.5rem;text-align:center;min-height:300px;">
        <div>
          <div style="width:3rem;height:3rem;background:var(--color-gold-muted);border:1px solid rgba(255,221,121,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="1.5">
              <rect x="3" y="11" width="18" height="11" rx="0"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3 style="font-family:var(--font-serif);font-size:1.2rem;font-weight:400;color:var(--color-text-primary);margin-bottom:0.75rem;">Off-Market Portal</h3>
          <p style="font-size:0.8rem;color:var(--color-text-muted);line-height:1.7;margin-bottom:1.5rem;max-width:22ch;margin-left:auto;margin-right:auto;">
            Access Sydney's most discreet listings before they reach the market.
          </p>
          <a href="/register" class="btn-gold" style="font-size:0.65rem;">Request Access</a>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     PRESTIGE COLLECTION
════════════════════════════════════════════ -->
