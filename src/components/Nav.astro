---
const navLinks = [
  { label: 'Listings', href: '/listings' },
  { label: 'Buyers', href: '/buyers' },
  { label: 'Property Tools', href: '/tools' },
  { label: 'Suburbs', href: '/suburbs' },
  { label: 'Insights', href: '/insights' },
  { label: 'About', href: '/about' },
];

const suburbs = [
  { label: 'Brisbane Inner East', href: '/brisbane-inner-east' },
  { label: 'Seven Hills',         href: '/suburbs/seven-hills' },
  { label: 'Carina',              href: '/suburbs/carina' },
  { label: 'Morningside',         href: '/suburbs/morningside' },
  { label: 'Cannon Hill',         href: '/suburbs/cannon-hill' },
  { label: 'Carina Heights',      href: '/suburbs/carina-heights' },
  { label: 'East Brisbane',       href: '/suburbs/east-brisbane' },
  { label: 'Coorparoo',           href: '/suburbs/coorparoo' },
  { label: 'Tingalpa',            href: '/suburbs/tingalpa' },
  { label: 'Murarrie',            href: '/suburbs/murarrie' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0" style="z-index:9999;transition:box-shadow 0.3s,border-color 0.3s,color 0.3s;">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div class="flex items-center justify-between h-[76px]">

      <!-- Logo -->
      <a href="/" class="flex flex-col leading-none group" style="gap:0.3rem;">
        <span id="logo-name" style="font-family:var(--font-serif);font-size:1.75rem;font-weight:400;font-style:italic;color:#f0ece4;letter-spacing:0.02em;transition:color 0.3s;">
          Daniel Gierach
        </span>
        <span class="flex items-start xl:items-center" style="gap:0.5rem;">
          <span class="mt-[0.3rem] xl:mt-0" style="display:block;height:1px;width:1.25rem;background:var(--color-gold);opacity:0.8;"></span>
          <span style="font-family:var(--font-sans);font-size:0.625rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-gold);opacity:0.85;"><span>Ray White Bulimba</span><span class="hidden xl:inline"> | </span><span class="block xl:inline agency-collective">The Collective</span></span>
        </span>
      </a>

      <!-- Desktop nav, hidden by default, JS shows on ≥1024px -->
      <nav id="nav-links" style="display:none;align-items:center;gap:2.5rem;">
        {navLinks.map((link) => (
          <a href={link.href} class="nav-link-mono" style="color:#f0ece4;">{link.label}</a>
        ))}
      </nav>

      <!-- CTA, hidden by default, JS shows on ≥1024px -->
      <div id="nav-cta" style="display:none;align-items:center;gap:1.5rem;">
        <a href="/contact" class="nav-link-mono" style="color:#f0ece4;">Contact</a>
        <a href="tel:+61412523821" id="nav-phone" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:1.05rem;font-weight:500;letter-spacing:0.03em;color:#f5d07a;text-decoration:none;padding:0.55rem 1rem;border:1px solid rgba(245,208,122,0.4);transition:background 0.2s,border-color 0.2s;"
           onmouseover="this.style.background='rgba(245,208,122,0.08)';this.style.borderColor='rgba(245,208,122,0.7)';"
           onmouseout="this.style.background='transparent';this.style.borderColor='rgba(245,208,122,0.4)';">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          0412 523 821
        </a>
      </div>

      <!-- Mobile toggle, shown by default, JS hides on >=1024px -->
      <button id="mobile-toggle" style="display:flex;flex-direction:column;align-items:flex-end;justify-content:center;gap:5px;padding:0.75rem;min-width:44px;min-height:44px;" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <span id="bar1" class="block w-6 transition-all duration-300" style="height:2px;background:#f0ece4;border-radius:1px;"></span>
        <span id="bar2" class="block w-6 transition-all duration-300" style="height:2px;background:#f0ece4;border-radius:1px;"></span>
        <span id="bar3" class="block w-4 transition-all duration-300 self-end" style="height:2px;background:#f0ece4;border-radius:1px;"></span>
      </button>
    </div>
  </div>

</header>

<!-- Full-screen overlay: sits above Leaflet GPU tile layers, closes menu on tap -->
<div id="nav-overlay" style="display:none;position:fixed;inset:0;z-index:9996;background:rgba(10,8,6,0.45);" aria-hidden="true"></div>

<!-- Mobile menu — sibling of header; z-index above overlay -->
<div
  id="mobile-menu"
  class="overflow-hidden transition-all duration-300"
  style="position:fixed;top:76px;left:0;right:0;z-index:9997;max-height:0;background:#f2efe9;"
  aria-hidden="true"
  inert
>
  <div class="max-w-[1400px] mx-auto px-8 pt-10 pb-6 flex flex-col gap-5">
    {navLinks.map((link) => (
      <a href={link.href} class="nav-link-mono mobile-nav-link">{link.label}</a>
    ))}

    <div class="pt-4 flex flex-col gap-3" style="border-top:1px solid rgba(28,25,23,0.12);">
      <a href="/contact" class="nav-link-mono">Contact</a>
      <a href="tel:+61412523821" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:1.25rem;font-weight:500;letter-spacing:0.03em;color:#1c1917;text-decoration:none;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        0412 523 821
      </a>
    </div>
  </div>
</div>

<style>
  .agency-collective {
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    opacity: 0.75;
  }
  @media (min-width: 1024px) {
    .agency-collective {
      font-size: 0.625rem;
      letter-spacing: 0.22em;
      opacity: 1;
    }
  }
</style>

<script>
  const header       = document.getElementById('site-header')!;
  const navLinksEl   = document.getElementById('nav-links')!;
  const navCtaEl     = document.getElementById('nav-cta')!;
  const mobileToggle = document.getElementById('mobile-toggle')!;
  const mobileMenu   = document.getElementById('mobile-menu')!;
  const navOverlay   = document.getElementById('nav-overlay')!;
  const bar1         = document.getElementById('bar1')!;
  const bar2         = document.getElementById('bar2')!;
  const bar3         = document.getElementById('bar3')!;
  const logoName     = document.getElementById('logo-name')!;
  const navLinkEls   = document.querySelectorAll<HTMLElement>('#nav-links .nav-link-mono, #nav-cta .nav-link-mono');
  const bars         = [bar1, bar2, bar3];
  let menuOpen = false;

  // ── Responsive layout (pure JS, no CSS classes) ──────────────────────────
  function applyLayout() {
    const desktop = window.innerWidth >= 1024;
    navLinksEl.style.display   = desktop ? 'flex' : 'none';
    navCtaEl.style.display     = desktop ? 'flex' : 'none';
    mobileToggle.style.display = desktop ? 'none' : 'flex';
    // Close mobile menu when resizing to desktop
    if (desktop && menuOpen) {
      closeMobileMenu();
    }
  }
  applyLayout();
  window.addEventListener('resize', applyLayout);

  // ── Highlight active mobile nav link ─────────────────────────────────────
  const currentPath = window.location.pathname;
  document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link').forEach(link => {
    if (link.getAttribute('href') === currentPath || currentPath.startsWith(link.getAttribute('href') + '/')) {
      link.style.color = 'var(--color-gold)';
      link.style.borderLeft = '2px solid var(--color-gold)';
      link.style.paddingLeft = '0.6rem';
    }
  });

  // ── Nav scroll state ─────────────────────────────────────────────────────
  const navPhone = document.getElementById('nav-phone') as HTMLAnchorElement | null;
  // PERF-007: passive listener + rAF throttling + state caching so we never
  // touch the DOM unless the scrolled state actually changes.
  let lastIsScrolled: boolean | null = null;
  let rafQueued = false;

  function applyNavState(isScrolled: boolean) {
    // Always dark — cream/gold colours regardless of scroll state.
    logoName.style.color = '#f0ece4';
    navLinkEls.forEach(el => el.style.color = '#f0ece4');
    bars.forEach(b => b.style.background = '#f0ece4');
    const trigger = document.querySelector<HTMLElement>('.nav-dropdown-trigger');
    if (trigger) trigger.style.color = '#f0ece4';
    if (navPhone) {
      navPhone.style.color = '#f5d07a';
      navPhone.style.borderColor = 'rgba(245,208,122,0.4)';
    }
    if (isScrolled) {
      header.classList.add('glass-nav');
    } else {
      header.classList.remove('glass-nav');
      header.style.boxShadow = 'none';
    }
  }

  function updateNav() {
    const isScrolled = window.scrollY > 50 || document.body.dataset.lightNav === 'true';
    if (isScrolled === lastIsScrolled) return;
    lastIsScrolled = isScrolled;
    applyNavState(isScrolled);
  }

  function onScroll() {
    if (rafQueued) return;
    rafQueued = true;
    requestAnimationFrame(() => {
      rafQueued = false;
      updateNav();
    });
  }

  updateNav();
  window.addEventListener('scroll', onScroll, { passive: true });

  // ── Mobile menu open/close + a11y ────────────────────────────────────────
  const mobileMenuLinks = mobileMenu.querySelectorAll<HTMLElement>('a, button');

  function setLeafletVisibility(visible: boolean) {
    // opacity:0 and visibility:hidden both leave GPU compositor layers active
    // on iOS Safari, so translate3d tile panes still paint above fixed elements.
    // display:none is the only change that removes elements from the render tree
    // entirely, which kills the GPU layers. Fire a resize after restoring so
    // Leaflet recalculates tile bounds.
    document.querySelectorAll<HTMLElement>('.leaflet-container').forEach(el => {
      el.style.display = visible ? '' : 'none';
      el.style.pointerEvents = visible ? '' : 'none';
    });
    if (visible) {
      requestAnimationFrame(() => window.dispatchEvent(new Event('resize')));
    }
  }

  function openMobileMenu() {
    menuOpen = true;
    setLeafletVisibility(false);
    mobileMenu.style.maxHeight = '600px';
    navOverlay.style.display = 'block';
    bar3.style.width = '1.5rem';
    mobileToggle.setAttribute('aria-expanded', 'true');
    mobileMenu.setAttribute('aria-hidden', 'false');
    mobileMenu.removeAttribute('inert');
    const first = mobileMenu.querySelector<HTMLElement>('a, button');
    if (first) setTimeout(() => first.focus(), 50);
  }

  function closeMobileMenu(returnFocus = false) {
    menuOpen = false;
    setLeafletVisibility(true);
    mobileMenu.style.maxHeight = '0';
    navOverlay.style.display = 'none';
    bar3.style.width = '1rem';
    mobileToggle.setAttribute('aria-expanded', 'false');
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileMenu.setAttribute('inert', '');
    if (returnFocus) mobileToggle.focus();
  }

  mobileToggle.addEventListener('click', () => {
    if (menuOpen) closeMobileMenu(); else openMobileMenu();
  });

  navOverlay.addEventListener('click', () => closeMobileMenu());

  // Close on Escape, return focus to toggle
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && menuOpen) {
      e.preventDefault();
      closeMobileMenu(true);
    }
  });

  // Trap focus while menu is open: cycle Tab / Shift+Tab between toggle + last link
  mobileMenu.addEventListener('keydown', (e: KeyboardEvent) => {
    if (!menuOpen || e.key !== 'Tab') return;
    const focusables = Array.from(
      mobileMenu.querySelectorAll<HTMLElement>('a, button')
    ).filter(el => !el.hasAttribute('disabled'));
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    const active = document.activeElement;
    if (e.shiftKey && active === first) {
      e.preventDefault();
      mobileToggle.focus();
    } else if (!e.shiftKey && active === last) {
      e.preventDefault();
      mobileToggle.focus();
    }
  });

  // From toggle, Tab forward into menu when open; Shift+Tab from toggle stays
  mobileToggle.addEventListener('keydown', (e: KeyboardEvent) => {
    if (!menuOpen || e.key !== 'Tab') return;
    if (!e.shiftKey) {
      e.preventDefault();
      const first = mobileMenu.querySelector<HTMLElement>('a, button');
      if (first) first.focus();
    }
  });

  // Close menu when a link inside is clicked (so navigation feels right)
  mobileMenuLinks.forEach(el => {
    el.addEventListener('click', () => {
      if (menuOpen) closeMobileMenu();
    });
  });
</script>
