---
const episodes = [
  {
    title: 'Designing an Impact Driven Life',
    guest: 'Tom Allen',
    org: 'Impact Boom',
    youtubeId: 'ZNs4fe4cvso',
  },
  {
    title: 'Rebuilding Lives After Domestic Violence',
    guest: 'Annie',
    org: 'Lovewell Foundation',
    youtubeId: 'tBk3eT3AFNM',
  },
  {
    title: 'Safe Spaces for Homelessness',
    guest: 'Norm',
    org: 'Beddown',
    youtubeId: 'qIc32Wdlfe0',
  },
  {
    title: "Mental Health & the Meaning of 'Good'",
    guest: 'Tina',
    org: 'Career Development Center',
    youtubeId: 'u-9B-us1CQk',
  },
];
---

<section id="insights" class="py-24 bg-[#060E23]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14" data-reveal>
      <div class="inline-flex items-center gap-2 bg-[#26A8FF]/15 border border-[#26A8FF]/30 text-[#26A8FF] text-sm font-medium px-4 py-1.5 rounded-full mb-4">
        <i class="fa-solid fa-podcast text-xs"></i>
        Chasing Good Podcast
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Stories of Purpose & Impact</h2>
      <p class="text-white/60 max-w-xl mx-auto">
        Conversations with leaders doing meaningful work across social enterprise, mental health, the environment, and community.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {episodes.map(ep => (
        <a
          href={`https://www.youtube.com/watch?v=${ep.youtubeId}`}
          target="_blank"
          rel="noopener noreferrer"
          data-reveal
          data-reveal-delay={episodes.indexOf(ep) * 80}
          class="bg-[#1F2848] rounded-2xl overflow-hidden hover:bg-[#203B63] transition-colors group block"
        >
          <!-- YouTube thumbnail -->
          <div class="aspect-video relative overflow-hidden">
            <img
              src={`https://img.youtube.com/vi/${ep.youtubeId}/hqdefault.jpg`}
              alt={ep.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/30 flex items-center justify-center group-hover:bg-black/20 transition-colors">
              <div class="w-12 h-12 rounded-full bg-[#26A8FF] flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg">
                <i class="fa-solid fa-play text-white pl-0.5"></i>
              </div>
            </div>
          </div>
          <div class="p-4">
            <h3 class="text-white font-semibold text-sm mb-2 leading-snug">{ep.title}</h3>
            <p class="text-[#26A8FF] text-xs">{ep.guest} · {ep.org}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="https://www.youtube.com/@cirqlegroup"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-white/20 text-white/80 hover:text-white hover:border-white/40 font-medium px-6 py-3 rounded-md transition-colors text-sm"
      >
        <i class="fa-brands fa-youtube text-red-500"></i>
        Watch All Episodes
      </a>
    </div>
  </div>
</section>
