---
const services = [
  {
    icon: 'fa-solid fa-users',
    title: 'Specialist IT Recruitment',
    description: 'Connect the brightest minds with the most challenging problems across data, cloud, cyber, and software development.',
    anchor: 'recruitment',
    highlights: ['Permanent & Contract', 'Data & Cloud', 'Cyber & Security', 'Software Development'],
  },
  {
    icon: 'fa-solid fa-handshake',
    title: 'Technology Talent Partners',
    description: 'A strategic, consultative approach to candidate management and acquisition — ensuring the perfect fit for every role, every time.',
    anchor: 'talent',
    highlights: ['Candidate Management', 'Strategic Sourcing', 'Cultural Alignment', 'Long-term Partnership'],
  },
  {
    icon: 'fa-solid fa-diagram-project',
    title: 'Technology Consultants',
    description: 'High-performing consultants with hands-on delivery experience who understand how to recruit because they do the work themselves.',
    anchor: 'consulting',
    highlights: ['Project Delivery', 'BA & Architecture', 'PMO Support', 'Programme Management'],
  },
  {
    icon: 'fa-solid fa-leaf',
    title: 'Profit for Purpose',
    description: 'Every engagement funds environmental and social impact. We commit all profits toward a better future for communities across Australia.',
    anchor: 'purpose',
    highlights: ['Reef Restoration', 'Disability Support', 'Homelessness', 'Mental Health'],
  },
];
---

<section id="services" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16" data-reveal>
      <div class="inline-flex items-center gap-2 bg-[#E5F3FA] text-[#26A8FF] text-sm font-medium px-4 py-1.5 rounded-full mb-4">
        What We Do
      </div>
      <h2 class="section-title">Why Choose Cirqle Group</h2>
      <p class="section-subtitle mx-auto text-center mt-4">
        We don't just place people — we deliver projects. That means we recruit with the insight of practitioners who understand what "good" looks like on the ground.
      </p>
    </div>

    <!-- Service cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service, i) => (
        <div
          id={service.anchor}
          data-reveal
          data-reveal-delay={i * 80}
          class="group relative bg-white border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col"
        >
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-[#E5F3FA] flex items-center justify-center mb-5 group-hover:bg-[#26A8FF] transition-colors duration-300">
            <i class={`${service.icon} text-[#26A8FF] text-lg group-hover:text-white transition-colors duration-300`}></i>
          </div>

          <!-- Content -->
          <h3 class="text-lg font-bold text-[#1F2848] mb-3">{service.title}</h3>
          <p class="text-[#383E4F] text-sm leading-relaxed mb-5 flex-grow">{service.description}</p>

          <!-- Highlights -->
          <ul class="space-y-1.5">
            {service.highlights.map(h => (
              <li class="flex items-center gap-2 text-xs text-[#383E4F]">
                <i class="fa-solid fa-check text-[#26A8FF] text-xs flex-shrink-0"></i>
                {h}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <a href="#enquire" class="btn-primary">
        Discuss Your Requirements <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>
  </div>
</section>
