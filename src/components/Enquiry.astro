---
---

<section id="enquire" class="py-24 bg-gradient-to-br from-[#1F2848] to-[#060E23]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Left: copy -->
      <div class="text-white">
        <div class="inline-flex items-center gap-2 bg-[#26A8FF]/15 border border-[#26A8FF]/30 text-[#26A8FF] text-sm font-medium px-4 py-1.5 rounded-full mb-6">
          <i class="fa-solid fa-envelope text-xs"></i>
          Get in Touch
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-5">
          Ready to Find Your<br />Next Tech Leader?
        </h2>
        <p class="text-white/70 leading-relaxed mb-8">
          Whether you need to build a delivery team, fill a critical role, or bring in specialist consultants — we're ready to help. Tell us about your requirement and we'll come back to you promptly.
        </p>

        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[#26A8FF]/15 flex items-center justify-center flex-shrink-0 mt-0.5">
              <i class="fa-solid fa-envelope text-[#26A8FF] text-sm"></i>
            </div>
            <div>
              <div class="text-white font-medium text-sm mb-0.5">Email</div>
              <a href="mailto:info@cirqlegroup.com" class="text-white/60 hover:text-[#26A8FF] text-sm transition-colors">info@cirqlegroup.com</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[#26A8FF]/15 flex items-center justify-center flex-shrink-0 mt-0.5">
              <i class="fa-solid fa-location-dot text-[#26A8FF] text-sm"></i>
            </div>
            <div>
              <div class="text-white font-medium text-sm mb-0.5">Location</div>
              <div class="text-white/60 text-sm">Brisbane, Queensland, Australia</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-[#26A8FF]/15 flex items-center justify-center flex-shrink-0 mt-0.5">
              <i class="fa-brands fa-linkedin text-[#26A8FF] text-sm"></i>
            </div>
            <div>
              <div class="text-white font-medium text-sm mb-0.5">Connect</div>
              <a href="https://www.linkedin.com/company/cirqlegroup" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-[#26A8FF] text-sm transition-colors">LinkedIn</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="bg-white rounded-2xl p-7 shadow-2xl">
        <h3 class="text-xl font-bold text-[#1F2848] mb-6">Send an Enquiry</h3>
        <form
          name="enquiry"
          method="POST"
          action="/thank-you"
          class="space-y-4"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="first-name" class="block text-sm font-medium text-[#383E4F] mb-1.5">First Name *</label>
              <input
                type="text"
                id="first-name"
                name="first-name"
                required
                aria-required="true"
                autocomplete="given-name"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition"
                placeholder="Jane"
              />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-[#383E4F] mb-1.5">Last Name *</label>
              <input
                type="text"
                id="last-name"
                name="last-name"
                required
                aria-required="true"
                autocomplete="family-name"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition"
                placeholder="Smith"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-[#383E4F] mb-1.5">Work Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              aria-required="true"
              autocomplete="email"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition"
              placeholder="jane@company.com.au"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-[#383E4F] mb-1.5">Organisation</label>
            <input
              type="text"
              id="company"
              name="company"
              autocomplete="organization"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition"
              placeholder="Dept. of XYZ / Company Name"
            />
          </div>

          <div>
            <label for="enquiry-type" class="block text-sm font-medium text-[#383E4F] mb-1.5">What can we help with? *</label>
            <select
              id="enquiry-type"
              name="enquiry-type"
              required
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition bg-white"
            >
              <option value="" disabled selected>Select an option</option>
              <option value="recruitment">IT Recruitment</option>
              <option value="consulting">Project Consulting</option>
              <option value="both">Both — Recruitment & Consulting</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-[#383E4F] mb-1.5">Tell us about your requirement</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition resize-none"
              placeholder="Roles you need to fill, project scope, timeline..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-[#26A8FF] text-white font-semibold py-3.5 rounded-lg hover:bg-[#0090e8] transition-colors flex items-center justify-center gap-2"
          >
            Send Enquiry <i class="fa-solid fa-paper-plane"></i>
          </button>

          <p class="text-xs text-gray-400 text-center">
            We typically respond within one business day.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
