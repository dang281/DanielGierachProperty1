<!-- Daniel Gierach Property — AI Chat Widget -->
<!-- Powered by Claude Haiku. Appears on every page as a floating bubble. -->

<div id="dg-chat" aria-label="Chat with Daniel Gierach Property" style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;font-family:var(--font-sans,system-ui,sans-serif);">

  <!-- Bubble trigger -->
  <button id="dg-chat-trigger"
    aria-label="Open chat"
    onclick="dgChatToggle()"
    style="width:56px;height:56px;border-radius:50%;background:#c4912a;border:none;cursor:pointer;box-shadow:0 4px 20px rgba(0,0,0,0.25);display:flex;align-items:center;justify-content:center;transition:transform 0.2s,box-shadow 0.2s;"
    onmouseenter="this.style.transform='scale(1.08)';this.style.boxShadow='0 6px 28px rgba(0,0,0,0.32)'"
    onmouseleave="this.style.transform='scale(1)';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.25)'">
    <svg id="dg-icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <svg id="dg-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none;">
      <path d="M18 6L6 18M6 6l12 12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- Unread dot -->
  <span id="dg-unread" style="position:absolute;top:0;right:0;width:14px;height:14px;background:#ef4444;border-radius:50%;border:2px solid #fff;"></span>

  <!-- Chat panel -->
  <div id="dg-chat-panel"
    style="display:none;position:absolute;bottom:68px;right:0;width:340px;max-height:520px;background:#fff;border-radius:16px;box-shadow:0 8px 40px rgba(0,0,0,0.18);overflow:hidden;display:none;flex-direction:column;">

    <!-- Header -->
    <div style="background:#1c1917;padding:1rem 1.25rem;display:flex;align-items:center;gap:0.75rem;">
      <div style="width:36px;height:36px;border-radius:50%;background:#c4912a;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="white" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="white" stroke-width="2"/></svg>
      </div>
      <div>
        <p style="color:#f0ece4;font-size:0.8rem;font-weight:600;line-height:1.2;margin:0;">Daniel Gierach Property</p>
        <p style="color:#c4912a;font-size:0.65rem;letter-spacing:0.08em;margin:0;">Ray White Bulimba</p>
      </div>
      <div style="margin-left:auto;width:8px;height:8px;border-radius:50%;background:#22c55e;" title="Online"></div>
    </div>

    <!-- Messages -->
    <div id="dg-messages"
      style="flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:0.75rem;min-height:200px;max-height:340px;background:#faf9f7;">
      <!-- Welcome message -->
      <div class="dg-msg dg-bot" style="display:flex;gap:0.5rem;align-items:flex-end;">
        <div style="width:28px;height:28px;border-radius:50%;background:#c4912a;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="white" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="white" stroke-width="1.8"/></svg>
        </div>
        <div style="background:#fff;border:1px solid rgba(28,25,23,0.08);border-radius:12px 12px 12px 2px;padding:0.65rem 0.875rem;max-width:240px;font-size:0.8rem;line-height:1.55;color:#1c1917;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
          Hi, I'm Daniel's assistant. Ask me anything about selling, buying or the Brisbane property market.
        </div>
      </div>
    </div>

    <!-- Suggestions -->
    <div id="dg-suggestions" style="padding:0 1rem 0.5rem;display:flex;flex-wrap:wrap;gap:0.4rem;">
      <button onclick="dgSend('What suburbs do you cover?')" style="font-size:0.7rem;padding:0.3rem 0.65rem;border-radius:999px;border:1px solid rgba(196,145,42,0.4);background:rgba(196,145,42,0.06);color:#a07828;cursor:pointer;transition:background 0.15s;" onmouseenter="this.style.background='rgba(196,145,42,0.14)'" onmouseleave="this.style.background='rgba(196,145,42,0.06)'">What suburbs do you cover?</button>
      <button onclick="dgSend('How do I get an appraisal?')" style="font-size:0.7rem;padding:0.3rem 0.65rem;border-radius:999px;border:1px solid rgba(196,145,42,0.4);background:rgba(196,145,42,0.06);color:#a07828;cursor:pointer;transition:background 0.15s;" onmouseenter="this.style.background='rgba(196,145,42,0.14)'" onmouseleave="this.style.background='rgba(196,145,42,0.06)'">How do I get an appraisal?</button>
      <button onclick="dgSend('How long does it take to sell?')" style="font-size:0.7rem;padding:0.3rem 0.65rem;border-radius:999px;border:1px solid rgba(196,145,42,0.4);background:rgba(196,145,42,0.06);color:#a07828;cursor:pointer;transition:background 0.15s;" onmouseenter="this.style.background='rgba(196,145,42,0.14)'" onmouseleave="this.style.background='rgba(196,145,42,0.06)'">How long does it take to sell?</button>
    </div>

    <!-- Input -->
    <div style="padding:0.75rem;border-top:1px solid rgba(28,25,23,0.08);background:#fff;display:flex;gap:0.5rem;align-items:flex-end;">
      <textarea id="dg-input"
        placeholder="Ask a question..."
        rows="1"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();dgSend()}"
        oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,96)+'px'"
        style="flex:1;resize:none;border:1px solid rgba(28,25,23,0.15);border-radius:8px;padding:0.5rem 0.75rem;font-size:0.8rem;font-family:inherit;line-height:1.5;outline:none;overflow:hidden;color:#1c1917;background:#faf9f7;transition:border-color 0.15s;"
        onfocus="this.style.borderColor='#c4912a'"
        onblur="this.style.borderColor='rgba(28,25,23,0.15)'">
      </textarea>
      <button id="dg-send-btn" onclick="dgSend()"
        style="width:36px;height:36px;border-radius:8px;background:#c4912a;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background 0.15s;"
        onmouseenter="this.style.background='#a07828'" onmouseleave="this.style.background='#c4912a'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22 2L11 13M22 2L15 22 11 13 2 9l20-7z" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  var messages = [];
  var open = false;

  window.dgChatToggle = function() {
    open = !open;
    var panel = document.getElementById('dg-chat-panel');
    var iconOpen = document.getElementById('dg-icon-open');
    var iconClose = document.getElementById('dg-icon-close');
    var unread = document.getElementById('dg-unread');
    if (open) {
      panel.style.display = 'flex';
      iconOpen.style.display = 'none';
      iconClose.style.display = 'block';
      if (unread) unread.style.display = 'none';
      setTimeout(function() { document.getElementById('dg-input').focus(); }, 100);
    } else {
      panel.style.display = 'none';
      iconOpen.style.display = 'block';
      iconClose.style.display = 'none';
    }
  };

  window.dgSend = function(preset) {
    var input = document.getElementById('dg-input');
    var text = (preset || input.value).trim();
    if (!text) return;
    input.value = '';
    input.style.height = 'auto';

    // Hide suggestions after first send
    var sugg = document.getElementById('dg-suggestions');
    if (sugg) sugg.style.display = 'none';

    messages.push({ role: 'user', content: text });
    dgAppendMsg('user', text);

    var typing = dgAppendMsg('bot', '...', true);
    document.getElementById('dg-send-btn').disabled = true;

    fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: messages }),
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      typing.remove();
      var reply = data.reply || 'Sorry, something went wrong. Please try again.';
      messages.push({ role: 'assistant', content: reply });
      dgAppendMsg('bot', reply);
    })
    .catch(function() {
      typing.remove();
      dgAppendMsg('bot', 'Network error. Please check your connection and try again.');
    })
    .finally(function() {
      document.getElementById('dg-send-btn').disabled = false;
    });
  };

  function dgAppendMsg(role, text, isTyping) {
    var container = document.getElementById('dg-messages');
    var wrap = document.createElement('div');
    wrap.style.cssText = 'display:flex;gap:0.5rem;align-items:flex-end;' + (role === 'user' ? 'justify-content:flex-end;' : '');

    if (role === 'bot') {
      var avatar = document.createElement('div');
      avatar.style.cssText = 'width:28px;height:28px;border-radius:50%;background:#c4912a;display:flex;align-items:center;justify-content:center;flex-shrink:0;';
      avatar.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="white" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="white" stroke-width="1.8"/></svg>';
      wrap.appendChild(avatar);
    }

    var bubble = document.createElement('div');
    bubble.style.cssText = role === 'user'
      ? 'background:#1c1917;color:#f0ece4;border-radius:12px 12px 2px 12px;padding:0.65rem 0.875rem;max-width:240px;font-size:0.8rem;line-height:1.55;'
      : 'background:#fff;border:1px solid rgba(28,25,23,0.08);border-radius:12px 12px 12px 2px;padding:0.65rem 0.875rem;max-width:240px;font-size:0.8rem;line-height:1.55;color:#1c1917;box-shadow:0 1px 4px rgba(0,0,0,0.06);';

    if (isTyping) {
      bubble.innerHTML = '<span style="opacity:0.5;">Typing...</span>';
    } else {
      bubble.textContent = text;
    }

    wrap.appendChild(bubble);
    container.appendChild(wrap);
    container.scrollTop = container.scrollHeight;
    return wrap;
  }
})();
</script>
