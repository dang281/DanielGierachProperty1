---
const year = new Date().getFullYear();
---

<footer style="background:var(--color-surface-0);border-top:1px solid rgba(72,72,72,0.15);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12 py-16 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-8 mb-16">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex flex-col leading-none mb-6" style="gap:0.3rem;">
          <span style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;font-style:italic;color:var(--color-text-primary);letter-spacing:0.02em;">
            Daniel Gierach
          </span>
          <span style="display:flex;align-items:center;gap:0.5rem;">
            <span style="display:block;height:1px;width:1.25rem;background:var(--color-gold);opacity:0.8;"></span>
            <span style="font-family:var(--font-sans);font-size:0.5rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-gold);opacity:0.85;">Ray White · The Collective</span>
          </span>
        </div>
        <p style="font-size:0.825rem;line-height:1.75;color:var(--color-text-muted);max-width:26ch;">
          Data-driven campaigns. Clear communication. Exceptional outcomes across Brisbane's inner east and south.
        </p>
        <div class="flex gap-5 mt-6">
          {[
            { label: 'Instagram', href: 'https://www.instagram.com/dgierach/', path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
            { label: 'LinkedIn', href: 'https://www.linkedin.com/in/danielgierach', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
          ].map(s => (
            <a href={s.href} aria-label={s.label} target="_blank" rel="noopener" style="color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d={s.path}/></svg>
            </a>
          ))}
          <!-- realestate.com.au -->
          <a href="https://www.realestate.com.au/agent/daniel-gierach-3819232" target="_blank" rel="noopener" aria-label="realestate.com.au profile" style="opacity:0.6;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">
            <img src="https://www.realestate.com.au/favicon.ico" width="16" height="16" alt="realestate.com.au" style="display:block;" />
          </a>
          <!-- Google Business Profile -->
          <a href="https://share.google/WipmgyJnjC5nkhGwx" target="_blank" rel="noopener" aria-label="Google Business Profile" style="color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <p class="eyebrow mb-6">Quick Links</p>
        <ul class="flex flex-col gap-3">
          {[
            { label: 'Request a Free Appraisal', href: '/appraisal' },
            { label: 'Current Listings', href: '/listings' },
            { label: 'Recently Sold', href: '/listings#sold' },
            { label: 'Suburb Price Guide', href: '/tools/heatmap' },
            { label: 'What Is My Home Worth?', href: '/tools/valuation' },
            { label: 'Insights & Articles', href: '/insights' },
            { label: 'Book a Call', href: '/contact' },
          ].map(item => (
            <li><a href={item.href} style="font-size:0.825rem;color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Tools -->
      <div>
        <p class="eyebrow mb-6">Free Tools</p>
        <ul class="flex flex-col gap-3">
          {[
            { label: 'Selling Cost Calculator', href: '/tools/selling-costs' },
            { label: 'Stamp Duty Calculator', href: '/tools/stamp-duty' },
            { label: 'Mortgage Calculator', href: '/tools/mortgage' },
            { label: 'Investment Yield', href: '/tools/investment-yield' },
            { label: 'Suburb Match Quiz', href: '/tools/suburb-match' },
            { label: 'Price Heatmap', href: '/tools/heatmap' },
          ].map(item => (
            <li><a href={item.href} style="font-size:0.825rem;color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Areas -->
      <div>
        <p class="eyebrow mb-6">Areas</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.35rem 1rem;">
          {[
            { label: 'Balmoral',            href: '/suburbs/balmoral' },
            { label: 'Belmont',             href: '/suburbs/belmont' },
            { label: 'Brisbane CBD',        href: '/suburbs/brisbane-cbd' },
            { label: 'Brisbane Inner East', href: '/brisbane-inner-east' },
            { label: 'Bulimba',             href: '/suburbs/bulimba' },
            { label: 'Camp Hill',           href: '/suburbs/camp-hill' },
            { label: 'Cannon Hill',         href: '/suburbs/cannon-hill' },
            { label: 'Carina',              href: '/suburbs/carina' },
            { label: 'Carina Heights',      href: '/suburbs/carina-heights' },
            { label: 'Carindale',           href: '/suburbs/carindale' },
            { label: 'Coorparoo',           href: '/suburbs/coorparoo' },
            { label: 'East Brisbane',       href: '/suburbs/east-brisbane' },
            { label: 'Fortitude Valley',    href: '/suburbs/fortitude-valley' },
            { label: 'Greenslopes',         href: '/suburbs/greenslopes' },
            { label: 'Hawthorne',           href: '/suburbs/hawthorne' },
            { label: 'Hemmant',             href: '/suburbs/hemmant' },
            { label: 'Holland Park',        href: '/suburbs/holland-park' },
            { label: 'Holland Park West',   href: '/suburbs/holland-park-west' },
            { label: 'Kangaroo Point',      href: '/suburbs/kangaroo-point' },
            { label: 'Morningside',         href: '/suburbs/morningside' },
            { label: 'Mount Gravatt',       href: '/suburbs/mount-gravatt' },
            { label: 'Mt Gravatt East',     href: '/suburbs/mount-gravatt-east' },
            { label: 'Murarrie',            href: '/suburbs/murarrie' },
            { label: 'New Farm',            href: '/suburbs/new-farm' },
            { label: 'Norman Park',         href: '/suburbs/norman-park' },
            { label: 'Seven Hills',         href: '/suburbs/seven-hills' },
            { label: 'Tarragindi',          href: '/suburbs/tarragindi' },
            { label: 'Teneriffe',           href: '/suburbs/teneriffe' },
            { label: 'Tingalpa',            href: '/suburbs/tingalpa' },
            { label: 'Upper Mt Gravatt',    href: '/suburbs/upper-mount-gravatt' },
            { label: 'Woolloongabba',       href: '/suburbs/woolloongabba' },
          ].map(item => (
            <a href={item.href} style="font-size:0.75rem;color:var(--color-text-muted);transition:color 0.2s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-muted)'">{item.label}</a>
          ))}
        </div>
      </div>

      <!-- Contact -->
      <div>
        <p class="eyebrow mb-6">Contact Daniel</p>
        <ul class="flex flex-col gap-5">
          <li>
            <p style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.3rem;">Office</p>
            <p style="font-size:0.825rem;color:var(--color-text-secondary);line-height:1.65;">Unit 6, 57–59 Oxford Street<br/>Bulimba QLD 4171</p>
          </li>
          <li>
            <p style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.3rem;">Mobile</p>
            <a href="tel:+61412523821" style="font-size:0.825rem;color:var(--color-text-secondary);">0412 523 821</a>
          </li>
          <li>
            <p style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.3rem;">Office Phone</p>
            <a href="tel:+61732541022" style="font-size:0.825rem;color:var(--color-text-secondary);">(07) 3254 1022</a>
          </li>
          <li>
            <p style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.3rem;">Email</p>
            <a href="mailto:daniel.gierach@raywhite.com" style="font-size:0.825rem;color:var(--color-text-secondary);">daniel.gierach@raywhite.com</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8" style="border-top:1px solid rgba(72,72,72,0.15);">
      <p style="font-size:0.7rem;color:var(--color-text-muted);letter-spacing:0.08em;text-transform:uppercase;">
        &copy; {year} Daniel Gierach Property · Ray White Bulimba. All rights reserved.
      </p>
      <div class="flex gap-6">
        {[
          { label: 'Privacy Policy', href: '/privacy' },
          { label: 'Terms of Use', href: '/terms' },
          { label: 'Sitemap', href: '/sitemap' },
        ].map(item => (
          <a href={item.href} style="font-size:0.7rem;color:var(--color-text-muted);letter-spacing:0.08em;text-transform:uppercase;transition:color 0.2s;" onmouseover="this.style.color='var(--color-text-secondary)'" onmouseout="this.style.color='var(--color-text-muted)'">{item.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
