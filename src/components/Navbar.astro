---
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0">
        <img
          src="/images/logo.svg"
          alt="Cirqle Group"
          class="h-10 w-auto"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
        />
        <span class="hidden text-white font-bold text-xl tracking-wide">Cirqle Group</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-8">
        <div class="relative group" data-dropdown>
          <button
            class="nav-link text-white/90 hover:text-white text-sm font-medium transition-colors flex items-center gap-1"
            aria-haspopup="true"
            aria-expanded="false"
          >
            For Employers <i class="fa-solid fa-chevron-down text-xs" aria-hidden="true"></i>
          </button>
          <div
            role="menu"
            class="absolute top-full left-0 mt-2 w-52 bg-white rounded-lg shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200"
          >
            <a href="/employers/" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">Overview</a>
            <a href="/employers/#recruitment" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">IT Recruitment</a>
            <a href="/employers/#consulting" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">Project Consulting</a>
          </div>
        </div>
        <div class="relative group" data-dropdown>
          <button
            class="nav-link text-white/90 hover:text-white text-sm font-medium transition-colors flex items-center gap-1"
            aria-haspopup="true"
            aria-expanded="false"
          >
            For Job Seekers <i class="fa-solid fa-chevron-down text-xs" aria-hidden="true"></i>
          </button>
          <div
            role="menu"
            class="absolute top-full left-0 mt-2 w-52 bg-white rounded-lg shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200"
          >
            <a href="/candidates/browse-jobs/" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">Browse Jobs</a>
            <a href="/candidates/register/" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">Register</a>
            <a href="/candidates/salary-calculator/" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">Salary Calculator</a>
          </div>
        </div>
        <a href="/profit-for-purpose/" class="nav-link text-white/90 hover:text-white text-sm font-medium transition-colors">Profit for Purpose</a>
        <div class="relative group" data-dropdown>
          <button
            class="nav-link text-white/90 hover:text-white text-sm font-medium transition-colors flex items-center gap-1"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Insights <i class="fa-solid fa-chevron-down text-xs" aria-hidden="true"></i>
          </button>
          <div
            role="menu"
            class="absolute top-full left-0 mt-2 w-52 bg-white rounded-lg shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200"
          >
            <a href="/news-updates/" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">Articles & Updates</a>
            <a href="/chasing-good/" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">Chasing Good Podcast</a>
            <a href="/technology-job-library/" role="menuitem" class="block px-4 py-2.5 text-sm text-[#383E4F] hover:text-[#26A8FF] hover:bg-[#E5F3FA]">Technology Job Library</a>
          </div>
        </div>
      </div>

      <!-- CTA + Mobile -->
      <div class="flex items-center gap-3">
        <a href="#enquire" class="hidden lg:inline-flex items-center gap-2 bg-[#26A8FF] text-white font-semibold text-sm px-5 py-2.5 rounded-md hover:bg-[#0090e8] transition-colors">
          Contact Us <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
        <button id="mobile-menu-btn" class="lg:hidden text-white p-2" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
          <i class="fa-solid fa-bars text-xl" aria-hidden="true"></i>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-[#060E23] border-t border-white/10">
    <div class="px-4 py-4 flex flex-col gap-1">
      <a href="/employers/" class="text-white/90 hover:text-[#26A8FF] py-3 text-sm font-medium border-b border-white/10">For Employers</a>
      <a href="/candidates/browse-jobs/" class="text-white/90 hover:text-[#26A8FF] py-3 text-sm font-medium border-b border-white/10">Browse Jobs</a>
      <a href="/candidates/register/" class="text-white/90 hover:text-[#26A8FF] py-3 text-sm font-medium border-b border-white/10">Register as Candidate</a>
      <a href="/profit-for-purpose/" class="text-white/90 hover:text-[#26A8FF] py-3 text-sm font-medium border-b border-white/10">Profit for Purpose</a>
      <a href="/news-updates/" class="text-white/90 hover:text-[#26A8FF] py-3 text-sm font-medium border-b border-white/10">Articles & Insights</a>
      <a href="/chasing-good/" class="text-white/90 hover:text-[#26A8FF] py-3 text-sm font-medium border-b border-white/10">Chasing Good Podcast</a>
      <a href="/contact-us/" class="mt-3 btn-primary text-center">Send an Enquiry</a>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  // Scroll behavior — white background after scrolling
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-[#060E23]', 'shadow-lg');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove('bg-[#060E23]', 'shadow-lg');
      navbar?.classList.add('bg-transparent');
    }
  });

  // Mobile menu toggle
  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    const icon = mobileMenuBtn.querySelector('i');
    if (icon) {
      icon.classList.toggle('fa-bars');
      icon.classList.toggle('fa-xmark');
    }
    mobileMenuBtn.setAttribute('aria-expanded', String(!isOpen));
    mobileMenuBtn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });

  // Close mobile menu on nav link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      const icon = mobileMenuBtn?.querySelector('i');
      if (icon) {
        icon.classList.add('fa-bars');
        icon.classList.remove('fa-xmark');
      }
      mobileMenuBtn?.setAttribute('aria-expanded', 'false');
      mobileMenuBtn?.setAttribute('aria-label', 'Open menu');
    });
  });

  // Desktop dropdown: Escape to close, aria-expanded sync
  document.querySelectorAll('[data-dropdown]').forEach(dropdown => {
    const btn = dropdown.querySelector('button');
    const menu = dropdown.querySelector('[role="menu"]');
    if (!btn || !menu) return;

    const open = () => btn.setAttribute('aria-expanded', 'true');
    const close = () => btn.setAttribute('aria-expanded', 'false');

    dropdown.addEventListener('mouseenter', open);
    dropdown.addEventListener('mouseleave', close);
    dropdown.addEventListener('focusin', open);
    dropdown.addEventListener('focusout', (e) => {
      if (!dropdown.contains((e as FocusEvent).relatedTarget as Node)) close();
    });

    btn.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') {
        close();
        btn.focus();
      }
    });

    menu.querySelectorAll('[role="menuitem"]').forEach(item => {
      (item as HTMLElement).addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Escape') {
          close();
          btn.focus();
        }
      });
    });
  });
</script>
