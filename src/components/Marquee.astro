---
const items = [
  'IT Recruitment',
  'Technology Consulting',
  'Social Enterprise',
  'Profit for Purpose',
  'Queensland Based',
  'Enterprise & Government',
  'Project Delivery',
  'SME Certified',
];
---

<div class="bg-[#26A8FF] relative pt-5 pb-16" aria-hidden="true">
  <div class="overflow-hidden">
    <div class="marquee-track flex items-center gap-0 whitespace-nowrap">
      {[...items, ...items].map(item => (
        <span class="inline-flex items-center gap-6 px-6">
          <span class="text-white font-bold text-base uppercase tracking-widest">{item}</span>
          <span class="text-white/40 text-sm">✦</span>
        </span>
      ))}
    </div>
  </div>

  <!-- Diagonal divider → flows into white Services section -->
  <div class="absolute bottom-0 left-0 right-0 leading-[0] pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 56" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full block" style="height:56px">
      <polygon points="0,0 1440,56 0,56" fill="white"/>
    </svg>
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee 35s linear infinite;
    width: max-content;
  }

  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
