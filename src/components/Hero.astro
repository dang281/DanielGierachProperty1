---
---

<section class="relative min-h-dvh flex items-center overflow-hidden bg-[#1a2a50]">

  <!-- Background grid texture -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 80px 60px;
    "
  ></div>

  <!-- Glow orbs -->
  <div class="absolute top-0 right-1/4 w-[500px] h-[500px] rounded-full bg-[#26A8FF]/12 blur-[130px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-[#26A8FF]/8 blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 lg:py-0 lg:min-h-dvh flex items-center w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center w-full">

      <!-- LEFT: Copy -->
      <div class="hero-left">
        <h1 class="hero-item hero-item-1 text-5xl sm:text-6xl lg:text-7xl xl:text-[5.5rem] font-black text-white uppercase leading-[0.92] tracking-tight mb-7">
          Shaping<br />
          Tomorrow<br />
          Through<br />
          <span class="text-[#26A8FF]">Technology</span><br />
          <span class="hero-outline">Excellence.</span>
        </h1>

        <p class="hero-item hero-item-2 text-base sm:text-lg text-white/70 leading-relaxed mb-10 max-w-lg">
          Transform your tech future with the right talent. We provide IT recruitment and project delivery services while investing in a better future for everyone.
        </p>

        <!-- Job search bar -->
        <div class="hero-item hero-item-3 flex flex-col sm:flex-row bg-white rounded-full shadow-2xl overflow-hidden max-w-2xl">
          <input
            type="text"
            name="keywords"
            placeholder="KEYWORDS"
            aria-label="Job keywords"
            class="flex-1 px-6 py-4 text-sm font-medium text-gray-500 placeholder-gray-400 uppercase tracking-wide outline-none bg-transparent"
          />
          <div class="hidden sm:block w-px bg-gray-200 self-stretch my-3"></div>
          <div class="hidden sm:flex items-center gap-2 px-6 py-4 text-sm font-medium text-gray-600 uppercase tracking-wide cursor-default">
            All Locations
            <i class="fa-solid fa-chevron-right text-gray-400 text-xs" aria-hidden="true"></i>
          </div>
          <a
            href="/candidates/browse-jobs/"
            class="flex items-center justify-center gap-2 bg-[#060E23] hover:bg-[#1F2848] text-white text-sm font-bold uppercase tracking-wide px-7 py-4 sm:rounded-full transition-colors duration-200 m-0 sm:m-1.5"
          >
            <i class="fa-solid fa-circle-arrow-right text-lg" aria-hidden="true"></i>
            Find Jobs
          </a>
        </div>
      </div>

      <!-- RIGHT: Circular image -->
      <div class="hero-right hidden lg:flex justify-center items-center">
        <div class="relative">
          <!-- Glow halo rings -->
          <div class="absolute inset-0 rounded-full" style="box-shadow: 0 0 0 16px rgba(38,168,255,0.15), 0 0 0 36px rgba(38,168,255,0.07), 0 0 80px 20px rgba(38,168,255,0.12);"></div>
          <!-- Image circle -->
          <div class="w-[440px] h-[440px] xl:w-[480px] xl:h-[480px] rounded-full border-[10px] border-white shadow-2xl overflow-hidden bg-[#0f1e40] relative z-10">
            <img
              src="/images/hero-team.jpg"
              alt="Cirqle Group team collaborating"
              width="480"
              height="480"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Diagonal section divider → flows into marquee blue -->
  <div class="absolute bottom-0 left-0 right-0 leading-[0] pointer-events-none z-20" aria-hidden="true">
    <svg viewBox="0 0 1440 64" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full block" style="height:64px">
      <polygon points="0,64 1440,0 1440,64" fill="#26A8FF"/>
    </svg>
  </div>

</section>

<style>
  /* Outlined headline word */
  .hero-outline {
    -webkit-text-stroke: 3px white;
    color: transparent;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-item {
      opacity: 0;
      transform: translateY(14px);
      animation: heroFadeUp 0.6s ease-out forwards;
    }

    .hero-item-1 { animation-delay: 0.05s; }
    .hero-item-2 { animation-delay: 0.2s; }
    .hero-item-3 { animation-delay: 0.32s; }

    .hero-right {
      opacity: 0;
      animation: heroFadeIn 0.8s ease-out 0.15s forwards;
    }

    @keyframes heroFadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes heroFadeIn {
      to { opacity: 1; }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-item, .hero-right { opacity: 1; transform: none; }
  }
</style>
