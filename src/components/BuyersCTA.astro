---
interface Props {
  suburb?: string;
}
const { suburb } = Astro.props;
const location = suburb ? `in ${suburb}` : "in Brisbane's inner east";
---

<!-- Centred to the suburb-page content column (max 800px + 24px gutters).
     GieMann palette: white card, gold accent, white text on the gold button. -->
<div style="max-width:848px;margin:2.5rem auto;padding:0 24px;box-sizing:border-box;">
  <div style="background:#ffffff;border-left:3px solid #b98229;border-radius:16px;padding:1.75rem 2rem;">
    <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#6b4610;margin:0 0 0.6rem;">Off-Market &amp; Pre-Market Access</p>
    <h3 style="font-family:var(--font-serif);font-size:1.25rem;font-weight:400;color:#191817;margin:0 0 0.65rem;line-height:1.2;">Looking to buy {location}?</h3>
    <p style="font-family:var(--font-sans);font-size:0.88rem;font-weight:300;color:rgba(25,24,23,0.72);line-height:1.75;margin:0 0 1.25rem;max-width:52ch;">Many of the best properties here are spoken for before a sign goes up. Register your brief and Daniel will reach out when something comes up that fits.</p>
    <a href="/buyers"
      style="display:inline-flex;align-items:center;gap:0.45rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;color:#ffffff;background:#b98229;padding:0.7rem 1.4rem;border-radius:10px;text-decoration:none;transition:background 0.2s;"
      onmouseover="this.style.background='#a26a1b'"
      onmouseout="this.style.background='#b98229'">
      Register your search
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</div>
