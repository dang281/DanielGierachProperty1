---
interface Props {
  suburb?: string;
}
const { suburb } = Astro.props;
const location = suburb ? `in ${suburb}` : "in Brisbane's inner east";
---

<div style="margin:2.5rem 0;background:var(--color-surface-1);border-left:3px solid #c4912a;padding:1.75rem 2rem;">
  <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#c4912a;margin:0 0 0.6rem;">Off-Market &amp; Pre-Market Access</p>
  <h3 style="font-family:var(--font-serif);font-size:1.25rem;font-weight:400;color:#1c1917;margin:0 0 0.65rem;line-height:1.2;">Looking to buy {location}?</h3>
  <p style="font-family:var(--font-sans);font-size:0.88rem;font-weight:300;color:#57534e;line-height:1.75;margin:0 0 1.25rem;max-width:52ch;">Many of the best properties here are spoken for before a sign goes up. Register your brief and Daniel will reach out when something comes up that fits.</p>
  <a href="/buyers"
    style="display:inline-flex;align-items:center;gap:0.45rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;color:#0a0806;background:#c4912a;padding:0.7rem 1.4rem;border-radius:8px;text-decoration:none;transition:background 0.2s;"
    onmouseover="this.style.background='#d4af4a'"
    onmouseout="this.style.background='#c4912a'">
    Register your search
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </a>
</div>
