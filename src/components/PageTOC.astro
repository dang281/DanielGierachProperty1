---
// Article-style right-rail TOC. Auto-generates from H2 elements inside
// #main. Renders a fixed sidebar at ≥1280px with a scrollspy that
// highlights the current section, plus a reading progress bar at the
// top of the page and a floating back-to-top button.
//
// Drop `<PageTOC />` anywhere inside the Layout body. It needs at least
// 3 H2s in the page to appear; below that it stays hidden.
---

<aside id="page-toc" aria-label="On this page" class="no-print" hidden>
  <p class="page-toc-title">On this page</p>
  <ol id="page-toc-list"></ol>
</aside>

<button id="page-back-to-top" type="button" aria-label="Back to top" class="no-print" hidden>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
</button>

<style is:global>
  #page-toc {
    position: fixed;
    top: 50%;
    right: 1.5rem;
    transform: translateY(-50%);
    width: 210px;
    max-height: 68vh;
    overflow-y: auto;
    padding: 0.95rem 1rem 1rem;
    background: rgba(242,234,212,0.94);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(107,70,16,0.15);
    border-radius: 12px;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 10px 28px rgba(107,70,16,0.10);
    z-index: 40;
  }
  .page-toc-title {
    font-family: var(--font-serif);
    font-variant-caps: all-small-caps;
    font-weight: 400;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    color: #6b4610;
    margin: 0 0 0.7rem;
    font-variation-settings: "opsz" 14;
  }
  #page-toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  #page-toc-list a {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    line-height: 1.3;
    color: rgba(25,24,23,0.55);
    text-decoration: none;
    display: block;
    padding: 0.32rem 0.5rem 0.32rem 0.6rem;
    border-left: 2px solid transparent;
    border-radius: 4px;
    transition: color 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    /* Truncate long section titles so the rail stays compact */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #page-toc-list a:hover {
    color: #191817;
    background: rgba(185,130,41,0.08);
  }
  #page-toc-list a.is-active {
    color: #191817;
    background: rgba(185,130,41,0.28);
    border-left: 3px solid #b98229;
    padding-left: 0.55rem;
    font-weight: 700;
  }
  #page-back-to-top {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 46px; height: 46px;
    border: 1px solid rgba(107,70,16,0.35);
    border-radius: 50%;
    background: #f2ead4;
    color: #6b4610;
    cursor: pointer;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(107,70,16,0.14);
    transition: background 0.18s, transform 0.18s;
  }
  #page-back-to-top:hover { background: #ede2c5; transform: translateY(-2px); }
  @media (max-width: 1279px) {
    #page-toc { display: none !important; }
    #page-back-to-top { bottom: 6rem; }
  }
</style>

<script is:inline>
  function initPageTOC() {
    var main = document.getElementById('main');
    if (!main) return;

    var btn = document.getElementById('page-back-to-top');
    function updateBackToTop() {
      if (!btn) return;
      btn.hidden = window.scrollY <= 600;
    }
    if (btn) btn.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });

    // Pick up h2s + any explicit .bio-eyebrow markers (team pages use
     // the eyebrow class as their section labels instead of h2 semantics)
    // Pick up h2s + any explicit .bio-eyebrow markers (team pages use
    // the eyebrow class as their section labels instead of h2 semantics)
    var headings = Array.prototype.slice.call(main.querySelectorAll('h2, .bio-eyebrow'));
    // Prefer innerText so <br> tags produce spaces instead of running
    // adjacent words together ("One listing.Six offices..." bug).
    function readText(el) {
      var t = (el.innerText || el.textContent || '').replace(/\s+/g, ' ').trim();
      return t;
    }
    var toc = document.getElementById('page-toc');
    var list = document.getElementById('page-toc-list');
    var links = [];
    if (headings.length >= 3 && toc && list) {
      headings.forEach(function (h, i) {
        var text = readText(h);
        if (!h.id) {
          var slug = text.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').slice(0, 60) || ('section-' + i);
          h.id = slug;
        }
        var li = document.createElement('li');
        var a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = text;
        a.dataset.target = h.id;
        li.appendChild(a);
        list.appendChild(li);
        links.push(a);
      });
      toc.hidden = false;

      // Simple scroll-position spy: highlight the LAST heading whose top
      // has crossed a virtual line 20% down the viewport. Always keeps
      // one entry active, so the reader can see where they are without
      // gaps between sections.
      function updateActive() {
        var trigger = window.scrollY + window.innerHeight * 0.22;
        var activeIdx = 0;
        for (var i = 0; i < headings.length; i++) {
          if (headings[i].getBoundingClientRect().top + window.scrollY <= trigger) {
            activeIdx = i;
          }
        }
        for (var j = 0; j < links.length; j++) {
          links[j].classList.toggle('is-active', j === activeIdx);
        }
      }
      updateActive();
      window.addEventListener('scroll', updateActive, { passive: true });
    }

    window.addEventListener('scroll', updateBackToTop, { passive: true });
    updateBackToTop();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPageTOC);
  } else {
    initPageTOC();
  }
</script>
