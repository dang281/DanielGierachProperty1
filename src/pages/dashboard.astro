---
import Layout from '../layouts/Layout.astro';
import { execSync } from 'child_process';
import { readdirSync, readFileSync } from 'fs';
import { join, dirname } from 'path';
import { fileURLToPath } from 'url';

// Works on both local machine and Vercel
const __dir = dirname(fileURLToPath(import.meta.url)); // src/pages/
const repoRoot = process.cwd();

let gitCommits: { hash: string; date: string; message: string; link: string }[] = [];
try {
  const raw = execSync(
    `git -C ${repoRoot} log --format="%H|%ad|%s" --date=format:"%d %b %Y" -30`,
    { encoding: 'utf-8' }
  ).trim();
  gitCommits = raw.split('\n').map(line => {
    const [hash, date, ...msgParts] = line.split('|');
    const message = msgParts.join('|');
    // Derive a live link from the commit message
    let link = '';
    const suburbMatch = message.match(/suburb[s]?\s+page[s]?\s+(?:for\s+)?([a-z\s\-]+)/i) ||
                        message.match(/add\s+([a-z\s\-]+)\s+suburb/i);
    const insightMatch = message.match(/selling[- ]in[- ]([a-z\-]+)/i) ||
                         message.match(/insights?\s+article\s+(?:for\s+)?([a-z\s\-]+)/i);
    const pathMatch = message.match(/at\s+(\/[a-z0-9\/\-]+)/i);
    if (insightMatch) {
      const slug = insightMatch[1].trim().toLowerCase().replace(/\s+/g, '-');
      link = `https://danielgierach.com/insights/selling-in-${slug}`;
    } else if (suburbMatch) {
      const slug = suburbMatch[1].trim().toLowerCase().replace(/\s+/g, '-');
      link = `https://danielgierach.com/suburbs/${slug}`;
    } else if (pathMatch) {
      link = `https://danielgierach.com${pathMatch[1]}`;
    } else if (message.toLowerCase().includes('homepage') || message.toLowerCase().includes('index')) {
      link = 'https://danielgierach.com';
    }
    return { hash: hash.slice(0, 7), date, message, link };
  });
} catch (_) {}

let suburbPages: string[] = [];
let insightPages: string[] = [];
try {
  suburbPages = readdirSync(join(__dir, 'suburbs'))
    .filter(f => f.endsWith('.astro') && f !== 'index.astro')
    .map(f => f.replace('.astro', ''));
  insightPages = readdirSync(join(__dir, 'insights'))
    .filter(f => f.endsWith('.astro') && f !== 'index.astro')
    .map(f => f.replace('.astro', ''));
} catch (_) {}

const buildTime = new Date().toLocaleString('en-AU', { timeZone: 'Australia/Brisbane', dateStyle: 'medium', timeStyle: 'short' });

// ── Social content drafts ──────────────────────────────────────────────────
const AVATAR = 'https://cdn6.ep.dynamics.net/s3/rw-media/memberphotos/88889915-cef5-4a5f-9c19-0cea700d7bca.jpeg';

interface SocialDraft {
  filename: string;
  platform: string;
  platformNorm: string; // 'instagram' | 'facebook' | 'linkedin' | 'other'
  title: string;
  date: string;
  body: string;
  hashtags: string;
  notes: string;
  goal: string;
  format: string;
}
let socialDrafts: SocialDraft[] = [];
try {
  const socialDir = join(repoRoot, 'content', 'social');
  const files = readdirSync(socialDir).filter(f => f.endsWith('.md') && f !== '.gitkeep');
  socialDrafts = files.map(filename => {
    const raw = readFileSync(join(socialDir, filename), 'utf-8');
    const titleMatch    = raw.match(/^#\s+(.+)/m);
    const platformMatch = raw.match(/\*\*Platform:\*\*\s*(.+)/i);
    const formatMatch   = raw.match(/\*\*Format:\*\*\s*(.+)/i);
    const goalMatch     = raw.match(/\*\*Goal:\*\*\s*(.+)/i);
    const captionMatch  = raw.match(/## Caption\s+([\s\S]+?)(?=\n## |\n---|\s*$)/i);
    const hashtagMatch  = raw.match(/## Hashtags\s+([\s\S]+?)(?=\n## |\n---|\s*$)/i);
    const notesMatch    = raw.match(/## Notes for Daniel\s+([\s\S]+?)(?=\n## |\s*$)/i);
    const dateFromFile  = filename.match(/^(\d{4}-\d{2}-\d{2})/)?.[1] || '';
    const dateFormatted = dateFromFile
      ? new Date(dateFromFile + 'T12:00:00').toLocaleDateString('en-AU', { weekday:'short', day:'numeric', month:'short', year:'numeric' })
      : '';
    const platformRaw = platformMatch?.[1]?.trim() || 'Social';
    const platformLower = platformRaw.toLowerCase();
    const platformNorm = platformLower.includes('instagram') ? 'instagram'
                       : platformLower.includes('facebook') ? 'facebook'
                       : platformLower.includes('linkedin') ? 'linkedin'
                       : 'other';
    return {
      filename,
      platform: platformRaw,
      platformNorm,
      title: titleMatch?.[1]?.trim() || filename.replace('.md',''),
      date: dateFormatted,
      body: captionMatch?.[1]?.trim() || raw.slice(0, 600),
      hashtags: hashtagMatch?.[1]?.trim() || '',
      notes: notesMatch?.[1]?.trim() || '',
      goal: goalMatch?.[1]?.trim() || '',
      format: formatMatch?.[1]?.trim() || '',
    };
  }).sort((a, b) => b.filename.localeCompare(a.filename));
} catch (_) {}

// ── Weekly Content Review ──────────────────────────────────────────────────
// Compute AEST-aware week boundaries (Mon–Sun)
function toAEST(d: Date) {
  // AEST = UTC+10 (no DST correction needed for date arithmetic)
  return new Date(d.toLocaleString('en-US', { timeZone: 'Australia/Brisbane' }));
}
const aestNow = toAEST(new Date());
const dow = aestNow.getDay(); // 0=Sun … 6=Sat
const daysToMon = dow === 0 ? 6 : dow - 1;

const thisMon = new Date(aestNow);
thisMon.setDate(aestNow.getDate() - daysToMon);
thisMon.setHours(0, 0, 0, 0);

const thisSun = new Date(thisMon);
thisSun.setDate(thisMon.getDate() + 6);
thisSun.setHours(23, 59, 59, 0);

const lastMon = new Date(thisMon);
lastMon.setDate(thisMon.getDate() - 7);

const lastSun = new Date(thisMon);
lastSun.setDate(thisMon.getDate() - 1);
lastSun.setHours(23, 59, 59, 0);

const fmtDay = (d: Date) => d.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', timeZone: 'Australia/Brisbane' });
const thisWeekLabel = `${fmtDay(thisMon)} – ${fmtDay(thisSun)}`;
const lastWeekLabel = `${fmtDay(lastMon)} – ${fmtDay(lastSun)}`;

function deriveLinkFromMessage(message: string): string {
  const suburbMatch = message.match(/suburb[s]?\s+page[s]?\s+(?:for\s+)?([a-z\s\-]+)/i) ||
                      message.match(/add\s+([a-z\s\-]+)\s+suburb/i);
  const insightMatch = message.match(/selling[- ]in[- ]([a-z\-]+)/i) ||
                       message.match(/insights?\s+article\s+(?:for\s+)?([a-z\s\-]+)/i);
  if (insightMatch) return `https://danielgierach.com/insights/selling-in-${insightMatch[1].trim().toLowerCase().replace(/\s+/g, '-')}`;
  if (suburbMatch) return `https://danielgierach.com/suburbs/${suburbMatch[1].trim().toLowerCase().replace(/\s+/g, '-')}`;
  if (/homepage|index/i.test(message)) return 'https://danielgierach.com';
  return '';
}

// ── Today's commits ───────────────────────────────────────────────────────
const todayLabel = aestNow.toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Australia/Brisbane' });
const todayISO = aestNow.toISOString().slice(0, 10);

let todayCommits: { time: string; message: string; link: string; type: string }[] = [];
try {
  const raw = execSync(
    `git -C ${repoRoot} log --format="%ad|%s" --date=format:"%H:%M" --after="${todayISO}T00:00:00+10:00"`,
    { encoding: 'utf-8' }
  ).trim();
  todayCommits = raw.split('\n').filter(Boolean).map(line => {
    const [time, ...msgParts] = line.split('|');
    const message = msgParts.join('|');
    const link = deriveLinkFromMessage(message);
    const type = /insight|article|selling[- ]in/i.test(message) ? 'Article'
               : /suburb/i.test(message) ? 'Suburb Page'
               : /social/i.test(message) ? 'Social'
               : 'Update';
    return { time, message, link, type };
  });
} catch (_) {}

let lastWeekContent: { date: string; message: string; link: string; type: string }[] = [];
try {
  const since = lastMon.toISOString().slice(0, 10);
  const until = thisMon.toISOString().slice(0, 10);
  const raw = execSync(
    `git -C ${repoRoot} log --format="%ad|%s" --date=format:"%d %b" --after="${since}" --before="${until}"`,
    { encoding: 'utf-8' }
  ).trim();
  lastWeekContent = raw.split('\n').filter(Boolean).map(line => {
    const [date, ...msgParts] = line.split('|');
    const message = msgParts.join('|');
    const link = deriveLinkFromMessage(message);
    const type = /insight|article|selling[- ]in/i.test(message) ? 'Article'
               : /suburb/i.test(message) ? 'Suburb Page' : 'Page';
    return { date, message, link, type };
  }).filter(c => c.link);
} catch (_) {}
---

<Layout title="Dashboard" description="Internal." hideMobileCta={true}>

<script>document.querySelector('meta[name="robots"]')?.setAttribute('content','noindex,nofollow');</script>

<!-- Password gate -->
<div id="gate" style="display:none;position:fixed;inset:0;background:#0f0d0c;z-index:9999;display:flex;align-items:center;justify-content:center;">
  <div style="text-align:center;padding:2rem;">
    <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin-bottom:1rem;">Daniel Gierach Property</p>
    <h2 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:300;color:#f2efe9;margin-bottom:1.5rem;">Dashboard Access</h2>
    <input id="gate-input" type="password" placeholder="Password" style="background:#1c1917;border:1px solid rgba(196,145,42,0.3);color:#f2efe9;font-family:var(--font-sans);font-size:0.9rem;padding:0.65rem 1rem;width:220px;outline:none;display:block;margin:0 auto 0.75rem;" />
    <p id="gate-error" style="font-family:var(--font-sans);font-size:0.75rem;color:#ef4444;min-height:1rem;margin-bottom:0.75rem;"></p>
    <button id="gate-btn" style="background:#c4912a;color:#1c1917;font-family:var(--font-sans);font-size:0.8rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;border:none;padding:0.65rem 1.75rem;cursor:pointer;">Enter</button>
  </div>
</div>

<div id="dashboard-content" style="display:none;">
<div style="background:#0f0d0c;min-height:100vh;padding:2rem 1.5rem 6rem;">
  <div style="max-width:1200px;margin:0 auto;">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:3rem;padding-bottom:1.5rem;border-bottom:1px solid rgba(196,145,42,0.2);">
      <div>
        <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin-bottom:0.4rem;">Daniel Gierach Property</p>
        <h1 style="font-family:var(--font-serif);font-size:1.8rem;font-weight:300;color:#f2efe9;margin:0;">Agent Dashboard</h1>
      </div>
      <div style="text-align:right;">
        <p style="font-family:var(--font-sans);font-size:0.7rem;color:rgba(242,239,233,0.4);margin:0;">Built {buildTime} AEST</p>
        <p style="font-family:var(--font-sans);font-size:0.7rem;color:rgba(242,239,233,0.4);margin:0.2rem 0 0;"><a href="/dashboard" style="color:#c4912a;text-decoration:none;">Refresh for latest data →</a></p>
      </div>
    </div>

    <!-- ═══════════════════════════════════════
         DAILY UPDATE
    ════════════════════════════════════════ -->
    <div style="background:linear-gradient(135deg,rgba(196,145,42,0.12) 0%,rgba(196,145,42,0.04) 100%);border:1px solid rgba(196,145,42,0.35);padding:1.75rem;margin-bottom:2rem;">

      <!-- Date + summary bar -->
      <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#c4912a;margin-bottom:0.3rem;">Daily Update</p>
          <p style="font-family:var(--font-serif);font-size:1.4rem;font-weight:300;color:#f2efe9;margin:0;">{todayLabel}</p>
        </div>
        <!-- Quick counts — filled client-side -->
        <div style="display:flex;gap:1.5rem;flex-wrap:wrap;align-items:center;">
          <div style="text-align:center;">
            <p style="font-family:var(--font-serif);font-size:1.6rem;font-weight:300;color:#22c55e;margin:0;" id="today-done-count">{todayCommits.length}</p>
            <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0.1rem 0 0;">Published</p>
          </div>
          <div style="text-align:center;">
            <p style="font-family:var(--font-serif);font-size:1.6rem;font-weight:300;color:#3b82f6;margin:0;" id="today-tasks-count">—</p>
            <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0.1rem 0 0;">Completed</p>
          </div>
          <div style="text-align:center;">
            <p style="font-family:var(--font-serif);font-size:1.6rem;font-weight:300;color:#c4912a;margin:0;" id="today-running-count">—</p>
            <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0.1rem 0 0;">In Progress</p>
          </div>
          <div style="text-align:center;">
            <p style="font-family:var(--font-serif);font-size:1.6rem;font-weight:300;color:#a855f7;margin:0;" id="today-review-count">—</p>
            <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0.1rem 0 0;">Needs Review</p>
          </div>
        </div>
      </div>

      <!-- Two columns -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;" class="daily-grid">

        <!-- Left: Published today (git, build-time) -->
        <div>
          <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(242,239,233,0.45);margin:0 0 0.85rem;">Published Today</p>
          {todayCommits.length === 0 ? (
            <p style="font-family:var(--font-sans);font-size:0.8rem;color:rgba(242,239,233,0.3);font-style:italic;">Nothing deployed yet today.</p>
          ) : (
            <div style="display:flex;flex-direction:column;gap:0.4rem;">
              {todayCommits.map(c => (
                <div style="display:flex;align-items:center;gap:0.6rem;padding:0.55rem 0.8rem;background:rgba(34,197,94,0.06);border:1px solid rgba(34,197,94,0.18);">
                  <span style="font-size:0.58rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;background:rgba(34,197,94,0.15);color:#22c55e;padding:0.1rem 0.35rem;border-radius:2px;flex-shrink:0;">{c.type}</span>
                  <p style="font-family:var(--font-sans);font-size:0.77rem;color:#f2efe9;margin:0;flex:1;line-height:1.3;">{c.message}</p>
                  <span style="font-size:0.62rem;color:rgba(242,239,233,0.3);flex-shrink:0;">{c.time}</span>
                  {c.link && <a href={c.link} target="_blank" style="flex-shrink:0;font-size:0.6rem;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;color:#22c55e;text-decoration:none;border:1px solid rgba(34,197,94,0.3);padding:0.15rem 0.4rem;">View ↗</a>}
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Right: Agent activity today (client-side) -->
        <div>
          <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(242,239,233,0.45);margin:0 0 0.85rem;">Agent Activity Today</p>
          <div id="today-activity"><p style="font-family:var(--font-sans);font-size:0.8rem;color:rgba(242,239,233,0.4);">Loading...</p></div>
        </div>

      </div>
    </div>

    <!-- Stats strip -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:1rem;margin-bottom:2.5rem;">
      <div style="background:#1c1917;border:1px solid rgba(196,145,42,0.15);padding:1.25rem 1.5rem;">
        <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Suburb Pages</p>
        <p style="font-family:var(--font-serif);font-size:2.2rem;font-weight:300;color:#f2efe9;margin:0;">{suburbPages.length}</p>
        <a href="https://danielgierach.com/suburbs" target="_blank" style="font-family:var(--font-sans);font-size:0.72rem;color:#c4912a;text-decoration:none;">View all suburbs →</a>
      </div>
      <div style="background:#1c1917;border:1px solid rgba(196,145,42,0.15);padding:1.25rem 1.5rem;">
        <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Insights Articles</p>
        <p style="font-family:var(--font-serif);font-size:2.2rem;font-weight:300;color:#f2efe9;margin:0;">{insightPages.length}</p>
        <a href="https://danielgierach.com/insights" target="_blank" style="font-family:var(--font-sans);font-size:0.72rem;color:#c4912a;text-decoration:none;">View all articles →</a>
      </div>
      <div style="background:#1c1917;border:1px solid rgba(196,145,42,0.15);padding:1.25rem 1.5rem;">
        <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Active Agents</p>
        <p style="font-family:var(--font-serif);font-size:2.2rem;font-weight:300;color:#f2efe9;margin:0;" id="agents-count">—</p>
        <p style="font-family:var(--font-sans);font-size:0.72rem;color:rgba(242,239,233,0.4);margin:0;">Paperclip team</p>
      </div>
      <div style="background:#1c1917;border:1px solid rgba(196,145,42,0.15);padding:1.25rem 1.5rem;">
        <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Tasks Completed</p>
        <p style="font-family:var(--font-serif);font-size:2.2rem;font-weight:300;color:#f2efe9;margin:0;" id="done-count">—</p>
        <p style="font-family:var(--font-sans);font-size:0.72rem;color:rgba(242,239,233,0.4);margin:0;">All time</p>
      </div>
      <div style="background:#1c1917;border:1px solid rgba(196,145,42,0.15);padding:1.25rem 1.5rem;">
        <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Open Tasks</p>
        <p style="font-family:var(--font-serif);font-size:2.2rem;font-weight:300;color:#f2efe9;margin:0;" id="open-issues-count">—</p>
        <p style="font-family:var(--font-sans);font-size:0.72rem;color:rgba(242,239,233,0.4);margin:0;">todo + in progress</p>
      </div>
    </div>

    <!-- ═══════════════════════════════════════
         WEEKLY CONTENT REVIEW
    ════════════════════════════════════════ -->
    <div style="background:#1c1917;border:1px solid rgba(196,145,42,0.3);padding:1.75rem;margin-bottom:2rem;">
      <!-- Header row -->
      <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;padding-bottom:1.25rem;border-bottom:1px solid rgba(196,145,42,0.15);">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin-bottom:0.35rem;">Weekly Content Review</p>
          <p style="font-family:var(--font-serif);font-size:1.2rem;font-weight:300;color:#f2efe9;margin:0;">This week: {thisWeekLabel}</p>
          <p style="font-family:var(--font-sans);font-size:0.72rem;color:rgba(242,239,233,0.4);margin:0.2rem 0 0;">Reviewed every Monday — approve items below to clear them for publishing.</p>
        </div>
        <!-- Approval progress (filled client-side) -->
        <div id="weekly-progress" style="text-align:right;min-width:160px;">
          <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0 0 0.4rem;">Approvals</p>
          <p style="font-family:var(--font-serif);font-size:1.8rem;font-weight:300;color:#22c55e;margin:0;" id="approval-fraction">—</p>
          <div style="margin-top:0.5rem;height:5px;background:rgba(255,255,255,0.07);border-radius:3px;overflow:hidden;width:160px;">
            <div id="approval-bar" style="height:100%;background:#22c55e;width:0%;transition:width 0.4s;border-radius:3px;"></div>
          </div>
        </div>
      </div>

      <!-- Two-column layout -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;" class="weekly-grid">

        <!-- Left: Last week's published content (build-time from git) -->
        <div>
          <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(242,239,233,0.5);margin:0 0 1rem;">Published Last Week <span style="color:rgba(242,239,233,0.3);font-weight:400;">({lastWeekLabel})</span></p>
          {lastWeekContent.length === 0 ? (
            <p style="font-family:var(--font-sans);font-size:0.8rem;color:rgba(242,239,233,0.3);font-style:italic;">No content commits found for last week.</p>
          ) : (
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
              {lastWeekContent.map(c => (
                <div style="display:flex;align-items:center;gap:0.75rem;padding:0.7rem 0.9rem;background:rgba(34,197,94,0.05);border:1px solid rgba(34,197,94,0.15);">
                  <div style="flex:1;min-width:0;">
