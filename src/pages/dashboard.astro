                    <div style="background:rgba(196,145,42,0.06);border:1px solid rgba(196,145,42,0.15);padding:0.75rem;">
                      <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#c4912a;margin:0 0 0.3rem;">Notes for Daniel</p>
                      <p style="font-family:var(--font-sans);font-size:0.75rem;color:rgba(242,239,233,0.65);margin:0;line-height:1.6;">{d.notes}</p>
                    </div>
                  )}
                  <div style="display:flex;align-items:center;justify-content:space-between;padding-top:0.5rem;border-top:1px solid rgba(255,255,255,0.06);">
                    <code style="font-size:0.6rem;color:rgba(242,239,233,0.25);">{d.filename}</code>
                    <a href={`https://github.com/dang281/DanielGierachProperty1/blob/main/content/social/${d.filename}`} target="_blank"
                      style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#c4912a;text-decoration:none;border:1px solid rgba(196,145,42,0.3);padding:0.2rem 0.5rem;">Edit on GitHub ↗</a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Recent Deploys -->
    <div style="background:#1c1917;border:1px solid rgba(196,145,42,0.15);padding:1.5rem;">
      <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#c4912a;margin-bottom:1.25rem;">Recent Deploys (last 30 commits)</p>
      <div style="display:flex;flex-direction:column;gap:0;">
        {gitCommits.map(commit => (
          <div style="display:flex;gap:1rem;align-items:center;padding:0.65rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
            <code style="font-size:0.68rem;color:#c4912a;flex-shrink:0;font-family:monospace;width:4rem;">{commit.hash}</code>
            <p style="font-family:var(--font-sans);font-size:0.8rem;font-weight:300;color:#f2efe9;margin:0;flex:1;line-height:1.4;">{commit.message}</p>
            <p style="font-family:var(--font-sans);font-size:0.68rem;color:rgba(242,239,233,0.35);flex-shrink:0;white-space:nowrap;">{commit.date}</p>
            {commit.link && (
              <a href={commit.link} target="_blank" style="flex-shrink:0;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#c4912a;text-decoration:none;border:1px solid rgba(196,145,42,0.3);padding:0.2rem 0.5rem;white-space:nowrap;">View ↗</a>
            )}
          </div>
        ))}
      </div>
    </div>

  </div>
</div>
</div> <!-- end dashboard-content -->

<script>
  const API = 'http://127.0.0.1:3100';
  const COMPANY = 'e01db3e8-fb70-4c7a-b7a7-495c1df05882';
  const SITE = 'https://danielgierach.com';

  const statusColour: Record<string, string> = {
    idle:       '#22c55e',
    running:    '#3b82f6',
    error:      '#ef4444',
    todo:       '#6b7280',
    in_progress:'#3b82f6',
    blocked:    '#ef4444',
    in_review:  '#a855f7',
    done:       '#22c55e',
    backlog:    '#4b5563',
  };

  const priorityColour: Record<string, string> = {
    critical: '#ef4444', high: '#f97316', medium: '#c4912a', low: '#6b7280',
  };

  function pill(label: string, colour: string) {
    return `<span style="display:inline-block;font-size:0.6rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;background:${colour}22;color:${colour};padding:0.15rem 0.5rem;border-radius:2px;">${label}</span>`;
  }

  // Derive a live URL from an issue title
  function issueLink(title: string): string {
    const t = title.toLowerCase();
    const suburbPageMatch = t.match(/(?:suburb page|suburb|page)\s+(?:for\s+)?([a-z\s]+?)(?:\s+suburb|\s+page|$)/);
    const sellingMatch = t.match(/selling[- ]in[- ]([a-z\s\-]+?)(?:\s+insight|\s+article|$)/);
    const insightMatch = t.match(/insights?\s+article\s+(?:for\s+)?([a-z\s]+?)(?:\s+suburb|\s+insight|$)/);
    if (sellingMatch) return `${SITE}/insights/selling-in-${sellingMatch[1].trim().replace(/\s+/g,'-')}`;
    if (insightMatch) return `${SITE}/insights/selling-in-${insightMatch[1].trim().replace(/\s+/g,'-')}`;
    if (suburbPageMatch) return `${SITE}/suburbs/${suburbPageMatch[1].trim().replace(/\s+/g,'-')}`;
    if (t.includes('dashboard')) return `${SITE}/dashboard`;
    if (t.includes('homepage') || t.includes('home page')) return SITE;
    if (t.includes('suburb')) return `${SITE}/suburbs`;
    if (t.includes('insight') || t.includes('article')) return `${SITE}/insights`;
    return '';
  }

  // ── Daily Update helpers ────────────────────────────────────────────────
  function isToday(dateStr: string): boolean {
    if (!dateStr) return false;
    const d = new Date(dateStr);
    const now = new Date();
    // Compare in AEST
    const aestD   = new Date(d.toLocaleString('en-US',   { timeZone: 'Australia/Brisbane' }));
    const aestNow = new Date(now.toLocaleString('en-US', { timeZone: 'Australia/Brisbane' }));
    return aestD.getFullYear() === aestNow.getFullYear() &&
           aestD.getMonth()    === aestNow.getMonth()    &&
           aestD.getDate()     === aestNow.getDate();
  }

  function renderDailyActivity(issues: any[]) {
    const completedToday = issues.filter(i => i.status === 'done' && isToday(i.completedAt));
    const inProgress     = issues.filter(i => i.status === 'in_progress');
    const needsReview    = issues.filter(i => ['in_review','blocked'].includes(i.status));

    document.getElementById('today-tasks-count')!.textContent   = String(completedToday.length);
    document.getElementById('today-running-count')!.textContent = String(inProgress.length);
    document.getElementById('today-review-count')!.textContent  = String(needsReview.length);

    const el = document.getElementById('today-activity')!;

    const rows: string[] = [];

    if (inProgress.length > 0) {
      rows.push(`<p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0 0 0.4rem;">Running now</p>`);
      inProgress.forEach(i => {
        rows.push(`<div style="display:flex;align-items:center;gap:0.6rem;padding:0.5rem 0.75rem;background:rgba(59,130,246,0.06);border:1px solid rgba(59,130,246,0.2);margin-bottom:0.35rem;">
          <div style="width:6px;height:6px;border-radius:50%;background:#3b82f6;flex-shrink:0;animation:pulse 1.5s infinite;"></div>
          <div style="flex:1;min-width:0;">
            <p style="font-family:var(--font-sans);font-size:0.78rem;color:#f2efe9;margin:0;line-height:1.3;">${i.title}</p>
            <p style="font-size:0.62rem;color:rgba(242,239,233,0.35);margin:0.1rem 0 0;">${agentMap[i.assigneeAgentId] || 'Agent'}</p>
          </div>
        </div>`);
      });
    }

    if (completedToday.length > 0) {
      rows.push(`<p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:${inProgress.length>0?'0.85rem':0} 0 0.4rem;">Completed today</p>`);
      completedToday.forEach(i => {
        const link = issueLink(i.title);
        rows.push(`<div style="display:flex;align-items:center;gap:0.6rem;padding:0.5rem 0.75rem;background:rgba(34,197,94,0.05);border:1px solid rgba(34,197,94,0.15);margin-bottom:0.35rem;">
          <div style="width:6px;height:6px;border-radius:50%;background:#22c55e;flex-shrink:0;"></div>
          <div style="flex:1;min-width:0;">
            <p style="font-family:var(--font-sans);font-size:0.78rem;color:#f2efe9;margin:0;line-height:1.3;">${i.title}</p>
            <p style="font-size:0.62rem;color:rgba(242,239,233,0.35);margin:0.1rem 0 0;">${agentMap[i.assigneeAgentId] || 'Agent'}</p>
          </div>
          ${link ? `<a href="${link}" target="_blank" style="flex-shrink:0;font-size:0.6rem;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;color:#c4912a;text-decoration:none;border:1px solid rgba(196,145,42,0.3);padding:0.15rem 0.4rem;">View ↗</a>` : ''}
        </div>`);
      });
    }

    if (needsReview.length > 0) {
      rows.push(`<p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(168,85,247,0.7);margin:${(inProgress.length||completedToday.length)?'0.85rem':0} 0 0.4rem;">Needs your attention</p>`);
      needsReview.forEach(i => {
        const colour = i.status === 'blocked' ? '#ef4444' : '#a855f7';
        rows.push(`<div style="display:flex;align-items:center;gap:0.6rem;padding:0.5rem 0.75rem;background:${colour}11;border:1px solid ${colour}33;margin-bottom:0.35rem;">
          <div style="width:6px;height:6px;border-radius:50%;background:${colour};flex-shrink:0;"></div>
          <p style="font-family:var(--font-sans);font-size:0.78rem;color:#f2efe9;margin:0;flex:1;line-height:1.3;">${i.title}</p>
          ${pill(i.status.replace('_',' '), colour)}
        </div>`);
      });
    }

    el.innerHTML = rows.length > 0 ? rows.join('') : '<p style="font-family:var(--font-sans);font-size:0.8rem;color:rgba(242,239,233,0.3);font-style:italic;">No agent activity recorded yet today.</p>';
  }

  // Approval state persisted in localStorage
  function getApproval(id: string): 'approved' | 'rejected' | null {
    return localStorage.getItem(`wcr_${id}`) as any;
  }
  function setApproval(id: string, state: 'approved' | 'rejected') {
    localStorage.setItem(`wcr_${id}`, state);
  }

  async function approveIssue(issueId: string, el: HTMLElement) {
    setApproval(issueId, 'approved');
    try {
      await fetch(`${API}/api/companies/${COMPANY}/issues/${issueId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'done' })
      });
    } catch {}
    renderWeeklyQueue(weeklyIssues);
  }

  async function rejectIssue(issueId: string) {
    setApproval(issueId, 'rejected');
    try {
      await fetch(`${API}/api/companies/${COMPANY}/issues/${issueId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'todo' })
      });
    } catch {}
    renderWeeklyQueue(weeklyIssues);
  }

  let weeklyIssues: any[] = [];

  function renderWeeklyQueue(items: any[]) {
    const el = document.getElementById('weekly-queue')!;
    const fracEl = document.getElementById('approval-fraction')!;
    const barEl = document.getElementById('approval-bar')!;

    // Content issues = in_review OR assigned to SEO agent that are todo/in_progress
    const SEO_AGENT = '8868cd83-6be1-4b6d-9c85-26eebb8d92b7';
    const contentItems = items.filter(i =>
      i.status === 'in_review' ||
      (i.assigneeAgentId === SEO_AGENT && ['todo','in_progress'].includes(i.status))
    );

    const approved = contentItems.filter(i => getApproval(i.id) === 'approved').length;
    const rejected = contentItems.filter(i => getApproval(i.id) === 'rejected').length;
    const pending  = contentItems.length - approved - rejected;
    const pct = contentItems.length > 0 ? Math.round((approved / contentItems.length) * 100) : 0;

    fracEl.textContent = `${approved} / ${contentItems.length}`;
    barEl.style.width = `${pct}%`;

    if (contentItems.length === 0) {
      el.innerHTML = '<p style="font-family:var(--font-sans);font-size:0.8rem;color:rgba(242,239,233,0.3);font-style:italic;">No content queued for approval this week.</p>';
      return;
    }

    el.innerHTML = contentItems.map(i => {
      const state = getApproval(i.id);
      const agentName = agentMap[i.assigneeAgentId] || 'Agent';
      const isContent = /insight|article|suburb|selling[- ]in/i.test(i.title);
      const why = i.description
        ? `<p style="font-size:0.72rem;color:rgba(242,239,233,0.45);margin:0.3rem 0 0.6rem;line-height:1.5;">${i.description.slice(0, 200)}${i.description.length > 200 ? '…' : ''}</p>`
        : `<p style="font-size:0.72rem;color:rgba(242,239,233,0.35);margin:0.3rem 0 0.6rem;font-style:italic;">Created by ${agentName} · ${i.status.replace('_',' ')}</p>`;

      const borderColour = state === 'approved' ? 'rgba(34,197,94,0.35)'
                         : state === 'rejected'  ? 'rgba(239,68,68,0.3)'
                         : 'rgba(168,85,247,0.25)';
      const bgColour     = state === 'approved' ? 'rgba(34,197,94,0.05)'
                         : state === 'rejected'  ? 'rgba(239,68,68,0.05)'
                         : 'rgba(168,85,247,0.05)';

      const link = issueLink(i.title);
      const viewBtn = link ? `<a href="${link}" target="_blank" style="font-size:0.62rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#c4912a;text-decoration:none;border:1px solid rgba(196,145,42,0.3);padding:0.2rem 0.5rem;white-space:nowrap;">View ↗</a>` : '';

      return `
        <div id="wqi-${i.id}" style="padding:0.85rem;background:${bgColour};border:1px solid ${borderColour};margin-bottom:0.6rem;border-radius:1px;">
          <div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.2rem;flex-wrap:wrap;">
            <code style="font-size:0.62rem;color:#c4912a;">${i.identifier}</code>
            ${pill(i.status.replace('_',' '), statusColour[i.status]||'#6b7280')}
            ${state === 'approved' ? pill('approved', '#22c55e') : state === 'rejected' ? pill('rejected', '#ef4444') : ''}
          </div>
          <p style="font-family:var(--font-sans);font-size:0.82rem;color:#f2efe9;margin:0.1rem 0 0;line-height:1.4;">${i.title}</p>
          ${why}
          <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
            ${state ? '' : `
              <button onclick="window.__approveIssue('${i.id}',this)" style="font-size:0.65rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;background:#22c55e;color:#0a0806;border:none;padding:0.3rem 0.75rem;cursor:pointer;">Approve ✓</button>
              <button onclick="window.__rejectIssue('${i.id}')" style="font-size:0.65rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;background:transparent;color:#ef4444;border:1px solid rgba(239,68,68,0.4);padding:0.3rem 0.75rem;cursor:pointer;">Reject ✗</button>
            `}
            ${state === 'rejected' ? `<button onclick="window.__approveIssue('${i.id}',this)" style="font-size:0.65rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;background:#22c55e;color:#0a0806;border:none;padding:0.3rem 0.75rem;cursor:pointer;">Approve anyway ✓</button>` : ''}
            ${viewBtn}
          </div>
        </div>`;
    }).join('');
  }

  // Expose approval handlers to global scope for inline onclick
  (window as any).__approveIssue = approveIssue;
  (window as any).__rejectIssue  = rejectIssue;

  let agentMap: Record<string, string> = {};
  let cachedAgents: any[] = [];

  async function loadAgents() {
    try {
      const res = await fetch(`${API}/api/companies/${COMPANY}/agents`);
      const agents: any[] = await res.json();
      cachedAgents = agents;
      agents.forEach(a => { agentMap[a.id] = a.name; });
      document.getElementById('agents-count')!.textContent = String(agents.length);
      // Token data loads alongside issues; agent intel rendered after both are ready
      await loadTokenData(agents.map(a => a.id));
    } catch {
      document.getElementById('agent-intel-grid')!.innerHTML = '<p style="font-size:0.8rem;color:#ef4444;">Could not reach Paperclip API. Is PaperclipAI running?</p>';
    }
  }

  async function loadIssues() {
    try {
      const res = await fetch(`${API}/api/companies/${COMPANY}/issues`);
      const all: any[] = await res.json();

      const open   = all.filter(i => ['todo','in_progress','blocked','in_review'].includes(i.status));
      const done   = all.filter(i => i.status === 'done');
      const review = all.filter(i => i.status === 'in_review');

      // Store for estimator
      doneIssues = done;

      // Build per-agent issue map and render agent intel (needs tokenData from loadAgents)
      const issuesByAgent: Record<string, any[]> = {};
      all.filter(i => ['todo','in_progress'].includes(i.status)).forEach(i => {
        if (!i.assigneeAgentId) return;
        if (!issuesByAgent[i.assigneeAgentId]) issuesByAgent[i.assigneeAgentId] = [];
        issuesByAgent[i.assigneeAgentId].push(i);
      });
      if (cachedAgents.length > 0) {
        renderAgentIntel(cachedAgents, issuesByAgent);
        updateEstimatorBaseline();
      }

      // Daily update
      renderDailyActivity(all);

      // Weekly review queue
      weeklyIssues = all;
      renderWeeklyQueue(all);

      document.getElementById('open-issues-count')!.textContent = String(open.length);
      document.getElementById('done-count')!.textContent = String(done.length);

      // Active tasks board
      const groups: Record<string, any[]> = { in_progress:[], todo:[], blocked:[], in_review:[] };
      open.forEach(i => { if (groups[i.status]) groups[i.status].push(i); });
      const labels: Record<string,string> = { in_progress:'In Progress', todo:'To Do', blocked:'Blocked', in_review:'In Review' };
      document.getElementById('issues-board')!.innerHTML = Object.entries(groups).map(([status, items]) => `
        <div>
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
            <div style="width:8px;height:8px;border-radius:50%;background:${statusColour[status]};"></div>
            <p style="font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,239,233,0.5);margin:0;">${labels[status]} (${items.length})</p>
          </div>
          ${items.length === 0
            ? '<p style="font-size:0.78rem;color:rgba(242,239,233,0.25);padding:0.5rem 0;">None</p>'
            : items.map(i => `
              <div style="padding:0.75rem;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);margin-bottom:0.5rem;">
                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.3rem;">
                  <code style="font-size:0.65rem;color:#c4912a;">${i.identifier}</code>
                  ${pill(i.priority||'medium', priorityColour[i.priority]||'#6b7280')}
                </div>
                <p style="font-family:var(--font-sans);font-size:0.8rem;color:#f2efe9;margin:0;line-height:1.4;">${i.title}</p>
                ${i.assigneeAgentId ? `<p style="font-size:0.68rem;color:rgba(242,239,233,0.35);margin:0.3rem 0 0;">${agentMap[i.assigneeAgentId] || 'Agent'}</p>` : ''}
              </div>`).join('')
          }
        </div>`).join('');

      // Pending review
      const approvalEl = document.getElementById('pending-approvals')!;
      approvalEl.innerHTML = review.length === 0
        ? '<p style="font-size:0.82rem;color:rgba(242,239,233,0.4);">Nothing awaiting review.</p>'
        : review.map(i => `
          <div style="padding:0.75rem;background:rgba(168,85,247,0.06);border:1px solid rgba(168,85,247,0.2);margin-bottom:0.5rem;">
            <code style="font-size:0.65rem;color:#a855f7;">${i.identifier}</code>
            <p style="font-size:0.82rem;color:#f2efe9;margin:0.3rem 0 0;line-height:1.4;">${i.title}</p>
          </div>`).join('');

      // Completed work — grouped by agent
      const byAgent: Record<string, any[]> = {};
      done.forEach(i => {
        const key = i.assigneeAgentId ? (agentMap[i.assigneeAgentId] || i.assigneeAgentId) : 'Unassigned';
        if (!byAgent[key]) byAgent[key] = [];
        byAgent[key].push(i);
      });

      document.getElementById('completed-work')!.innerHTML = Object.entries(byAgent).map(([agentName, items]) => `
        <div style="margin-bottom:1.75rem;">
          <p style="font-family:var(--font-sans);font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,239,233,0.5);margin:0 0 0.75rem;padding-bottom:0.5rem;border-bottom:1px solid rgba(255,255,255,0.06);">
            ${agentName} — ${items.length} completed
          </p>
          <div style="display:flex;flex-direction:column;gap:0.4rem;">
            ${items.map(i => {
              const link = issueLink(i.title);
              const completedAt = i.completedAt
                ? new Date(i.completedAt).toLocaleString('en-AU', { timeZone:'Australia/Brisbane', dateStyle:'short', timeStyle:'short' })
                : '';
              return `
                <div style="display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0.85rem;background:rgba(34,197,94,0.04);border:1px solid rgba(34,197,94,0.12);">
                  <div style="width:6px;height:6px;border-radius:50%;background:#22c55e;flex-shrink:0;"></div>
                  <div style="flex:1;min-width:0;">
                    <p style="font-family:var(--font-sans);font-size:0.8rem;color:#f2efe9;margin:0;line-height:1.4;">${i.title}</p>
                    ${completedAt ? `<p style="font-size:0.65rem;color:rgba(242,239,233,0.35);margin:0.15rem 0 0;">Completed ${completedAt} AEST</p>` : ''}
                  </div>
                  ${link ? `<a href="${link}" target="_blank" style="flex-shrink:0;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#c4912a;text-decoration:none;border:1px solid rgba(196,145,42,0.3);padding:0.25rem 0.6rem;white-space:nowrap;">View ↗</a>` : ''}
                </div>`;
            }).join('')}
          </div>
        </div>`).join('');

    } catch {
      document.getElementById('completed-work')!.innerHTML = '<p style="font-size:0.8rem;color:#ef4444;">Could not reach Paperclip API. Is PaperclipAI running?</p>';
    }
  }

  // ── Token / run data ───────────────────────────────────────────────────
  let tokenData: Record<string, {
    totalRuns: number; totalInput: number; totalOutput: number;
    totalCached: number; totalCost: number; avgTokensPerRun: number;
    avgCostPerRun: number; recentRuns: any[];
  }> = {};
  let doneIssues: any[] = [];

  async function loadTokenData(agentIds: string[]): Promise<void> {
    await Promise.all(agentIds.map(async (agentId) => {
      try {
        const res = await fetch(`${API}/api/companies/${COMPANY}/heartbeat-runs?agentId=${agentId}`);
        const runs: any[] = await res.json();
        let totalInput = 0, totalOutput = 0, totalCached = 0, totalCost = 0;
        const recentRuns: any[] = [];
        runs.forEach(run => {
          const u = run.usageJson || {};
          totalInput  += u.inputTokens  || 0;
          totalOutput += u.outputTokens || 0;
          totalCached += u.cachedInputTokens || 0;
          totalCost   += u.costUsd || 0;
          if (recentRuns.length < 4 && run.status === 'succeeded') {
            recentRuns.push({
              startedAt: run.startedAt,
              input:  u.inputTokens  || 0,
              output: u.outputTokens || 0,
              cached: u.cachedInputTokens || 0,
              cost:   u.costUsd || 0,
              summary: run.resultJson?.result?.replace(/\*\*/g,'').slice(0, 180) || '',
            });
          }
        });
        const total = totalInput + totalOutput;
        tokenData[agentId] = {
          totalRuns: runs.length,
          totalInput, totalOutput, totalCached, totalCost,
          avgTokensPerRun: runs.length > 0 ? Math.round(total / runs.length) : 0,
          avgCostPerRun:   runs.length > 0 ? totalCost / runs.length : 0,
          recentRuns,
        };
      } catch {
        tokenData[agentId] = { totalRuns:0, totalInput:0, totalOutput:0, totalCached:0, totalCost:0, avgTokensPerRun:0, avgCostPerRun:0, recentRuns:[] };
      }
    }));
  }

  function fmtK(n: number): string {
    if (n >= 1_000_000) return (n/1_000_000).toFixed(1) + 'M';
    if (n >= 1_000)     return Math.round(n/1_000) + 'K';
    return String(n);
  }
  function fmtUsd(n: number): string {
    if (n >= 1) return '$' + n.toFixed(2);
    return '$' + n.toFixed(3);
  }

  function renderAgentIntel(agents: any[], issuesByAgent: Record<string, any[]>) {
    const el = document.getElementById('agent-intel-grid')!;
    if (!agents.length) { el.innerHTML = '<p style="color:#ef4444;font-size:0.8rem;">Could not load agent data.</p>'; return; }

    // Global token totals for reference bar scaling
    const maxCost = Math.max(...agents.map(a => tokenData[a.id]?.totalCost || 0), 0.01);

    el.innerHTML = agents.map(a => {
      const td = tokenData[a.id];
      const colour = statusColour[a.status] || '#6b7280';
      const tasks  = issuesByAgent[a.id] || [];
      const active = tasks.find(t => t.status === 'in_progress');
      const queue  = tasks.filter(t => t.status === 'todo');
      const lastBeat = a.lastHeartbeatAt
        ? new Date(a.lastHeartbeatAt).toLocaleString('en-AU', { timeZone:'Australia/Brisbane', hour:'numeric', minute:'2-digit', day:'numeric', month:'short' })
        : 'Never';

      const totalTok = td ? td.totalInput + td.totalOutput : 0;
      const costFrac = td ? (td.totalCost / maxCost) : 0;
      const barWidth = Math.round(costFrac * 100);

      const currentProject = active
        ? `<div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);padding:0.6rem 0.85rem;margin-bottom:0.6rem;">
            <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#3b82f6;margin:0 0 0.2rem;">Working on</p>
            <div style="display:flex;align-items:center;gap:0.4rem;">
              <div style="width:6px;height:6px;border-radius:50%;background:#3b82f6;flex-shrink:0;animation:pulse 1.5s infinite;"></div>
              <p style="font-family:var(--font-sans);font-size:0.78rem;color:#f2efe9;margin:0;line-height:1.35;">${active.title}</p>
            </div>
          </div>`
        : `<div style="padding:0.5rem 0.75rem;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05);margin-bottom:0.6rem;">
            <p style="font-family:var(--font-sans);font-size:0.75rem;color:rgba(242,239,233,0.3);margin:0;font-style:italic;">No active task</p>
          </div>`;

      const queueHtml = queue.length > 0
        ? queue.slice(0,3).map(t => `<div style="display:flex;align-items:center;gap:0.5rem;padding:0.35rem 0;border-bottom:1px solid rgba(255,255,255,0.04);">
            <code style="font-size:0.6rem;color:rgba(196,145,42,0.6);flex-shrink:0;">${t.identifier}</code>
            <p style="font-family:var(--font-sans);font-size:0.72rem;color:rgba(242,239,233,0.7);margin:0;flex:1;line-height:1.3;">${t.title}</p>
          </div>`).join('') + (queue.length > 3 ? `<p style="font-size:0.65rem;color:rgba(242,239,233,0.3);margin:0.4rem 0 0;">+${queue.length - 3} more in queue</p>` : '')
        : `<p style="font-family:var(--font-sans);font-size:0.72rem;color:rgba(242,239,233,0.25);margin:0;font-style:italic;">Queue empty</p>`;

      const lastRunHtml = td?.recentRuns[0]?.summary
        ? `<div style="margin-top:0.75rem;padding:0.6rem 0.75rem;background:rgba(255,255,255,0.02);border-left:2px solid rgba(196,145,42,0.2);">
            <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.3);margin:0 0 0.2rem;">Last run summary</p>
            <p style="font-family:var(--font-sans);font-size:0.71rem;color:rgba(242,239,233,0.55);margin:0;line-height:1.55;">${td.recentRuns[0].summary}${td.recentRuns[0].summary.length === 180 ? '…' : ''}</p>
          </div>`
        : '';

      return `
        <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);padding:1.1rem;display:flex;flex-direction:column;gap:0.85rem;">

          <!-- Header -->
          <div style="display:flex;align-items:center;gap:0.65rem;padding-bottom:0.85rem;border-bottom:1px solid rgba(255,255,255,0.06);">
            <div style="width:10px;height:10px;border-radius:50%;background:${colour};flex-shrink:0;${a.status==='running'?'animation:pulse 1.5s infinite;':''}"></div>
            <div style="flex:1;min-width:0;">
              <p style="font-family:var(--font-sans);font-size:0.88rem;font-weight:600;color:#f2efe9;margin:0;">${a.name}</p>
              <p style="font-family:var(--font-sans);font-size:0.64rem;color:rgba(242,239,233,0.35);margin:0.1rem 0 0;">Last active: ${lastBeat} AEST</p>
            </div>
            ${pill(a.status, colour)}
          </div>

          <!-- Token usage -->
          <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.4rem;">
              <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0;">Token Usage</p>
              <p style="font-family:var(--font-sans);font-size:0.65rem;color:#c4912a;margin:0;">${td ? fmtUsd(td.totalCost) : '—'} total</p>
            </div>
            <!-- Cost bar (relative to most expensive agent) -->
            <div style="height:6px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden;margin-bottom:0.5rem;">
              <div style="height:100%;width:${barWidth}%;background:linear-gradient(90deg,#c4912a,#f59e0b);border-radius:3px;transition:width 0.6s;"></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.5rem;">
              <div style="text-align:center;padding:0.4rem;background:rgba(255,255,255,0.03);">
                <p style="font-family:var(--font-serif);font-size:1rem;font-weight:300;color:#f2efe9;margin:0;">${td ? fmtK(totalTok) : '—'}</p>
                <p style="font-family:var(--font-sans);font-size:0.55rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:rgba(242,239,233,0.35);margin:0.1rem 0 0;">Total tokens</p>
              </div>
              <div style="text-align:center;padding:0.4rem;background:rgba(255,255,255,0.03);">
                <p style="font-family:var(--font-serif);font-size:1rem;font-weight:300;color:#f2efe9;margin:0;">${td ? fmtK(td.avgTokensPerRun) : '—'}</p>
                <p style="font-family:var(--font-sans);font-size:0.55rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:rgba(242,239,233,0.35);margin:0.1rem 0 0;">Avg / run</p>
              </div>
              <div style="text-align:center;padding:0.4rem;background:rgba(255,255,255,0.03);">
                <p style="font-family:var(--font-serif);font-size:1rem;font-weight:300;color:#f2efe9;margin:0;">${td ? String(td.totalRuns) : '—'}</p>
                <p style="font-family:var(--font-sans);font-size:0.55rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:rgba(242,239,233,0.35);margin:0.1rem 0 0;">Total runs</p>
              </div>
            </div>
            <!-- cached tokens note -->
            ${td && td.totalCached > 0 ? `<p style="font-family:var(--font-sans);font-size:0.6rem;color:rgba(242,239,233,0.25);margin:0.4rem 0 0;">${fmtK(td.totalCached)} cached (prompt cache hits)</p>` : ''}
          </div>

          <!-- Current project + queue -->
          <div>
            <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0 0 0.5rem;">Project Pipeline</p>
            ${currentProject}
            ${queueHtml}
          </div>

          ${lastRunHtml}
        </div>`;
    }).join('');
  }

  // ── Project Cost Estimator ──────────────────────────────────────────────
  function updateEstimatorBaseline() {
    const done = doneIssues.length;
    const allAgentIds = Object.keys(tokenData);
    const totalTok = allAgentIds.reduce((s, id) => s + (tokenData[id]?.totalInput||0) + (tokenData[id]?.totalOutput||0), 0);
    const totalCost = allAgentIds.reduce((s, id) => s + (tokenData[id]?.totalCost||0), 0);
    const el = document.getElementById('est-baseline');
    if (!el) return;
    if (done > 0 && totalTok > 0) {
      const tokPerTask = Math.round(totalTok / done);
      const costPerTask = totalCost / done;
      el.textContent = `Baseline: ~${fmtK(tokPerTask)} tokens per task · ${fmtUsd(costPerTask)} avg · from ${done} completed tasks`;
    } else {
      el.textContent = 'Not enough data yet — complete some tasks first.';
    }
  }

  function estimateCost() {
    const input = (document.getElementById('est-input') as HTMLTextAreaElement).value.trim();
    const el = document.getElementById('est-result')!;
    if (!input) { el.innerHTML = '<p style="color:rgba(242,239,233,0.4);font-size:0.78rem;">Enter a project description above.</p>'; return; }

    const done = doneIssues.length;
    if (done === 0) {
      el.innerHTML = '<p style="color:rgba(242,239,233,0.4);font-size:0.78rem;">No completed tasks yet to base an estimate on.</p>';
      return;
    }

    const allAgentIds = Object.keys(tokenData);
    const totalTok  = allAgentIds.reduce((s, id) => s + (tokenData[id]?.totalInput||0) + (tokenData[id]?.totalOutput||0), 0);
    const totalCost = allAgentIds.reduce((s, id) => s + (tokenData[id]?.totalCost||0), 0);
    const baseTokensPerTask = totalTok / done;
    const baseCostPerTask   = totalCost / done;

    // Detect task type and count from the description
    const lower = input.toLowerCase();
    let taskCount = 1;
    let multiplier = 1.0;
    let breakdown: string[] = [];

    // Count items in lists (e.g. "Bulimba, Hawthorne and Balmoral" = 3)
    const listItems = input.split(/,|\band\b/).map(s => s.trim()).filter(Boolean);
    if (listItems.length > 1) taskCount = listItems.length;

    // Adjust multiplier by task type
    if (/suburb page|suburb seo|suburb content/i.test(input)) {
      multiplier = 1.2; breakdown.push('Suburb pages are slightly heavier than average (template + SEO copy).');
    } else if (/insight|article|selling guide|seller guide|blog/i.test(input)) {
      multiplier = 1.0; breakdown.push('Insights articles align closely with historical average.');
    } else if (/social|instagram|facebook|linkedin|post/i.test(input)) {
      multiplier = 0.65; breakdown.push('Social posts are lighter than average.');
    } else if (/suburb|page/i.test(input)) {
      multiplier = 1.1; breakdown.push('Suburb pages estimated at 1.1x baseline.');
    } else if (/multi|series|all suburb|every suburb|campaign/i.test(input)) {
      multiplier = 1.3; breakdown.push('Multi-item projects estimated at 1.3x baseline per item.');
    }

    const estTokensPerTask = Math.round(baseTokensPerTask * multiplier);
    const estCostPerTask   = baseCostPerTask * multiplier;
    const estTotalTokens   = estTokensPerTask * taskCount;
    const estTotalCost     = estCostPerTask * taskCount;

    // Detect which agent would handle this
    let agentHint = 'SEO & Content Agent';
    if (/social|instagram|facebook|linkedin/i.test(input)) agentHint = 'Social Media Agent';
    else if (/seo|suburb|insight|article|content/i.test(input)) agentHint = 'SEO & Content Agent';

    el.innerHTML = `
      <div style="background:rgba(59,130,246,0.06);border:1px solid rgba(59,130,246,0.2);padding:1.25rem;">
        <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#3b82f6;margin:0 0 0.85rem;">Cost Estimate</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:0.75rem;margin-bottom:1rem;">
          <div style="text-align:center;padding:0.75rem;background:rgba(0,0,0,0.2);">
            <p style="font-family:var(--font-serif);font-size:1.5rem;font-weight:300;color:#f2efe9;margin:0;">${taskCount}</p>
            <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0.1rem 0 0;">Task${taskCount !== 1 ? 's' : ''} detected</p>
          </div>
          <div style="text-align:center;padding:0.75rem;background:rgba(0,0,0,0.2);">
            <p style="font-family:var(--font-serif);font-size:1.5rem;font-weight:300;color:#f2efe9;margin:0;">${fmtK(estTokensPerTask)}</p>
            <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0.1rem 0 0;">Tokens / task</p>
          </div>
          <div style="text-align:center;padding:0.75rem;background:rgba(0,0,0,0.2);">
            <p style="font-family:var(--font-serif);font-size:1.5rem;font-weight:300;color:#c4912a;margin:0;">${fmtK(estTotalTokens)}</p>
            <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0.1rem 0 0;">Total tokens</p>
          </div>
          <div style="text-align:center;padding:0.75rem;background:rgba(0,0,0,0.2);">
            <p style="font-family:var(--font-serif);font-size:1.5rem;font-weight:300;color:#c4912a;margin:0;">${fmtUsd(estTotalCost)}</p>
            <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:rgba(242,239,233,0.4);margin:0.1rem 0 0;">Est. cost</p>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.3rem;">
          <p style="font-family:var(--font-sans);font-size:0.72rem;color:rgba(242,239,233,0.5);margin:0;">Agent: <strong style="color:#f2efe9;">${agentHint}</strong></p>
          ${breakdown.map(b => `<p style="font-family:var(--font-sans);font-size:0.7rem;color:rgba(242,239,233,0.4);margin:0;">${b}</p>`).join('')}
          <p style="font-family:var(--font-sans);font-size:0.65rem;color:rgba(242,239,233,0.25);margin:0.4rem 0 0;">Based on ${done} completed tasks · ${fmtK(Math.round(baseTokensPerTask))} tokens avg · ${fmtUsd(baseCostPerTask)} avg/task</p>
        </div>
      </div>`;
  }
  (window as any).__estimateCost = estimateCost;

  // Password gate
  const PASS = 'dang2026';
  const gate = document.getElementById('gate')!;
  const content = document.getElementById('dashboard-content')!;
  const inp = document.getElementById('gate-input') as HTMLInputElement;
  const btn = document.getElementById('gate-btn')!;
  const err = document.getElementById('gate-error')!;

  function unlock() {
    if (inp.value === PASS) {
      sessionStorage.setItem('dash_auth','1');
      gate.style.display = 'none';
      content.style.display = 'block';
      loadAgents().then(loadIssues);
    } else {
      err.textContent = 'Incorrect password.';
      inp.value = '';
      inp.focus();
    }
  }

  if (sessionStorage.getItem('dash_auth') === '1') {
    gate.style.display = 'none';
    content.style.display = 'block';
    loadAgents().then(loadIssues);
  } else {
    gate.style.display = 'flex';
  }

  btn.addEventListener('click', unlock);
  inp.addEventListener('keydown', (e) => { if (e.key === 'Enter') unlock(); });

  // Auto-refresh every 60 seconds
  if (sessionStorage.getItem('dash_auth') === '1') setTimeout(() => location.reload(), 60000);
</script>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @media (max-width: 640px) {
    #issues-board { grid-template-columns: 1fr !important; }
    .weekly-grid  { grid-template-columns: 1fr !important; }
    .daily-grid   { grid-template-columns: 1fr !important; }
  }
</style>

</Layout>
