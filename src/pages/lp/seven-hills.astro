---
import LandingLayout from '../../layouts/LandingLayout.astro';
---

<LandingLayout
  title="What Is Your Home Worth? | Free Property Estimate"
  description="Find out what your Brisbane inner west property is worth based on recent comparable sales. Free, no obligation. Daniel Gierach, Ray White."
>

<style>
  /* ── Topbar ── */
  .lp-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2rem; height: 72px;
    background: rgba(10,8,6,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(245,208,122,0.10);
  }
  .lp-bar-logo { display: flex; flex-direction: column; gap: 0.25rem; text-decoration: none; line-height: 1; }
  .lp-bar-logo-name { font-family: var(--font-serif); font-size: 1.6rem; font-weight: 400; font-style: italic; color: #f0ece4; }
  .lp-bar-logo-sub { display: flex; align-items: center; gap: 0.5rem; }
  .lp-bar-logo-line { display: block; height: 1px; width: 1.1rem; background: var(--gold); opacity: 0.8; }
  .lp-bar-logo-agency { font-family: var(--font-sans); font-size: 0.58rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); }
  .lp-bar-phone { font-family: var(--font-sans); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold-light); text-decoration: none; display: flex; align-items: center; gap: 0.4rem; }

  /* ── Hero ── */
  .lp-hero { min-height: 100dvh; position: relative; display: flex; align-items: center; overflow: hidden; }
  .lp-hero-bg { position: absolute; inset: 0; }
  .lp-hero-bg img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(10%) brightness(0.52); }
  .lp-hero-grad { position: absolute; inset: 0; z-index: 1; background: linear-gradient(130deg, rgba(10,8,6,0.62) 0%, rgba(10,8,6,0.12) 100%); }
  .lp-hero-inner { position: relative; z-index: 2; width: 100%; max-width: 1400px; margin: 0 auto; padding: 7rem 1.5rem 4rem; }

  .lp-card {
    max-width: 620px;
    background: rgba(0,0,0,0.50);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(80,80,80,0.22);
    padding: 2.75rem 3rem;
  }
  .lp-avatar-badge { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.1rem; }
  .lp-avatar-img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; object-position: center 10%; border: 1.5px solid rgba(197,160,60,0.55); flex-shrink: 0; }
  .lp-avatar-name { font-family: var(--font-sans); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #f5d07a; }

  .lp-h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4.2vw, 3.5rem); font-weight: 400; line-height: 1.08; letter-spacing: -0.02em; color: #f0ece4; margin-bottom: 0.9rem; }
  .lp-h1 em { font-style: italic; color: var(--gold); }

  .lp-sub { font-size: 0.95rem; color: rgba(240,236,228,0.70); line-height: 1.75; max-width: 44ch; margin-bottom: 1.5rem; }

  /* Quick benefits row */
  .lp-benefits { display: flex; gap: 1.25rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .lp-benefit { display: flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; font-weight: 600; color: rgba(240,236,228,0.65); letter-spacing: 0.04em; }
  .lp-benefit-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }

  /* Form — inline */
  .lp-form-inline { display: flex; gap: 0; max-width: 540px; }
  .lp-input {
    flex: 1; min-width: 0;
    padding: 0.9rem 1.1rem;
    background: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.18);
    border-right: none;
    color: #f0ece4; font-family: var(--font-sans); font-size: 0.85rem;
    outline: none; box-sizing: border-box; -webkit-appearance: none;
    transition: border-color 0.2s;
  }
  .lp-input:focus { border-color: rgba(197,160,60,0.6); }
  .lp-input::placeholder { color: rgba(240,236,228,0.38); }
  .lp-submit {
    padding: 0.9rem 1.4rem; background: #c5a03c; border: none; cursor: pointer;
    font-family: var(--font-sans); font-size: 0.68rem; font-weight: 800;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--dark);
    display: flex; align-items: center; gap: 0.4rem; white-space: nowrap; flex-shrink: 0;
    transition: background 0.2s;
  }
  .lp-submit:hover { background: #d4af4a; }
  .lp-trust { font-size: 0.72rem; color: rgba(240,236,228,0.55); margin-top: 0.6rem; letter-spacing: 0.06em; }

  /* ── Stats bar ── */
  .lp-stats-bar { background: rgba(10,8,6,0.95); border-top: 1px solid rgba(197,160,60,0.12); border-bottom: 1px solid rgba(197,160,60,0.12); padding: 1.5rem; }
  .lp-stats-inner { max-width: 800px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap; }
  .lp-stat { text-align: center; }
  .lp-stat-num { font-family: var(--font-serif); font-size: 1.6rem; color: var(--gold-light); line-height: 1; margin-bottom: 0.2rem; }
  .lp-stat-label { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(240,236,228,0.4); }
  .lp-stat-divider { width: 1px; height: 2.5rem; background: rgba(197,160,60,0.18); }

  /* ── What's in your report ── */
  .lp-report-preview { background: #0f0d0b; padding: 4.5rem 1.5rem; border-top: 1px solid rgba(242,239,233,0.06); }
  .lp-report-inner { max-width: 760px; margin: 0 auto; }
  .lp-section-label { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.75rem; display: block; }
  .lp-report-title { font-family: var(--font-serif); font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 400; color: var(--cream); margin-bottom: 2rem; }
  .lp-report-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: rgba(242,239,233,0.07); }
  .lp-report-item { background: #0f0d0b; padding: 1.75rem 1.5rem; }
  .lp-report-icon { font-size: 1.5rem; margin-bottom: 0.6rem; }
  .lp-report-item-title { font-family: var(--font-serif); font-size: 1rem; color: var(--cream); margin-bottom: 0.4rem; }
  .lp-report-item-body { font-size: 0.75rem; color: rgba(242,239,233,0.45); line-height: 1.6; }

  /* ── Sold strip ── */
  .lp-sold { background: #111; border-top: 1px solid rgba(242,239,233,0.06); padding: 4.5rem 1.5rem; }
  .lp-sold-inner { max-width: 900px; margin: 0 auto; }
  .lp-sold-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.75rem; flex-wrap: wrap; gap: 0.5rem; }
  .lp-sold-label { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); }
  .lp-sold-hint { font-size: 0.65rem; color: rgba(242,239,233,0.3); }
  .lp-sold-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(242,239,233,0.08); }
  .lp-sold-item { background: #111; padding: 1.5rem 1.25rem; text-align: center; }
  .lp-sold-addr { font-family: var(--font-serif); font-size: 0.88rem; color: var(--cream); margin-bottom: 0.3rem; line-height: 1.3; }
  .lp-sold-sub { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(242,239,233,0.35); margin-bottom: 0.75rem; }
  .lp-sold-price { font-family: var(--font-serif); font-size: 1.4rem; color: var(--gold-light); filter: blur(5px); user-select: none; margin-bottom: 0.2rem; }
  .lp-sold-cta { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); }

  /* ── How it works ── */
  .lp-how { background: var(--dark); padding: 5rem 1.5rem; border-top: 1px solid rgba(242,239,233,0.06); }
  .lp-how-inner { max-width: 760px; margin: 0 auto; }
  .lp-how-title { font-family: var(--font-serif); font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 400; color: var(--cream); text-align: center; margin-bottom: 3rem; }
  .lp-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .lp-step { text-align: center; }
  .lp-step-num { font-family: var(--font-serif); font-size: 2.25rem; font-weight: 300; color: var(--gold); line-height: 1; margin-bottom: 0.85rem; }
  .lp-step-title { font-family: var(--font-serif); font-size: 1rem; font-style: italic; color: var(--cream); margin-bottom: 0.5rem; }
  .lp-step-body { font-size: 0.78rem; font-weight: 300; color: rgba(242,239,233,0.5); line-height: 1.7; }

  /* ── FAQ ── */
  .lp-faq { background: #0f0d0b; padding: 5rem 1.5rem; border-top: 1px solid rgba(242,239,233,0.06); }
  .lp-faq-inner { max-width: 680px; margin: 0 auto; }
  .lp-faq-title { font-family: var(--font-serif); font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 400; color: var(--cream); text-align: center; margin-bottom: 2.5rem; }
  .lp-faq-item { border-bottom: 1px solid rgba(242,239,233,0.08); padding: 1.5rem 0; }
  .lp-faq-q { font-family: var(--font-serif); font-size: 1rem; color: var(--cream); margin-bottom: 0.6rem; }
  .lp-faq-a { font-size: 0.82rem; color: rgba(242,239,233,0.5); line-height: 1.75; }

  /* ── Testimonials ── */
  .lp-testimonials { background: #111; padding: 5rem 1.5rem; border-top: 1px solid rgba(242,239,233,0.06); }
  .lp-testimonials-inner { max-width: 960px; margin: 0 auto; }
  .lp-testimonials-title { font-family: var(--font-serif); font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 400; color: var(--cream); text-align: center; margin-bottom: 2.5rem; }
  .lp-testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .lp-testimonial-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(242,239,233,0.07); padding: 1.75rem 1.5rem; }
  .lp-stars { display: flex; gap: 0.2rem; margin-bottom: 0.8rem; }
  .lp-quote { font-family: var(--font-serif); font-size: 0.9rem; font-style: italic; color: rgba(242,239,233,0.82); line-height: 1.65; margin-bottom: 1rem; }
  .lp-attr { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(242,239,233,0.35); }

  /* ── Daniel section ── */
  .lp-daniel { background: var(--dark); padding: 5rem 1.5rem; border-top: 1px solid rgba(242,239,233,0.06); }
  .lp-daniel-inner { max-width: 640px; margin: 0 auto; display: flex; align-items: flex-start; gap: 2.5rem; flex-wrap: wrap; }
  .lp-avatar { width: 88px; height: 88px; border-radius: 50%; flex-shrink: 0; background: url('https://cdn6.ep.dynamics.net/s3/rw-media/memberphotos/88889915-cef5-4a5f-9c19-0cea700d7bca.jpeg') center 10%/cover; border: 2px solid rgba(196,145,42,0.4); }
  .lp-daniel-name { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 400; color: var(--cream); margin-bottom: 0.2rem; }
  .lp-daniel-role { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.75rem; }
  .lp-daniel-body { font-size: 0.82rem; font-weight: 300; color: rgba(242,239,233,0.55); line-height: 1.7; margin-bottom: 1.1rem; }
  .lp-credentials { display: flex; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .lp-cred { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; color: rgba(242,239,233,0.45); }
  .lp-cred strong { color: var(--gold-light); font-size: 0.9rem; display: block; font-family: var(--font-serif); font-weight: 400; }
  .lp-call-btn { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-sans); font-size: 0.68rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--dark); background: var(--gold); padding: 0.75rem 1.5rem; text-decoration: none; transition: background 0.18s; }
  .lp-call-btn:hover { background: #d4a035; }

  /* ── Footer ── */
  .lp-footer { background: #111; padding: 2rem 1.5rem; border-top: 1px solid rgba(242,239,233,0.06); text-align: center; }
  .lp-footer p { font-size: 0.6rem; color: rgba(242,239,233,0.25); letter-spacing: 0.06em; line-height: 1.8; }
  .lp-footer a { color: rgba(242,239,233,0.4); text-decoration: none; }

  /* ── Mobile sticky CTA ── */
  .lp-sticky-cta {
    display: none;
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
    background: var(--gold); padding: 1rem 1.5rem;
    align-items: center; justify-content: center; gap: 0.5rem;
    font-family: var(--font-sans); font-size: 0.78rem; font-weight: 800;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--dark);
    cursor: pointer; border: none; width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .lp-bar { padding: 0.85rem 1.25rem; height: 60px; }
    .lp-hero { min-height: 100dvh; }
    .lp-hero-inner { padding: 5rem 1rem 7rem; }
    .lp-card { padding: 1.75rem 1.25rem; max-width: 100%; }
    .lp-h1 { font-size: clamp(1.9rem, 8vw, 2.5rem); }
    .lp-sub { font-size: 0.9rem; margin-bottom: 1.25rem; }
    .lp-form-inline { flex-direction: column; }
    .lp-input {
      border-right: 1.5px solid rgba(255,255,255,0.18);
      border-bottom: none;
      font-size: 1rem;
      padding: 1rem 1.1rem;
    }
    .lp-submit { justify-content: center; padding: 1rem 1.4rem; font-size: 0.75rem; min-height: 54px; }
    .lp-report-grid { grid-template-columns: 1fr; }
    .lp-sold-grid { grid-template-columns: 1fr; }
    .lp-steps { grid-template-columns: 1fr; gap: 2.5rem; }
    .lp-testimonials-grid { grid-template-columns: 1fr; }
    .lp-daniel-inner { flex-direction: column; gap: 1.5rem; }
    .lp-call-btn { width: 100%; justify-content: center; min-height: 54px; }
    .lp-stats-inner { gap: 1.5rem; }
    .lp-stat-divider { display: none; }
    .lp-sticky-cta { display: flex; min-height: 54px; }
    body { padding-bottom: 4rem; }
  }
</style>

<!-- Topbar -->
<header class="lp-bar">
  <a href="/" class="lp-bar-logo">
    <span class="lp-bar-logo-name">Daniel Gierach</span>
    <span class="lp-bar-logo-sub">
      <span class="lp-bar-logo-line"></span>
      <span class="lp-bar-logo-agency">Property</span>
    </span>
  </a>
  <a href="tel:+61412523821" class="lp-bar-phone">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 5.92 5.92l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.21 16z"/></svg>
    0412 523 821
  </a>
</header>

<!-- Hero -->
<section class="lp-hero">
  <div class="lp-hero-bg">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1440&q=70&fm=webp&auto=format"
      srcset="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=640&q=80&fm=webp&auto=format 640w, https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1200&q=80&fm=webp&auto=format 1200w, https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1440&q=70&fm=webp&auto=format 1440w"
      sizes="100vw"
      alt="Seven Hills property"
      fetchpriority="high"
      width="1920" height="1080"
    />
    <div class="lp-hero-grad"></div>
  </div>
  <div class="lp-hero-inner">
    <div class="lp-card">
      <div class="lp-avatar-badge">
        <img
          class="lp-avatar-img"
          src="https://cdn6.ep.dynamics.net/s3/rw-media/memberphotos/88889915-cef5-4a5f-9c19-0cea700d7bca.jpeg"
          alt="Daniel Gierach"
          width="40" height="40"
        />
        <span class="lp-avatar-name">Daniel Gierach</span>
      </div>
      <h1 class="lp-h1">Curious what your<br/><em>home could<br/>sell for?</em></h1>
      <p class="lp-sub">Most homeowners underestimate what their property is worth. Find out where yours really sits.</p>

      <form class="lp-form-inline" id="lpForm" action="/property-report" method="get">
        <input
          class="lp-input"
          type="text"
          name="address"
          id="lpAddress"
          placeholder="Enter your property address…"
          autocomplete="off"
          required
        />
        <button type="submit" class="lp-submit">
          What's Your Property Worth?
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </form>

      <p class="lp-trust">Free &nbsp;·&nbsp; You'll get an indicative value range based on recent comparable sales in your street.</p>
    </div>
  </div>
</section>


<!-- What's in your report -->
<section class="lp-report-preview">
  <div class="lp-report-inner">
    <span class="lp-section-label">Your Free Report Includes</span>
    <h2 class="lp-report-title">Everything you need to know before you decide.</h2>
    <div class="lp-report-grid">
      <div class="lp-report-item">
        <div class="lp-report-icon">📊</div>
        <div class="lp-report-item-title">Estimated Value Range</div>
        <p class="lp-report-item-body">A realistic price bracket based on what homes like yours have actually sold for — not a generic algorithm estimate.</p>
      </div>
      <div class="lp-report-item">
        <div class="lp-report-icon">🏡</div>
        <div class="lp-report-item-title">Recent Comparable Sales</div>
        <p class="lp-report-item-body">The most relevant nearby sales from the last 6–12 months, with commentary on how they compare to your property.</p>
      </div>
      <div class="lp-report-item">
        <div class="lp-report-icon">📅</div>
        <div class="lp-report-item-title">Days on Market</div>
        <p class="lp-report-item-body">How long similar homes are taking to sell in your area right now, so you can plan your timeline with confidence.</p>
      </div>
      <div class="lp-report-item">
        <div class="lp-report-icon">📈</div>
        <div class="lp-report-item-title">Suburb Price Trend</div>
        <p class="lp-report-item-body">Whether values in your street are rising, levelling, or softening, and what that means for your decision.</p>
      </div>
    </div>
  </div>
</section>

<!-- Recent Sales strip -->
<section class="lp-sold">
  <div class="lp-sold-inner">
    <div class="lp-sold-header">
      <span class="lp-sold-label">Recent Sales Nearby</span>
      <span class="lp-sold-hint">Prices blurred — enter your address above to unlock</span>
    </div>
    <div class="lp-sold-grid">
      <div class="lp-sold-item">
        <div class="lp-sold-addr">11 Pandanus Street</div>
        <div class="lp-sold-sub">Seven Hills · Sold 2026</div>
        <div class="lp-sold-price">$1,310,000</div>
        <div class="lp-sold-cta">Compare to my home →</div>
      </div>
      <div class="lp-sold-item">
        <div class="lp-sold-addr">19 Hoop Pine Street</div>
        <div class="lp-sold-sub">Seven Hills · Sold 2026</div>
        <div class="lp-sold-price">$1,380,000</div>
        <div class="lp-sold-cta">Compare to my home →</div>
      </div>
      <div class="lp-sold-item">
        <div class="lp-sold-addr">6 Kauri Court</div>
        <div class="lp-sold-sub">Seven Hills · Sold 2026</div>
        <div class="lp-sold-price">$1,240,000</div>
        <div class="lp-sold-cta">Compare to my home →</div>
      </div>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="lp-how">
  <div class="lp-how-inner">
    <h2 class="lp-how-title">How it works</h2>
    <div class="lp-steps">
      <div class="lp-step">
        <div class="lp-step-num">01</div>
        <div class="lp-step-title">Enter your address</div>
        <p class="lp-step-body">Just your property address. Takes 10 seconds. No commitment.</p>
      </div>
      <div class="lp-step">
        <div class="lp-step-num">02</div>
        <div class="lp-step-title">Receive your report</div>
        <p class="lp-step-body">Daniel prepares a personalised report based on recent comparable sales and sends it to your inbox.</p>
      </div>
      <div class="lp-step">
        <div class="lp-step-num">03</div>
        <div class="lp-step-title">Decide with confidence</div>
        <p class="lp-step-body">No pressure. If you'd like a precise in-person appraisal, Daniel can arrange that — free, no obligation.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="lp-faq">
  <div class="lp-faq-inner">
    <h2 class="lp-faq-title">Common questions</h2>

    <div class="lp-faq-item">
      <div class="lp-faq-q">Is this actually free?</div>
      <p class="lp-faq-a">Yes, completely. There is no charge, no hidden fee, and no obligation to list. The report is Daniel's way of introducing himself to homeowners who are thinking about their options.</p>
    </div>

    <div class="lp-faq-item">
      <div class="lp-faq-q">Will someone call me?</div>
