<script>
  // UTM + pixel tracking
  (function() {
    const params = new URLSearchParams(location.search);
    const utm = {};
    ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'].forEach(k => {
      if (params.get(k)) utm[k] = params.get(k);
    });
    if (Object.keys(utm).length) sessionStorage.setItem('utm_data', JSON.stringify(utm));

    const form = document.getElementById('lpForm');
    if (form) {
      form.addEventListener('submit', function() {
        const stored = sessionStorage.getItem('utm_data');
        if (stored) {
          Object.entries(JSON.parse(stored)).forEach(([k, v]) => {
            const inp = document.createElement('input');
            inp.type = 'hidden'; inp.name = k; inp.value = v;
            form.appendChild(inp);
          });
        }
        if (typeof fbq !== 'undefined') fbq('track', 'Lead', { content_name: 'Brisbane Inner East Property Report', content_category: 'Address Submission' });
        if (typeof gtag !== 'undefined') gtag('event', 'generate_lead', { suburb: 'inner_east', source: 'lp' });
      });
    }
  })();
</script>

