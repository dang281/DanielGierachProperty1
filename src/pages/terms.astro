---
import Layout from '../layouts/Layout.astro';

const lastUpdated = "23 March 2026";

const sections = [
  {
    title: "1. Acceptance of Terms",
    content: [
      "By accessing or using this website (danielgierach.com), you agree to be bound by these Terms of Use. If you do not agree with any part of these terms, please do not use this website.",
      "These terms apply to all visitors, users and others who access or use the site.",
    ],
  },
  {
    title: "2. About This Website",
    content: [
      "This website is operated by Daniel Gierach, a licensed real estate agent operating under Ray White Bulimba in Queensland, Australia.",
      "The site is intended to provide general information about property services, market insights and tools available to buyers, sellers and investors in Brisbane's inner east.",
    ],
  },
  {
    title: "3. Nature of Information Provided",
    content: [
      "The content on this website, including property market commentary, suburb guides, tools and calculators, is provided for general informational purposes only. It does not constitute financial, legal, taxation or investment advice.",
      "You should seek independent professional advice before making any decision based on information found on this website.",
      "While we take care to ensure accuracy, we make no representations or warranties regarding the completeness, currency or suitability of any information on this site.",
    ],
  },
  {
    title: "4. Property Information",
    content: [
      "Property details, estimated values, sold prices and market data displayed on this website are indicative only. They are based on available information at the time of publication and may not reflect current market conditions.",
      "Any property appraisal or market assessment provided through this website or following a direct enquiry is an opinion only and does not constitute a formal valuation under the Property Valuers Registration Act 1992 (Qld) or equivalent legislation.",
    ],
  },
  {
    title: "5. Online Tools and Calculators",
    content: [
      "Tools and calculators available on this website (including mortgage calculators, stamp duty estimates and yield calculators) are provided as a convenience only.",
      "Results are estimates based on the inputs you provide and generalised assumptions. They should not be relied upon as accurate or complete. Always consult a qualified financial adviser, mortgage broker or legal professional before making financial decisions.",
    ],
  },
  {
    title: "6. Intellectual Property",
    content: [
      "All content on this website, including text, design, graphics, logos and code, is owned by or licensed to Daniel Gierach and is protected by Australian copyright law.",
      "You may not reproduce, distribute, modify or republish any content from this website without prior written permission, except as permitted under the Copyright Act 1968 (Cth).",
    ],
  },
  {
    title: "7. Third-Party Links",
    content: [
      "This website may contain links to third-party websites including Ray White's platforms, property listing portals and external resources. These links are provided for convenience only.",
      "We do not endorse or take responsibility for the content, accuracy or practices of any third-party websites. Accessing those sites is at your own risk.",
    ],
  },
  {
    title: "8. Limitation of Liability",
    content: [
      "To the maximum extent permitted by law, Daniel Gierach and Ray White Bulimba will not be liable for any loss or damage arising from your use of, or reliance on, information or tools on this website.",
      "This includes but is not limited to direct, indirect, incidental or consequential loss, loss of profit, or loss arising from errors or omissions in the information provided.",
      "Nothing in these terms excludes, restricts or modifies any rights or remedies you may have under the Australian Consumer Law or other applicable legislation that cannot be excluded by agreement.",
    ],
  },
  {
    title: "9. Australian Consumer Law",
    content: [
      "Our services come with guarantees that cannot be excluded under the Australian Consumer Law. For major failures with a service, you are entitled to cancel and receive a refund. You are also entitled to compensation for other reasonably foreseeable loss or damage.",
      "Nothing in these terms is intended to exclude or limit those statutory guarantees.",
    ],
  },
  {
    title: "10. Privacy",
    content: [
      "Your use of this website is also governed by our Privacy Policy, which explains how we collect, use and store your personal information in accordance with the Privacy Act 1988 (Cth) and the Australian Privacy Principles.",
      "By using this website, you consent to the practices described in our Privacy Policy.",
    ],
  },
  {
    title: "11. User Conduct",
    content: [
      "You agree not to use this website in any way that:",
      "- Is unlawful or breaches any applicable Australian law or regulation\n- Transmits spam, malware or other harmful content\n- Attempts to gain unauthorised access to any part of the website or its systems\n- Misrepresents your identity or affiliation\n- Infringes the intellectual property rights of any person",
    ],
  },
  {
    title: "12. Changes to These Terms",
    content: [
      "We may update these Terms of Use from time to time without notice. The current version will always be available on this page with the date of last update shown above.",
      "Continued use of the website after any changes constitutes your acceptance of the updated terms.",
    ],
  },
  {
    title: "13. Governing Law",
    content: [
      "These terms are governed by the laws of Queensland, Australia. Any disputes arising in connection with these terms will be subject to the exclusive jurisdiction of the courts of Queensland.",
    ],
  },
];
---

<Layout title="Terms of Use | Daniel Gierach Property" description="Terms of Use for danielgierach.com, governed by the laws of Queensland, Australia.">


<!-- ════════════════════════════════════════════
     HERO
════════════════════════════════════════════ -->
<section style="background:#1c1917;padding:8rem 0 5rem;border-bottom:1px solid rgba(240,236,228,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <span style="font-family:var(--font-sans);font-size:0.75rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#f5d07a;display:block;margin-bottom:1.5rem;">Legal</span>
    <h1 style="font-family:var(--font-serif);font-size:clamp(2.2rem,5vw,3.5rem);font-weight:400;color:#f0ece4;line-height:1.1;letter-spacing:-0.02em;margin-bottom:1rem;">
      Terms of Use
    </h1>
    <p style="font-size:0.85rem;color:rgba(240,236,228,0.45);letter-spacing:0.06em;">Last updated: {lastUpdated}</p>
  </div>
</section>


<!-- ════════════════════════════════════════════
     INTRO
════════════════════════════════════════════ -->
<section style="background:var(--color-base);padding:4rem 0 2rem;border-bottom:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div style="max-width:72ch;">
      <p style="font-family:var(--font-serif);font-size:1.05rem;color:#1c1917;line-height:1.8;">
        These Terms of Use govern your access to and use of this website. Please read them carefully. They have been prepared with reference to Australian Consumer Law, Queensland property legislation and general website terms requirements.
      </p>
    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     TERMS SECTIONS
════════════════════════════════════════════ -->
<section style="background:var(--color-base);padding:2rem 0 6rem;">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div style="max-width:72ch;display:flex;flex-direction:column;gap:0;">

      {sections.map((s) => (
        <div style="padding:2.5rem 0;border-top:1px solid rgba(28,25,23,0.1);">
          <h2 style="font-family:var(--font-serif);font-size:1.05rem;font-weight:400;color:#1c1917;margin-bottom:1rem;line-height:1.3;">{s.title}</h2>
          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            {s.content.map((para) => (
              <p style="font-size:0.88rem;color:#44403c;line-height:1.9;white-space:pre-line;">{para}</p>
            ))}
          </div>
        </div>
      ))}

      <!-- Contact -->
      <div style="padding:2.5rem 0;border-top:1px solid rgba(28,25,23,0.1);border-bottom:1px solid rgba(28,25,23,0.1);">
        <h2 style="font-family:var(--font-serif);font-size:1.05rem;font-weight:400;color:#1c1917;margin-bottom:1rem;">14. Contact Us</h2>
        <p style="font-size:0.88rem;color:#44403c;line-height:1.9;margin-bottom:1.5rem;">
          If you have any questions about these Terms of Use, please contact:
        </p>
        <div style="display:flex;flex-direction:column;gap:0.4rem;padding:1.5rem;background:rgba(196,145,42,0.06);border:1px solid rgba(196,145,42,0.2);">
          <p style="font-family:var(--font-sans);font-size:0.82rem;font-weight:700;color:#1c1917;">Daniel Gierach</p>
          <p style="font-size:0.82rem;color:#44403c;">Ray White Bulimba</p>
          <a href="tel:+61412523821" style="font-size:0.82rem;color:#c4912a;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">0412 523 821</a>
          <a href="mailto:daniel.gierach@raywhite.com" style="font-size:0.82rem;color:#c4912a;text-decoration:none;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">daniel.gierach@raywhite.com</a>
        </div>
      </div>

    </div>
  </div>
</section>

</Layout>
