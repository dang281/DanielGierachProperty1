<!-- ════════════════════════════════════════════
     SCRIPTS
════════════════════════════════════════════ -->
<script>
  // ── Tab switching ──
  const tabs = document.querySelectorAll<HTMLButtonElement>('.s-tab');
  const panels = document.querySelectorAll<HTMLElement>('.search-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const target = tab.dataset.tab!;
      panels.forEach(p => (p.style.display = 'none'));
      const active = document.getElementById(`panel-${target}`);
      if (active) active.style.display = 'block';
    });
  });

  // ── Hero parallax ──
  const heroBg = document.getElementById('hero-bg');
  if (heroBg) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      heroBg.style.transform = `translateY(${y * 0.3}px)`;
    }, { passive: true });
  }

  // ── Stat counters ──
  const counters = document.querySelectorAll<HTMLElement>('.stat-counter');
  const countObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseFloat(el.dataset.value!);
      const suffix = el.dataset.suffix || '';
      const prefix = el.dataset.prefix || '';
      const isDecimal = String(target).includes('.');
      const duration = 1800;
      const start = performance.now();

      const tick = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = target * eased;
        el.textContent = prefix + (isDecimal ? current.toFixed(1) : Math.round(current).toLocaleString()) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
      countObserver.unobserve(el);
    });
  }, { threshold: 0.5 });

  counters.forEach(el => countObserver.observe(el));

  // ── Hero address input ─────────────────────────────────────────────
  (function() {
    const input  = document.getElementById('hero-address-input') as HTMLInputElement;
    const acList = document.getElementById('hero-ac-list') as HTMLElement;
    const form   = document.getElementById('hero-address-form') as HTMLFormElement;
    let acDebounce: ReturnType<typeof setTimeout>;
    let selectedAddress = '';

    input?.addEventListener('input', function() {
      clearTimeout(acDebounce);
      const q = this.value.trim();
      selectedAddress = '';
      if (q.length < 4) { acList.style.display = 'none'; return; }
      acDebounce = setTimeout(() => fetchAC(q), 320);
    });

    document.addEventListener('click', function(e) {
      if (!form?.contains(e.target as Node)) acList.style.display = 'none';
    });

    async function fetchAC(q: string) {
      try {
        const res  = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q + ', Brisbane, Australia')}&format=json&limit=5&countrycodes=au`, { headers: { 'Accept-Language': 'en', 'User-Agent': 'DanielGierachProperty/1.0' } });
        const data = await res.json();
        if (!data.length) { acList.style.display = 'none'; return; }
        acList.innerHTML = '';
        data.forEach((item: any) => {
          const label = item.display_name.split(', ').slice(0, 4).join(', ');
          const div   = document.createElement('div');
          div.textContent = label;
          div.style.cssText = 'padding:0.65rem 1rem;font-size:0.82rem;color:#f0ece4;cursor:pointer;border-bottom:1px solid rgba(255,255,255,0.07);';
          div.addEventListener('mouseover', () => div.style.background = 'rgba(197,160,60,0.1)');
          div.addEventListener('mouseout',  () => div.style.background = '');
          div.addEventListener('mousedown', (e) => {
            e.preventDefault();
            input.value = label;
            selectedAddress = label;
            acList.style.display = 'none';
          });
          acList.appendChild(div);
        });
        acList.style.display = 'block';
      } catch(_) { acList.style.display = 'none'; }
    }

    form?.addEventListener('submit', function(e) {
      e.preventDefault();
      const addr = selectedAddress || input.value.trim();
      gtag('event', 'hero_address_submit', { event_category: 'lead', event_label: addr });
      window.location.href = '/property-worth?address=' + encodeURIComponent(addr);
    });
  })();

  // Track listing card clicks
  document.querySelectorAll('.listing-card').forEach(function(card) {
    card.addEventListener('click', function() {
      const address = card.querySelector('h3')?.textContent || 'unknown';
      gtag('event', 'listing_click', {
        event_category: 'listings',
        event_label: address
      });
    });
  });

  // Track tool card clicks
  document.querySelectorAll('a[href^="/tools/"]').forEach(function(link) {
    link.addEventListener('click', function() {
      gtag('event', 'tool_click', {
        event_category: 'tools',
        event_label: link.getAttribute('href') || 'unknown'
      });
    });
  });

  // ── Homepage tools filter ──────────────────────────────────────
  const hPillColors: Record<string, string> = {
    All: '#1c1917', Seller: '#b89a2a', Buyer: '#3a8fa8', Investor: '#4a9e4a', Market: '#888'
  };
  const hPills = document.querySelectorAll<HTMLButtonElement>('.home-filter-pill');
  const hCards = document.querySelectorAll<HTMLElement>('.home-tool-card');

  function applyHomeFilter(active: string) {
    hPills.forEach(pill => {
      const phase = pill.dataset.hfilter!;
      const isActive = phase === active;
      const col = hPillColors[phase] || '#1c1917';
      pill.style.background  = isActive ? col   : 'transparent';
      pill.style.color       = isActive ? (phase === 'All' ? 'var(--color-base)' : '#fff') : 'var(--color-text-muted)';
      pill.style.borderColor = isActive ? col   : 'rgba(28,25,23,0.2)';
    });
    hCards.forEach(card => {
      card.style.display = (active === 'All' || card.dataset.hphase === active) ? '' : 'none';
    });
  }

  hPills.forEach(pill => pill.addEventListener('click', () => applyHomeFilter(pill.dataset.hfilter!)));
  applyHomeFilter('All');
</script>

