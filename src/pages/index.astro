const prestige = [
  {
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/b485-H3473001-192442478__1773707732-39332-6-print-70-longland-st-203.jpg',
    suburb: 'Newstead',
    address: '203/70 Longland Street',
    price: 'Auction 18 April at The Calile Hotel',
    beds: 2, baths: 2, cars: 1,
    desc: 'Engineered timber floors, Miele appliances and sweeping views over the historic Gasometer, a rare inner-city apartment of genuine architectural distinction.',
    tag: 'Forthcoming Auction',
    href: 'https://raywhitebulimba.com.au/properties/residential-for-sale/qld/newstead-4006/apartment/3473001',
  },
  {
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/e543-H3474534-192843678__1773807208-74050-IMG2700p.jpg',
    suburb: 'Bridgeman Downs',
    address: '5 Neville Road',
    price: 'For Sale by Negotiation',
    beds: 3, baths: 2, cars: 6,
    desc: 'An elevated 607m² hilltop allotment surrounded by multi-million-dollar acreage homes, a rare opportunity to landbank or rebuild in one of Brisbane\'s most prestigious pockets.',
    tag: 'Blue-Chip Land',
    href: 'https://raywhitebulimba.com.au/properties/residential-for-sale/qld/bridgeman-downs-4035/house/3474534',
  },
];

const stats = [
  { value: 600000, suffix: '+', prefix: '',  label: 'Active Buyer Database' },
  { value: 5, suffix: '-Star', prefix: '',  label: 'Client Reviews' },
  { value: 28, suffix: '', prefix: '',  label: 'Median Days on Market' },
];

const reasons = [
  { n: '01', title: 'Deep Local Knowledge', body: 'Born and raised in Brisbane, Daniel brings a decade of property economics expertise and hyper-local intelligence across the inner east and south, delivering insights no broad-market agency can match.' },
  { n: '02', title: 'Data-Driven Campaigns', body: 'Every campaign is grounded in data, detail and clear communication. From pricing strategy to buyer targeting, decisions are backed by market evidence rather than gut feel.' },
  { n: '03', title: 'Access to 600,000+ Buyers', body: 'Through the Ray White Collective network, your property is exposed to Australia\'s largest active buyer database, ensuring maximum competition and the strongest possible result.' },
];

const toolPhaseColors: Record<string, string> = { Seller: '#ffdd79', Buyer: '#7ec8e3', Investor: '#a8e6a3', Market: '#c8c6c8' };

const showcaseTools = [
  { href: '/tools/selling-costs',    phase: 'Seller',   label: 'Selling Cost Calculator', desc: 'See your true net proceeds after all selling costs.' },
  { href: '/tools/stamp-duty',       phase: 'Buyer',    label: 'Stamp Duty Calculator',   desc: 'QLD stamp duty, FHB concessions & upfront costs.' },
  { href: '/tools/mortgage',         phase: 'Buyer',    label: 'Mortgage Calculator',     desc: 'Weekly or monthly repayments + amortisation chart.' },
  { href: '/tools/investment-yield', phase: 'Investor', label: 'Investment Yield',        desc: 'Net yield, cash flow & 10-year capital projection.' },
  { href: '/tools/renovation-roi',   phase: 'Seller',   label: 'Renovation ROI',          desc: 'Which upgrades add the most value before you sell.' },
  { href: '/tools/suburb-match',     phase: 'Buyer',    label: 'Suburb Match Quiz',       desc: 'Answer 8 questions to find your ideal Brisbane suburb.' },
  { href: '/tools/valuation',        phase: 'Seller',   label: 'Instant Valuation',       desc: 'Get an indicative property value in minutes.' },
  { href: '/tools/heatmap',          phase: 'Market',   label: 'Price Heatmap',           desc: 'Visual median price & growth map across Brisbane.' },
  { href: '/tools/borrowing-power',  phase: 'Buyer',    label: 'Borrowing Power',         desc: 'Estimate how much you can borrow based on income and expenses.' },
  { href: '/tools/equity-calculator', phase: 'Seller',  label: 'Home Equity Calculator',  desc: 'See your equity position and how much you could access or take forward.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What suburbs does Daniel Gierach service?",
      "acceptedAnswer": { "@type": "Answer", "text": "Daniel specialises in Brisbane's inner east and south, including Bulimba, Hawthorne, Balmoral, Norman Park, Camp Hill, Seven Hills, Morningside, Murarrie, Cannon Hill, Carina, Coorparoo, East Brisbane and surrounding suburbs via Ray White Bulimba and the Ray White Collective network." }
    },
    {
      "@type": "Question",
      "name": "How long does it take to sell a property in Brisbane's inner east?",
      "acceptedAnswer": { "@type": "Answer", "text": "Daniel's median days on market is 28 days. Well-positioned homes in Brisbane's inner east typically sell within 2–4 weeks when priced accurately and supported by a targeted buyer campaign." }
    },
    {
      "@type": "Question",
      "name": "Should I sell my Brisbane home by auction or private treaty?",
      "acceptedAnswer": { "@type": "Answer", "text": "The best method depends on your property type, price point and local demand. Auction creates urgency and genuine competition; private treaty suits homes where buyers need more time. Daniel will recommend the right approach based on your specific property and current market conditions." }
    },
    {
      "@type": "Question",
      "name": "How do I get a free property appraisal with Daniel?",
      "acceptedAnswer": { "@type": "Answer", "text": "Fill in the appraisal request form at danielgierach.com/appraisal or call Daniel directly on 0412 523 821. There is no obligation and Daniel will typically be in touch within 24 hours to arrange a time that suits you." }
    }
  ]
};
---

<Layout title="Daniel Gierach Property | Ray White Bulimba" description="Brisbane inner-east real estate agent. Daniel Gierach specialises in selling homes across Camp Hill, Norman Park, Hawthorne, Balmoral and surrounds. Ray White Bulimba. Call 0412 523 821." schema={faqSchema} preloadImage="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1440&q=70&fm=webp&auto=format">

<!-- ════════════════════════════════════════════
     HERO
════════════════════════════════════════════ -->
<section class="relative min-h-dvh sm:min-h-dvh flex items-center overflow-hidden hero-section" style="background:var(--color-base);">

  <!-- Parallax bg -->
  <div class="absolute inset-0 z-0" id="hero-bg">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1440&q=70&fm=webp&auto=format"
      srcset="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=640&q=80&fm=webp&auto=format 640w, https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1200&q=80&fm=webp&auto=format 1200w, https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1440&q=70&fm=webp&auto=format 1440w"
      sizes="100vw"
      alt="Modern white Brisbane property"
      class="w-full h-full object-cover"
      style="filter:grayscale(8%) brightness(0.58);"
      fetchpriority="high"
      width="1920" height="1080"
    />
    <div class="absolute inset-0" style="background:linear-gradient(120deg,rgba(10,8,6,0.55) 0%,rgba(10,8,6,0.15) 100%);"></div>
  </div>

  <!-- Glass card -->
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-4 sm:px-8 lg:px-12 pt-24 sm:pt-28 pb-16 sm:pb-20">
    <div class="hero-card max-w-2xl" style="background:rgba(0,0,0,0.45);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(72,72,72,0.2);padding:3rem 3.5rem;">

      <span class="eyebrow mb-5 reveal" data-delay="200" style="color:#f5d07a;">Brisbane Property Sales Specialist</span>

      <h1 class="hero-h1 reveal" data-delay="380"
        style="font-family:var(--font-serif);font-size:clamp(2.2rem,4.5vw,3.8rem);font-weight:400;line-height:1.08;letter-spacing:-0.02em;color:#f0ece4;margin-bottom:1.5rem;">
        Curious what your<br />
        <em style="font-style:italic;color:var(--color-gold);">home could sell for?</em>
      </h1>

      <p class="reveal" data-delay="560"
        style="font-size:1rem;color:rgba(240,236,228,0.72);line-height:1.8;max-width:46ch;margin-bottom:0.75rem;">
        Most homeowners underestimate what their property is worth. Find out where yours really sits, free, in under 60 seconds.
      </p>

      <div class="reveal" data-delay="820">
        <form id="hero-address-form" style="display:flex;gap:0;max-width:480px;">
          <div style="position:relative;flex:1;">
            <input
              id="hero-address-input"
              type="text"
              placeholder="Enter your property address…"
              autocomplete="off"
              style="width:100%;padding:0.9rem 1.1rem;background:rgba(255,255,255,0.08);border:1.5px solid rgba(255,255,255,0.18);border-right:none;color:#f0ece4;font-family:var(--font-sans);font-size:0.85rem;outline:none;box-sizing:border-box;"
            />
            <div id="hero-ac-list" style="display:none;position:absolute;top:100%;left:0;right:0;background:#1c1917;border:1px solid rgba(255,255,255,0.12);border-top:none;z-index:200;max-height:180px;overflow-y:auto;"></div>
          </div>
          <button type="submit" class="hero-cta" style="padding:0.9rem 1.25rem;background:#c5a03c;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;border:none;cursor:pointer;white-space:nowrap;flex-shrink:0;display:flex;align-items:center;gap:0.4rem;transition:background 0.2s;"
            onmouseover="this.style.background='#d4af4a'" onmouseout="this.style.background='#c5a03c'">
            Get My Estimate
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </form>
        <p style="font-size:0.65rem;color:rgba(240,236,228,0.4);margin-top:0.6rem;letter-spacing:0.06em;">Free · 60 seconds · No obligation</p>
      </div>

      <!-- Stats -->
      <div class="flex justify-between mt-10 pt-8 reveal" data-delay="980"
        style="border-top:1px solid rgba(255,255,255,0.12);">
        {stats.map((s) => (
          <div class="flex-1 text-center">
            <p class="stat-counter" data-value={s.value} data-suffix={s.suffix} data-prefix={s.prefix}
              style="font-family:var(--font-serif);font-size:1.8rem;font-weight:400;color:#f0ece4;line-height:1;letter-spacing:-0.02em;">
              {s.prefix}0{s.suffix}
            </p>
            <p style="font-size:0.62rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:rgba(240,236,228,0.7);margin-top:0.4rem;">
              {s.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll nudge -->
  <div class="absolute bottom-8 right-12 hidden lg:flex flex-col items-center gap-2">
    <span aria-hidden="true" style="font-size:0.55rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(161,161,161,0.7);writing-mode:vertical-rl;">Scroll</span>
    <div style="width:1px;height:48px;background:linear-gradient(to bottom,rgba(255,221,121,0.4),transparent);"></div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     MARQUEE RIBBON
════════════════════════════════════════════ -->
<div style="background:#1c1917;padding:1.1rem 0;overflow:hidden;">
  <div class="marquee-track">
    {[
      'Family Homes',
      'Units & Townhomes',
      'Prestige & Luxury',
      'Riverfront Properties',
      'New Developments',
      'Land & Development Sites',
      'Off-Market Access',
      'Family Homes',
      'Units & Townhomes',
      'Prestige & Luxury',
      'Riverfront Properties',
      'New Developments',
      'Land & Development Sites',
      'Off-Market Access',
    ].map((item, i) => (
      <span class="flex items-center gap-5 flex-shrink-0 px-10" style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#c4912a;">
        {item}
        <span style="display:inline-block;width:4px;height:4px;background:rgba(196,145,42,0.35);border-radius:50%;"></span>
      </span>
    ))}
  </div>
</div>


<!-- ════════════════════════════════════════════
     CURATED LISTINGS
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-0);padding:6rem 0 7rem;">
  <div class="max-w-[1280px] mx-auto px-8 sm:px-12 lg:px-16">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-16">
      <div class="reveal" style="max-width:36rem;">
        <span class="eyebrow mb-4">Daniel's</span>
        <h2 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,2.75rem);font-weight:400;color:var(--color-text-primary);letter-spacing:-0.01em;line-height:1.1;">
          Recent Listings
        </h2>
        <p style="font-size:0.9rem;color:var(--color-text-secondary);margin-top:1rem;line-height:1.8;">
          Current properties listed by Daniel across Brisbane.
        </p>
      </div>
      <a href="/listings" class="reveal" data-delay="100"
        style="font-family:var(--font-sans);font-size:0.68rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);border-bottom:1px solid var(--color-gold);padding-bottom:3px;white-space:nowrap;transition:opacity 0.2s;flex-shrink:0;align-self:flex-end;">
        View All Properties →
      </a>
    </div>

    <!-- 3-column card grid, matches listings page style -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px" style="background:rgba(28,25,23,0.08);">
      {listings.map((p, i) => (
        <a href={p.href} target="_blank" rel="noopener noreferrer"
          class="card-reveal listing-card" data-delay={i * 130}
          style="background:#ffffff;display:flex;flex-direction:column;text-decoration:none;"
        >
          <!-- Image -->
          <div style="aspect-ratio:4/3;overflow:hidden;position:relative;">
            <img src={p.image} alt={p.address} width="800" height="600"
              loading={i === 0 ? 'eager' : 'lazy'}
              style={`width:100%;height:100%;object-fit:cover;${p.tag === 'Sold' ? 'filter:grayscale(30%);' : ''}`}
            />
            <span style={`position:absolute;top:1rem;left:1rem;font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;background:${p.tag === 'Sold' ? '#44403c' : p.tag === 'Pre-Market' ? '#a8e6a3' : p.tag === 'Auction' ? '#7ec8e3' : '#f5d07a'};color:${p.tag === 'Sold' ? '#f0ece4' : '#0a0806'};padding:0.3rem 0.65rem;`}>
              {p.tag}
            </span>
          </div>
          <!-- Details -->
          <div style="padding:1.5rem;flex:1;display:flex;flex-direction:column;gap:0.5rem;">
            <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#c4912a;">{p.suburb}</p>
            <h3 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:#1c1917;line-height:1.2;">{p.address}</h3>
            <p style="font-size:0.78rem;color:#78716c;">{p.street}</p>
            <p style="font-family:var(--font-sans);font-size:0.78rem;font-weight:600;color:#44403c;margin-top:0.25rem;">{p.price}</p>
            <div style="display:flex;gap:1.25rem;margin-top:auto;padding-top:1rem;border-top:1px solid rgba(28,25,23,0.1);">
              <span style="font-size:0.72rem;color:#78716c;">{p.beds} bed</span>
              <span style="font-size:0.72rem;color:#78716c;">{p.baths} bath</span>
              <span style="font-size:0.72rem;color:#78716c;">{p.cars} car</span>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>


<!-- ════════════════════════════════════════════
     PRESTIGE COLLECTION
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-2);padding:6rem 0 7rem;">
  <div class="max-w-[1280px] mx-auto px-8 sm:px-12 lg:px-16">

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-16">
      <div class="reveal" style="max-width:36rem;">
        <span class="eyebrow mb-4">Ray White - The Collective</span>
        <h2 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,2.75rem);font-weight:400;color:var(--color-text-primary);letter-spacing:-0.01em;line-height:1.1;">
          Recent Listings
        </h2>
        <p style="font-size:0.875rem;color:var(--color-text-secondary);margin-top:0.75rem;max-width:48ch;line-height:1.75;">
          A selection of recent and current properties listed by Daniel across Brisbane's inner east.
        </p>
      </div>
      <a href="https://raywhitecollective.com.au" target="_blank" rel="noopener noreferrer" class="btn-outline-gold reveal self-end" data-delay="100">View All Collective Listings</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {prestige.map((p, i) => (
        <a href={p.href} target="_blank" rel="noopener noreferrer"
          class={`prop-card reveal${i === 1 ? '-right' : '-left'}`} data-delay={`${i * 80}`}
          style="display:block;text-decoration:none;background:var(--color-surface-0);">
          <div class="img-wrap relative" style="aspect-ratio:3/2;">
            <img src={p.image} alt={p.address} width="1200" height="800" loading="lazy"
              style="filter:grayscale(25%) brightness(0.75);" />
            <div class="absolute top-5 left-5"><span class="gold-pill">{p.tag}</span></div>
            <div class="absolute inset-0 pointer-events-none"
              style="background:linear-gradient(to top,rgba(14,14,14,0.92) 0%,transparent 55%);"></div>
          </div>
          <div style="padding:1.75rem;">
            <span style="font-size:0.6rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.4rem;">{p.suburb}</span>
            <h3 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:var(--color-text-primary);margin-bottom:0.6rem;">{p.address}</h3>
            <p style="font-size:0.825rem;color:var(--color-text-secondary);line-height:1.75;margin-bottom:1.25rem;max-width:52ch;">{p.desc}</p>
            <div style="display:flex;align-items:center;justify-content:space-between;padding-top:1rem;border-top:1px solid rgba(28,25,23,0.1);">
              <div style="display:flex;gap:1.25rem;">
                <span style="font-size:0.65rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">{p.beds} Bed</span>
                <span style="font-size:0.65rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">{p.baths} Bath</span>
                <span style="font-size:0.65rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">{p.cars} Car</span>
              </div>
              <span style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-gold);">{p.price}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA block -->
    <div class="reveal mt-6 p-10 lg:p-12 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-6"
      style="background:var(--color-gold-muted);border:1px solid rgba(196,145,42,0.15);" data-delay="100">
      <div>
        <h3 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:var(--color-text-primary);margin-bottom:0.5rem;font-style:italic;">
          Looking for Something Specific?
        </h3>
        <p style="font-size:0.85rem;color:var(--color-text-muted);max-width:52ch;line-height:1.75;">
          Daniel's network spans Ray White Bulimba and the broader Ray White The Collective. Tell him what you're looking for.
        </p>
      </div>
