  'Under Contract': '#f4a261',
  'Blue-Chip Land': '#c8c6c8',
  'Sold': '#6b4610',
};
// White text on the dark-fill tags so they stay legible; dark text on the light tags.
const tagText: Record<string, string> = {
  'For Sale': '#ffffff',
  'Sold': '#ffffff',
  'Under Contract': '#191817',
};

const allSuburbs = [...new Set([...forSale, ...sold].map(p => p.suburb))].sort();

