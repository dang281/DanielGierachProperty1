      "@type": "ListItem",
      "position": i + 1,
      "name": `${p.address}, ${p.street}`,
      "url": p.href,
      "description": `${p.beds} bed ${p.baths} bath, ${p.price}, listed by Daniel Gierach, Ray White Bulimba`
