---

<Layout title="Listings | Daniel Gierach Property" description="Current listings and recently sold homes in Brisbane's inner east. View Daniel Gierach's sales results across Camp Hill, Norman Park, Hawthorne, and Balmoral." schema={listingsSchema}>

<!-- Hero -->
<section class="relative min-h-[40vh] flex items-center overflow-hidden" style="background:#0a0806;">
  <div class="absolute inset-0 z-0">
    <img
      src="/_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2F93d1-H3480857-194603639__1774840446-82684-03-2226DuttonstreetHawthorne20.jpg&w=1200&q=70"
      alt="Brisbane property"
      class="w-full h-full object-cover"
      style="filter:grayscale(8%) brightness(0.4);"
    />
    <div class="absolute inset-0" style="background:linear-gradient(120deg,rgba(10,8,6,0.7) 0%,rgba(10,8,6,0.3) 100%);"></div>
  </div>
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-8 lg:px-12 pt-32 pb-16">
    <span class="eyebrow mb-4 reveal" style="display:block;color:#f5d07a;">Daniel Gierach · Ray White Bulimba</span>
    <h1 class="reveal" data-delay="80"
      style="font-family:var(--font-serif);font-size:clamp(2.5rem,5vw,4rem);font-weight:400;color:#f0ece4;letter-spacing:-0.02em;line-height:1.1;margin-bottom:0.75rem;">
      Current listings &amp; recent sales.
    </h1>
    <p class="reveal" data-delay="160"
      style="font-size:0.95rem;color:rgba(240,236,228,0.6);max-width:44ch;line-height:1.8;">
      Looking for off-market access? <a href="/contact" style="color:#f5d07a;text-decoration:none;font-weight:600;">Get in touch directly.</a>
    </p>
  </div>
</section>


<!-- Suburb filter -->
<section style="background:var(--color-base);padding:1.5rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;">
      <button class="suburb-filter active" data-filter="all">All suburbs</button>
      {allSuburbs.map(s => (
        <button class="suburb-filter" data-filter={s.toLowerCase().replace(/ /g, '-')}>{s}</button>
      ))}
    </div>
  </div>
</section>

<!-- For Sale -->
<section style="background:var(--color-base);padding:6rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:3rem;">
      {/* TODO Daniel: confirm whether these listings are exclusively your own or office-wide. If exclusive to you, change eyebrow to "For Sale by Daniel Gierach"; if these are network listings handled across the Bulimba team, "Ray White Bulimba" is the accurate label. Left as office-network framing pending confirmation. */}
      <div class="reveal">
        <span class="eyebrow mb-3" style="display:block;">For Sale via Ray White Collective</span>
        <h2 style="font-family:var(--font-serif);font-size:clamp(1.75rem,3vw,2.5rem);font-weight:400;color:#1c1917;letter-spacing:-0.01em;">
          For Sale
        </h2>
      </div>
      <a href="https://raywhitebulimba.com.au/agents/daniel-gierach" target="_blank" rel="noopener"
        style="font-family:var(--font-sans);font-size:0.68rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#78716c;text-decoration:none;transition:color 0.2s;"
        onmouseover="this.style.color='#c4912a'"
        onmouseout="this.style.color='#78716c'">
        View All on Ray White →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style="background:rgba(28,25,23,0.08);">
      {forSale.map((p, i) => (
        <a href={p.href} target="_blank" rel="noopener"
          class="reveal listing-card" data-delay={i * 60}
          data-suburb={p.suburb.toLowerCase().replace(/ /g, '-')}
          style="background:#ffffff;display:flex;flex-direction:column;text-decoration:none;transition:background 0.2s;"
          onmouseover="this.style.background='#edeae3'"
          onmouseout="this.style.background='#ffffff'"
        >
          <!-- Image -->
          <div style="aspect-ratio:4/3;overflow:hidden;position:relative;">
            <img src={p.image} alt={p.address} class="w-full h-full object-cover"
              style="transition:transform 0.4s;"
              onmouseover="this.style.transform='scale(1.04)'"
              onmouseout="this.style.transform='scale(1)'"
              loading="lazy"
            />
            <span style={`position:absolute;top:1rem;left:1rem;font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:#0a0806;background:${tagColors[p.tag] || '#f5d07a'};padding:0.3rem 0.65rem;`}>
              {p.tag}
            </span>
          </div>
          <!-- Details -->
          <div style="padding:1.5rem;flex:1;display:flex;flex-direction:column;gap:0.5rem;">
            <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#c4912a;">{p.suburb}</p>
            <h3 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:#1c1917;line-height:1.2;">{p.address}</h3>
            <p style="font-size:0.78rem;color:#78716c;">{p.street}</p>
            <p style="font-family:var(--font-sans);font-size:0.78rem;font-weight:600;color:#44403c;margin-top:0.25rem;">{p.price}</p>
            <div style="display:flex;gap:1.25rem;margin-top:auto;padding-top:1rem;border-top:1px solid rgba(28,25,23,0.1);">
              <span style="font-size:0.72rem;color:#78716c;">{p.beds} bed</span>
              <span style="font-size:0.72rem;color:#78716c;">{p.baths} bath</span>
              <span style="font-size:0.72rem;color:#78716c;">{p.cars} car</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- Recently Sold -->
<section id="sold" style="background:var(--color-surface-1);padding:6rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:3rem;">
      <div class="reveal">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Recently Sold via Ray White Collective</p>
        <h2 style="font-family:var(--font-serif);font-size:clamp(1.75rem,3vw,2.5rem);font-weight:400;color:#1c1917;letter-spacing:-0.01em;">
          Recently Sold
        </h2>
      </div>
      <a href="https://raywhitebulimba.com.au/agents/daniel-gierach" target="_blank" rel="noopener"
        style="font-family:var(--font-sans);font-size:0.68rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#78716c;text-decoration:none;transition:color 0.2s;"
        onmouseover="this.style.color='#c4912a'"
        onmouseout="this.style.color='#78716c'">
        Full Sales History →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style="background:rgba(28,25,23,0.08);">
      {sold.map((p, i) => (
        <a href={p.href} target="_blank" rel="noopener"
          class="reveal listing-card" data-delay={i * 60}
          data-suburb={p.suburb.toLowerCase().replace(/ /g, '-')}
          style="background:#f2efe9;display:flex;flex-direction:column;text-decoration:none;transition:background 0.2s;"
          onmouseover="this.style.background='#edeae3'"
          onmouseout="this.style.background='#f2efe9'"
        >
          <div style="aspect-ratio:4/3;overflow:hidden;position:relative;">
            <img src={p.image} alt={p.address} class="w-full h-full object-cover"
              style="filter:grayscale(30%);transition:filter 0.3s,transform 0.4s;"
              onmouseover="this.style.filter='grayscale(10%)';this.style.transform='scale(1.04)'"
              onmouseout="this.style.filter='grayscale(30%)';this.style.transform='scale(1)'"
              loading="lazy"
            />
            <span style="position:absolute;top:1rem;left:1rem;font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:rgba(240,236,228,0.9);background:rgba(28,25,23,0.65);padding:0.3rem 0.65rem;">
              Sold
            </span>
          </div>
          <div style="padding:1.5rem;flex:1;display:flex;flex-direction:column;gap:0.5rem;">
            <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#c4912a;">{p.suburb}</p>
            <h3 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:#1c1917;line-height:1.2;">{p.address}</h3>
            <p style="font-size:0.78rem;color:#78716c;">{p.street}</p>
            <div style="display:flex;gap:1.25rem;margin-top:auto;padding-top:1rem;border-top:1px solid rgba(28,25,23,0.1);">
              <span style="font-size:0.72rem;color:#78716c;">{p.beds} bed</span>
              <span style="font-size:0.72rem;color:#78716c;">{p.baths} bath</span>
              <span style="font-size:0.72rem;color:#78716c;">{p.cars} car</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .suburb-filter {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #78716c;
    background: transparent;
    border: 1px solid rgba(28,25,23,0.18);
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    border-radius: 8px;
  }
  .suburb-filter:hover {
    border-color: #c4912a;
    color: #c4912a;
  }
  .suburb-filter.active {
    background: #c4912a;
    border-color: #c4912a;
    color: #ffffff;
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.suburb-filter');
  const cards = document.querySelectorAll<HTMLElement>('.listing-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      filterBtns.forEach(b => b.classList.toggle('active', b === btn));
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.suburb === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<!-- Property Report CTA -->
<section style="background:#f2efe9;padding:4rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div class="reveal" style="padding:2.5rem;background:rgba(196,145,42,0.06);border:1px solid rgba(196,145,42,0.2);display:flex;flex-direction:column;align-items:center;text-align:center;gap:1rem;">
      <p style="font-family:var(--font-serif);font-size:1.1rem;font-style:italic;color:#1c1917;">What is your property worth?</p>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;">Get an instant digital property report, powered by Ray White, no obligation.</p>
      <a href="/walkthrough" class="btn-gold">
        Get My Free Property Report
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

</Layout>
