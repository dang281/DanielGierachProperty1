---
import Layout from '../../layouts/Layout.astro';
import PageTOC from '../../components/PageTOC.astro';

// Recent sales, pulled from Daniel's confirmed listings.
// Sources verified via raywhitebulimba.com.au agent page.
const recentSales = [
  {
    suburb: 'Seven Hills',
    address: '64 Valaria Avenue',
    price: '$1,800,000',
    beds: 5, baths: 3, cars: 2,
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/b7ae-H3494515-197181379__1776384722-43921-AMY4184.JPG',
    href: 'https://raywhitebulimba.com.au/properties/sold-residential/qld/seven-hills-4170/house/3494515',
  },
  {
    suburb: 'West End',
    address: '11103/41 Tondara Lane',
    price: '$3,400,000',
    beds: 3, baths: 3, cars: 4,
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/7149-H3442687-184436620__1769558771-34622-FJD9608.jpg',
    href: 'https://raywhitebulimba.com.au/properties/sold-residential/qld/west-end-4101/unit/3442687',
  },
  {
    suburb: 'Victoria Point',
    address: '5 Holz Street',
    price: '$1,025,000',
    beds: 3, baths: 2, cars: 4,
    image: 'https://cdn6.ep.dynamics.net/s3/rw-propertyimages/e3af-H3485122-195546888__1775524459-58394-AMY1219.jpg',
    href: 'https://raywhitebulimba.com.au/properties/sold-residential/qld/victoria-point-4165/house/3485122',
  },
];

// Licence number confirmed by Daniel 2026-07-16.
const credentials = [
  { icon: 'cap',    label: 'Bachelor of Property Economics, QUT' },
  { icon: 'badge',  label: 'Registered real estate agent · Licence No. 4873633' },
  { icon: 'network', label: 'Ray White Collective · Bulimba office' },
];
---

<Layout
  title="Daniel Gierach | Lead Agent | Ray White Collective"
  description="Daniel Gierach, Brisbane-born property professional at Ray White Collective. Degree in Property Economics, 10+ years across residential sales, marketing, business operations and construction."
  hideNav={true}
  hideBreadcrumbs={true}
>

<PageTOC />

<script is:inline>
  // Override the site-wide theme-color meta tag (#f2ead4 dark charcoal
  // from Layout.astro) with a warm cream that matches this page's
  // palette. Prevents iOS Safari status bar area from rendering as black.
  (function () {
    var color = '#e6d9bd';
    var metas = document.querySelectorAll('meta[name="theme-color"]');
    metas.forEach(function (m) { m.setAttribute('content', color); });
    if (!metas.length) {
      var meta = document.createElement('meta');
      meta.setAttribute('name', 'theme-color');
      meta.setAttribute('content', color);
      document.head.appendChild(meta);
    }
  })();
</script>

<style is:global>
  /* Playfair Display comes from Layout.astro's async font link; a CSS @import
     here would re-fetch it as a render-blocking chain. */

  :root {
    /* Palette override to match /meet-the-team. */
    --color-base:            #f9f5e8;
    --color-surface-0:       #f9f5e8;
    --color-surface-1:       #f2ead4;
    --color-surface-2:       #e6d9bd;
    --color-surface-3:       #ffffff;
    --color-surface-4:       #efe6ce;
    --color-surface-5:       #e6d9bd;

    --color-gold:            #8f6317;
    --color-gold-dim:        #6b4610;
    --color-gold-muted:      rgba(143,99,23,0.10);

    --color-accent:          #191817;
    --color-accent-soft:     #2a2724;
    --color-eyebrow:         #6b4610;

    --color-text-primary:    #191817;
    --color-text-secondary:  rgba(25,24,23,0.72);
    --color-text-muted:      rgba(25,24,23,0.55);
    --color-ghost:           rgba(25,24,23,0.10);

    --font-serif: 'Playfair Display', Georgia, serif;
    --font-sans:  'Manrope', system-ui, sans-serif;
  }

  html, body {
    background: #e6d9bd !important;
  }

  /* Serif elements get Fraunces optical size axis tuning. */
  h1, h2, h3, .section-eyebrow + p, article [style*="font-serif"] {
    font-feature-settings: "ss01" 1, "calt" 1;
  }
</style>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <!-- ── Hero ────────────────────────────────────────────────── -->
  <div style="position:relative;background:linear-gradient(180deg,#e6d9bd 0%,#ecdfc4 55%,#f2ead4 100%);padding:3.5rem 0 2.5rem;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 40%,rgba(185,130,41,0.13) 0%,transparent 70%);z-index:0;pointer-events:none;"></div>
    <div class="max-w-[780px] mx-auto px-8 flex flex-col items-center text-center" style="position:relative;z-index:1;">
      <img src="/img/daniel-headshot-tight.jpg" alt="Daniel Gierach"
        style="width:160px;height:160px;border-radius:18px;object-fit:cover;border:2px solid #b98229;box-shadow:0 8px 28px rgba(25,24,23,0.12);margin-bottom:1.5rem;" />
      <h1 style="font-family:var(--font-serif);font-style:italic;font-size:clamp(2rem,4.5vw,3rem);font-weight:400;color:#191817;line-height:1.1;letter-spacing:-0.01em;margin-bottom:0.55rem;">
        Daniel Gierach
      </h1>
      <span style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#6b4610;margin-bottom:1.5rem;">Lead Agent &middot; Ray White Collective</span>

      <div class="hero-contact">
        <a href="tel:+61412523821" data-cta="team_daniel_call">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          0412 523 821
        </a>
        <a href="mailto:daniel.gierach@raywhite.com" data-cta="team_daniel_email">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          daniel.gierach@raywhite.com
        </a>
        <a href="https://www.instagram.com/dgierach/" target="_blank" rel="noopener" data-cta="team_daniel_instagram">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          @dgierach
        </a>
      </div>
    </div>
  </div>

  <!-- ── Bio ─────────────────────────────────────────────────── -->
  <div style="padding:3.5rem 0 3.5rem;">
    <div class="max-w-[720px] mx-auto px-8 bio-body">

      <p class="bio-eyebrow">The background</p>
      <p class="bio-lede">Born and raised in Brisbane, Daniel spent a decade across residential sales, marketing, business operations and construction before settling into the listing side of the business. His degree in Property Economics from QUT sits behind the numbers-first approach he brings to every campaign.</p>

      <p>He works out of Ray White Bulimba and lists most heavily across Brisbane's inner east and south east: Seven Hills, Norman Park, Murarrie, Morningside, Carina, Carina Heights and Cannon Hill through to Coorparoo, Greenslopes, Bulimba, Hawthorne, Balmoral and both Mount Gravatt and Mount Gravatt East. That is where his local knowledge is deepest and where the strongest results come from knowing which buyers are already registered on which street.</p>

      <p class="bio-eyebrow" style="margin-top:2.5rem;">How Daniel works</p>
      <p>Every campaign is built on what buyers in your specific suburb are searching for right now. Pricing, marketing timing, and the shortlist of buyers Daniel calls first all come from current data, not a generic playbook.</p>

      <p>Through the Ray White Collective, a group of six inner-Brisbane offices sharing a single buyer database, your property is exposed to more than 550,000 pre-registered buyers from day one. That reach is what creates competition and protects the result.</p>

      <!-- Pull quote -->
      <figure class="pull-quote">
        <p>&ldquo;The conversations before the listing are where the result is decided.&rdquo;</p>
        <figcaption>Daniel Gierach &middot; Ray White Bulimba</figcaption>
      </figure>

      <p class="bio-eyebrow">Beyond the sale</p>
      <p>Daniel treats real estate as a long-term relationship, not a transaction. Most of the vendors he lists have been introduced by a past client. The campaign matters, but so does the year that follows.</p>

    </div>
  </div>

  <!-- ── Credentials ─────────────────────────────────────────── -->
  <div style="background:var(--color-surface-1);padding:3rem 0;border-top:1px solid rgba(28,25,23,0.08);border-bottom:1px solid rgba(28,25,23,0.08);">
    <div class="max-w-[900px] mx-auto px-8">
      <p class="section-eyebrow">Credentials</p>
      <div class="credentials-row">
        {credentials.map(c => (
          <div class="credential">
            <span class="credential-icon">
              {c.icon === 'cap' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10L12 5 2 10l10 5 10-5v6"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              )}
              {c.icon === 'badge' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><polyline points="15.09,13.94 15.09,22 12,20 8.91,22 8.91,13.94"/></svg>
              )}
              {c.icon === 'network' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="5" cy="5" r="2"/><circle cx="19" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><line x1="7" y1="7" x2="10" y2="10"/><line x1="17" y1="7" x2="14" y2="10"/><line x1="7" y1="17" x2="10" y2="14"/><line x1="17" y1="17" x2="14" y2="14"/></svg>
              )}
            </span>
            <span class="credential-label">{c.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Recent sales ────────────────────────────────────────── -->
  <div style="padding:3.5rem 0;">
    <div class="max-w-[1100px] mx-auto px-8">
      <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.5rem;gap:1rem;flex-wrap:wrap;">
        <div>
          <p class="section-eyebrow" style="margin-bottom:0.3rem;">Recent Sales</p>
          <h2 style="font-family:var(--font-serif);font-size:clamp(1.4rem,2.6vw,1.9rem);font-weight:400;color:var(--color-text-primary);letter-spacing:-0.01em;">
            A snapshot of Daniel's recent results
          </h2>
        </div>
        <a href="/listings#sold" style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(25,24,23,0.44);text-decoration:none;">
          Full sales history &rarr;
        </a>
      </div>

      <div class="sales-grid">
        {recentSales.map(s => (
          <a href={s.href} target="_blank" rel="noopener" class="sale-card" data-cta={`team_daniel_sale_${s.address.replace(/[^a-z0-9]/gi, '_').toLowerCase()}`}>
            <div class="sale-img-wrap">
              <img src={s.image} alt={s.address} loading="lazy" />
              <span class="sale-badge">Sold</span>
            </div>
            <div class="sale-body">
              <p class="sale-suburb">{s.suburb}</p>
              <p class="sale-address">{s.address}</p>
              <p class="sale-price">{s.price}</p>
              <div class="sale-stats">
                <span>{s.beds} bed</span>
                <span>{s.baths} bath</span>
                <span>{s.cars} car</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Bottom CTA ──────────────────────────────────────────── -->
  <div style="background:var(--color-surface-1);padding:3.5rem 0;border-top:1px solid rgba(28,25,23,0.08);">
    <div class="max-w-[900px] mx-auto px-8">
      <div class="cta-panel">
        <div style="flex:1;min-width:0;">
          <p class="section-eyebrow" style="color:var(--color-gold);margin-bottom:0.5rem;">Book a call</p>
          <p style="font-family:var(--font-serif);font-size:clamp(1.2rem,2.2vw,1.55rem);font-weight:400;color:var(--color-text-primary);line-height:1.3;margin-bottom:0.4rem;">
            Twenty minutes on the phone, no pitch.
          </p>
          <p style="font-size:0.85rem;color:var(--color-text-muted);line-height:1.7;">
            Daniel returns every call the same day. Ask about pricing, timing, or the current buyer pool in your street.
          </p>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.65rem;flex-shrink:0;">
          <a href="tel:+61412523821" class="btn-gold" data-cta="team_daniel_cta_call">
            Call 0412 523 821
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          </a>
          <a href="/property-worth" class="btn-outline" data-cta="team_daniel_cta_report">
            Get a free property report
          </a>
        </div>
      </div>

      <div style="margin-top:2rem;text-align:center;">
        <a href="/meet-your-team" style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);text-decoration:none;">&larr; Back to your team</a>
      </div>
    </div>
  </div>

</article>

<style>
  /* ── Hero contact pills ── */
  .hero-contact {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.55rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
  }
  .hero-contact a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.95rem;
    background: rgba(25, 24, 23, 0.06);
    border: 1px solid rgba(185, 130, 41, 0.4);
    border-radius: 999px;
    color: #6b4610;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .hero-contact a:hover {
    background: rgba(185, 130, 41, 0.12);
    border-color: #b98229;
  }
  @media (max-width: 560px) {
    .hero-contact {
      flex-direction: column;
      gap: 0.5rem;
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }
    .hero-contact a { justify-content: center; width: 100%; }
  }

  /* ── Bio body ── */
  .bio-body {
    font-size: 1rem;
    color: rgba(25,24,23,0.78);
    line-height: 1.85;
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }
  .bio-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 -0.4rem 0;
  }
  .bio-lede { font-size: 1.05rem; }

  /* ── Pull quote ── */
  .pull-quote {
    margin: 1.5rem 0 0.5rem;
    padding: 1.75rem 1.75rem 1.5rem;
    background: rgba(185,130,41,0.06);
    border: 1px solid rgba(185,130,41,0.22);
    border-left: 3px solid var(--color-gold);
    border-radius: 8px;
  }
  .pull-quote p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-text-primary);
    line-height: 1.55;
    margin-bottom: 0.75rem;
  }
  .pull-quote figcaption {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  /* ── Section eyebrow (shared) ── */
  .section-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6b4610;
    margin-bottom: 1rem;
  }

  /* ── Credentials ── */
  .credentials-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .credentials-row { grid-template-columns: 1fr; }
  }
  .credential {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1rem 1.15rem;
    background: #ffffff;
    border: 1px solid rgba(28,25,23,0.08);
    border-radius: 8px;
  }
  .credential-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px; height: 34px;
    border-radius: 8px;
    background: rgba(185,130,41,0.1);
    color: var(--color-gold);
    flex-shrink: 0;
  }
  .credential-label {
    font-size: 0.8rem;
    color: var(--color-text-primary);
    line-height: 1.35;
  }

  /* ── Recent sales grid ── */
  .sales-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .sales-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .sales-grid { grid-template-columns: 1fr; }
  }
  .sale-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid rgba(28,25,23,0.08);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .sale-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(230,217,189,0.1);
    border-color: rgba(185,130,41,0.35);
  }
  .sale-img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    position: relative;
  }
  .sale-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(25%);
    transition: filter 0.3s, transform 0.4s;
  }
  .sale-card:hover .sale-img-wrap img {
    filter: grayscale(0%);
    transform: scale(1.04);
  }
  .sale-badge {
    position: absolute;
    top: 0.85rem; left: 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ffffff;
    background: #b98229;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
  }
  .sale-body {
    padding: 1.15rem 1.15rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }
  .sale-suburb {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .sale-address {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-primary);
    line-height: 1.25;
  }
  .sale-price {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    color: #44403c;
  }
  .sale-stats {
    display: flex;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(28,25,23,0.08);
    font-size: 0.7rem;
    color: rgba(25,24,23,0.44);
  }

  /* ── CTA panel ── */
  .cta-panel {
    padding: 2rem 2rem;
    background: #ffffff;
    border: 1px solid rgba(185,130,41,0.22);
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) {
    .cta-panel { flex-direction: column; align-items: stretch; }
  }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.7rem 1.1rem;
    background: transparent;
    border: 1px solid rgba(28,25,23,0.2);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .btn-outline:hover { border-color: var(--color-gold); color: var(--color-gold); }
</style>

</Layout>
</content>
</invoke>