---

<Layout title="Sitemap | Daniel Gierach Property" description="Full sitemap for danielgierach.com — Brisbane inner-east real estate specialist.">


<!-- ════════════════════════════════════════════
     HERO
════════════════════════════════════════════ -->
<section style="background:#1c1917;padding:8rem 0 5rem;border-bottom:1px solid rgba(240,236,228,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <span style="font-family:var(--font-sans);font-size:0.75rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#f5d07a;display:block;margin-bottom:1.5rem;">Navigation</span>
    <h1 style="font-family:var(--font-serif);font-size:clamp(2.2rem,5vw,3.5rem);font-weight:400;color:#f0ece4;line-height:1.1;letter-spacing:-0.02em;margin-bottom:1rem;">
      Sitemap
    </h1>
    <p style="font-size:0.88rem;color:rgba(240,236,228,0.45);max-width:52ch;line-height:1.75;">
      A complete index of every page on this site. Use this to navigate directly to any section.
    </p>
  </div>
</section>


<!-- ════════════════════════════════════════════
     SITEMAP GROUPS
════════════════════════════════════════════ -->
<section style="background:var(--color-base);padding:5rem 0;">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div style="display:flex;flex-direction:column;gap:4rem;">

      {groups.map((group) => (
        <div>
          <p style="font-family:var(--font-sans);font-size:0.75rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#c4912a;margin-bottom:1.75rem;">{group.label}</p>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style="background:rgba(28,25,23,0.08);">
            {group.links.map((link) => (
              <a
                href={link.href}
                style="background:var(--color-base);padding:1.5rem 1.75rem;text-decoration:none;display:flex;flex-direction:column;gap:0.35rem;transition:background 0.2s;"
                onmouseover="this.style.background='#edeae3'"
                onmouseout="this.style.background='var(--color-base)'"
              >
                <span style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                  <span style="font-family:var(--font-serif);font-size:0.95rem;color:#1c1917;line-height:1.3;">{link.title}</span>
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#c4912a" stroke-width="2.5" style="flex-shrink:0;opacity:0.6;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
                <span style="font-size:0.78rem;color:#78716c;line-height:1.5;">{link.desc}</span>
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>
  </div>
</section>


<!-- ════════════════════════════════════════════
     XML SITEMAP NOTE
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-0);padding:3rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <p style="font-size:0.82rem;color:#78716c;line-height:1.75;">
      Search engines: an XML sitemap is available at
      <a href="/sitemap.xml" style="color:#c4912a;text-decoration:none;font-weight:600;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">/sitemap.xml</a>
    </p>
  </div>
</section>

</Layout>
