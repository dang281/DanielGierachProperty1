      <span class="ds-section-title">4. Food &amp; Dining</span>
      <div class="ds-row"><label>Groceries &amp; supermarket</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-groceries" value="600" /></div></div>
      <div class="ds-row"><label>Dining out &amp; takeaway</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-dining" value="300" /></div></div>
      <div class="ds-row"><label>Coffee</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-coffee" value="80" /></div></div>
      <div class="ds-cat-total"><span>Food Total</span><span id="total-food">$980</span></div>
    </div>

    <!-- ── EXPENSES: TRANSPORT ── -->
    <div class="ds-card">
      <span class="ds-section-title">5. Transport</span>
      <div class="ds-row"><label>Car loan repayment</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-car-loan" value="0" /></div></div>
      <div class="ds-row"><label>Fuel</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-fuel" value="150" /></div></div>
      <div class="ds-row"><label>Registration &amp; insurance</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-car-ins" value="100" /></div></div>
      <div class="ds-row"><label>Public transport</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-pt" value="0" /></div></div>
      <div class="ds-cat-total"><span>Transport Total</span><span id="total-transport">$250</span></div>
    </div>

    <!-- ── EXPENSES: LIFESTYLE ── -->
    <div class="ds-card">
      <span class="ds-section-title">6. Lifestyle &amp; Personal</span>
      <div class="ds-row"><label>Gym &amp; sports</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-gym" value="60" /></div></div>
      <div class="ds-row"><label>Entertainment &amp; hobbies</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-entertainment" value="150" /></div></div>
      <div class="ds-row"><label>Subscriptions (Netflix, Spotify…)</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-subs" value="50" /></div></div>
      <div class="ds-row"><label>Clothing &amp; personal care</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-clothing" value="100" /></div></div>
      <div class="ds-row"><label>Health &amp; medical</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-health" value="60" /></div></div>
      <div class="ds-row"><label>Pet costs</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-pets" value="0" /></div></div>
      <div class="ds-cat-total"><span>Lifestyle Total</span><span id="total-lifestyle">$420</span></div>
    </div>

    <!-- ── EXPENSES: OTHER ── -->
    <div class="ds-card">
      <span class="ds-section-title">7. Insurance &amp; Other</span>
      <div class="ds-row"><label>Health insurance</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-health-ins" value="120" /></div></div>
      <div class="ds-row"><label>Life / income protection</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-life-ins" value="0" /></div></div>
      <div class="ds-row"><label>Childcare &amp; school fees</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-childcare" value="0" /></div></div>
      <div class="ds-row"><label>Student loan / HECS repayment</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-hecs" value="0" /></div></div>
      <div class="ds-row"><label>Credit card / personal loan</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-debt" value="0" /></div></div>
      <div class="ds-row"><label>Gifts &amp; holidays</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-holidays" value="100" /></div></div>
      <div class="ds-row"><label>Other</label><div class="ds-input-wrap"><span class="ds-prefix">$</span><input type="number" class="ds-input exp-input" id="exp-misc" value="0" /></div></div>
      <div class="ds-cat-total"><span>Other Total</span><span id="total-other">$220</span></div>
    </div>

  </div>

  <!-- ═══════════════════════════════════════
       RIGHT: RESULTS (2 cols)
  ═══════════════════════════════════════ -->
  <div class="lg:col-span-2">
    <div style="position:sticky;top:100px;">

      <!-- Savings goal -->
      <div class="ds-result-card" style="border-top:3px solid var(--color-gold);">
        <span class="ds-result-label">Total Savings Needed</span>
        <div class="ds-result-value gold" id="r-total-needed">$178,025</div>
        <div class="ds-progress-wrap">
          <div class="ds-progress-bar" id="r-progress" style="width:0%"></div>
        </div>
        <div class="ds-result-sub" id="r-progress-label">$0 saved of $178,025 (0%)</div>
      </div>

      <!-- Monthly cashflow -->
      <div class="ds-result-card">
        <span class="ds-result-label">Monthly Income</span>
        <div class="ds-result-value" id="r-income">$5,000</div>
      </div>
      <div class="ds-result-card">
        <span class="ds-result-label">Monthly Expenses</span>
        <div class="ds-result-value" id="r-expenses">$3,970</div>
      </div>
      <div class="ds-result-card" style="border-top:3px solid var(--color-gold);">
        <span class="ds-result-label">Monthly Surplus</span>
        <div class="ds-result-value surplus-positive" id="r-surplus">$1,030</div>
        <div class="ds-result-sub" id="r-surplus-pct">20.6% of income</div>
      </div>

      <!-- Time to goal -->
      <div class="ds-result-card" style="background:var(--color-text-primary);padding:1.5rem;">
        <span class="ds-result-label" style="color:rgba(240,236,228,0.55);">Time to Reach Goal</span>
        <div class="ds-result-value" style="color:#f0ece4;" id="r-time">11.5 years</div>
        <div class="ds-result-sub" style="color:rgba(240,236,228,0.55);" id="r-date">You'd be ready around <strong id="r-ready-date" style="color:#f5d07a;">Aug 2037</strong></div>
      </div>

      <!-- Savings scenarios -->
      <div class="ds-result-card">
        <span class="ds-result-label" style="margin-bottom:0.75rem;display:block;">What If I Saved More?</span>
        <table class="ds-breakdown">
          <tr><td>Save $500/mth extra</td><td id="sc-500">—</td></tr>
          <tr><td>Save $1,000/mth extra</td><td id="sc-1000">—</td></tr>
          <tr><td>Save $2,000/mth extra</td><td id="sc-2000">—</td></tr>
        </table>
      </div>

      <!-- Tips -->
      <div class="ds-result-card">
        <span class="ds-result-label" style="margin-bottom:0.75rem;display:block;">Smart Saving Tips</span>
        <div id="tips-container"></div>
      </div>

      <!-- Download -->
      <div class="ds-result-card">
        <span class="ds-result-label" style="margin-bottom:0.5rem;display:block;">Download Your Budget</span>
        <p style="font-size:0.75rem;color:var(--color-text-muted);line-height:1.6;margin-bottom:0.75rem;">Export a fully functional Excel spreadsheet with all your figures, formulas, and a month-by-month savings timeline.</p>
        <button class="ds-download-btn" id="download-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Excel Spreadsheet
        </button>
      </div>

    </div>
  </div>

</div>

<!-- ExcelJS for styled Excel export -->
<script src="https://unpkg.com/exceljs@4.4.0/dist/exceljs.min.js"></script>

<script>
(function() {

  // ── State ──────────────────────────────────────────────────────────
  let depositPct  = 20;
  let buyerType   = 'owner';
  const MISC_COSTS = 3500;

  // ── QLD Stamp Duty ─────────────────────────────────────────────────
  function calcStampDuty(price: number, buyer: string): number {
    let duty = 0;
    if (price <= 350000)       duty = price * 0.01;
    else if (price <= 540000)  duty = 3500 + (price - 350000) * 0.035;
    else if (price <= 1000000) duty = 10150 + (price - 540000) * 0.045;
    else                       duty = 30850 + (price - 1000000) * 0.0575;

    if (buyer === 'fhb') {
      if (price <= 500000)       duty = 0;
      else if (price <= 550000)  duty = duty * ((price - 500000) / 50000);
    }
    return Math.round(duty);
  }

  // ── LMI estimate ──────────────────────────────────────────────────
  function calcLMI(price: number, dep: number): number {
    if (dep >= 20) return 0;
    const loan = price * (1 - dep / 100);
    const lvr  = (loan / price) * 100;
    let rate = 0;
    if (lvr <= 80)       rate = 0;
    else if (lvr <= 85)  rate = 0.01;
    else if (lvr <= 90)  rate = 0.02;
    else if (lvr <= 95)  rate = 0.04;
    return Math.round(loan * rate);
  }

  // ── Format currency ───────────────────────────────────────────────
  const fmt  = (n: number) => '$' + Math.round(n).toLocaleString('en-AU');
  const fmtN = (n: number) => n.toLocaleString('en-AU');

  // ── Time to target ────────────────────────────────────────────────
  function monthsToDate(months: number): string {
    const d = new Date();
    d.setMonth(d.getMonth() + Math.ceil(months));
    return d.toLocaleDateString('en-AU', { month: 'short', year: 'numeric' });
  }
  function formatMonths(m: number): string {
    if (!isFinite(m) || m < 0) return '—';
    const yrs = Math.floor(m / 12);
    const mths = Math.round(m % 12);
    if (yrs === 0) return mths + ' months';
    if (mths === 0) return yrs + (yrs === 1 ? ' year' : ' years');
    return yrs + 'y ' + mths + 'm';
  }

  // ── Read inputs ───────────────────────────────────────────────────
  function v(id: string): number {
    const el = document.getElementById(id) as HTMLInputElement;
    return parseFloat(el?.value || '0') || 0;
  }

  // ── Category totals ───────────────────────────────────────────────
  function sumCat(ids: string[]): number {
    return ids.reduce((a, id) => a + v(id), 0);
  }

  // ── Main calc ─────────────────────────────────────────────────────
  function calc() {
    const price    = v('property-price');
    const saved    = v('current-savings');

    const deposit  = price * (depositPct / 100);
    const stamp    = calcStampDuty(price, buyerType);
    const lmi      = calcLMI(price, depositPct);
    const total    = deposit + stamp + lmi + MISC_COSTS;
    const remaining = Math.max(0, total - saved);

    // Income
    const income = sumCat(['inc-salary','inc-partner','inc-rental','inc-side','inc-other']);

    // Expenses
    const housing   = sumCat(['exp-rent','exp-utilities','exp-internet','exp-rates']);
    const food      = sumCat(['exp-groceries','exp-dining','exp-coffee']);
    const transport = sumCat(['exp-car-loan','exp-fuel','exp-car-ins','exp-pt']);
    const lifestyle = sumCat(['exp-gym','exp-entertainment','exp-subs','exp-clothing','exp-health','exp-pets']);
    const other     = sumCat(['exp-health-ins','exp-life-ins','exp-childcare','exp-hecs','exp-debt','exp-holidays','exp-misc']);
    const expenses  = housing + food + transport + lifestyle + other;
    const surplus   = income - expenses;

    // Time
    const months = surplus > 0 ? remaining / surplus : Infinity;

    // Progress
    const pct = Math.min(100, total > 0 ? (saved / total) * 100 : 0);

    // ── Update DOM ──────────────────────────────────────────────────
    (document.getElementById('bd-deposit') as HTMLElement).textContent = fmt(deposit);
    (document.getElementById('bd-stamp') as HTMLElement).textContent   = fmt(stamp);
    (document.getElementById('bd-lmi') as HTMLElement).textContent     = lmi > 0 ? fmt(lmi) : '$0';
    (document.getElementById('bd-total') as HTMLElement).textContent   = fmt(total);

    (document.getElementById('r-total-needed') as HTMLElement).textContent = fmt(total);
    (document.getElementById('r-progress') as HTMLElement).style.width     = pct.toFixed(1) + '%';
    (document.getElementById('r-progress-label') as HTMLElement).textContent =
      fmt(saved) + ' saved of ' + fmt(total) + ' (' + pct.toFixed(1) + '%)';

    (document.getElementById('r-income') as HTMLElement).textContent   = fmt(income);
    (document.getElementById('r-expenses') as HTMLElement).textContent = fmt(expenses);

    const surplusEl = document.getElementById('r-surplus') as HTMLElement;
    surplusEl.textContent = fmt(surplus);
    surplusEl.className   = 'ds-result-value ' + (surplus >= 0 ? 'surplus-positive' : 'surplus-negative');

    const surplusPct = income > 0 ? ((surplus / income) * 100).toFixed(1) : '0';
    (document.getElementById('r-surplus-pct') as HTMLElement).textContent =
      surplusPct + '% of income';

    (document.getElementById('r-time') as HTMLElement).textContent = formatMonths(months);
    const rdEl = document.getElementById('r-ready-date') as HTMLElement;
    rdEl.textContent = isFinite(months) && months >= 0 ? monthsToDate(months) : '—';

    // Category totals
    (document.getElementById('total-income') as HTMLElement).textContent    = fmt(income);
    (document.getElementById('total-housing') as HTMLElement).textContent   = fmt(housing);
    (document.getElementById('total-food') as HTMLElement).textContent      = fmt(food);
    (document.getElementById('total-transport') as HTMLElement).textContent = fmt(transport);
    (document.getElementById('total-lifestyle') as HTMLElement).textContent = fmt(lifestyle);
    (document.getElementById('total-other') as HTMLElement).textContent     = fmt(other);

    // Scenarios
    ['500','1000','2000'].forEach(extra => {
      const m = surplus + parseInt(extra) > 0 ? remaining / (surplus + parseInt(extra)) : Infinity;
      (document.getElementById('sc-' + extra) as HTMLElement).textContent =
        isFinite(m) ? formatMonths(m) : '—';
    });

    // Tips
    buildTips(surplus, income, housing, food, lifestyle, depositPct, lmi);

    // Store for download
    (window as any).__dsState = { price, saved, deposit, stamp, lmi, total, remaining, income, expenses, surplus, months, housing, food, transport, lifestyle, other, depositPct, buyerType };
  }

  // ── Smart tips ────────────────────────────────────────────────────
  function buildTips(surplus: number, income: number, housing: number, food: number, lifestyle: number, dep: number, lmi: number) {
    const tips: string[] = [];
    const savingsRate = income > 0 ? surplus / income : 0;

    if (surplus <= 0) {
      tips.push('⚠️ Your expenses exceed your income. Review your biggest cost categories above to find room to cut.');
    }
    if (savingsRate < 0.15 && surplus > 0) {
      tips.push('Aim for a savings rate of at least 20% of take-home income. Try trimming dining, subscriptions, or lifestyle spend.');
    }
    if (dep < 20 && lmi > 0) {
      tips.push(`Saving to 20% deposit eliminates ~${fmt(lmi)} in LMI and reduces your interest from day one.`);
    }
    if (food > 500) {
      tips.push('Meal planning and reducing dining out by $200/month saves $2,400/year, real progress toward your goal.');
    }
    if (lifestyle > 400) {
      tips.push('Review subscriptions and entertainment. Cutting $150/month frees $1,800 per year for your deposit fund.');
    }
    if (surplus > 500) {
      tips.push(`Auto-transfer your monthly surplus of ${fmt(surplus)} into a high-interest savings account on payday.`);
    }
    tips.push('QLD First Home Buyers Grant: up to $30,000 for new builds under $750,000. Check your eligibility at qld.gov.au.');

    const container = document.getElementById('tips-container') as HTMLElement;
    container.innerHTML = tips.map(t => `<div class="ds-tip">${t}</div>`).join('');
  }

