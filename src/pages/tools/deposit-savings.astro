      const wsub = ws2.getCell('A2');
      wsub.value = `Savings data from "Budget Planner" sheet  ·  Update inputs there to refresh  ·  Generated ${genDate}`;
      wsub.font = { name:'Calibri', size:9, italic:true, color:{ argb:'FFBCB0A4' } };
      wsub.fill = { type:'pattern', pattern:'solid', fgColor:{ argb: C.dark2 } };
      wsub.alignment = { horizontal:'center', vertical:'middle' };
      ws2.getRow(2).height = 18;

      ws2.getRow(3).height = 6;
      ['A','B','C','D','E','F','G'].forEach(col => {
        ws2.getCell(`${col}3`).fill = { type:'pattern', pattern:'solid', fgColor:{ argb: C.white } };
      });

      ['Month','Date','Opening Balance','Monthly Savings','Closing Balance','% of Goal','Milestone'].forEach((h, i) => {
        const col = String.fromCharCode(65+i);
        const cell = ws2.getCell(`${col}4`);
        cell.value = h;
        cell.font = { name:'Calibri', size:9, bold:true, color:{ argb: C.dark } };
        cell.fill = { type:'pattern', pattern:'solid', fgColor:{ argb: C.gold } };
        cell.alignment = { horizontal: i>=2&&i<=5 ? 'right' : 'center', vertical:'middle' };
        cell.border = { bottom:{ style:'medium', color:{ argb:'FF8B7335' } } };
      });
      ws2.getRow(4).height = 22;

      const contrib   = Math.max(0, s.surplus || 0);
      const startSav  = s.saved || 0;
      const goalAmt   = s.total || 1;
      const maxR      = Math.min(isFinite(s.months||0) ? Math.ceil(s.months||0) + 1 : 120, 360);

      for (let i = 1; i <= maxR; i++) {
        const r       = 4 + i;
        const opening = Math.min(startSav + (i-1) * contrib, goalAmt);
        const closing = Math.min(opening + contrib, goalAmt);
        const pct     = goalAmt > 0 ? closing / goalAmt : 0;
        const reached = closing >= goalAmt;
        const isEven  = i % 2 === 0;
        const rowBg   = reached ? 'FFD1FAE5' : (isEven ? C.rowAlt : C.white);

        ws2.getRow(r).height = 18;
        ['A','B','C','D','E','F','G'].forEach(col => {
          ws2.getCell(`${col}${r}`).fill = { type:'pattern', pattern:'solid', fgColor:{ argb: rowBg } };
        });

        const d = new Date(); d.setMonth(d.getMonth() + i);
        const dateStr = d.toLocaleDateString('en-AU', { month:'short', year:'numeric' });

        let ms = '';
        if (reached)        ms = '🎉 GOAL REACHED!';
        else if (pct>=0.75) ms = '75% — nearly there';
        else if (pct>=0.5)  ms = '50% — halfway!';
        else if (pct>=0.25) ms = '25% — great start';

        [{col:'A',val:i,fmt:'0',h:'center'},{col:'B',val:dateStr,fmt:'@',h:'center'},
         {col:'C',val:opening,fmt:'$#,##0',h:'right'},{col:'D',val:contrib,fmt:'$#,##0',h:'right'},
         {col:'E',val:closing,fmt:'$#,##0',h:'right'},{col:'F',val:pct,fmt:'0.0%',h:'right'},
         {col:'G',val:ms,fmt:'@',h:'left'}].forEach(({ col, val, fmt, h }) => {
          const cell = ws2.getCell(`${col}${r}`);
          cell.value = val; cell.numFmt = fmt;
          cell.font = { name:'Calibri', size:9, bold:reached, color:{ argb: reached ? C.green : C.text2 } };
          cell.alignment = { horizontal: h as any, vertical:'middle' };
        });

        if (reached) break;
      }

      // ── SHEET 3: Instructions ───────────────────────────────────
      const ws3 = wb.addWorksheet('Instructions');
      ws3.columns = [{ width:5 }, { width:75 }, { width:5 }];

      ws3.mergeCells('A1:C1');
      const ti3 = ws3.getCell('A1');
      ti3.value = 'HOW TO USE YOUR DEPOSIT SAVINGS PLANNER';
      ti3.font = { name:'Calibri', size:16, bold:true, color:{ argb: C.gold } };
      ti3.fill = { type:'pattern', pattern:'solid', fgColor:{ argb: C.dark } };
      ti3.alignment = { horizontal:'center', vertical:'middle' };
      ws3.getRow(1).height = 40;

      ws3.mergeCells('A2:C2');
      const si3 = ws3.getCell('A2');
      si3.value = 'Daniel Gierach Property  ·  Ray White Bulimba  ·  danielgierach.com  ·  0412 523 821';
      si3.font = { name:'Calibri', size:10, italic:true, color:{ argb:'FFBCB0A4' } };
      si3.fill = { type:'pattern', pattern:'solid', fgColor:{ argb: C.dark2 } };
      si3.alignment = { horizontal:'center', vertical:'middle' };
      ws3.getRow(2).height = 20;

      const instRows: [string, 'section'|'body'|'blank'][] = [
        ['', 'blank'],
        ['GETTING STARTED', 'section'],
        ['Go to the "Budget Planner" tab — this is your main working sheet.', 'body'],
        ['Edit any cell with a yellow background. These are input cells you can change freely.', 'body'],
        ['All formula cells (cream / grey background) update automatically — do not edit these.', 'body'],
        ['Start with Section 1 (Deposit Goal): enter property price, deposit % and buyer type.', 'body'],
        ['Work through income and expenses section by section with your real monthly figures.', 'body'],
        ['', 'blank'],
        ['READING YOUR RESULTS', 'section'],
        ['Monthly Surplus: the amount available to save after all expenses.', 'body'],
        ['Savings Rate: your surplus as % of income. Aim for 20% or more.', 'body'],
        ['Months to Goal: how long to reach your full deposit amount at current savings rate.', 'body'],
        ['Scenarios: time to goal if you find an extra $500, $1,000 or $2,000 per month.', 'body'],
        ['', 'blank'],
        ['TIPS FOR FASTER SAVING', 'section'],
        ['Save to 20% deposit: eliminates LMI (potentially $10,000–$40,000) and reduces your interest rate.', 'body'],
        ['Auto-transfer: set up an automatic transfer on payday into a high-interest savings account.', 'body'],
        ['Review expenses monthly: trimming $300/month adds $3,600/year to your deposit fund.', 'body'],
        ['QLD First Home Buyer Grant: up to $30,000 for eligible new builds under $750,000. See qld.gov.au.', 'body'],
        ['First Home Super Saver Scheme (FHSS): save up to $50,000 in super for your deposit (ATO approved).', 'body'],
        ['', 'blank'],
        ['UNDERSTANDING THE CALCULATIONS', 'section'],
        ['Stamp Duty: QLD Transfer Duty rates as at 2025. FHB concession auto-applied if selected.', 'body'],
        ['LMI: Estimated at 1–4% of the loan depending on your LVR. Get an exact quote from your broker.', 'body'],
        ['Conveyancing: $3,500 estimate. Actual costs typically range $1,500–$4,000.', 'body'],
        ['', 'blank'],
        ['NEED HELP WITH YOUR NEXT STEP?', 'section'],
        ['Daniel Gierach  |  Ray White Bulimba  |  Brisbane Inner East Specialist', 'body'],
        ['📞  0412 523 821  (7 days, 7am–8pm)', 'body'],
        ['🌐  danielgierach.com', 'body'],
        ['📧  daniel.gierach@raywhite.com', 'body'],
        ['Free property appraisals available anytime — no obligation.', 'body'],
        ['', 'blank'],
        ['DISCLAIMER', 'section'],
        ['This spreadsheet is for general information only. It does not constitute financial, legal, or taxation advice.', 'body'],
        ['All calculations are estimates based on published rates and may not reflect your exact situation.', 'body'],
        ['Always consult a licensed mortgage broker, financial adviser, or accountant before making decisions.', 'body'],
      ];

      let ir = 3;
      instRows.forEach(([text, type]) => {
        if (type==='blank') {
          ws3.getRow(ir).height = 8;
          ws3.mergeCells(`A${ir}:C${ir}`);
          ws3.getCell(`A${ir}`).fill = { type:'pattern', pattern:'solid', fgColor:{ argb: C.white } };
        } else if (type==='section') {
          ws3.getRow(ir).height = 24;
          ws3.mergeCells(`A${ir}:C${ir}`);
          const c = ws3.getCell(`A${ir}`);
          c.value = text; c.font = { name:'Calibri', size:10, bold:true, color:{ argb: C.dark } };
          c.fill = { type:'pattern', pattern:'solid', fgColor:{ argb: C.gold } };
          c.alignment = { vertical:'middle', indent:1 };
          c.border = { top:{ style:'medium', color:{ argb:'FF8B7335' } } };
        } else {
          ws3.getRow(ir).height = 18;
          ws3.mergeCells(`A${ir}:C${ir}`);
          const c = ws3.getCell(`A${ir}`);
          c.value = text; c.font = { name:'Calibri', size:10, color:{ argb: C.text2 } };
          c.fill = { type:'pattern', pattern:'solid', fgColor:{ argb:'FFFAFAF7' } };
          c.alignment = { vertical:'middle', indent:2, wrapText:true };
        }
        ir++;
      });

      // Write file
      const buffer = await wb.xlsx.writeBuffer();
      const blob   = new Blob([buffer], { type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
      const url    = URL.createObjectURL(blob);
      const a      = document.createElement('a');
      a.href = url;
      a.download = `Deposit-Savings-Planner-${new Date().toLocaleDateString('en-AU').replace(/\//g,'-')}.xlsx`;
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      URL.revokeObjectURL(url);

    } catch(err: any) {
      if (err?.message==='loading') alert('Spreadsheet library still loading — try again in a moment.');
      else alert('Could not generate spreadsheet. Please try again.');
      console.error(err);
    } finally {
      btn.innerHTML = origHTML;
      btn.disabled = false;
    }
  });

  // ── Init ──────────────────────────────────────────────────────────
  calc();

})();
</script>

</ToolLayout>
