---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Suburb Match Quiz"
  description="Answer 8 questions to discover your ideal Brisbane inner east or south suburb based on lifestyle, budget, and priorities."
  tool="Suburb Match"
  phase="Buyer Tools"
>
  <div class="max-w-2xl mx-auto pt-8">

    <!-- Progress -->
    <div style="margin-bottom:2rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
        <span id="progress-label" style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-text-muted);">Question 1 of 8</span>
        <span id="progress-pct" style="font-size:0.65rem;color:var(--color-gold);">0%</span>
      </div>
      <div style="height:2px;background:var(--color-surface-4);width:100%;">
        <div id="progress-bar" style="height:2px;background:var(--color-gold);width:0%;transition:width 0.4s ease;"></div>
      </div>
    </div>

    <!-- Questions container -->
    <div id="quiz-container"></div>

    <!-- Results -->
    <div id="results" style="display:none;">
      <div style="text-align:center;margin-bottom:2rem;">
        <span class="eyebrow" style="display:block;margin-bottom:0.75rem;">Your Results</span>
        <h2 style="font-family:var(--font-serif);font-size:2rem;font-weight:400;color:var(--color-text-primary);">Your Top Suburb Matches</h2>
        <p style="font-size:0.85rem;color:var(--color-text-secondary);margin-top:0.5rem;">Based on your lifestyle preferences and budget.</p>
      </div>
      <div id="results-grid" class="flex flex-col gap-4 mb-8"></div>
      <div style="text-align:center;">
        <button id="restart-btn" class="btn-outline-gold" style="margin-right:1rem;">Retake Quiz</button>
        <a href="/appraisal" class="btn-gold">Talk to Dan →</a>
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  interface Question {
    id: string;
    text: string;
    options: { label: string; value: string; tags: string[] }[];
  }

  const QUESTIONS: Question[] = [
    {
      id: 'budget',
      text: 'What is your maximum purchase budget?',
      options: [
        { label: 'Under $1M',        value: 'budget-low',     tags: ['tingalpa','murarrie','carina','carina-heights','carindale'] },
        { label: '$1M – $1.5M',     value: 'budget-mid',     tags: ['morningside','cannon-hill','coorparoo','greenslopes','mt-gravatt','norman-park'] },
        { label: '$1.5M – $2M',     value: 'budget-high',    tags: ['bulimba','hawthorne','camp-hill','seven-hills','woolloongabba','east-brisbane'] },
        { label: '$2M – $2.5M',     value: 'budget-upper',   tags: ['balmoral','bulimba','hawthorne','seven-hills','kangaroo-point'] },
        { label: '$2.5M – $3M',     value: 'budget-premium', tags: ['balmoral','hawthorne','seven-hills','kangaroo-point'] },
        { label: '$3M+',            value: 'budget-luxury',  tags: ['balmoral','bulimba','hawthorne'] },
      ],
    },
    {
      id: 'lifestyle',
      text: 'Which lifestyle best describes you?',
      options: [
        { label: 'Café & restaurant culture',   value: 'cafe',    tags: ['bulimba','hawthorne','morningside','woolloongabba','east-brisbane'] },
        { label: 'Quiet leafy streets',          value: 'leafy',   tags: ['balmoral','camp-hill','seven-hills','norman-park','holland-park-west'] },
        { label: 'Inner-city energy',            value: 'urban',   tags: ['kangaroo-point','east-brisbane','woolloongabba','brisbane-cbd'] },
        { label: 'Family community & reserves',  value: 'family',  tags: ['seven-hills','cannon-hill','carina','carindale','morningside'] },
      ],
    },
    {
      id: 'commute',
      text: 'How do you prefer to commute?',
      options: [
        { label: 'Ferry to CBD',   value: 'ferry',  tags: ['bulimba','hawthorne','kangaroo-point','east-brisbane'] },
        { label: 'Train / bus',    value: 'train',  tags: ['morningside','coorparoo','greenslopes','woolloongabba','cannon-hill','norman-park'] },
        { label: 'Drive / car',    value: 'car',    tags: ['balmoral','seven-hills','carindale','carina','tingalpa','mt-gravatt'] },
        { label: 'Walk / cycle',   value: 'walk',   tags: ['kangaroo-point','east-brisbane','woolloongabba','brisbane-cbd'] },
      ],
    },
    {
      id: 'type',
      text: 'What property type are you looking for?',
      options: [
        { label: 'Freestanding house',   value: 'house',   tags: ['balmoral','seven-hills','camp-hill','norman-park','carina','morningside'] },
        { label: 'Apartment / unit',     value: 'apt',     tags: ['kangaroo-point','east-brisbane','brisbane-cbd','woolloongabba','greenslopes'] },
        { label: 'Queenslander / character', value: 'qlder', tags: ['bulimba','hawthorne','morningside','norman-park','balmoral'] },
        { label: 'Whatever suits',       value: 'any',     tags: ['bulimba','morningside','coorparoo','cannon-hill','camp-hill','woolloongabba'] },
      ],
    },
    {
      id: 'priority',
      text: 'What is your top priority?',
      options: [
        { label: 'Schools & family amenities',  value: 'schools',  tags: ['balmoral','seven-hills','norman-park','camp-hill','cannon-hill'] },
        { label: 'Capital growth potential',    value: 'growth',   tags: ['woolloongabba','morningside','cannon-hill','murarrie','tingalpa'] },
        { label: 'Rental yield (investment)',   value: 'yield',    tags: ['brisbane-cbd','kangaroo-point','morningside','tingalpa','murarrie'] },
        { label: 'Lifestyle & prestige',        value: 'prestige', tags: ['balmoral','bulimba','hawthorne','seven-hills'] },
      ],
    },
    {
      id: 'character',
      text: 'What architectural style appeals to you?',
      options: [
        { label: 'Modern / contemporary',     value: 'modern',   tags: ['kangaroo-point','east-brisbane','brisbane-cbd','woolloongabba'] },
        { label: 'Classic Queenslander',      value: 'qlder',    tags: ['bulimba','balmoral','hawthorne','morningside','norman-park'] },
        { label: 'Renovated character home',  value: 'reno',     tags: ['norman-park','seven-hills','coorparoo','camp-hill'] },
        { label: 'No preference',             value: 'any',      tags: ['bulimba','morningside','coorparoo','cannon-hill','camp-hill','greenslopes'] },
      ],
    },
    {
      id: 'vibe',
      text: 'Which best describes your lifestyle stage?',
      options: [
        { label: 'Young professionals',      value: 'young',   tags: ['kangaroo-point','east-brisbane','morningside','woolloongabba','greenslopes'] },
        { label: 'Growing family',           value: 'family',  tags: ['balmoral','seven-hills','camp-hill','cannon-hill','carina','morningside'] },
        { label: 'Downsizing / established', value: 'estab',   tags: ['balmoral','bulimba','hawthorne','camp-hill'] },
        { label: 'Investor',                 value: 'invest',  tags: ['woolloongabba','morningside','cannon-hill','murarrie','tingalpa','brisbane-cbd'] },
      ],
    },
    {
      id: 'dealbreaker',
      text: 'What would be a dealbreaker?',
      options: [
        { label: 'Far from the CBD',           value: 'far',     tags: ['bulimba','hawthorne','morningside','east-brisbane','kangaroo-point','coorparoo'] },
        { label: 'Flood risk',                 value: 'flood',   tags: ['balmoral','seven-hills','camp-hill','mt-gravatt','holland-park-west'] },
        { label: 'Poor school catchments',     value: 'schools', tags: ['balmoral','seven-hills','norman-park','camp-hill','cannon-hill'] },
        { label: 'High density / apartments',  value: 'density', tags: ['balmoral','seven-hills','camp-hill','carina','carindale'] },
      ],
    },
  ];

  const SUBURBS: Record<string, { name: string; region: string; desc: string; medianHouse: string; medianUnit: string }> = {
    'bulimba':         { name: 'Bulimba',         region: 'Inner East', desc: 'Oxford Street café culture, ferry access to CBD, and some of Brisbane\'s most loved Queenslander streetscapes.', medianHouse: '$1.75M', medianUnit: '$685K' },
    'balmoral':        { name: 'Balmoral',         region: 'Inner East', desc: 'Brisbane\'s most prestigious inner-east suburb: elevated, leafy, and dominated by blue-chip family homes.', medianHouse: '$1.9M', medianUnit: '$720K' },
    'hawthorne':       { name: 'Hawthorne',        region: 'Inner East', desc: 'Charming village feel, excellent café options, and a strong community culture with great ferry access.', medianHouse: '$1.62M', medianUnit: '$660K' },
    'morningside':     { name: 'Morningside',      region: 'Inner East', desc: 'Brisbane\'s fastest-growing inner-east suburb, popular with young professionals, with a thriving café scene and direct Airport Link access.', medianHouse: '$1.28M', medianUnit: '$620K' },
    'cannon-hill':     { name: 'Cannon Hill',      region: 'Inner East', desc: 'Family-friendly suburb anchored by Cannon Hill Anglican College with consistent above-average price growth.', medianHouse: '$1.15M', medianUnit: '$580K' },
    'east-brisbane':   { name: 'East Brisbane',    region: 'Inner City', desc: 'Just 2km from the CBD, with Mowbray Park, excellent cafés, ferry access, and an outstanding growth trajectory.', medianHouse: '$1.45M', medianUnit: '$650K' },
    'norman-park':     { name: 'Norman Park',      region: 'Inner East', desc: 'Beautiful Queenslander streetscapes, Seven Hills Bushland access, and proximity to elite private schools.', medianHouse: '$1.35M', medianUnit: '$600K' },
    'kangaroo-point':  { name: 'Kangaroo Point',   region: 'Inner City', desc: 'Iconic cliff-top suburb walking distance to the CBD, with Story Bridge walks, restaurants, and stunning river views.', medianHouse: '$1.52M', medianUnit: '$710K' },
    'brisbane-cbd':    { name: 'Brisbane CBD',      region: 'City',       desc: 'The city\'s most urban address, with Olympic transformation underway and some of Australia\'s best investment yields.', medianHouse: 'N/A', medianUnit: '$650K' },
    'seven-hills':     { name: 'Seven Hills',      region: 'Inner East', desc: 'One of Brisbane\'s most tightly held family suburbs, with bushland reserve backing, privacy, and top school access.', medianHouse: '$1.2M', medianUnit: '$560K' },
    'murarrie':        { name: 'Murarrie',          region: 'Inner East', desc: 'Brisbane\'s best-value inner-east suburb, with a strong growth trajectory and improving lifestyle amenity.', medianHouse: '$950K', medianUnit: '$520K' },
    'coorparoo':       { name: 'Coorparoo',         region: 'Inner South', desc: 'Dynamic inner-south suburb anchored by Coorparoo Square with excellent transport and growing café scene.', medianHouse: '$1.32M', medianUnit: '$610K' },
    'camp-hill':       { name: 'Camp Hill',         region: 'Inner South', desc: 'Prestigious leafy suburb with Camp Hill Marketplace, wide streets, and larger-than-average blocks.', medianHouse: '$1.38M', medianUnit: '$630K' },
    'tingalpa':        { name: 'Tingalpa',          region: 'Inner East', desc: 'Best-value family suburb in the inner east, with strong growth, easy highway access, and sub-$1m entry.', medianHouse: '$850K', medianUnit: '$490K' },
    'carina':          { name: 'Carina',            region: 'Inner South East', desc: 'Well-established family suburb with excellent sporting facilities and strong community culture.', medianHouse: '$920K', medianUnit: '$510K' },
    'carina-heights':  { name: 'Carina Heights',    region: 'Inner South East', desc: 'Quiet elevated suburb with nature reserves and exceptional freeway access, and an outstanding growth record.', medianHouse: '$870K', medianUnit: '$480K' },
    'carindale':       { name: 'Carindale',         region: 'Inner South East', desc: 'Anchored by Westfield Carindale with large family blocks, parklands, and excellent private school access.', medianHouse: '$910K', medianUnit: '$500K' },
    'mt-gravatt':      { name: 'Mt Gravatt',        region: 'South Brisbane', desc: 'Major education and transport hub anchored by Griffith University, with strong investment fundamentals and growing amenity.', medianHouse: '$970K', medianUnit: '$530K' },
    'mt-gravatt-east': { name: 'Mt Gravatt East',   region: 'South Brisbane', desc: 'Quieter village feel with a charming local strip, parklands, and excellent value relative to Camp Hill.', medianHouse: '$920K', medianUnit: '$510K' },
    'holland-park-west':{ name: 'Holland Park West', region: 'Inner South', desc: 'Wide leafy streets offering Camp Hill lifestyle at a more accessible entry point, with outstanding growth.', medianHouse: '$980K', medianUnit: '$530K' },
    'greenslopes':     { name: 'Greenslopes',       region: 'Inner South', desc: 'Gateway between inner city and inner south, with a hospital precinct, café strip, and strong Olympic spill-over demand.', medianHouse: '$1.1M', medianUnit: '$560K' },
    'woolloongabba':   { name: 'Woolloongabba',     region: 'Inner South', desc: 'Brisbane\'s most exciting investment story, with 2032 Olympic transformation driving extraordinary growth around The Gabba.', medianHouse: '$1.25M', medianUnit: '$620K' },
  };

  let currentQ = 0;
  const scores: Record<string, number> = {};
  Object.keys(SUBURBS).forEach((s: string) => { scores[s] = 0; });

  function renderQuestion() {
    const q = QUESTIONS[currentQ];
    const container = document.getElementById('quiz-container')!;

    container.innerHTML = `
      <div style="background:var(--color-surface-3);padding:2rem;margin-bottom:1.5rem;">
        <p style="font-family:var(--font-serif);font-size:1.4rem;font-weight:400;color:var(--color-text-primary);margin-bottom:1.5rem;line-height:1.4;">${q.text}</p>
        <div class="flex flex-col gap-3">
          ${q.options.map((opt, i) => `
            <button class="quiz-option" data-index="${i}" data-tags='${JSON.stringify(opt.tags)}'
              style="text-align:left;padding:1rem 1.25rem;background:var(--color-surface-4);border:2px solid transparent;font-size:0.9rem;color:var(--color-text-secondary);cursor:pointer;transition:all 0.2s;width:100%;">
              ${opt.label}
            </button>
          `).join('')}
        </div>
      </div>
    `;

    container.querySelectorAll('.quiz-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const tags: string[] = JSON.parse((btn as HTMLElement).dataset.tags || '[]');
        tags.forEach(tag => { if (scores[tag] !== undefined) scores[tag] += 1; });
        nextQuestion();
      });
    });

    updateProgress();
  }

  function updateProgress() {
    const pct = Math.round((currentQ / QUESTIONS.length) * 100);
    document.getElementById('progress-bar')!.style.width = `${pct}%`;
    document.getElementById('progress-label')!.textContent = `Question ${currentQ + 1} of ${QUESTIONS.length}`;
    document.getElementById('progress-pct')!.textContent = `${pct}%`;
  }

  function nextQuestion() {
    currentQ++;
    if (currentQ >= QUESTIONS.length) {
      showResults();
    } else {
      renderQuestion();
    }
  }

  function showResults() {
    document.getElementById('quiz-container')!.innerHTML = '';
    document.getElementById('progress-bar')!.style.width = '100%';
    document.getElementById('progress-label')!.textContent = 'Complete';
    document.getElementById('progress-pct')!.textContent = '100%';
    document.getElementById('results')!.style.display = 'block';

    const sorted = Object.entries(scores)
      .sort(([, a], [, b]) => b - a)
      .slice(0, 3);

    const medals = ['#ffdd79', '#c8c6c8', '#cd7f32'];

    document.getElementById('results-grid')!.innerHTML = sorted.map(([slug, score], i) => {
      const s = SUBURBS[slug];
      const maxScore = sorted[0][1];
      const pct = maxScore > 0 ? Math.round((score / maxScore) * 100) : 0;
      return `
        <div style="background:var(--color-surface-3);padding:2rem;border-left:4px solid ${medals[i]};">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;margin-bottom:0.75rem;">
            <div>
              <p style="font-size:0.55rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:${medals[i]};margin-bottom:0.3rem;">${['Best Match', 'Strong Match', 'Good Match'][i]}</p>
              <h3 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;color:var(--color-text-primary);">${s.name}</h3>
              <p style="font-size:0.7rem;color:var(--color-text-muted);">${s.region}</p>
            </div>
            <div style="text-align:right;">
              <p style="font-family:var(--font-serif);font-size:1.8rem;color:${medals[i]};">${pct}%</p>
              <p style="font-size:0.6rem;color:var(--color-text-muted);">match</p>
            </div>
          </div>
          <p style="font-size:0.82rem;color:var(--color-text-secondary);line-height:1.7;margin-bottom:1rem;">${s.desc}</p>
          <div style="display:flex;gap:2rem;">
            <div>
              <p style="font-size:0.6rem;color:var(--color-text-muted);margin-bottom:0.2rem;">Median House</p>
              <p style="font-size:0.9rem;font-weight:700;color:var(--color-text-primary);">${s.medianHouse}</p>
            </div>
            <div>
              <p style="font-size:0.6rem;color:var(--color-text-muted);margin-bottom:0.2rem;">Median Unit</p>
              <p style="font-size:0.9rem;font-weight:700;color:var(--color-text-primary);">${s.medianUnit}</p>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  document.getElementById('restart-btn')?.addEventListener('click', () => {
    currentQ = 0;
    Object.keys(scores).forEach(k => scores[k] = 0);
    document.getElementById('results')!.style.display = 'none';
    renderQuestion();
  });

  renderQuestion();
</script>
