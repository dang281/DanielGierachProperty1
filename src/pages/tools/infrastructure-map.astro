<script>
(function () {
  // ── Data sources ──────────────────────────────────────────────────────────
  const SVC = {
    // BCC Cadastre (rendered first — sits under all infrastructure lines)
    propertyBoundary: 'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/property_boundaries_parcel/FeatureServer/0',
    // BCC Stormwater
    stormPipe:    'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Stormwater_Pipe_Existing/FeatureServer/0',
    stormManhole: 'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Stormwater_Manhole_Existing/FeatureServer/0',
    gully:        'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Stormwater_Gully_Existing/FeatureServer/0',
    surfaceDrain: 'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Stormwater_Surface_Drain_Existing/FeatureServer/0',
    // QUU Water & Sewer
    sewerMain:    'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Sewer_OpenData/FeatureServer/18',
    sewerService: 'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Sewer_OpenData/FeatureServer/30',
    waterMain:    'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Water_OpenData/FeatureServer/21',
    waterService: 'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Water_OpenData/FeatureServer/28',
    sewerManhole: 'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Sewer_OpenData/FeatureServer/20',
    hydrant:      'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Water_OpenData/FeatureServer/15',
    // BCC Flood overlays (City Plan 2014)
    floodOverland: 'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Flood_overlay_Overland_flow/FeatureServer/0',
  };

  const IS_POLYGON = new Set(['propertyBoundary', 'floodOverland']);

  const FLOOD_KEYS = new Set(['floodOverland']);

  const FLOOD_COLORS: Record<string,{fill:string;stroke:string;fillOpacity:number}> = {
    FHA_OFP: { fill:'#0090c0', stroke:'#00b4e4', fillOpacity:0.22 },
  };

  const STYLE: Record<string,any> = {
    propertyBoundary: { color: '#9e8c6a', weight: 1.2, opacity: 0.5, fillColor: '#c4912a', fillOpacity: 0.04 },
    stormPipe:    { color: '#2a8c9c', weight: 2.4, opacity: 0.9 },
    stormManhole: { radius: 4,   fillColor: '#1f6f7d', color: '#fff', weight: 1.5, fillOpacity: 0.95 },
    gully:        { radius: 3.5, fillColor: '#d77b32', color: '#fff', weight: 1.3, fillOpacity: 0.95 },
    surfaceDrain: { color: '#4dadb8', weight: 2, opacity: 0.9, dashArray: '5 4' },
    sewerMain:    { color: '#8a6e2f', weight: 2.6, opacity: 0.9 },
    sewerService: { color: '#b8904a', weight: 1.4, opacity: 0.75 },
    waterMain:    { color: '#2c7fc4', weight: 2.2, opacity: 0.9 },
    waterService: { color: '#6fb5e0', weight: 1.4, opacity: 0.75 },
    sewerManhole: { radius: 4,   fillColor: '#6c5320', color: '#fff', weight: 1.5, fillOpacity: 0.95 },
    hydrant:      { radius: 4,   fillColor: '#c43a3a', color: '#fff', weight: 1.5, fillOpacity: 0.95 },
    floodOverland: { color: '#00b4e4', weight: 0.8, opacity: 0.7, fillColor: '#0090c0', fillOpacity: 0.18, dashArray: '4 3' },
  };

  const IS_POINT = new Set(['stormManhole','gully','sewerManhole','hydrant']);

  const OUT_FIELDS: Record<string,string> = {
    propertyBoundary: 'OBJECTID,LOTPLAN,LOT,PLAN_,HOUSE_NUMBER,CORRIDOR_NAME,SUBURB,LOT_AREA,TENURE_DESC,PARCEL_TYP_DESC',
    stormPipe:    'OBJECTID,ASSETID,PIPETYPE,DIAMETER,WIDTH,USIL,DSIL,UPSTREAMDEPTHINVERT,DOWNSTREAMDEPTHINVERT,AVERAGEDEPTH,MEASUREDLENGTH,OWNER,STATUS',
    stormManhole: 'OBJECTID,ASSETID,MANHOLETYPE,DIAMETER,LENGTH,WIDTH,SL,IL,OWNER,STATUS',
    gully:        'OBJECTID,ASSETID,INLETTYPE,OUTLETTYPE,DIAMETER,LENGTH,WIDTH,SL,OWNER,STATUS',
    surfaceDrain: 'OBJECTID,ASSETID,SURFACEDRAINTYPE,AVERAGEBASE,LOWFLOW,USSL,USIL,OWNER,STATUS',
    sewerMain:    'OBJECTID,ASSETID,MATERIAL,DIAMETER,SEGMENTTYPE,GRADE,USIL,DSIL,STATUS,OWNER',
    sewerService: 'OBJECTID,ASSETID,DIAMETER,OWNER',
    waterMain:    'OBJECTID,ASSETID,MATERIAL,DIAMETER,WATERTYPE,SUBTYPECD,OWNER',
    waterService: 'OBJECTID,ASSETID,DIAMETER,SERVICETYPE,WATERTYPE,OWNER',
    sewerManhole: 'OBJECTID,ASSETID,MANHOLEUSE,SL,IL,DEPTH,OWNER',
    hydrant:      'OBJECTID,ASSETID,HYDRANTTYPE,WATERTYPE,OWNER',
    floodOverland: 'OBJECTID,OVL2_DESC,OVL2_CAT',
  };

  const TITLES: Record<string,string> = {
    propertyBoundary: 'Property parcel',
    stormPipe:    'Stormwater pipe',
    stormManhole: 'Stormwater manhole',
    gully:        'Gully / kerb inlet',
    surfaceDrain: 'Surface drain',
    sewerMain:    'Sewer main',
    sewerService: 'Sewer connection',
    waterMain:    'Water main',
    waterService: 'Water connection',
    sewerManhole: 'Sewer manhole',
    hydrant:      'Hydrant',
    floodOverland: 'Overland flow flood area',
  };

  const NOTES: Record<string,string> = {
    propertyBoundary: 'Cadastral parcel boundaries from BCC open data. These are the legal lot boundaries, not necessarily fence lines. Cross-reference with a survey or title search before relying on any boundary for construction or fencing decisions.',
    stormPipe:    'Where a council stormwater pipe runs through private land, an easement is usually registered. The easement footprint is wider than the pipe and limits what can be built above it.',
    stormManhole: 'Manholes mark stormwater alignment and access. They are usually located at pipe junctions, bends, or changes of grade.',
    gully:        'Gullies and kerb inlets are where surface water enters the underground network. Their location influences how stormwater flows on and off the property in heavy rain.',
    surfaceDrain: 'Surface drains are the visible part of the stormwater network. They define the path of overland flow during heavy rain.',
    sewerMain:    'Sewer mains carry sewer easements over private land. The easement footprint is wider than the pipe (typically 3 m total). Council and QUU restrict what can be built within the easement.',
    sewerService: 'The sewer service connection runs from the property boundary to the gravity main in the road. Its location determines where the sanitary drain exits the property.',
    waterMain:    'Water mains run beneath the road or footpath in most cases. Connection to the property is via a service line at the kerb.',
    waterService: 'The water service connection runs from the water main to the property meter at the boundary. Diameter indicates the service capacity available to the property.',
    sewerManhole: 'Manholes mark sewer access points. They indicate the sewer alignment and depth at this location.',
    hydrant:      'Hydrants are spaced for fire-fighting access. Their presence is a code requirement, not a property feature.',
    floodOverland: 'This property is within the overland flow flood planning area. Surface water flows across the land during major rainfall. Development must maintain overland flow paths and may require drainage design.',
  };

  const INTERPRETATIONS: Record<string,string> = {
    propertyBoundary: 'Lot size and shape confirmed from BCC cadastral data. Verify with a registered survey before relying on any boundary for fencing, building setbacks, or pool placement.',
    stormPipe:    'This pipe likely carries a council drainage easement. The restricted corridor is typically 1.5 m either side of the pipe centreline. No permanent structures or pools are permitted within that zone without council approval.',
    stormManhole: 'Manholes mark the stormwater pipe alignment. Any new structure near this point should allow the required clearance from the underground pipe.',
    gully:        'Kerb inlets capture runoff from the road and footpath. Their position shows how overland flow is designed to drain during heavy rain.',
    surfaceDrain: 'This drain defines the overland flow path. Low-lying land adjacent to a surface drain can flood when rainfall exceeds its capacity.',
    sewerMain:    'QUU gravity sewer mains carry an easement, typically 1.5 m either side of the centreline (3 m total). No permanent structures, pools, or large trees are permitted within the easement without QUU written approval.',
    sewerService: 'The individual property sewer connection from the boundary to the gravity main in the road. Its location and depth determine where the drainage plumbing exits the building.',
    waterMain:    'The reticulated water supply main, typically beneath the road or footpath. The service connection to the property meter branches off from this main.',
    waterService: 'The water supply line from the main to the property meter at the boundary. Diameter indicates the flow capacity available to this property.',
    sewerManhole: 'Manholes indicate the sewer pipe alignment. Their presence near a boundary can signal an easement constraint on what can be built in that area.',
    hydrant:      'Hydrant placement is a building code requirement for fire-fighting access. It does not typically restrict development or affect property value directly.',
    floodOverland: 'Overland flow flood planning area. Surface water flows across this land during major rainfall. Development must preserve overland flow paths.',
  };

  const BNE_BOUNDS = [[-27.85, 152.66], [-27.07, 153.55]];

  const active: Record<string,boolean> = {
    propertyBoundary: true,
    stormPipe: true, stormManhole: false, gully: true, surfaceDrain: false,
    sewerMain: true, sewerService: true, waterMain: true, waterService: true,
    sewerManhole: false, hydrant: false,
    floodOverland: false,
  };

  let map: any, layers: Record<string,any> = {}, pinMarker: any;
  let fetchAborts: Record<string,AbortController> = {}, acDebounce: any, canvasRenderer: any;

  function initMap() {
    map = L.map('im-map', {
      maxBounds: BNE_BOUNDS, minZoom: 11, maxBoundsViscosity: 0.5,
      tap: false,
    }).setView([-27.46, 153.04], 13);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap contributors &copy; CARTO &middot; BCC &amp; QUU open data',
      subdomains: 'abcd', maxZoom: 19,
    }).addTo(map);

    canvasRenderer = L.canvas({ padding: 0.2 });
    Object.keys(SVC).forEach(k => {
      layers[k] = L.layerGroup();
      if (active[k]) layers[k].addTo(map);
    });

    // Restore shared view from URL params (?lat=&lng=&z=)
    const sp = new URLSearchParams(location.search);
    const pLat = sp.get('lat'), pLng = sp.get('lng'), pZ = sp.get('z');
    if (pLat && pLng) {
      map.setView([parseFloat(pLat), parseFloat(pLng)], pZ ? parseInt(pZ) : 17);
      dismissGuide();
    }

    map.on('moveend', loadVisible);
    map.on('click', (e: any) => identifyAt(e.latlng.lat, e.latlng.lng));
    wireUpControls();
    loadVisible();
  }

  function loadOne(key: string) {
    if (!active[key]) { layers[key].clearLayers(); return; }
    if (map.getZoom() < 14) { layers[key].clearLayers(); return; }
    if (fetchAborts[key]) fetchAborts[key].abort();
    fetchAborts[key] = new AbortController();

    const b = map.getBounds();
    const sw = b.getSouthWest(), ne = b.getNorthEast();
    const params = new URLSearchParams({
      geometry: `${sw.lng},${sw.lat},${ne.lng},${ne.lat}`,
      geometryType: 'esriGeometryEnvelope',
      inSR: '4326', outSR: '4326',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: OUT_FIELDS[key],
      returnGeometry: 'true',
      resultRecordCount: '4000',
      f: 'geojson',
    });

    fetch(`${SVC[key]}/query?${params}`, { signal: fetchAborts[key].signal })
      .then(r => r.json())
      .then(geo => {
        layers[key].clearLayers();
        const pt = IS_POINT.has(key);
        const isFlood = FLOOD_KEYS.has(key);
        const styleFn = pt ? null : (f: any) => {
          if (!isFlood) return STYLE[key];
          const cat = f?.properties?.OVL2_CAT || '';
          const fc = FLOOD_COLORS[cat];
          if (!fc) return STYLE[key];
          const base = STYLE[key];
          return { ...base, color: fc.stroke, fillColor: fc.fill, fillOpacity: fc.fillOpacity };
        };
        L.geoJSON(geo, {
          renderer: canvasRenderer,
          style: styleFn,
          pointToLayer: pt ? (f: any, latlng: any) => L.circleMarker(latlng, { ...STYLE[key], renderer: canvasRenderer }) : undefined,
          onEachFeature(f: any, layer: any) {
            layer.on('click', (e: any) => {
              L.DomEvent.stopPropagation(e);
              showResult(key, f.properties || {});
            });
          },
        }).addTo(layers[key]);
      })
      .catch((err: any) => {
        if (err.name === 'AbortError') return;
        const s = document.getElementById('im-status');
        if (s) s.textContent = 'Some layers could not load. Try refreshing.';
      });
  }

  function dismissGuide() {
    document.getElementById('im-guide')?.classList.add('hidden');
  }

  function loadVisible() {
    const s = document.getElementById('im-status')!;
    const z = map.getZoom();
    if (z < 14) {
      Object.keys(layers).forEach(k => layers[k].clearLayers());
      s.textContent = 'Zoom in to load infrastructure (level 14+).';
      return;
    }
    dismissGuide();
    s.textContent = 'Loading assets...';
    Object.keys(SVC).forEach(loadOne);
    setTimeout(() => { if (map.getZoom() >= 14) s.textContent = 'Assets loaded. Click any pipe or feature.'; }, 700);
  }

  function identifyAt(lat: number, lon: number) {
    const s = document.getElementById('im-status')!;
    s.textContent = 'Identifying...';
    const tasks = Object.keys(SVC).filter(k => active[k]).map(k =>
      fetchNearest(k, lat, lon).then((f: any) => f && { key: k, feature: f })
    );
    Promise.all(tasks).then((results: any[]) => {
      const hits = results.filter(Boolean);
      if (!hits.length) { s.textContent = 'No asset within 30 m. Try clicking on the road.'; return; }
      hits.sort((a, b) => a.feature._dist - b.feature._dist);
      showResult(hits[0].key, hits[0].feature.attributes);
      s.textContent = 'Asset identified.';
    });
  }

  function fetchNearest(key: string, lat: number, lon: number) {
    const params = new URLSearchParams({
      geometry: JSON.stringify({ x: lon, y: lat, spatialReference: { wkid: 4326 } }),
      geometryType: 'esriGeometryPoint',
      inSR: '4326', outSR: '4326',
      distance: '30', units: 'esriSRUnit_Meter',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: OUT_FIELDS[key],
      returnGeometry: 'true', f: 'json',
      resultRecordCount: '5',
    });
    return fetch(`${SVC[key]}/query?${params}`)
      .then(r => r.json())
      .then((d: any) => {
        const feats = d.features || [];
        if (!feats.length) return null;
        let best = feats[0]; best._dist = featDist(best, lat, lon);
        for (const f of feats.slice(1)) {
          const dd = featDist(f, lat, lon);
          if (dd < best._dist) { best = f; best._dist = dd; }
        }
        return best;
      })
      .catch(() => null);
  }

  function featDist(f: any, lat: number, lon: number) {
    const g = f.geometry || {};
    if (g.x != null && g.y != null) return distSq(g.y, g.x, lat, lon);
    if (Array.isArray(g.paths) && g.paths.length) {
      let min = Infinity;
      for (const path of g.paths) for (const [x, y] of path) { const d = distSq(y, x, lat, lon); if (d < min) min = d; }
      return min;
    }
    return Infinity;
  }
  function distSq(lat1: number, lon1: number, lat2: number, lon2: number) {
    const dy = (lat1 - lat2) * 111320;
    const dx = (lon1 - lon2) * 111320 * Math.cos((lat1 + lat2) / 2 * Math.PI / 180);
    return dx * dx + dy * dy;
  }

  function showResult(key: string, attrs: Record<string,any>) {
    const el = document.getElementById('im-result')!;
    el.className = `kind-${key}`;
    el.classList.add('open');
    document.getElementById('im-result-eyebrow')!.textContent = TITLES[key] || key;
    document.getElementById('im-result-title')!.textContent = headlineFor(key, attrs);
    document.getElementById('im-result-interp')!.textContent = INTERPRETATIONS[key] || '';

    const rows = renderAttrs(key, attrs);
    document.getElementById('im-result-attrs')!.innerHTML =
      rows.map(([k, v]: [string,string]) => `<dt>${k}</dt><dd>${esc(v)}</dd>`).join('');

    // Close layer panel if open so the result drawer isn't obscured
    const panel = document.getElementById('im-layer-panel');
    const toggle = document.getElementById('im-layer-toggle');
    if (panel?.classList.contains('open')) {
      panel.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  }

  function headlineFor(key: string, a: Record<string,any>) {
    const num = (v: any) => (v == null || v === '') ? null : v;
    if (key === 'propertyBoundary') {
      const addr = [a.HOUSE_NUMBER, a.CORRIDOR_NAME].filter(Boolean).join(' ');
      return addr || a.LOTPLAN || TITLES[key];
    }
    if (key === 'stormPipe') {
      const dia = num(a.DIAMETER) ? `DN${a.DIAMETER}` : '';
      return [dia, a.PIPETYPE].filter(Boolean).join(' · ') || TITLES[key];
    }
    if (key === 'sewerService') {
      return a.DIAMETER ? `DN${a.DIAMETER} sewer connection` : TITLES[key];
    }
    if (key === 'waterService') {
      return a.SERVICETYPE ? `${a.SERVICETYPE} water connection${a.DIAMETER ? ` DN${a.DIAMETER}` : ''}` : (a.DIAMETER ? `DN${a.DIAMETER} water connection` : TITLES[key]);
    }
    if (key === 'sewerMain' || key === 'waterMain') {
      const dia = num(a.DIAMETER) ? `DN${a.DIAMETER}` : '';
      return [dia, a.MATERIAL].filter(Boolean).join(' · ') || TITLES[key];
    }
    if (key === 'sewerManhole') {
      const depth = num(a.DEPTH) ? `${(+a.DEPTH).toFixed(1)} m deep` : '';
      return [a.MANHOLEUSE, depth].filter(Boolean).join(' · ') || TITLES[key];
    }
    if (key === 'stormManhole') {
      return a.MANHOLETYPE || TITLES[key];
    }
    if (key === 'gully') {
      return a.INLETTYPE || TITLES[key];
    }
    if (key === 'hydrant') return a.HYDRANTTYPE || TITLES[key];
    if (key === 'surfaceDrain') return a.SURFACEDRAINTYPE || TITLES[key];
    if (FLOOD_KEYS.has(key)) return a.OVL2_DESC || TITLES[key];
    return TITLES[key] || 'Asset';
  }

  function renderAttrs(key: string, a: Record<string,any>): [string,string][] {
    const rows: [string,string][] = [];
    const push = (k: string, v: any) => { if (v != null && v !== '') rows.push([k, String(v)]); };
    if (key === 'propertyBoundary') {
      push('Lot/Plan', a.LOTPLAN);
      const addr = [a.HOUSE_NUMBER, a.CORRIDOR_NAME].filter(Boolean).join(' ');
      if (addr) push('Address', addr);
      push('Suburb', a.SUBURB);
      push('Area', a.LOT_AREA ? `${(+a.LOT_AREA).toFixed(0)} m²` : null);
      push('Tenure', a.TENURE_DESC);
      push('Type', a.PARCEL_TYP_DESC);
    } else if (key === 'stormPipe') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Type', a.PIPETYPE);
      push('Length', a.MEASUREDLENGTH ? `${(+a.MEASUREDLENGTH).toFixed(1)} m` : null);
      push('Avg depth', a.AVERAGEDEPTH ? `${(+a.AVERAGEDEPTH).toFixed(2)} m` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'stormManhole') {
      push('Type', a.MANHOLETYPE);
      push('Surface level', a.SL != null ? `${(+a.SL).toFixed(2)} mAHD` : null);
      push('Invert level', a.IL != null ? `${(+a.IL).toFixed(2)} mAHD` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'gully') {
      push('Inlet type', a.INLETTYPE); push('Outlet type', a.OUTLETTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'surfaceDrain') {
      push('Type', a.SURFACEDRAINTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'sewerService') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'waterService') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Type', a.SERVICETYPE); push('Water type', a.WATERTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'sewerMain') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Material', a.MATERIAL); push('Type', a.SEGMENTTYPE);
      push('Grade', a.GRADE != null ? `${a.GRADE}` : null);
      push('US invert', a.USIL != null ? `${(+a.USIL).toFixed(2)} mAHD` : null);
      push('DS invert', a.DSIL != null ? `${(+a.DSIL).toFixed(2)} mAHD` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'waterMain') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Material', a.MATERIAL); push('Water type', a.WATERTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'sewerManhole') {
      push('Use', a.MANHOLEUSE);
      push('Surface level', a.SL != null ? `${(+a.SL).toFixed(2)} mAHD` : null);
      push('Invert level', a.IL != null ? `${(+a.IL).toFixed(2)} mAHD` : null);
      push('Depth', a.DEPTH != null ? `${(+a.DEPTH).toFixed(2)} m` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'hydrant') {
      push('Type', a.HYDRANTTYPE); push('Water type', a.WATERTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (FLOOD_KEYS.has(key)) {
      push('Area', a.OVL2_DESC);
      push('Category', a.OVL2_CAT);
    }
    return rows;
  }

  function esc(s: string) {
    return String(s).replace(/[&<>"']/g, (c: string) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c] || c);
  }

  // ── Address search ────────────────────────────────────────────────────────
  async function geocode(addr: string) {
    const u = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(addr + ', Brisbane, Australia')}&format=json&limit=1&countrycodes=au`;
    const data = await fetch(u, { headers: { 'Accept-Language': 'en' } }).then(r => r.json());
    if (!data.length) throw new Error('not found');
    return { lat: parseFloat(data[0].lat), lon: parseFloat(data[0].lon) };
  }

  function suggestions(q: string) {
    return fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(q)}&limit=5&lang=en&bbox=152.6,-27.8,153.5,-27.1`)
      .then(r => r.json()).then((d: any) => d.features || []);
  }

  function renderSuggestions(features: any[]) {
    const list = document.getElementById('im-autocomplete')!;
    list.innerHTML = '';
    if (!features.length) { list.style.display = 'none'; return; }
    features.forEach(f => {
      const p = f.properties;
      const streetPart = p.housenumber && p.street ? `${p.housenumber} ${p.street}` : (p.street || p.name || '');
      const granular = p.suburb || p.locality || p.district || p.neighbourhood || p.county;
      const locality = granular || (p.city && p.city !== 'Brisbane' ? p.city : (p.postcode ? `Brisbane ${p.postcode}` : (p.city || '')));
      const label = [streetPart, locality].filter(Boolean).join(', ');
      const item = document.createElement('div');
      item.className = 'im-ac-item'; item.textContent = label;
      item.addEventListener('mousedown', () => {
        const lat = f.geometry.coordinates[1], lon = f.geometry.coordinates[0];
        (document.getElementById('im-search') as HTMLInputElement).value = label;
        list.style.display = 'none';
        flyAndIdentify(lat, lon);
      });
      list.appendChild(item);
    });
    list.style.display = 'block';
  }

  function dropPin(lat: number, lon: number) {
    if (pinMarker) map.removeLayer(pinMarker);
    pinMarker = L.marker([lat, lon], {
      icon: L.divIcon({
        className: '',
        html: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="36" viewBox="0 0 28 36"><path d="M14 0C6.27 0 0 6.27 0 14c0 9.63 14 22 14 22S28 23.63 28 14C28 6.27 21.73 0 14 0zm0 20a6 6 0 1 1 0-12 6 6 0 0 1 0 12z" fill="#c5a03c" stroke="#fff" stroke-width="1.5"/></svg>`,
        iconSize: [28, 36], iconAnchor: [14, 36],
      }),
    }).addTo(map);
  }

  function flyAndIdentify(lat: number, lon: number) {
    dropPin(lat, lon);
    map.setView([lat, lon], 18);
    setTimeout(() => identifyAt(lat, lon), 800);
  }

  async function doSearch() {
    const v = (document.getElementById('im-search') as HTMLInputElement).value.trim();
    if (!v) return;
    const s = document.getElementById('im-status')!;
    const btn = document.getElementById('im-search-btn') as HTMLButtonElement;
    s.textContent = 'Locating address...';
    btn.disabled = true;
    dismissGuide();
    document.getElementById('im-autocomplete')!.style.display = 'none';
    try {
      const { lat, lon } = await geocode(v);
      flyAndIdentify(lat, lon);
    } catch {
      s.textContent = 'Address not found. Add the suburb (e.g. 12 Main St, Camp Hill).';
    }
    btn.disabled = false;
  }

  function wireUpControls() {
    const search = document.getElementById('im-search') as HTMLInputElement;
    document.getElementById('im-search-btn')!.addEventListener('click', doSearch);
    search.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
      if (e.key === 'Escape') document.getElementById('im-autocomplete')!.style.display = 'none';
    });
    search.addEventListener('input', () => {
      clearTimeout(acDebounce);
      const q = search.value.trim();
      if (q.length < 3) { document.getElementById('im-autocomplete')!.style.display = 'none'; return; }
      acDebounce = setTimeout(() => suggestions(q).then(renderSuggestions), 130);
    });
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target as Element).closest('#im-search-wrap'))
        document.getElementById('im-autocomplete')!.style.display = 'none';
    });

    document.getElementById('im-guide-dismiss')?.addEventListener('click', dismissGuide);

    const toggle = document.getElementById('im-layer-toggle')!;
    const panel  = document.getElementById('im-layer-panel')!;
    toggle.addEventListener('click', () => {
      const open = panel.classList.toggle('open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    panel.querySelectorAll<HTMLInputElement>('input[data-layer]').forEach(cb => {
      cb.addEventListener('change', () => {
        const k = cb.dataset.layer!;
        active[k] = cb.checked;
        if (active[k]) { layers[k].addTo(map); loadOne(k); }
        else map.removeLayer(layers[k]);
      });
    });

    document.getElementById('im-result-close')!.addEventListener('click', () => {
      document.getElementById('im-result')!.classList.remove('open');
    });

    // GPS / My Location button
    const gpsBtn = document.getElementById('im-gps-btn') as HTMLButtonElement | null;
    if (gpsBtn) {
      gpsBtn.addEventListener('click', () => {
        if (!navigator.geolocation) {
          document.getElementById('im-status')!.textContent = 'Geolocation not supported by your browser.';
          return;
        }
        document.getElementById('im-status')!.textContent = 'Getting your location...';
        gpsBtn.disabled = true;
        gpsBtn.classList.add('locating');
        navigator.geolocation.getCurrentPosition(
          pos => {
            gpsBtn.disabled = false;
            gpsBtn.classList.remove('locating');
            dismissGuide();
            flyAndIdentify(pos.coords.latitude, pos.coords.longitude);
          },
          () => {
            gpsBtn.disabled = false;
            gpsBtn.classList.remove('locating');
            document.getElementById('im-status')!.textContent = 'Location access denied. Try searching by address.';
          },
          { timeout: 10000 }
        );
      });
    }

    // Share / copy map link button
    const shareBtn = document.getElementById('im-share-btn') as HTMLButtonElement | null;
    if (shareBtn) {
      shareBtn.addEventListener('click', () => {
        const c = map.getCenter();
        const z = map.getZoom();
        const url = `${location.origin}${location.pathname}?lat=${c.lat.toFixed(5)}&lng=${c.lng.toFixed(5)}&z=${z}`;
        const reset = () => { shareBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg> Copy map link'; shareBtn.classList.remove('copied'); };
        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(() => {
            shareBtn.textContent = 'Copied!';
            shareBtn.classList.add('copied');
            setTimeout(reset, 2200);
          }).catch(() => { prompt('Copy this link:', url); });
        } else {
          prompt('Copy this link:', url);
        }
      });
    }

    // Prevent the browser from zooming the page when the user pinches the map.
    // On iOS Safari, even with touch-action:none on the element, a pinch gesture
    // can still trigger viewport zoom unless we temporarily lock maximum-scale.
    const metaVp = document.querySelector('meta[name="viewport"]') as HTMLMetaElement | null;
    const mapEl = document.getElementById('im-map');
    if (metaVp && mapEl) {
      const lockZoom  = () => { metaVp.content = 'width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no'; };
      const unlockZoom = () => { metaVp.content = 'width=device-width, initial-scale=1'; };
      mapEl.addEventListener('touchstart',  lockZoom,   { passive: true });
      mapEl.addEventListener('touchend',    unlockZoom, { passive: true });
      mapEl.addEventListener('touchcancel', unlockZoom, { passive: true });
    }

    const status = document.getElementById('im-status')!;
    let fadeTimer: any;
    new MutationObserver(() => {
      clearTimeout(fadeTimer);
      status.style.opacity = '1';
      if (/loaded|identified/i.test(status.textContent || ''))
        fadeTimer = setTimeout(() => { status.style.opacity = '0'; }, 1800);
    }).observe(status, { childList: true, characterData: true, subtree: true });
  }

  function whenLeafletReady() {
    if ((window as any).L) initMap();
    else requestAnimationFrame(whenLeafletReady);
  }
  whenLeafletReady();
})();
</script>

