        <label class="im-layer-row">
          <input type="checkbox" data-layer="waterService" checked />
          <span class="im-swatch"><span class="im-swatch-line" style="background:#6fb5e0;opacity:0.7;"></span></span>
          <span class="im-layer-name">Water connections
            <span class="im-layer-hint">Individual property water service lines</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="sewerManhole" />
          <span class="im-swatch"><span class="im-swatch-dot" style="background:#6c5320;"></span></span>
