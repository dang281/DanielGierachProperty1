        <p class="im-layer-group-head" style="margin-top:0.4rem;border-top:1px solid rgba(28,25,23,0.07);padding-top:0.7rem;">Stormwater (BCC)</p>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="stormPipe" checked />
          <span class="im-swatch"><span class="im-swatch-line" style="background:#2a8c9c;"></span></span>
