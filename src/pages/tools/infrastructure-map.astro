---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Brisbane Infrastructure Map"
  tool="Infrastructure Map"
  phase="Buyer Tools"
  description="See stormwater pipes, sewer mains and water mains overlaid on one map for any Brisbane address. Useful for understanding easements, drainage paths and infrastructure constraints before buying or developing."
>

<style>
  .im-shell { max-width: 1400px; margin: 0 auto; padding: 1.25rem 1rem 3rem; }
  @media (min-width: 1024px) { .im-shell { padding: 1.5rem 2rem 4rem; } }

  .im-eduline {
    margin-bottom: 0.6rem;
    padding: 0.5rem 0.85rem;
    background: rgba(196,145,42,0.07);
    border-left: 3px solid var(--color-gold);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }
  .im-eduline strong {
    font-weight: 800; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--color-gold);
    font-size: 0.62rem; margin-right: 0.4rem;
  }

  .im-search-bar { display: flex; gap: 0.4rem; margin-bottom: 0.85rem; }
  #im-search-wrap { position: relative; flex: 1; }
  #im-search {
    width: 100%;
    font-family: var(--font-sans); font-size: 0.95rem;
    padding: 0.95rem 1.1rem;
    border: 1px solid rgba(28,25,23,0.18);
    background: var(--color-surface-4);
    color: var(--color-text-primary);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  #im-search:focus {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(196,145,42,0.15);
  }
  #im-search::placeholder { color: var(--color-text-muted); }
  #im-search-btn {
    padding: 0 1.5rem;
    background: var(--color-gold); color: #0a0806;
    font-family: var(--font-sans); font-size: 0.7rem; font-weight: 800;
    letter-spacing: 0.1em; text-transform: uppercase;
    border: none; cursor: pointer; white-space: nowrap;
    transition: background 0.2s;
  }
  #im-search-btn:hover { background: #d4af4a; }
  #im-search-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  #im-autocomplete {
    position: absolute; top: 100%; left: 0; right: 0;
    background: var(--color-surface-4);
    border: 1px solid rgba(28,25,23,0.18); border-top: none;
    z-index: 1100; max-height: 240px; overflow-y: auto;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  .im-ac-item {
    padding: 0.65rem 1rem; font-size: 0.85rem;
    color: var(--color-text-primary); cursor: pointer;
    border-bottom: 1px solid rgba(28,25,23,0.06); line-height: 1.4;
  }
  .im-ac-item:last-child { border-bottom: none; }
  .im-ac-item:hover { background: rgba(197,160,60,0.08); }

  .im-map-wrap { position: relative; }
  #im-map { height: 700px; width: 100%; border: 1px solid rgba(28,25,23,0.1); }
  @media (max-width: 768px) { #im-map { height: 540px; } }

  .im-control {
    position: absolute; z-index: 500;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(28,25,23,0.1);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }
  .im-control-tr { top: 12px; right: 12px; }

  #im-status {
    position: absolute; top: 12px; left: 12px; z-index: 500;
    background: rgba(255,255,255,0.94);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(28,25,23,0.08);
    padding: 0.45rem 0.85rem;
    font-size: 0.72rem; color: var(--color-text-secondary);
    line-height: 1.4; max-width: 280px;
    pointer-events: none; transition: opacity 0.3s;
  }
  @media (max-width: 768px) {
    #im-status { left: 12px; right: 150px; max-width: none; font-size: 0.66rem; padding: 0.4rem 0.65rem; }
  }

  .im-layer-toggle {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.55rem 0.85rem;
    background: transparent; border: none; cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--color-text-primary);
  }
  .im-layer-toggle:hover { background: rgba(197,160,60,0.08); }
  .im-layer-toggle .toggle-arrow { transition: transform 0.2s; opacity: 0.5; }
  .im-layer-toggle[aria-expanded="true"] .toggle-arrow { transform: rotate(180deg); }

  .im-layer-panel {
    display: none; border-top: 1px solid rgba(28,25,23,0.08);
    width: 300px; padding: 0.4rem 0.5rem 0.7rem;
  }
  .im-layer-panel.open { display: block; }
  @media (max-width: 480px) { .im-layer-panel { width: 250px; } }

  .im-layer-group-head {
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 800; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--color-text-muted);
    padding: 0.55rem 0.6rem 0.25rem;
  }

  .im-layer-row {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.45rem 0.6rem;
    cursor: pointer; user-select: none; transition: background 0.15s;
  }
  .im-layer-row:hover { background: rgba(197,160,60,0.06); }
  .im-layer-row input { accent-color: var(--color-gold); cursor: pointer; }
  .im-swatch { width: 24px; height: 14px; flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; }
  .im-swatch-line { width: 24px; height: 3px; }
  .im-swatch-line-dash { width: 24px; height: 3px; background-image: repeating-linear-gradient(90deg, currentColor 0, currentColor 5px, transparent 5px, transparent 9px); }
  .im-swatch-dot { width: 9px; height: 9px; border-radius: 50%; border: 1.5px solid white; box-shadow: 0 0 0 1px rgba(0,0,0,0.2); }
  .im-layer-name {
    font-family: var(--font-sans);
    font-size: 0.74rem; font-weight: 600;
    color: var(--color-text-primary); line-height: 1.3; flex: 1;
  }
  .im-layer-hint {
    display: block; font-weight: 400;
    font-size: 0.66rem; color: var(--color-text-muted); margin-top: 0.1rem;
  }

  #im-result {
    position: absolute; left: 14px; bottom: 14px; z-index: 600;
    background: rgba(255,255,255,0.98);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border-left: 3px solid var(--color-gold);
    box-shadow: 0 8px 28px rgba(0,0,0,0.16);
    padding: 0.95rem 1.15rem; max-width: 440px;
    width: calc(100% - 28px);
    transform: translate3d(0, calc(100% + 24px), 0);
    transition: transform 0.28s cubic-bezier(0.2,0.7,0.2,1), border-left-color 0.2s;
    visibility: hidden;
  }
  #im-result.open { transform: translate3d(0,0,0); visibility: visible; }
  @media (min-width: 768px) { #im-result { width: 440px; } }
  #im-result.kind-stormPipe    { border-left-color: #2a8c9c; }
  #im-result.kind-stormManhole { border-left-color: #1f6f7d; }
  #im-result.kind-gully        { border-left-color: #d77b32; }
  #im-result.kind-surfaceDrain { border-left-color: #4dadb8; }
  #im-result.kind-sewerMain    { border-left-color: #8a6e2f; }
  #im-result.kind-sewerManhole { border-left-color: #6c5320; }
  #im-result.kind-waterMain    { border-left-color: #2c7fc4; }
  #im-result.kind-hydrant      { border-left-color: #c43a3a; }

  .im-result-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 0.5rem; margin-bottom: 0.55rem;
  }
  .im-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--color-text-muted);
  }
  .im-close {
    background: transparent; border: none; cursor: pointer;
    width: 26px; height: 26px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--color-text-muted); padding: 0;
    transition: color 0.15s, background 0.15s;
  }
  .im-close:hover { color: var(--color-text-primary); background: rgba(28,25,23,0.06); }
  #im-result h3 {
    font-family: var(--font-serif); font-size: 1.05rem; font-weight: 400;
    color: var(--color-text-primary); line-height: 1.25; margin-bottom: 0.5rem;
  }
  .im-attrs {
    display: grid; grid-template-columns: max-content 1fr;
    gap: 0.3rem 0.85rem; font-size: 0.78rem; line-height: 1.55;
  }
  .im-attrs dt {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--color-text-muted); align-self: center;
  }
  .im-attrs dd { color: var(--color-text-primary); margin: 0; }
  .im-result-note {
    margin-top: 0.65rem; font-size: 0.74rem;
    color: var(--color-text-muted); line-height: 1.6;
    font-style: italic;
    border-top: 1px solid rgba(28,25,23,0.08); padding-top: 0.55rem;
  }

  .im-foot {
    margin-top: 0.85rem;
    display: flex; flex-wrap: wrap; gap: 0.85rem 1.5rem;
    align-items: baseline; justify-content: space-between;
    font-size: 0.72rem; color: var(--color-text-muted); line-height: 1.6;
  }
  .im-foot a {
    font-family: var(--font-sans); font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--color-gold); text-decoration: none; white-space: nowrap;
  }
  .im-foot a:hover { color: #d4af4a; }
</style>

<div class="im-shell">

  <p class="im-eduline">
    <strong>Educational use only</strong> BCC and QUU open data. Always commission a Dial Before You Dig (1100) search before excavating and order official plans before any connection or development decision.
  </p>

  <div class="im-search-bar">
    <div id="im-search-wrap">
      <input type="text" id="im-search" placeholder="Search address e.g. 12 Oxford St, Bulimba" autocomplete="off" inputmode="search" enterkeyhint="search" />
      <div id="im-autocomplete" style="display:none;"></div>
    </div>
    <button id="im-search-btn">Search</button>
  </div>

  <div class="im-map-wrap">
    <div id="im-map"></div>

    <div id="im-status">Click any pipe or feature, or search an address.</div>

    <!-- Layer toggle (top-right) -->
    <div class="im-control im-control-tr">
      <button class="im-layer-toggle" id="im-layer-toggle" aria-expanded="false" aria-controls="im-layer-panel">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2l10 6-10 6L2 8l10-6zM2 16l10 6 10-6M2 12l10 6 10-6"/></svg>
        Layers
        <svg class="toggle-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="im-layer-panel" id="im-layer-panel">

        <p class="im-layer-group-head">Stormwater (BCC)</p>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="stormPipe" checked />
          <span class="im-swatch"><span class="im-swatch-line" style="background:#2a8c9c;"></span></span>
          <span class="im-layer-name">Stormwater pipes
            <span class="im-layer-hint">Underground drainage pipes</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="stormManhole" />
          <span class="im-swatch"><span class="im-swatch-dot" style="background:#1f6f7d;"></span></span>
          <span class="im-layer-name">Stormwater manholes
            <span class="im-layer-hint">Access chambers and junctions</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="gully" checked />
          <span class="im-swatch"><span class="im-swatch-dot" style="background:#d77b32;"></span></span>
          <span class="im-layer-name">Gullies / kerb inlets
            <span class="im-layer-hint">Where runoff enters the underground network</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="surfaceDrain" />
          <span class="im-swatch"><span class="im-swatch-line-dash" style="color:#4dadb8;"></span></span>
          <span class="im-layer-name">Surface drains
            <span class="im-layer-hint">Overland flow paths and open drains</span>
          </span>
        </label>

        <p class="im-layer-group-head" style="margin-top:0.4rem;border-top:1px solid rgba(28,25,23,0.07);padding-top:0.7rem;">Water & Sewer (QUU)</p>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="sewerMain" checked />
          <span class="im-swatch"><span class="im-swatch-line" style="background:#8a6e2f;"></span></span>
          <span class="im-layer-name">Sewer mains
            <span class="im-layer-hint">Gravity sewer running underground</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="waterMain" checked />
          <span class="im-swatch"><span class="im-swatch-line" style="background:#2c7fc4;"></span></span>
          <span class="im-layer-name">Water mains
            <span class="im-layer-hint">Pressure mains supplying drinking water</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="sewerService" checked />
          <span class="im-swatch"><span class="im-swatch-line" style="background:#b8904a;opacity:0.7;"></span></span>
          <span class="im-layer-name">Sewer connections
            <span class="im-layer-hint">Individual property sewer laterals</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="waterService" checked />
          <span class="im-swatch"><span class="im-swatch-line" style="background:#6fb5e0;opacity:0.7;"></span></span>
          <span class="im-layer-name">Water connections
            <span class="im-layer-hint">Individual property water service lines</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="sewerManhole" />
          <span class="im-swatch"><span class="im-swatch-dot" style="background:#6c5320;"></span></span>
          <span class="im-layer-name">Sewer manholes
            <span class="im-layer-hint">Access chambers along sewer mains</span>
          </span>
        </label>
        <label class="im-layer-row">
          <input type="checkbox" data-layer="hydrant" />
          <span class="im-swatch"><span class="im-swatch-dot" style="background:#c43a3a;"></span></span>
          <span class="im-layer-name">Hydrants
            <span class="im-layer-hint">Fire hydrants on the water network</span>
          </span>
        </label>
      </div>
    </div>

    <!-- Result drawer -->
    <div id="im-result" role="region" aria-label="Asset information">
      <div class="im-result-head">
        <span class="im-eyebrow" id="im-result-eyebrow">Asset</span>
        <button class="im-close" id="im-result-close" aria-label="Close">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <h3 id="im-result-title"></h3>
      <dl class="im-attrs" id="im-result-attrs"></dl>
      <p class="im-result-note" id="im-result-note"></p>
    </div>
  </div>

  <div class="im-foot">
    <span><strong style="color:var(--color-text-secondary);">Educational use only.</strong> Stormwater data: Brisbane City Council open data. Water &amp; sewer data: Queensland Urban Utilities open data.</span>
    <span style="display:flex;gap:1rem;">
      <a href="https://urbanutilities.com.au/help-and-advice/manage-your-property/property-information" target="_blank" rel="noopener">QUU official plans →</a>
      <a href="https://www.1100.com.au/" target="_blank" rel="noopener">Dial Before You Dig →</a>
    </span>
  </div>

  <div style="margin-top:3rem;background:#1c1917;padding:2.5rem 2rem;text-align:center;">
    <p style="font-family:var(--font-serif);font-size:clamp(1.1rem,2.4vw,1.6rem);font-weight:400;color:#f0ece4;line-height:1.3;margin-bottom:0.85rem;">
      Easements and drainage constraints can limit what you build and affect what the land is worth.
    </p>
    <p style="font-size:0.85rem;color:rgba(240,236,228,0.6);max-width:54ch;margin:0 auto 1.5rem;line-height:1.75;">
      Daniel can help you read the plans, understand the easement implications, and decide whether to proceed.
    </p>
    <a href="/contact" data-cta="tool_to_contact"
      style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.85rem 2rem;background:#c5a03c;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;"
      onmouseover="this.style.background='#d4af4a'" onmouseout="this.style.background='#c5a03c'">
      Ask Daniel
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</div>

<link rel="preconnect" href="https://services2.arcgis.com" crossorigin />
<link rel="preconnect" href="https://services3.arcgis.com" crossorigin />
<link rel="preconnect" href="https://basemaps.cartocdn.com" crossorigin />
<link rel="preconnect" href="https://photon.komoot.io" crossorigin />
<link rel="preconnect" href="https://nominatim.openstreetmap.org" crossorigin />

<link rel="stylesheet" href="/lib/leaflet/leaflet.css" />
<link rel="preload" as="script" href="/lib/leaflet/leaflet.js" />
<script is:inline defer src="/lib/leaflet/leaflet.js"></script>

<script>
(function () {
  // ── Data sources ──────────────────────────────────────────────────────────
  const SVC = {
    // BCC Stormwater
    stormPipe:    'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Stormwater_Pipe_Existing/FeatureServer/0',
    stormManhole: 'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Stormwater_Manhole_Existing/FeatureServer/0',
    gully:        'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Stormwater_Gully_Existing/FeatureServer/0',
    surfaceDrain: 'https://services2.arcgis.com/dEKgZETqwmDAh1rP/arcgis/rest/services/Stormwater_Surface_Drain_Existing/FeatureServer/0',
    // QUU Water & Sewer
    sewerMain:    'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Sewer_OpenData/FeatureServer/18',
    sewerService: 'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Sewer_OpenData/FeatureServer/30',
    waterMain:    'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Water_OpenData/FeatureServer/21',
    waterService: 'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Water_OpenData/FeatureServer/28',
    sewerManhole: 'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Sewer_OpenData/FeatureServer/20',
    hydrant:      'https://services3.arcgis.com/ocUCNI2h4moKOpKX/arcgis/rest/services/UU_Water_OpenData/FeatureServer/15',
  };

  const STYLE = {
    stormPipe:    { color: '#2a8c9c', weight: 2.4, opacity: 0.9 },
    stormManhole: { radius: 4,   fillColor: '#1f6f7d', color: '#fff', weight: 1.5, fillOpacity: 0.95 },
    gully:        { radius: 3.5, fillColor: '#d77b32', color: '#fff', weight: 1.3, fillOpacity: 0.95 },
    surfaceDrain: { color: '#4dadb8', weight: 2, opacity: 0.9, dashArray: '5 4' },
    sewerMain:    { color: '#8a6e2f', weight: 2.6, opacity: 0.9 },
    sewerService: { color: '#b8904a', weight: 1.4, opacity: 0.75 },
    waterMain:    { color: '#2c7fc4', weight: 2.2, opacity: 0.9 },
    waterService: { color: '#6fb5e0', weight: 1.4, opacity: 0.75 },
    sewerManhole: { radius: 4,   fillColor: '#6c5320', color: '#fff', weight: 1.5, fillOpacity: 0.95 },
    hydrant:      { radius: 4,   fillColor: '#c43a3a', color: '#fff', weight: 1.5, fillOpacity: 0.95 },
  };

  const IS_POINT = new Set(['stormManhole','gully','sewerManhole','hydrant']);

  const OUT_FIELDS: Record<string,string> = {
    stormPipe:    'OBJECTID,ASSETID,PIPETYPE,DIAMETER,WIDTH,USIL,DSIL,UPSTREAMDEPTHINVERT,DOWNSTREAMDEPTHINVERT,AVERAGEDEPTH,MEASUREDLENGTH,OWNER,STATUS',
    stormManhole: 'OBJECTID,ASSETID,MANHOLETYPE,DIAMETER,LENGTH,WIDTH,SL,IL,OWNER,STATUS',
    gully:        'OBJECTID,ASSETID,INLETTYPE,OUTLETTYPE,DIAMETER,LENGTH,WIDTH,SL,OWNER,STATUS',
    surfaceDrain: 'OBJECTID,ASSETID,SURFACEDRAINTYPE,AVERAGEBASE,LOWFLOW,USSL,USIL,OWNER,STATUS',
    sewerMain:    'OBJECTID,ASSETID,MATERIAL,DIAMETER,SEGMENTTYPE,GRADE,USIL,DSIL,STATUS,OWNER',
    sewerService: 'OBJECTID,ASSETID,DIAMETER,OWNER',
    waterMain:    'OBJECTID,ASSETID,MATERIAL,DIAMETER,WATERTYPE,SUBTYPECD,OWNER',
    waterService: 'OBJECTID,ASSETID,DIAMETER,SERVICETYPE,WATERTYPE,OWNER',
    sewerManhole: 'OBJECTID,ASSETID,MANHOLEUSE,SL,IL,DEPTH,OWNER',
    hydrant:      'OBJECTID,ASSETID,HYDRANTTYPE,WATERTYPE,OWNER',
  };

  const TITLES: Record<string,string> = {
    stormPipe:    'Stormwater pipe',
    stormManhole: 'Stormwater manhole',
    gully:        'Gully / kerb inlet',
    surfaceDrain: 'Surface drain',
    sewerMain:    'Sewer main',
    sewerService: 'Sewer connection',
    waterMain:    'Water main',
    waterService: 'Water connection',
    sewerManhole: 'Sewer manhole',
    hydrant:      'Hydrant',
  };

  const NOTES: Record<string,string> = {
    stormPipe:    'Where a council stormwater pipe runs through private land, an easement is usually registered. The easement footprint is wider than the pipe and limits what can be built above it.',
    stormManhole: 'Manholes mark stormwater alignment and access. They are usually located at pipe junctions, bends, or changes of grade.',
    gully:        'Gullies and kerb inlets are where surface water enters the underground network. Their location influences how stormwater flows on and off the property in heavy rain.',
    surfaceDrain: 'Surface drains are the visible part of the stormwater network. They define the path of overland flow during heavy rain.',
    sewerMain:    'Sewer mains carry sewer easements over private land. The easement footprint is wider than the pipe (typically 3 m total). Council and QUU restrict what can be built within the easement.',
    sewerService: 'The sewer service connection runs from the property boundary to the gravity main in the road. Its location determines where the sanitary drain exits the property.',
    waterMain:    'Water mains run beneath the road or footpath in most cases. Connection to the property is via a service line at the kerb.',
    waterService: 'The water service connection runs from the water main to the property meter at the boundary. Diameter indicates the service capacity available to the property.',
    sewerManhole: 'Manholes mark sewer access points. They indicate the sewer alignment and depth at this location.',
    hydrant:      'Hydrants are spaced for fire-fighting access. Their presence is a code requirement, not a property feature.',
  };

  const BNE_BOUNDS = [[-27.85, 152.66], [-27.07, 153.55]];

  const active: Record<string,boolean> = {
    stormPipe: true, stormManhole: false, gully: true, surfaceDrain: false,
    sewerMain: true, sewerService: true, waterMain: true, waterService: true,
    sewerManhole: false, hydrant: false,
  };

  let map: any, layers: Record<string,any> = {}, pinMarker: any;
  let fetchAborts: Record<string,AbortController> = {}, acDebounce: any, canvasRenderer: any;

  function initMap() {
    map = L.map('im-map', {
      maxBounds: BNE_BOUNDS, minZoom: 11, maxBoundsViscosity: 0.5,
    }).setView([-27.46, 153.04], 13);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap contributors &copy; CARTO &middot; BCC &amp; QUU open data',
      subdomains: 'abcd', maxZoom: 19,
    }).addTo(map);

    canvasRenderer = L.canvas({ padding: 0.2 });
    Object.keys(SVC).forEach(k => {
      layers[k] = L.layerGroup();
      if (active[k]) layers[k].addTo(map);
    });

    map.on('moveend', loadVisible);
    map.on('click', (e: any) => identifyAt(e.latlng.lat, e.latlng.lng));
    wireUpControls();
    loadVisible();
  }

  function loadOne(key: string) {
    if (!active[key]) { layers[key].clearLayers(); return; }
    if (map.getZoom() < 14) { layers[key].clearLayers(); return; }
    if (fetchAborts[key]) fetchAborts[key].abort();
    fetchAborts[key] = new AbortController();

    const b = map.getBounds();
    const sw = b.getSouthWest(), ne = b.getNorthEast();
    const params = new URLSearchParams({
      geometry: `${sw.lng},${sw.lat},${ne.lng},${ne.lat}`,
      geometryType: 'esriGeometryEnvelope',
      inSR: '4326', outSR: '4326',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: OUT_FIELDS[key],
      returnGeometry: 'true',
      resultRecordCount: '4000',
      f: 'geojson',
    });

    fetch(`${SVC[key]}/query?${params}`, { signal: fetchAborts[key].signal })
      .then(r => r.json())
      .then(geo => {
        layers[key].clearLayers();
        const pt = IS_POINT.has(key);
        L.geoJSON(geo, {
          renderer: canvasRenderer,
          style: pt ? null : () => STYLE[key],
          pointToLayer: pt ? (f: any, latlng: any) => L.circleMarker(latlng, { ...STYLE[key], renderer: canvasRenderer }) : undefined,
          onEachFeature(f: any, layer: any) {
            layer.on('click', (e: any) => {
              L.DomEvent.stopPropagation(e);
              showResult(key, f.properties || {});
            });
          },
        }).addTo(layers[key]);
      })
      .catch((err: any) => {
        if (err.name === 'AbortError') return;
        const s = document.getElementById('im-status');
        if (s) s.textContent = 'Some layers could not load. Try refreshing.';
      });
  }

  function loadVisible() {
    const s = document.getElementById('im-status')!;
    const z = map.getZoom();
    if (z < 14) {
      Object.keys(layers).forEach(k => layers[k].clearLayers());
      s.textContent = 'Zoom in to load infrastructure (level 14+).';
      return;
    }
    s.textContent = 'Loading assets...';
    Object.keys(SVC).forEach(loadOne);
    setTimeout(() => { if (map.getZoom() >= 14) s.textContent = 'Assets loaded. Click any pipe or feature.'; }, 700);
  }

  function identifyAt(lat: number, lon: number) {
    const s = document.getElementById('im-status')!;
    s.textContent = 'Identifying...';
    const tasks = Object.keys(SVC).filter(k => active[k]).map(k =>
      fetchNearest(k, lat, lon).then((f: any) => f && { key: k, feature: f })
    );
    Promise.all(tasks).then((results: any[]) => {
      const hits = results.filter(Boolean);
      if (!hits.length) { s.textContent = 'No asset within 30 m. Try clicking on the road.'; return; }
      hits.sort((a, b) => a.feature._dist - b.feature._dist);
      showResult(hits[0].key, hits[0].feature.attributes);
      s.textContent = 'Asset identified.';
    });
  }

  function fetchNearest(key: string, lat: number, lon: number) {
    const params = new URLSearchParams({
      geometry: JSON.stringify({ x: lon, y: lat, spatialReference: { wkid: 4326 } }),
      geometryType: 'esriGeometryPoint',
      inSR: '4326', outSR: '4326',
      distance: '30', units: 'esriSRUnit_Meter',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: OUT_FIELDS[key],
      returnGeometry: 'true', f: 'json',
      resultRecordCount: '5',
    });
    return fetch(`${SVC[key]}/query?${params}`)
      .then(r => r.json())
      .then((d: any) => {
        const feats = d.features || [];
        if (!feats.length) return null;
        let best = feats[0]; best._dist = featDist(best, lat, lon);
        for (const f of feats.slice(1)) {
          const dd = featDist(f, lat, lon);
          if (dd < best._dist) { best = f; best._dist = dd; }
        }
        return best;
      })
      .catch(() => null);
  }

  function featDist(f: any, lat: number, lon: number) {
    const g = f.geometry || {};
    if (g.x != null && g.y != null) return distSq(g.y, g.x, lat, lon);
    if (Array.isArray(g.paths) && g.paths.length) {
      let min = Infinity;
      for (const path of g.paths) for (const [x, y] of path) { const d = distSq(y, x, lat, lon); if (d < min) min = d; }
      return min;
    }
    return Infinity;
  }
  function distSq(lat1: number, lon1: number, lat2: number, lon2: number) {
    const dy = (lat1 - lat2) * 111320;
    const dx = (lon1 - lon2) * 111320 * Math.cos((lat1 + lat2) / 2 * Math.PI / 180);
    return dx * dx + dy * dy;
  }

  function showResult(key: string, attrs: Record<string,any>) {
    const el = document.getElementById('im-result')!;
    el.className = `kind-${key}`;
    el.classList.add('open');
    document.getElementById('im-result-eyebrow')!.textContent = TITLES[key] || key;
    document.getElementById('im-result-title')!.textContent = headlineFor(key, attrs);

    const rows = renderAttrs(key, attrs);
    document.getElementById('im-result-attrs')!.innerHTML =
      rows.map(([k, v]: [string,string]) => `<dt>${k}</dt><dd>${esc(v)}</dd>`).join('');
    document.getElementById('im-result-note')!.textContent = NOTES[key] || '';
  }

  function headlineFor(key: string, a: Record<string,any>) {
    const num = (v: any) => (v == null || v === '') ? null : v;
    if (key === 'stormPipe') {
      const dia = num(a.DIAMETER) ? `DN${a.DIAMETER}` : '';
      return [dia, a.PIPETYPE].filter(Boolean).join(' · ') || TITLES[key];
    }
    if (key === 'sewerService') {
      return a.DIAMETER ? `DN${a.DIAMETER} sewer connection` : TITLES[key];
    }
    if (key === 'waterService') {
      return a.SERVICETYPE ? `${a.SERVICETYPE} water connection${a.DIAMETER ? ` DN${a.DIAMETER}` : ''}` : (a.DIAMETER ? `DN${a.DIAMETER} water connection` : TITLES[key]);
    }
    if (key === 'sewerMain' || key === 'waterMain') {
      const dia = num(a.DIAMETER) ? `DN${a.DIAMETER}` : '';
      return [dia, a.MATERIAL].filter(Boolean).join(' · ') || TITLES[key];
    }
    if (key === 'sewerManhole') {
      const depth = num(a.DEPTH) ? `${(+a.DEPTH).toFixed(1)} m deep` : '';
      return [a.MANHOLEUSE, depth].filter(Boolean).join(' · ') || TITLES[key];
    }
    if (key === 'stormManhole') {
      return a.MANHOLETYPE || TITLES[key];
    }
    if (key === 'gully') {
      return a.INLETTYPE || TITLES[key];
    }
    if (key === 'hydrant') return a.HYDRANTTYPE || TITLES[key];
    if (key === 'surfaceDrain') return a.SURFACEDRAINTYPE || TITLES[key];
    return TITLES[key] || 'Asset';
  }

  function renderAttrs(key: string, a: Record<string,any>): [string,string][] {
    const rows: [string,string][] = [];
    const push = (k: string, v: any) => { if (v != null && v !== '') rows.push([k, String(v)]); };
    if (key === 'stormPipe') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Type', a.PIPETYPE);
      push('Length', a.MEASUREDLENGTH ? `${(+a.MEASUREDLENGTH).toFixed(1)} m` : null);
      push('Avg depth', a.AVERAGEDEPTH ? `${(+a.AVERAGEDEPTH).toFixed(2)} m` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'stormManhole') {
      push('Type', a.MANHOLETYPE);
      push('Surface level', a.SL != null ? `${(+a.SL).toFixed(2)} mAHD` : null);
      push('Invert level', a.IL != null ? `${(+a.IL).toFixed(2)} mAHD` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'gully') {
      push('Inlet type', a.INLETTYPE); push('Outlet type', a.OUTLETTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'surfaceDrain') {
      push('Type', a.SURFACEDRAINTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'sewerService') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'waterService') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Type', a.SERVICETYPE); push('Water type', a.WATERTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'sewerMain') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Material', a.MATERIAL); push('Type', a.SEGMENTTYPE);
      push('Grade', a.GRADE != null ? `${a.GRADE}` : null);
      push('US invert', a.USIL != null ? `${(+a.USIL).toFixed(2)} mAHD` : null);
      push('DS invert', a.DSIL != null ? `${(+a.DSIL).toFixed(2)} mAHD` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'waterMain') {
      push('Diameter', a.DIAMETER ? `${a.DIAMETER} mm` : null);
      push('Material', a.MATERIAL); push('Water type', a.WATERTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'sewerManhole') {
      push('Use', a.MANHOLEUSE);
      push('Surface level', a.SL != null ? `${(+a.SL).toFixed(2)} mAHD` : null);
      push('Invert level', a.IL != null ? `${(+a.IL).toFixed(2)} mAHD` : null);
      push('Depth', a.DEPTH != null ? `${(+a.DEPTH).toFixed(2)} m` : null);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    } else if (key === 'hydrant') {
      push('Type', a.HYDRANTTYPE); push('Water type', a.WATERTYPE);
      push('Owner', a.OWNER); push('Asset ID', a.ASSETID);
    }
    return rows;
  }

  function esc(s: string) {
    return String(s).replace(/[&<>"']/g, (c: string) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c] || c);
  }

  // ── Address search ────────────────────────────────────────────────────────
  async function geocode(addr: string) {
    const u = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(addr + ', Brisbane, Australia')}&format=json&limit=1&countrycodes=au`;
    const data = await fetch(u, { headers: { 'Accept-Language': 'en' } }).then(r => r.json());
    if (!data.length) throw new Error('not found');
    return { lat: parseFloat(data[0].lat), lon: parseFloat(data[0].lon) };
  }

  function suggestions(q: string) {
    return fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(q)}&limit=5&lang=en&bbox=152.6,-27.8,153.5,-27.1`)
      .then(r => r.json()).then((d: any) => d.features || []);
  }

  function renderSuggestions(features: any[]) {
    const list = document.getElementById('im-autocomplete')!;
    list.innerHTML = '';
    if (!features.length) { list.style.display = 'none'; return; }
    features.forEach(f => {
      const p = f.properties;
      const label = [p.name, p.street && p.housenumber ? `${p.street} ${p.housenumber}` : p.street, p.city || p.suburb].filter(Boolean).join(', ');
      const item = document.createElement('div');
      item.className = 'im-ac-item'; item.textContent = label;
      item.addEventListener('mousedown', () => {
        const lat = f.geometry.coordinates[1], lon = f.geometry.coordinates[0];
        (document.getElementById('im-search') as HTMLInputElement).value = label;
        list.style.display = 'none';
        flyAndIdentify(lat, lon);
      });
      list.appendChild(item);
    });
    list.style.display = 'block';
  }

  function dropPin(lat: number, lon: number) {
    if (pinMarker) map.removeLayer(pinMarker);
    pinMarker = L.marker([lat, lon], {
      icon: L.divIcon({
        className: '',
        html: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="36" viewBox="0 0 28 36"><path d="M14 0C6.27 0 0 6.27 0 14c0 9.63 14 22 14 22S28 23.63 28 14C28 6.27 21.73 0 14 0zm0 20a6 6 0 1 1 0-12 6 6 0 0 1 0 12z" fill="#c5a03c" stroke="#fff" stroke-width="1.5"/></svg>`,
        iconSize: [28, 36], iconAnchor: [14, 36],
      }),
    }).addTo(map);
  }

  function flyAndIdentify(lat: number, lon: number) {
    dropPin(lat, lon);
    map.setView([lat, lon], 18);
    setTimeout(() => identifyAt(lat, lon), 800);
  }

  async function doSearch() {
    const v = (document.getElementById('im-search') as HTMLInputElement).value.trim();
    if (!v) return;
    const s = document.getElementById('im-status')!;
    const btn = document.getElementById('im-search-btn') as HTMLButtonElement;
    s.textContent = 'Locating address...';
    btn.disabled = true;
    document.getElementById('im-autocomplete')!.style.display = 'none';
    try {
      const { lat, lon } = await geocode(v);
      flyAndIdentify(lat, lon);
    } catch {
      s.textContent = 'Address not found. Add the suburb (e.g. 12 Main St, Camp Hill).';
    }
    btn.disabled = false;
  }

  function wireUpControls() {
    const search = document.getElementById('im-search') as HTMLInputElement;
    document.getElementById('im-search-btn')!.addEventListener('click', doSearch);
    search.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
      if (e.key === 'Escape') document.getElementById('im-autocomplete')!.style.display = 'none';
    });
    search.addEventListener('input', () => {
      clearTimeout(acDebounce);
      const q = search.value.trim();
      if (q.length < 3) { document.getElementById('im-autocomplete')!.style.display = 'none'; return; }
      acDebounce = setTimeout(() => suggestions(q).then(renderSuggestions), 130);
    });
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target as Element).closest('#im-search-wrap'))
        document.getElementById('im-autocomplete')!.style.display = 'none';
    });

    const toggle = document.getElementById('im-layer-toggle')!;
    const panel  = document.getElementById('im-layer-panel')!;
    toggle.addEventListener('click', () => {
      const open = panel.classList.toggle('open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    panel.querySelectorAll<HTMLInputElement>('input[data-layer]').forEach(cb => {
      cb.addEventListener('change', () => {
        const k = cb.dataset.layer!;
        active[k] = cb.checked;
        if (active[k]) { layers[k].addTo(map); loadOne(k); }
        else map.removeLayer(layers[k]);
      });
    });

    document.getElementById('im-result-close')!.addEventListener('click', () => {
      document.getElementById('im-result')!.classList.remove('open');
    });

    const status = document.getElementById('im-status')!;
    let fadeTimer: any;
    new MutationObserver(() => {
      clearTimeout(fadeTimer);
      status.style.opacity = '1';
      if (/loaded|identified/i.test(status.textContent || ''))
        fadeTimer = setTimeout(() => { status.style.opacity = '0'; }, 1800);
    }).observe(status, { childList: true, characterData: true, subtree: true });
  }

  function whenLeafletReady() {
    if ((window as any).L) initMap();
    else requestAnimationFrame(whenLeafletReady);
  }
  whenLeafletReady();
})();
</script>

</ToolLayout>
