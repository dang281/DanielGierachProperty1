---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Interest Rate Sensitivity Calculator"
  tool="Interest Rate Sensitivity Calculator"
  phase="Buyer Tools"
  description="See how your mortgage repayments change if interest rates rise. Model your exposure to rate increases of 0.25% through to 2%."
>

<style>
  .rs-input {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(28,25,23,0.2);
    background: #fff;
    color: #1c1917;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .rs-input:focus { border-color: var(--color-gold); }

  .rate-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 0;
    border-bottom: 1px solid rgba(28,25,23,0.08);
    align-items: stretch;
  }
  .rate-row:last-child { border-bottom: none; }
  .rate-cell {
    padding: 0.9rem 1.25rem;
    font-size: 0.82rem;
    color: #1c1917;
    border-right: 1px solid rgba(28,25,23,0.08);
  }
  .rate-cell:last-child { border-right: none; }
  .rate-row.header .rate-cell {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #78716c;
    background: #f9f7f4;
  }
  .rate-row.current-row { background: rgba(196,145,42,0.06); }
  .rate-row.current-row .rate-cell { font-weight: 700; }

  .bar-wrap { display: flex; align-items: center; gap: 0.75rem; }
  .bar-bg { flex: 1; height: 6px; background: rgba(28,25,23,0.08); border-radius: 3px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; background: #c4912a; transition: width 0.5s ease; }

  @media (max-width: 640px) {
    .rate-row { grid-template-columns: 1fr 1fr; }
    .rate-cell:nth-child(3), .rate-cell:nth-child(4) { border-top: 1px solid rgba(28,25,23,0.06); }
  }
</style>

<div style="display:flex;flex-direction:column;gap:2rem;max-width:860px;">

  <!-- Inputs -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1.25rem;">
    <div>
      <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Loan Amount ($)</label>
      <input id="rs-loan" class="rs-input" type="number" placeholder="600000" value="600000" min="50000" max="5000000" step="10000" />
    </div>
    <div>
      <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Current Interest Rate (%)</label>
      <input id="rs-rate" class="rs-input" type="number" placeholder="6.2" value="6.2" min="1" max="15" step="0.05" />
    </div>
    <div>
      <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Loan Term (years)</label>
      <input id="rs-term" class="rs-input" type="number" placeholder="30" value="30" min="5" max="30" step="1" />
    </div>
  </div>

  <!-- Callout: stress test guideline -->
  <div style="background:rgba(196,145,42,0.06);border-left:3px solid #c4912a;padding:1rem 1.25rem;">
    <p style="font-size:0.82rem;color:#1c1917;line-height:1.7;margin:0;">
      <strong>APRA stress test:</strong> Since October 2021, Australian lenders must assess borrowers at their current rate plus a 3% serviceability buffer. If your rate is 6.2%, your lender is checking you can afford 9.2%. This calculator shows the real repayment impact at each rate level.
    </p>
  </div>

  <!-- Results table -->
  <div id="results-wrap" style="background:#fff;border:1px solid rgba(28,25,23,0.1);overflow:hidden;">
    <div style="padding:1.25rem 1.5rem;border-bottom:1px solid rgba(28,25,23,0.08);background:#f9f7f4;">
      <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin:0;">Rate Sensitivity Analysis</p>
    </div>

    <div class="rate-row header">
      <div class="rate-cell">Scenario</div>
      <div class="rate-cell">Monthly</div>
      <div class="rate-cell">Weekly</div>
      <div class="rate-cell">Extra / month vs now</div>
    </div>

    <div id="rows-wrap"></div>
  </div>

  <!-- Annual impact summary -->
  <div id="impact-wrap" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;"></div>

  <p style="font-size:0.75rem;color:#a8a29e;line-height:1.6;">
    Principal and interest repayments only. Does not include fees, charges, or offset account effects. Rates shown are illustrative. Always consult a licensed mortgage broker or your lender for personalised advice.
  </p>

</div>

<script>
  const loanInput = document.getElementById('rs-loan')   as HTMLInputElement;
  const rateInput = document.getElementById('rs-rate')   as HTMLInputElement;
  const termInput = document.getElementById('rs-term')   as HTMLInputElement;
  const rowsWrap  = document.getElementById('rows-wrap')!;
  const impactWrap= document.getElementById('impact-wrap')!;

  function calcMonthly(principal: number, annualRate: number, termYears: number): number {
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    if (r === 0) return principal / n;
    return principal * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
  }

  function fmt(n: number) {
    return '$' + Math.round(n).toLocaleString('en-AU');
  }

  const INCREMENTS = [0, 0.25, 0.5, 1, 1.5, 2];

  function render() {
    const loan = parseFloat(loanInput.value) || 600000;
    const baseRate = parseFloat(rateInput.value) || 6.2;
    const term = parseInt(termInput.value) || 30;

    const baseMonthly = calcMonthly(loan, baseRate, term);
    rowsWrap.innerHTML = '';

    let maxMonthly = 0;
    INCREMENTS.forEach(inc => {
      const r = baseRate + inc;
      const m = calcMonthly(loan, r, term);
      if (m > maxMonthly) maxMonthly = m;
    });

    INCREMENTS.forEach(inc => {
      const r = baseRate + inc;
      const m = calcMonthly(loan, r, term);
      const w = m * 12 / 52;
      const extra = m - baseMonthly;
      const isCurrent = inc === 0;

      const row = document.createElement('div');
      row.className = 'rate-row' + (isCurrent ? ' current-row' : '');

      const label = isCurrent
        ? `Current (${r.toFixed(2)}%)`
        : `+${inc.toFixed(2)}% → ${r.toFixed(2)}%`;

      const barPct = (m / maxMonthly) * 100;
      const barColor = inc === 0 ? '#c4912a' : inc <= 0.5 ? '#e07a3a' : inc <= 1 ? '#c0392b' : '#8b0000';

      row.innerHTML = `
        <div class="rate-cell" style="${isCurrent?'font-weight:700;':''}">${label}</div>
        <div class="rate-cell">
          <div class="bar-wrap">
            <span style="min-width:80px;">${fmt(m)}</span>
            <div class="bar-bg"><div class="bar-fill" style="width:${barPct}%;background:${barColor};"></div></div>
          </div>
        </div>
        <div class="rate-cell">${fmt(w)}</div>
        <div class="rate-cell" style="color:${isCurrent?'#78716c':extra>1000?'#c0392b':'#c4912a'};font-weight:${isCurrent?'400':'700'};">
          ${isCurrent ? 'Baseline' : '+' + fmt(extra) + '/mo'}
        </div>
      `;
      rowsWrap.appendChild(row);
    });

    // Annual impact cards for key scenarios
    impactWrap.innerHTML = '';
    [[0.5,'Possible'],[1,'Likely stress test'],[2,'Severe stress']].forEach(([inc, label]) => {
      const r = baseRate + (inc as number);
      const extra = calcMonthly(loan, r, term) - baseMonthly;
      const card = document.createElement('div');
      card.style.cssText = 'background:#fff;border:1px solid rgba(28,25,23,0.1);padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:0.3rem;';
      card.innerHTML = `
        <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:#c0392b;">${label}</span>
        <span style="font-family:var(--font-serif);font-size:1.4rem;font-weight:400;color:#1c1917;">+${fmt(extra * 12)}/yr</span>
        <span style="font-size:0.78rem;color:#78716c;">if rates rise +${inc}%</span>
      `;
      impactWrap.appendChild(card);
    });
  }

  [loanInput, rateInput, termInput].forEach(el => el.addEventListener('input', render));
  render();
</script>

</ToolLayout>
