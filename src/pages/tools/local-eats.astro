---
import ToolLayout from '../../layouts/ToolLayout.astro';

const MAPS_KEY = 'AIzaSyD2sghjRZa7NJeUDKUm6_EHt_aAL0ntvzw';
---

<ToolLayout
  title="Local Cafes & Restaurants"
  tool="Local Cafes & Restaurants"
  phase="Buyer Tools"
  description="Find cafes and restaurants in any Brisbane suburb. Enter a suburb to see what's around before you buy."
>

<style>
  #suburb-input {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid rgba(28,25,23,0.2);
    background: var(--color-surface-4);
    color: var(--color-text-primary);
    outline: none;
    transition: border-color 0.2s;
  }
  #suburb-input:focus { border-color: var(--color-gold); }
  #suburb-input::placeholder { color: var(--color-text-muted); }

  .place-card {
    background: #fff;
    border: 1px solid rgba(28,25,23,0.1);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 1px 4px rgba(28,25,23,0.05);
    transition: box-shadow 0.2s, border-color 0.2s;
    text-decoration: none;
  }
  .place-card:hover {
    box-shadow: 0 6px 20px rgba(28,25,23,0.08);
    border-color: rgba(196,145,42,0.25);
  }

  .stars { color: #c4912a; letter-spacing: -0.02em; }

  .section-heading {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    color: #1c1917;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(28,25,23,0.1);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  #places-map { display: none; width: 1px; height: 1px; }
</style>

<div style="display:flex;flex-direction:column;gap:2.5rem;">

  <!-- Search row -->
  <div>
    <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.5rem;">Suburb</label>
    <div style="display:flex;gap:0.75rem;">
      <input id="suburb-input" type="text" placeholder="e.g. Hawthorne, Balmoral, Coorparoo" autocomplete="off" />
      <button id="search-btn" class="btn-gold" style="white-space:nowrap;padding:0.9rem 1.5rem;flex-shrink:0;">
        Search
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </button>
    </div>
    <p id="status-msg" style="margin-top:0.6rem;min-height:1.2em;font-size:0.82rem;color:var(--color-text-muted);font-style:italic;"></p>
  </div>

  <!-- Results by category -->
  <div id="results-wrap" style="display:none;flex-direction:column;gap:3rem;"></div>

  <div id="no-results" style="display:none;text-align:center;padding:3rem 0;color:var(--color-text-muted);font-size:0.9rem;">
    No places found for that suburb. Try a different spelling.
  </div>

</div>

<div id="places-map"></div>

<script define:vars={{ MAPS_KEY }}>
  const input       = document.getElementById('suburb-input');
  const searchBtn   = document.getElementById('search-btn');
  const statusMsg   = document.getElementById('status-msg');
  const resultsWrap = document.getElementById('results-wrap');
  const noResults   = document.getElementById('no-results');
  const mapDiv      = document.getElementById('places-map');

  let service = null;
  let map     = null;

  function loadGoogleMaps() {
    return new Promise((resolve) => {
      if (window.google && window.google.maps) { resolve(); return; }
      window.__placesReady = resolve;
      const s = document.createElement('script');
      s.src = `https://maps.googleapis.com/maps/api/js?key=${MAPS_KEY}&libraries=places&callback=__placesReady`;
      s.async = true;
      document.head.appendChild(s);
    });
  }

  function starsHtml(rating) {
    if (!rating) return '';
    const full  = Math.round(rating);
    const stars = '★'.repeat(full) + '☆'.repeat(5 - full);
    return `<span class="stars">${stars}</span> <span style="font-size:0.75rem;color:#78716c;">${rating.toFixed(1)}</span>`;
  }

  function getCategory(types) {
    if (!types) return 'other';
    if (types.includes('cafe'))       return 'cafe';
    if (types.includes('bar'))        return 'bar';
    if (types.includes('restaurant')) return 'restaurant';
    return 'other';
  }

  function renderCard(place) {
    const mapsUrl = `https://www.google.com/maps/place/?q=place_id:${place.place_id}`;
    const openNow = place.opening_hours?.isOpen?.() ?? null;
    const openTag = openNow === true
      ? `<span style="font-size:0.65rem;font-weight:700;color:#2a7a45;">Open now</span>`
      : openNow === false
      ? `<span style="font-size:0.65rem;font-weight:700;color:#a33;">Closed now</span>`
      : '';

    return `
      <a href="${mapsUrl}" target="_blank" rel="noopener" class="place-card">
        <span style="font-family:var(--font-serif);font-size:1rem;font-weight:400;color:#1c1917;line-height:1.3;">${place.name}</span>
        ${place.vicinity ? `<p style="font-size:0.78rem;color:#78716c;margin:0;line-height:1.5;">${place.vicinity}</p>` : ''}
        <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-top:0.15rem;">
          ${place.rating ? starsHtml(place.rating) : ''}
          ${place.user_ratings_total ? `<span style="font-size:0.72rem;color:#a8a29e;">(${place.user_ratings_total.toLocaleString()} reviews)</span>` : ''}
          ${openTag}
        </div>
        <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#c4912a;margin-top:0.25rem;">View on Google Maps →</span>
      </a>
    `;
  }

  const SECTIONS = [
    { key: 'cafe',       label: 'Cafes',       dot: '#c4912a',  queries: ['cafes'] },
    { key: 'restaurant', label: 'Restaurants',  dot: '#3a8fa8',  queries: ['restaurants'] },
    { key: 'bar',        label: 'Bars & Pubs',  dot: '#78716c',  queries: ['bars and pubs'] },
  ];

  function renderSection(label, dot, places) {
    if (places.length === 0) return '';
    return `
      <div>
        <div class="section-heading">
          <span style="width:10px;height:10px;border-radius:50%;background:${dot};flex-shrink:0;display:inline-block;"></span>
          ${label}
          <span style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.12em;color:#a8a29e;">${places.length} places</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3" style="gap:1rem;">
          ${places.map(renderCard).join('')}
        </div>
      </div>
    `;
  }

  function searchPlaces(suburb) {
    statusMsg.textContent = 'Searching...';
    resultsWrap.style.display = 'none';
    resultsWrap.innerHTML     = '';
    noResults.style.display   = 'none';

    // Run 3 separate searches — one per category
    const buckets = { cafe: [], restaurant: [], bar: [] };
    let pending = SECTIONS.length;

    SECTIONS.forEach(({ key, queries }) => {
      const query = `${queries[0]} in ${suburb} Brisbane QLD`;
      service.textSearch({ query }, (results, status) => {
        if (results && status === google.maps.places.PlacesServiceStatus.OK) {
          const seen = new Set();
          results.forEach(p => {
            if (!seen.has(p.place_id)) {
              seen.add(p.place_id);
              buckets[key].push(p);
            }
          });
          buckets[key].sort((a, b) => (b.rating || 0) - (a.rating || 0));
        }
        pending--;
        if (pending > 0) return;

        statusMsg.textContent = '';
        const total = Object.values(buckets).reduce((s, arr) => s + arr.length, 0);
        if (total === 0) { noResults.style.display = 'block'; return; }

        resultsWrap.innerHTML = SECTIONS
          .map(({ key, label, dot }) => renderSection(label, dot, buckets[key]))
          .join('');
        resultsWrap.style.display = 'flex';
      });
    });
  }

  async function doSearch() {
    const suburb = input.value.trim();
    if (!suburb) return;

    if (!map) {
      statusMsg.textContent = 'Loading...';
      await loadGoogleMaps();
      map     = new google.maps.Map(mapDiv, { center: { lat: -27.47, lng: 153.02 }, zoom: 14 });
      service = new google.maps.places.PlacesService(map);
    }

    searchPlaces(suburb);
  }

  searchBtn.addEventListener('click', doSearch);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });
</script>

</ToolLayout>
