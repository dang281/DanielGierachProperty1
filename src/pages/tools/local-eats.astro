---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Local Cafes & Restaurants"
  tool="Local Cafes & Restaurants"
  phase="Buyer Tools"
  description="Find cafes and restaurants near any Brisbane suburb. Search by suburb to explore the local dining scene before you buy."
>

<style>
  #suburb-input {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid rgba(28,25,23,0.2);
    background: var(--color-surface-4);
    color: var(--color-text-primary);
    outline: none;
    transition: border-color 0.2s;
  }
  #suburb-input:focus { border-color: var(--color-gold); }
  #suburb-input::placeholder { color: var(--color-text-muted); }

  #map {
    height: 420px;
    width: 100%;
    border: 1px solid rgba(28,25,23,0.1);
  }

  .place-card {
    background: var(--color-surface-3);
    border: 1px solid rgba(28,25,23,0.08);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
  }
  .place-card:hover { border-color: var(--color-gold); background: var(--color-surface-4); }

  .place-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }
  .dot-cafe       { background: #c4912a; }
  .dot-restaurant { background: #3a8fa8; }

  .type-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.52rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.18rem 0.45rem;
  }
  .badge-cafe       { background: rgba(196,145,42,0.12); color: #a07020; }
  .badge-restaurant { background: rgba(58,143,168,0.12); color: #2a6a85; }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.1rem;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    border: 1.5px solid;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  #status-msg {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div style="display:flex;flex-direction:column;gap:1.5rem;">

  <!-- Search row -->
  <div>
    <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.5rem;">Suburb</label>
    <div style="display:flex;gap:0.75rem;">
      <input id="suburb-input" type="text" placeholder="e.g. Hawthorne, Balmoral, Coorparoo" autocomplete="off" />
      <button id="search-btn" class="btn-gold" style="white-space:nowrap;padding:0.9rem 1.5rem;flex-shrink:0;">
        Search
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </button>
    </div>
    <p id="status-msg" style="margin-top:0.6rem;min-height:1.2em;"></p>
  </div>

  <!-- Filter + count row -->
  <div id="controls-row" style="display:none;align-items:center;gap:0.5rem;flex-wrap:wrap;">
    <button class="filter-btn" id="btn-all"        style="background:#1c1917;color:#f0ece4;border-color:#1c1917;">All</button>
    <button class="filter-btn" id="btn-cafe"       style="background:transparent;color:#78716c;border-color:rgba(28,25,23,0.22);">Cafes</button>
    <button class="filter-btn" id="btn-restaurant" style="background:transparent;color:#78716c;border-color:rgba(28,25,23,0.22);">Restaurants</button>
    <span id="result-count" style="margin-left:auto;font-family:var(--font-sans);font-size:0.72rem;color:var(--color-text-muted);"></span>
  </div>

  <!-- Map -->
  <div id="map" style="display:none;"></div>

  <!-- Results -->
  <div id="results-grid" style="display:none;flex-direction:column;gap:0.5rem;"></div>

  <!-- Empty state -->
  <p id="no-results" style="display:none;text-align:center;padding:3rem 0;font-size:0.9rem;color:var(--color-text-muted);">No results found for that filter.</p>

</div>

<script>
  // ── Leaflet ──────────────────────────────────────────────────────────────
  // @ts-ignore
  const L = await import('https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js');

  const suburbInput = document.getElementById('suburb-input') as HTMLInputElement;
  const searchBtn   = document.getElementById('search-btn')   as HTMLButtonElement;
  const statusMsg   = document.getElementById('status-msg')   as HTMLParagraphElement;
  const controlsRow = document.getElementById('controls-row') as HTMLDivElement;
  const mapEl       = document.getElementById('map')          as HTMLDivElement;
  const resultsGrid = document.getElementById('results-grid') as HTMLDivElement;
  const noResults   = document.getElementById('no-results')   as HTMLParagraphElement;
  const resultCount = document.getElementById('result-count') as HTMLSpanElement;
  const btnAll      = document.getElementById('btn-all')      as HTMLButtonElement;
  const btnCafe     = document.getElementById('btn-cafe')     as HTMLButtonElement;
  const btnRest     = document.getElementById('btn-restaurant') as HTMLButtonElement;

  let map: any = null;
  let markers: any[] = [];
  let allPlaces: Place[] = [];
  let activeFilter = 'all';

  interface Place {
    id: number;
    name: string;
    type: 'cafe' | 'restaurant';
    lat: number;
    lon: number;
    tags: Record<string, string>;
  }

  // ── Geocode suburb → {lat, lon} ──────────────────────────────────────────
  async function geocodeSuburb(suburb: string): Promise<{ lat: number; lon: number } | null> {
    const query = encodeURIComponent(`${suburb}, Queensland, Australia`);
    const url = `https://nominatim.openstreetmap.org/search?q=${query}&format=json&limit=1&countrycodes=au`;
    const res = await fetch(url, { headers: { 'Accept-Language': 'en' } });
    const data = await res.json();
    if (!data.length) return null;
    return { lat: parseFloat(data[0].lat), lon: parseFloat(data[0].lon) };
  }

  // ── Overpass: cafes + restaurants within radius ───────────────────────────
  async function fetchPlaces(lat: number, lon: number, radiusM = 1200): Promise<Place[]> {
    const query = `
      [out:json][timeout:15];
      (
        node["amenity"="cafe"](around:${radiusM},${lat},${lon});
        node["amenity"="restaurant"](around:${radiusM},${lat},${lon});
        way["amenity"="cafe"](around:${radiusM},${lat},${lon});
        way["amenity"="restaurant"](around:${radiusM},${lat},${lon});
      );
      out center tags;
    `;
    const res = await fetch('https://overpass-api.de/api/interpreter', {
      method: 'POST',
      body: query,
    });
    const data = await res.json();
    return (data.elements as any[])
      .filter((e: any) => e.tags?.name)
      .map((e: any) => ({
        id:   e.id,
        name: e.tags.name,
        type: e.tags.amenity === 'cafe' ? 'cafe' : 'restaurant',
        lat:  e.lat ?? e.center?.lat,
        lon:  e.lon ?? e.center?.lon,
        tags: e.tags,
      }))
      .filter((p: Place) => p.lat && p.lon)
      .sort((a: Place, b: Place) => a.name.localeCompare(b.name));
  }

  // ── Render ───────────────────────────────────────────────────────────────
  function renderPlaces(places: Place[]) {
    // Clear markers
    markers.forEach(m => m.remove());
    markers = [];
    resultsGrid.innerHTML = '';

    const filtered = activeFilter === 'all'
      ? places
      : places.filter(p => p.type === activeFilter);

    resultCount.textContent = `${filtered.length} result${filtered.length !== 1 ? 's' : ''}`;
    noResults.style.display = filtered.length === 0 ? 'block' : 'none';
    resultsGrid.style.display = filtered.length > 0 ? 'flex' : 'none';

    filtered.forEach(p => {
      // Map marker
      const color = p.type === 'cafe' ? '#c4912a' : '#3a8fa8';
      const icon = L.divIcon({
        className: '',
        html: `<div style="width:12px;height:12px;border-radius:50%;background:${color};border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,0.25);"></div>`,
        iconSize: [12, 12],
        iconAnchor: [6, 6],
      });
      const marker = L.marker([p.lat, p.lon], { icon }).addTo(map);
      const cuisine = p.tags.cuisine ? ` · ${p.tags.cuisine.replace(/_/g,' ')}` : '';
      const hours   = p.tags.opening_hours ? `<br/><span style="font-size:0.75rem;color:#78716c;">${p.tags.opening_hours}</span>` : '';
      const phone   = p.tags.phone ? `<br/><span style="font-size:0.75rem;color:#78716c;">${p.tags.phone}</span>` : '';
      marker.bindPopup(`<strong style="font-size:0.85rem;">${p.name}</strong>${cuisine}${hours}${phone}`);
      markers.push(marker);

      // Card
      const card = document.createElement('div');
      card.className = 'place-card';
      const addr = [p.tags['addr:housenumber'], p.tags['addr:street'], p.tags['addr:suburb']]
        .filter(Boolean).join(' ');
      const cuisineLabel = p.tags.cuisine
        ? p.tags.cuisine.replace(/_/g,' ').replace(/;/g, ', ')
        : '';
      card.innerHTML = `
        <div class="place-dot ${p.type === 'cafe' ? 'dot-cafe' : 'dot-restaurant'}"></div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.3rem;">
            <span style="font-family:var(--font-serif);font-size:1rem;font-weight:400;color:var(--color-text-primary);">${p.name}</span>
            <span class="type-badge ${p.type === 'cafe' ? 'badge-cafe' : 'badge-restaurant'}">${p.type}</span>
          </div>
          ${cuisineLabel ? `<p style="font-size:0.78rem;color:var(--color-text-muted);text-transform:capitalize;margin-bottom:0.2rem;">${cuisineLabel}</p>` : ''}
          ${addr ? `<p style="font-size:0.78rem;color:var(--color-text-muted);">${addr}</p>` : ''}
          ${p.tags.opening_hours ? `<p style="font-size:0.75rem;color:var(--color-text-muted);margin-top:0.2rem;">${p.tags.opening_hours}</p>` : ''}
        </div>
        ${p.tags.website || p.tags['contact:website']
          ? `<a href="${p.tags.website || p.tags['contact:website']}" target="_blank" rel="noopener"
               style="font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-gold);white-space:nowrap;text-decoration:none;flex-shrink:0;align-self:center;">
               Visit →
             </a>`
          : ''}
      `;
      card.addEventListener('click', () => marker.openPopup());
      resultsGrid.appendChild(card);
    });
  }

  // ── Filter buttons ───────────────────────────────────────────────────────
  function setFilter(f: string) {
    activeFilter = f;
    const active = { background: '#1c1917', color: '#f0ece4', borderColor: '#1c1917' };
    const inactive = { background: 'transparent', color: '#78716c', borderColor: 'rgba(28,25,23,0.22)' };
    [btnAll, btnCafe, btnRest].forEach(b => {
      Object.assign(b.style, inactive);
    });
    const target = f === 'all' ? btnAll : f === 'cafe' ? btnCafe : btnRest;
    Object.assign(target.style, active);
    renderPlaces(allPlaces);
  }

  btnAll.addEventListener('click',  () => setFilter('all'));
  btnCafe.addEventListener('click', () => setFilter('cafe'));
  btnRest.addEventListener('click', () => setFilter('restaurant'));

  // ── Main search ───────────────────────────────────────────────────────────
  async function doSearch() {
    const suburb = suburbInput.value.trim();
    if (!suburb) return;

    searchBtn.disabled = true;
    searchBtn.textContent = 'Searching...';
    statusMsg.textContent = 'Locating suburb...';
    controlsRow.style.display = 'none';
    mapEl.style.display = 'none';
    resultsGrid.style.display = 'none';
    noResults.style.display = 'none';

    try {
      const coords = await geocodeSuburb(suburb);
      if (!coords) {
        statusMsg.textContent = 'Could not find that suburb. Try a more specific name like "Hawthorne, Brisbane".';
        return;
      }

      statusMsg.textContent = 'Loading cafes and restaurants...';

      // Init or reset map
      mapEl.style.display = 'block';
      if (!map) {
        map = L.map('map').setView([coords.lat, coords.lon], 15);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
          maxZoom: 19,
        }).addTo(map);
      } else {
        map.setView([coords.lat, coords.lon], 15);
      }

      allPlaces = await fetchPlaces(coords.lat, coords.lon);

      controlsRow.style.display = 'flex';
      activeFilter = 'all';
      setFilter('all');

      const total = allPlaces.length;
      statusMsg.textContent = total > 0
        ? `Found ${total} place${total !== 1 ? 's' : ''} within 1.2 km of ${suburb}.`
        : `No cafes or restaurants found near ${suburb}.`;

    } catch (e) {
      statusMsg.textContent = 'Something went wrong. Please try again.';
      console.error(e);
    } finally {
      searchBtn.disabled = false;
      searchBtn.innerHTML = 'Search <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>';
    }
  }

  searchBtn.addEventListener('click', doSearch);
  suburbInput.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') doSearch();
  });
</script>

</ToolLayout>
