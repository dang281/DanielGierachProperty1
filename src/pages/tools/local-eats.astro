---
import ToolLayout from '../../layouts/ToolLayout.astro';

const MAPS_KEY = 'AIzaSyD2sghjRZa7NJeUDKUm6_EHt_aAL0ntvzw';
---

<ToolLayout
  title="Local Cafes & Restaurants"
  tool="Local Cafes & Restaurants"
  phase="Buyer Tools"
  description="Find cafes and restaurants near any Brisbane suburb. Search by suburb to explore the local dining scene before you buy."
>

<style>
  #suburb-input {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid rgba(28,25,23,0.2);
    background: var(--color-surface-4);
    color: var(--color-text-primary);
    outline: none;
    transition: border-color 0.2s;
  }
  #suburb-input:focus { border-color: var(--color-gold); }
  #suburb-input::placeholder { color: var(--color-text-muted); }

  #map-frame {
    width: 100%;
    height: 520px;
    border: 1px solid rgba(28,25,23,0.1);
    display: none;
  }
</style>

<div style="display:flex;flex-direction:column;gap:1.5rem;">

  <!-- Search row -->
  <div>
    <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:0.5rem;">Suburb</label>
    <div style="display:flex;gap:0.75rem;">
      <input id="suburb-input" type="text" placeholder="e.g. Hawthorne, Balmoral, Coorparoo" autocomplete="off" />
      <button id="search-btn" class="btn-gold" style="white-space:nowrap;padding:0.9rem 1.5rem;flex-shrink:0;">
        Search
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </button>
    </div>
    <p id="status-msg" style="margin-top:0.6rem;min-height:1.2em;font-size:0.82rem;color:var(--color-text-muted);font-style:italic;"></p>
  </div>

  <!-- Filter row -->
  <div id="filter-row" style="display:none;gap:0.5rem;flex-wrap:wrap;">
    <button data-q="cafes and restaurants" class="qbtn" style="background:#1c1917;color:#f0ece4;border:1.5px solid #1c1917;padding:0.5rem 1.1rem;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.13em;text-transform:uppercase;cursor:pointer;">All</button>
    <button data-q="cafes"                 class="qbtn" style="background:transparent;color:#78716c;border:1.5px solid rgba(28,25,23,0.22);padding:0.5rem 1.1rem;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.13em;text-transform:uppercase;cursor:pointer;">Cafes</button>
    <button data-q="restaurants"           class="qbtn" style="background:transparent;color:#78716c;border:1.5px solid rgba(28,25,23,0.22);padding:0.5rem 1.1rem;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.13em;text-transform:uppercase;cursor:pointer;">Restaurants</button>
    <button data-q="bars and pubs"         class="qbtn" style="background:transparent;color:#78716c;border:1.5px solid rgba(28,25,23,0.22);padding:0.5rem 1.1rem;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.13em;text-transform:uppercase;cursor:pointer;">Bars &amp; Pubs</button>
  </div>

  <!-- Google Maps iframe -->
  <iframe id="map-frame" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>

</div>

<script define:vars={{ MAPS_KEY }}>
  const input     = document.getElementById('suburb-input');
  const searchBtn = document.getElementById('search-btn');
  const statusMsg = document.getElementById('status-msg');
  const filterRow = document.getElementById('filter-row');
  const mapFrame  = document.getElementById('map-frame');
  const qbtns     = document.querySelectorAll('.qbtn');

  let currentSuburb = '';
  let activeQ = 'cafes and restaurants';

  function buildUrl(suburb, q) {
    const query = encodeURIComponent(`${q} in ${suburb} Brisbane QLD`);
    return `https://www.google.com/maps/embed/v1/search?key=${MAPS_KEY}&q=${query}&zoom=15`;
  }

  function setActive(btn) {
    qbtns.forEach(b => {
      b.style.background  = 'transparent';
      b.style.color       = '#78716c';
      b.style.borderColor = 'rgba(28,25,23,0.22)';
    });
    btn.style.background  = '#1c1917';
    btn.style.color       = '#f0ece4';
    btn.style.borderColor = '#1c1917';
  }

  function showMap(suburb, q) {
    mapFrame.src = buildUrl(suburb, q);
    mapFrame.style.display = 'block';
  }

  function doSearch() {
    const suburb = input.value.trim();
    if (!suburb) return;
    currentSuburb = suburb;
    activeQ = 'cafes and restaurants';
    statusMsg.textContent = '';
    filterRow.style.display = 'flex';
    setActive(qbtns[0]);
    showMap(suburb, activeQ);
  }

  searchBtn.addEventListener('click', doSearch);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });

  qbtns.forEach(btn => {
    btn.addEventListener('click', () => {
      if (!currentSuburb) return;
      activeQ = btn.dataset.q;
      setActive(btn);
      showMap(currentSuburb, activeQ);
    });
  });
</script>

</ToolLayout>
