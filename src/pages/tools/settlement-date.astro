---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Settlement Date Calculator"
  description="Calculate the real settlement date from your contract date and conditions. Queensland business days, finance and building-and-pest condition periods, public holidays."
  tool="Settlement Date Calculator"
  phase="Seller Tools"
>
<div class="grid grid-cols-1 lg:grid-cols-5 gap-8 pt-8">

  <div class="lg:col-span-3 flex flex-col gap-6">

    <div style="background:var(--color-surface-3);padding:2rem;">
      <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:1rem;">Contract Date</label>
      <input type="date" id="contract-date" class="obs-input" style="width:100%;font-size:1rem;" />
      <p style="font-size:0.7rem;color:var(--color-text-muted);margin-top:0.5rem;">The date both parties signed the contract.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Cooling-Off (days)</label>
        <input type="number" id="cooling-off" value="5" min="0" max="14" class="obs-input" style="font-size:1rem;" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Finance (days)</label>
        <input type="number" id="finance-days" value="21" min="0" max="60" class="obs-input" style="font-size:1rem;" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Building &amp; Pest (days)</label>
        <input type="number" id="bp-days" value="14" min="0" max="30" class="obs-input" style="font-size:1rem;" />
      </div>
    </div>

    <div style="background:var(--color-surface-3);padding:2rem;">
      <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:1rem;">Settlement Days from Contract</label>
      <div class="flex items-center gap-3">
        <input type="range" id="settlement-days" min="14" max="120" step="1" value="30"
          style="flex:1;accent-color:var(--color-gold);cursor:pointer;height:3px;" />
        <div style="background:var(--color-surface-4);padding:0.5rem 0.75rem;min-width:5rem;text-align:center;">
          <span id="settlement-display" style="font-size:1rem;font-weight:700;color:var(--color-text-primary);">30 days</span>
        </div>
      </div>
    </div>

    <div style="background:var(--color-surface-3);padding:2rem;">
      <label style="display:flex;align-items:center;gap:0.75rem;cursor:pointer;">
        <input id="business-days" type="checkbox" checked style="width:18px;height:18px;cursor:pointer;accent-color:var(--color-gold);" />
        <span style="font-size:0.9rem;color:var(--color-text-primary);">Shift weekend/public holiday settlement to next business day</span>
      </label>
    </div>

  </div>

  <div class="lg:col-span-2">
    <div style="background:var(--color-surface-3);padding:2rem;position:sticky;top:6rem;">
      <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:var(--color-text-primary);margin-bottom:1.5rem;border-bottom:1px solid rgba(72,72,72,0.2);padding-bottom:1rem;">
        Timeline
      </h2>
      <div id="milestones" class="flex flex-col gap-0"></div>
      <div style="margin-top:1.5rem;padding:1.25rem;background:rgba(255,221,121,0.08);border-left:3px solid var(--color-gold);">
        <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.4rem;">Settlement Date</p>
        <p id="settlement-date" style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;color:var(--color-gold);line-height:1;"></p>
      </div>
      <p style="font-size:0.7rem;color:var(--color-text-muted);margin-top:1rem;line-height:1.6;">
        QLD public holidays excluded. Confirm exact dates with your solicitor before relying on them for finance or moving arrangements.
      </p>
      <a href="/walkthrough" class="btn-gold" style="width:100%;margin-top:1.5rem;justify-content:center;">Book a Free Appraisal</a>
    </div>
  </div>

</div>
</ToolLayout>

<script>
  // QLD public holidays 2026-2028 (approximate, confirm with Fair Trading QLD before relying on them).
  const HOLIDAYS = [
    '2026-01-01','2026-01-26','2026-04-03','2026-04-04','2026-04-05','2026-04-06','2026-04-25','2026-05-04','2026-08-12','2026-10-05','2026-12-25','2026-12-28',
    '2027-01-01','2027-01-26','2027-03-26','2027-03-27','2027-03-28','2027-03-29','2027-04-26','2027-05-03','2027-08-11','2027-10-04','2027-12-27','2027-12-28',
    '2028-01-03','2028-01-26','2028-04-14','2028-04-15','2028-04-16','2028-04-17','2028-04-25','2028-05-01','2028-08-09','2028-10-02','2028-12-25','2028-12-26',
  ];

  function addDays(d: Date, n: number): Date {
    const r = new Date(d); r.setDate(r.getDate() + n); return r;
  }
  function isBusinessDay(d: Date): boolean {
    const day = d.getDay();
    if (day === 0 || day === 6) return false;
    const iso = d.toISOString().slice(0,10);
    return !HOLIDAYS.includes(iso);
  }
  function nextBusinessDay(d: Date): Date {
    let r = new Date(d);
    while (!isBusinessDay(r)) r = addDays(r, 1);
    return r;
  }
  function fmtDate(d: Date): string {
    return d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' });
  }

  function calc() {
    const raw = (document.getElementById('contract-date') as HTMLInputElement).value;
    if (!raw) return;
    const contract = new Date(raw + 'T12:00:00');
    const coolOff = addDays(contract, Number((document.getElementById('cooling-off') as HTMLInputElement).value) || 0);
    const fin = addDays(contract, Number((document.getElementById('finance-days') as HTMLInputElement).value) || 0);
    const bp = addDays(contract, Number((document.getElementById('bp-days') as HTMLInputElement).value) || 0);
    let settle = addDays(contract, Number((document.getElementById('settlement-days') as HTMLInputElement).value) || 30);
    const shift = (document.getElementById('business-days') as HTMLInputElement).checked;
    if (shift) settle = nextBusinessDay(settle);

    const unconditional = new Date(Math.max(fin.getTime(), bp.getTime()));

    const milestones = [
      { label: 'Contract Date', date: contract },
      { label: 'Cooling-Off Ends', date: coolOff },
      { label: 'Finance Due', date: fin },
      { label: 'Building &amp; Pest Due', date: bp },
      { label: 'Unconditional', date: unconditional },
      { label: 'Settlement', date: settle, hi: true },
    ];

    document.getElementById('milestones')!.innerHTML = milestones.map(m => `
      <div style="display:flex;justify-content:space-between;align-items:center;padding:0.65rem 0;border-bottom:1px solid rgba(72,72,72,0.15);">
        <span style="font-size:0.8rem;color:${m.hi ? 'var(--color-gold)' : 'var(--color-text-muted)'};">${m.label}</span>
        <span style="font-size:0.78rem;font-weight:600;color:var(--color-text-primary);">${fmtDate(m.date)}</span>
      </div>
    `).join('');

    document.getElementById('settlement-date')!.textContent = fmtDate(settle);
    document.getElementById('settlement-display')!.textContent = `${(document.getElementById('settlement-days') as HTMLInputElement).value} days`;
  }

  const today = new Date().toISOString().slice(0,10);
  (document.getElementById('contract-date') as HTMLInputElement).value = today;
  document.querySelectorAll('input').forEach(el => el.addEventListener('input', calc));
  calc();
</script>
