---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Brisbane Topographic Map"
  tool="Topographic Map"
  phase="Buyer Tools"
  description="See contour lines, elevation shading and terrain across Brisbane. Search any address to view the topography and get a point elevation in metres above sea level."
>

<style>
  .tm-shell { max-width: 1400px; margin: 0 auto; padding: 1.25rem 1rem 3rem; }
  @media (min-width: 1024px) { .tm-shell { padding: 1.5rem 2rem 4rem; } }

  .tm-eduline {
    margin-bottom: 0.6rem;
    padding: 0.5rem 0.85rem;
    background: rgba(196,145,42,0.07);
    border-left: 3px solid var(--color-gold);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }
  .tm-eduline strong {
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-size: 0.62rem;
    margin-right: 0.4rem;
  }

  .tm-search-bar { display: flex; gap: 0.4rem; margin-bottom: 0.85rem; }
  #tm-search-wrap { position: relative; flex: 1; }
  #tm-search {
    width: 100%;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.95rem 1.1rem;
    border: 1px solid rgba(28,25,23,0.18);
    background: var(--color-surface-4);
    color: var(--color-text-primary);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  #tm-search:focus { border-color: var(--color-gold); box-shadow: 0 0 0 3px rgba(196,145,42,0.15); }
  #tm-search::placeholder { color: var(--color-text-muted); }
  #tm-search-btn {
    padding: 0 1.5rem;
    background: var(--color-gold); color: #0a0806;
    font-family: var(--font-sans);
    font-size: 0.7rem; font-weight: 800;
    letter-spacing: 0.1em; text-transform: uppercase;
    border: none; cursor: pointer; white-space: nowrap;
    transition: background 0.2s;
  }
  #tm-search-btn:hover { background: #d4af4a; }
  #tm-search-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  #tm-gps-btn {
    flex-shrink: 0; width: 46px;
    background: #f5f2eb;
    border: 1px solid rgba(28,25,23,0.12);
    color: rgba(28,25,23,0.5); cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: color 0.2s, background 0.2s;
  }
  #tm-gps-btn:hover { color: var(--color-gold); background: rgba(196,145,42,0.08); }
  #tm-gps-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  #tm-gps-btn.locating { color: var(--color-gold); }
  #tm-autocomplete {
    position: absolute; top: 100%; left: 0; right: 0;
    background: #ffffff;
    border: 1px solid rgba(28,25,23,0.12); border-top: none;
    z-index: 1100; max-height: 240px; overflow-y: auto;
    box-shadow: 0 8px 28px rgba(0,0,0,0.12);
  }
  .tm-ac-item {
    padding: 0.85rem 1rem; font-size: 0.85rem;
    color: rgba(28,25,23,0.88); cursor: pointer;
    border-bottom: 1px solid rgba(28,25,23,0.08); line-height: 1.4;
    min-height: 44px; display: flex; align-items: center;
    transition: background 0.15s;
  }
  .tm-ac-item:last-child { border-bottom: none; }
  .tm-ac-item:hover, .tm-ac-item:active { background: rgba(196,145,42,0.1); }

  @media (max-width: 640px) {
    .tm-search-sticky {
      position: sticky; top: 72px; z-index: 1010;
      background: var(--color-base);
      padding: 0.6rem 0 0.5rem;
      margin: 0 -0.75rem;
      padding-left: 0.75rem; padding-right: 0.75rem;
      border-bottom: 1px solid rgba(28,25,23,0.08);
      box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    }
    .tm-search-bar { margin-bottom: 0; }
    #tm-search { font-size: 16px; height: 48px; padding: 0 0.9rem; }
    #tm-search-btn { height: 48px; padding: 0 1rem; font-size: 0.68rem; }
    #tm-gps-btn { width: 48px; height: 48px; }
    .tm-ac-item { padding: 1rem; min-height: 48px; font-size: 0.92rem; }
    .tm-eduline { display: none; }
    #tm-map { height: calc(100svh - 133px) !important; }
    .leaflet-top.leaflet-left { top: auto !important; bottom: 68px !important; }
  }

  .tm-map-wrap { position: relative; }
  #tm-map { height: 700px; width: 100%; border: 1px solid rgba(28,25,23,0.1); background: #e8e3d8; }
  @media (max-width: 768px) { #tm-map { height: 540px; } }

  .tm-control {
    position: absolute;
    z-index: 500;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(28,25,23,0.1);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }
  .tm-control-tr { top: 12px; right: 12px; }

  #tm-status {
    position: absolute; top: 12px; left: 12px;
    z-index: 500;
    background: rgba(255,255,255,0.94);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(28,25,23,0.08);
    padding: 0.45rem 0.85rem;
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    max-width: 300px;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  @media (max-width: 768px) {
    #tm-status { left: 12px; right: 150px; max-width: none; font-size: 0.66rem; padding: 0.4rem 0.65rem; }
  }

  .tm-layer-toggle {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.55rem 0.85rem;
    background: transparent; border: none; cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }
  .tm-layer-toggle:hover { background: rgba(197,160,60,0.08); }
  .tm-layer-toggle .toggle-arrow { transition: transform 0.2s; opacity: 0.5; }
  .tm-layer-toggle[aria-expanded="true"] .toggle-arrow { transform: rotate(180deg); }
  .tm-layer-panel { display: none; border-top: 1px solid rgba(28,25,23,0.08); width: 260px; padding: 0.55rem 0.65rem 0.75rem; }
  .tm-layer-panel.open { display: block; }
  .tm-section-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.55rem; font-weight: 800; letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(28,25,23,0.45);
    padding: 0.35rem 0.5rem 0.25rem;
  }
  .tm-layer-row {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.45rem 0.5rem;
    cursor: pointer; user-select: none;
    transition: background 0.15s;
    border-radius: 2px;
  }
  .tm-layer-row:hover { background: rgba(197,160,60,0.06); }
  .tm-layer-row input { accent-color: var(--color-gold); cursor: pointer; }
  .tm-layer-name { font-family: var(--font-sans); font-size: 0.74rem; font-weight: 600; color: var(--color-text-primary); line-height: 1.3; }
  .tm-opacity-row { display: flex; align-items: center; gap: 0.55rem; padding: 0.5rem 0.5rem 0.2rem; }
  .tm-opacity-label { font-family: var(--font-sans); font-size: 0.58rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(28,25,23,0.55); white-space: nowrap; }
  #tm-opacity-val { color: rgba(196,145,42,0.9); }
  .tm-opacity-slider { flex: 1; accent-color: var(--color-gold); cursor: pointer; height: 3px; }

  /* Result drawer */
  #tm-result {
    position: absolute;
    left: 14px; bottom: 14px;
    z-index: 600;
    background: rgba(255,255,255,0.98);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border-left: 3px solid var(--color-gold);
    box-shadow: 0 8px 28px rgba(0,0,0,0.16);
    padding: 0.95rem 1.15rem;
    max-width: 320px;
    width: calc(100% - 28px);
    transform: translate3d(0, calc(100% + 24px), 0);
    transition: transform 0.28s cubic-bezier(0.2,0.7,0.2,1);
    visibility: hidden;
  }
  #tm-result.open { transform: translate3d(0,0,0); visibility: visible; }
  @media (min-width: 768px) { #tm-result { width: 320px; } }
  .tm-result-head { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.55rem; }
  .tm-eyebrow { font-family: var(--font-sans); font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-text-muted); }
  .tm-close { background: transparent; border: none; cursor: pointer; width: 26px; height: 26px; display: inline-flex; align-items: center; justify-content: center; color: var(--color-text-muted); padding: 0; transition: color 0.15s, background 0.15s; }
  .tm-close:hover { color: var(--color-text-primary); background: rgba(28,25,23,0.06); }
  #tm-elev-value { font-family: var(--font-serif); font-size: 1.85rem; font-weight: 400; color: var(--color-text-primary); line-height: 1; margin-bottom: 0.2rem; }
  #tm-elev-unit { font-size: 0.78rem; color: var(--color-text-muted); font-style: italic; }
  #tm-elev-coords { font-family: var(--font-sans); font-size: 0.68rem; color: var(--color-text-muted); margin-top: 0.55rem; padding-top: 0.55rem; border-top: 1px solid rgba(28,25,23,0.08); }
  #tm-elev-note { font-size: 0.7rem; color: var(--color-text-muted); margin-top: 0.5rem; line-height: 1.55; font-style: italic; }

  /* Footer */
  .tm-foot {
    margin-top: 0.85rem;
    display: flex; flex-wrap: wrap; gap: 0.85rem 1.5rem;
    align-items: baseline; justify-content: space-between;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  .tm-foot a {
    font-family: var(--font-sans);
    font-size: 0.62rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold); text-decoration: none;
    white-space: nowrap;
  }
  .tm-foot a:hover { color: #d4af4a; }
</style>

<div class="tm-shell">

  <p class="tm-eduline">
    <strong>Educational use only</strong> Contour lines and elevation shading are indicative, drawn from public terrain data (SRTM, OpenStreetMap, OpenTopoMap). Point elevations are accurate to roughly plus or minus 5 metres. Always commission a licensed survey for any building, drainage or boundary decision.
  </p>

  <div class="tm-search-sticky">
    <div class="tm-search-bar">
      <div id="tm-search-wrap">
        <input type="text" id="tm-search" placeholder="Search address e.g. 12 Oxford St, Bulimba" autocomplete="off" inputmode="search" enterkeyhint="search" />
        <div id="tm-autocomplete" style="display:none;"></div>
      </div>
      <button id="tm-search-btn">Search</button>
      <button id="tm-gps-btn" title="Use my location" aria-label="Use my location" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/><circle cx="12" cy="12" r="9" stroke-opacity="0.3"/></svg>
      </button>
    </div>
  </div>

  <div class="tm-map-wrap">
    <div id="tm-map"></div>

    <div id="tm-status">Search an address, tap anywhere on the map, or use your location to see the elevation.</div>

    <div class="tm-control tm-control-tr">
      <button class="tm-layer-toggle" id="tm-layer-toggle" aria-expanded="false" aria-controls="tm-layer-panel">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2l10 6-10 6L2 8l10-6zM2 16l10 6 10-6M2 12l10 6 10-6"/></svg>
        Layers
        <svg class="toggle-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="tm-layer-panel" id="tm-layer-panel">
        <span class="tm-section-label">Basemap</span>
        <label class="tm-layer-row">
          <input type="radio" name="tm-base" value="topo" checked />
          <span class="tm-layer-name">Topographic (OpenTopoMap)</span>
        </label>
        <label class="tm-layer-row">
          <input type="radio" name="tm-base" value="streets" />
          <span class="tm-layer-name">Streets (CARTO)</span>
        </label>
        <label class="tm-layer-row">
          <input type="radio" name="tm-base" value="satellite" />
          <span class="tm-layer-name">Satellite (Esri)</span>
        </label>
        <div class="tm-opacity-row">
          <span class="tm-opacity-label">Topo opacity <span id="tm-opacity-val">100%</span></span>
        </div>
        <div class="tm-opacity-row" style="padding-top:0;">
          <input type="range" id="tm-opacity-slider" min="20" max="100" step="5" value="100" class="tm-opacity-slider" />
        </div>
      </div>
    </div>

    <div id="tm-result" role="region" aria-label="Elevation">
      <div class="tm-result-head">
        <span class="tm-eyebrow" id="tm-result-eyebrow">Elevation</span>
        <button class="tm-close" id="tm-result-close" aria-label="Close">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="tm-elev-value">--</div>
      <div id="tm-elev-unit">metres above sea level</div>
      <div id="tm-elev-coords"></div>
      <p id="tm-elev-note">Educational estimate from SRTM 30m data. Use a licensed survey for any construction or drainage decision.</p>
    </div>
  </div>

  <div class="tm-foot">
    <span><strong style="color:var(--color-text-secondary);">For educational purposes only.</strong> Topographic tiles: OpenTopoMap (OSM + SRTM, CC-BY-SA). Point elevation: opentopodata.org (SRTM 30m). Indicative only. For surveys, building, drainage, or boundary decisions, commission a licensed surveyor and confirm flood and overland flow with Brisbane City Council.</span>
    <span style="display:flex;gap:1.25rem;align-items:center;flex-wrap:wrap;">
      <a href="https://opentopomap.org/" target="_blank" rel="noopener">OpenTopoMap &rarr;</a>
      <a href="https://www.opentopodata.org/" target="_blank" rel="noopener">OpenTopoData &rarr;</a>
      <a href="/tools/property-map">Property Map &rarr;</a>
    </span>
  </div>

  <div style="margin-top:3rem;background:#1c1917;padding:2.5rem 2rem;text-align:center;">
    <p style="font-family:var(--font-serif);font-size:clamp(1.1rem,2.4vw,1.6rem);font-weight:400;color:#f0ece4;line-height:1.3;margin-bottom:0.85rem;">
      Elevation, slope and overland flow shape what you can build and how a block sells.
    </p>
    <p style="font-size:0.85rem;color:rgba(240,236,228,0.6);max-width:54ch;margin:0 auto 1.5rem;line-height:1.75;">
      Daniel can help you read the terrain alongside flood overlays, easements and zoning so you understand what a sloping block really means before you buy or sell.
    </p>
    <a href="/contact" data-cta="tool_to_contact"
      style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.85rem 2rem;background:#c5a03c;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;"
      onmouseover="this.style.background='#d4af4a'" onmouseout="this.style.background='#c5a03c'">
      Ask Daniel
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</div>

<link rel="preconnect" href="https://a.tile.opentopomap.org" crossorigin />
<link rel="preconnect" href="https://basemaps.cartocdn.com" crossorigin />
<link rel="preconnect" href="https://server.arcgisonline.com" crossorigin />
<link rel="preconnect" href="https://photon.komoot.io" crossorigin />
<link rel="preconnect" href="https://nominatim.openstreetmap.org" crossorigin />
<link rel="preconnect" href="https://api.opentopodata.org" crossorigin />

<link rel="stylesheet" href="/lib/leaflet/leaflet.css" />
<link rel="preload" as="script" href="/lib/leaflet/leaflet.js" />
<script is:inline defer src="/lib/leaflet/leaflet.js"></script>

<script>
(function () {
  const L = (window as any).L;
  const BNE_BOUNDS: [[number,number],[number,number]] = [[-27.85, 152.66], [-27.07, 153.55]];

  let map: any;
  let pinMarker: any = null;
  let baseLayers: Record<string, any> = {};
  let currentBase = 'topo';
  let acDebounce: any;
  let elevAbort: AbortController | null = null;

  function initMap() {
    const Lwin = (window as any).L;
    map = Lwin.map('tm-map', { maxBounds: BNE_BOUNDS, minZoom: 9, maxBoundsViscosity: 0.5, tap: false })
      .setView([-27.5, 153.04], 11);
    map.attributionControl.setPrefix('');

    baseLayers.topo = Lwin.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap, SRTM &middot; style: OpenTopoMap (CC-BY-SA)',
      subdomains: 'abc', maxZoom: 17, opacity: 1,
    });
    baseLayers.streets = Lwin.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OSM &middot; CARTO',
      subdomains: 'abcd', maxZoom: 19,
    });
    baseLayers.satellite = Lwin.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      attribution: 'Imagery &copy; Esri, Maxar, Earthstar Geographics',
      maxZoom: 19,
    });

    baseLayers.topo.addTo(map);

    const sp = new URLSearchParams(location.search);
    const pLat = sp.get('lat'), pLng = sp.get('lng'), pZ = sp.get('z');
    if (pLat && pLng) {
      const la = parseFloat(pLat), lo = parseFloat(pLng);
      map.setView([la, lo], pZ ? parseInt(pZ) : 16);
      dropPin(la, lo);
      lookupElevation(la, lo);
    }

    map.on('click', (e: any) => {
      const { lat, lng } = e.latlng;
      dropPin(lat, lng);
      lookupElevation(lat, lng);
    });

    wireUpControls();
  }

  function dropPin(lat: number, lon: number) {
    const Lwin = (window as any).L;
    if (pinMarker) map.removeLayer(pinMarker);
    pinMarker = Lwin.marker([lat, lon], {
      icon: Lwin.divIcon({
        className: '',
        html: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="36" viewBox="0 0 28 36"><path d="M14 0C6.27 0 0 6.27 0 14c0 9.63 14 22 14 22S28 23.63 28 14C28 6.27 21.73 0 14 0zm0 20a6 6 0 1 1 0-12 6 6 0 0 1 0 12z" fill="#c5a03c" stroke="#fff" stroke-width="1.5"/></svg>`,
        iconSize: [28, 36], iconAnchor: [14, 36],
      }),
    }).addTo(map);
  }

  function flyTo(lat: number, lon: number) {
    map.setView([lat, lon], 16);
    dropPin(lat, lon);
    lookupElevation(lat, lon);
  }

  async function lookupElevation(lat: number, lon: number) {
    const status = document.getElementById('tm-status')!;
    const drawer = document.getElementById('tm-result')!;
    const valEl = document.getElementById('tm-elev-value')!;
    const unitEl = document.getElementById('tm-elev-unit')!;
    const coordsEl = document.getElementById('tm-elev-coords')!;
    const noteEl = document.getElementById('tm-elev-note')!;

    if (elevAbort) elevAbort.abort();
    elevAbort = new AbortController();

    status.textContent = 'Fetching elevation…';
    drawer.classList.add('open');
    valEl.textContent = '…';
    unitEl.textContent = 'metres above sea level';
    coordsEl.textContent = `${lat.toFixed(5)}, ${lon.toFixed(5)}`;
    noteEl.textContent = 'Educational estimate from SRTM 30m data. Use a licensed survey for any construction or drainage decision.';

    const url = `https://api.opentopodata.org/v1/srtm30m?locations=${lat},${lon}`;
    try {
      const r = await fetch(url, { signal: elevAbort.signal });
      const j = await r.json();
      const elev = j?.results?.[0]?.elevation;
      if (typeof elev === 'number') {
        valEl.textContent = elev.toFixed(1) + ' m';
        status.textContent = 'Click anywhere to check another point.';
      } else {
        valEl.textContent = 'Unavailable';
        unitEl.textContent = '';
        noteEl.textContent = 'Elevation service did not return a value for this point. The OpenTopoData service is rate-limited; try again in a moment.';
      }
    } catch (e) {
      if ((e as any)?.name === 'AbortError') return;
      valEl.textContent = 'Unavailable';
      unitEl.textContent = '';
      noteEl.textContent = 'Could not reach the elevation service. Contour lines on the map remain the most reliable read of the terrain.';
      status.textContent = 'Elevation lookup failed. Contour lines on the map still show the terrain.';
    }
  }

  function switchBase(key: string) {
    if (key === currentBase) return;
    if (baseLayers[currentBase]) map.removeLayer(baseLayers[currentBase]);
    baseLayers[key].addTo(map);
    currentBase = key;
    const slider = document.getElementById('tm-opacity-slider') as HTMLInputElement | null;
    const val = slider ? parseInt(slider.value) / 100 : 1;
    baseLayers.topo.setOpacity(key === 'topo' ? val : val);
  }

  async function geocode(addr: string) {
    const u = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(addr + ', Brisbane, Australia')}&format=json&limit=1&countrycodes=au`;
    const data = await fetch(u, { headers: { 'Accept-Language': 'en' } }).then(r => r.json());
    if (!data.length) throw new Error('not found');
    return { lat: parseFloat(data[0].lat), lon: parseFloat(data[0].lon) };
  }
  function suggestions(q: string) {
    return fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(q)}&limit=5&lang=en&bbox=152.6,-27.8,153.5,-27.1`)
      .then(r => r.json()).then(d => d.features || []);
  }
  function renderSuggestions(features: any[]) {
    const list = document.getElementById('tm-autocomplete')!;
    list.innerHTML = '';
    if (!features.length) { list.style.display = 'none'; return; }
    features.forEach(f => {
      const p = f.properties;
      const streetPart = p.housenumber && p.street ? `${p.housenumber} ${p.street}` : (p.street || p.name || '');
      const granular = p.suburb || p.locality || p.district || p.neighbourhood || p.county;
      const locality = granular || (p.city && p.city !== 'Brisbane' ? p.city : (p.postcode ? `Brisbane ${p.postcode}` : (p.city || '')));
      const label = [streetPart, locality].filter(Boolean).join(', ');
      const item = document.createElement('div');
      item.className = 'tm-ac-item';
      item.textContent = label;
      item.addEventListener('mousedown', () => {
        const lat = f.geometry.coordinates[1], lon = f.geometry.coordinates[0];
        (document.getElementById('tm-search') as HTMLInputElement).value = label;
        list.style.display = 'none';
        flyTo(lat, lon);
      });
      list.appendChild(item);
    });
    list.style.display = 'block';
  }

  async function doSearch() {
    const input = document.getElementById('tm-search') as HTMLInputElement;
    const v = input.value.trim();
    if (!v) return;
    const status = document.getElementById('tm-status')!;
    const btn = document.getElementById('tm-search-btn') as HTMLButtonElement;
    status.textContent = 'Locating address…';
    btn.disabled = true;
    document.getElementById('tm-autocomplete')!.style.display = 'none';
    try {
      const { lat, lon } = await geocode(v);
      flyTo(lat, lon);
    } catch {
      status.textContent = 'Address not found. Add the suburb (e.g. 12 Main St, Camp Hill).';
    }
    btn.disabled = false;
  }

  function wireUpControls() {
    const search = document.getElementById('tm-search') as HTMLInputElement;
    document.getElementById('tm-search-btn')!.addEventListener('click', doSearch);
    search.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
      if (e.key === 'Escape') document.getElementById('tm-autocomplete')!.style.display = 'none';
    });
    search.addEventListener('input', () => {
      clearTimeout(acDebounce);
      const q = search.value.trim();
      if (q.length < 3) { document.getElementById('tm-autocomplete')!.style.display = 'none'; return; }
      acDebounce = setTimeout(() => suggestions(q).then(renderSuggestions), 130);
    });
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target as Element).closest('#tm-search-wrap'))
        document.getElementById('tm-autocomplete')!.style.display = 'none';
    });

    const gpsBtn = document.getElementById('tm-gps-btn') as HTMLButtonElement | null;
    if (gpsBtn) {
      gpsBtn.addEventListener('click', () => {
        const st = document.getElementById('tm-status')!;
        if (!navigator.geolocation) { st.textContent = 'Geolocation not supported on this device.'; return; }
        st.textContent = 'Getting your location…';
        gpsBtn.disabled = true; gpsBtn.classList.add('locating');
        navigator.geolocation.getCurrentPosition(
          pos => { gpsBtn.disabled = false; gpsBtn.classList.remove('locating'); flyTo(pos.coords.latitude, pos.coords.longitude); },
          () => { gpsBtn.disabled = false; gpsBtn.classList.remove('locating'); st.textContent = 'Location denied. Try searching by address.'; },
          { timeout: 10000 }
        );
      });
    }

    const toggle = document.getElementById('tm-layer-toggle')!;
    const panel = document.getElementById('tm-layer-panel')!;
    toggle.addEventListener('click', () => {
      const open = panel.classList.toggle('open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    panel.querySelectorAll<HTMLInputElement>('input[name="tm-base"]').forEach(r => {
      r.addEventListener('change', () => { if (r.checked) switchBase(r.value); });
    });

    const slider = document.getElementById('tm-opacity-slider') as HTMLInputElement | null;
    if (slider) {
      slider.addEventListener('input', () => {
        const val = parseInt(slider.value);
        document.getElementById('tm-opacity-val')!.textContent = val + '%';
        if (baseLayers.topo) baseLayers.topo.setOpacity(val / 100);
      });
    }

    document.getElementById('tm-result-close')!.addEventListener('click', () => {
      document.getElementById('tm-result')!.classList.remove('open');
    });
  }

  function whenLeafletReady() {
    if ((window as any).L) initMap();
    else requestAnimationFrame(whenLeafletReady);
  }
  whenLeafletReady();
})();
</script>

</ToolLayout>
