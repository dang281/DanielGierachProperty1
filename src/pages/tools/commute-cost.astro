---
import ToolLayout from '../../layouts/ToolLayout.astro';
---


<ToolLayout
  title="Fuel Commute Cost Comparison"
  description="Compare the real annual fuel cost and drive time to work from your current home versus a property you are considering buying. Pin locations on the map and get instant results."
  tool="Fuel Commute Cost Comparison"
  phase="Buyer Tools"
>

<style is:global>
  /* ─── Layout ────────────────────────────────────────────── */
  .cc-alert {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    background: rgba(196,145,42,0.07);
    border-left: 3px solid var(--color-gold);
    padding: 0.9rem 1.1rem;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  /* ─── Vehicle bar ───────────────────────────────────────── */
  .cc-vehicle-bar {
    background: #fff;
    border: 1px solid rgba(28,25,23,0.1);
    padding: 1.25rem 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .cc-vfield {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .cc-vfield label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .cc-vinput {
    width: 72px;
    padding: 0.4rem 0.5rem;
    font-size: 0.82rem;
    font-family: var(--font-sans);
    color: var(--color-text-primary);
    background: var(--color-surface-4);
    border: 1.5px solid rgba(28,25,23,0.14);
    text-align: right;
    -moz-appearance: textfield;
  }
  .cc-vinput::-webkit-outer-spin-button,
  .cc-vinput::-webkit-inner-spin-button { -webkit-appearance: none; }
  .cc-vinput:focus { outline: none; border-color: var(--color-gold); }
  .cc-vpresets { display: flex; flex-wrap: wrap; gap: 0.35rem; align-items: center; }
  .cc-vpreset {
    padding: 0.3rem 0.65rem;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1.5px solid rgba(28,25,23,0.2);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .cc-vpreset:hover, .cc-vpreset.active {
    background: var(--color-gold);
    border-color: var(--color-gold);
    color: #0a0806;
  }
  .cc-vsep {
    width: 1px;
    height: 28px;
    background: rgba(28,25,23,0.1);
    flex-shrink: 0;
  }

  /* ─── Location pickers ──────────────────────────────────── */
  .cc-locations {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .cc-loc-card {
    background: #fff;
    border: 1px solid rgba(28,25,23,0.1);
    border-top: 3px solid rgba(28,25,23,0.12);
    padding: 1.1rem 1.25rem;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .cc-loc-card.work-card  { border-top-color: #c5a03c; }
  .cc-loc-card.home-card  { border-top-color: #7ec8e3; }
  .cc-loc-card.prop-card  { border-top-color: #a8e6a3; }
  .cc-loc-card.cc-active  { box-shadow: 0 0 0 2px var(--color-gold); }

  .cc-loc-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.65rem;
  }
  .cc-loc-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .work-card  .cc-loc-dot { background: #c5a03c; }
  .home-card  .cc-loc-dot { background: #3a8fa8; }
  .prop-card  .cc-loc-dot { background: #4a9e4a; }

  .cc-loc-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .work-card  .cc-loc-label { color: #b89a2a; }
  .home-card  .cc-loc-label { color: #3a8fa8; }
  .prop-card  .cc-loc-label { color: #4a9e4a; }

  .cc-search-wrap { position: relative; }
  .cc-search-input {
    width: 100%;
    padding: 0.5rem 0.65rem;
    font-size: 0.78rem;
    font-family: var(--font-sans);
    color: var(--color-text-primary);
    background: var(--color-surface-4);
    border: 1.5px solid rgba(28,25,23,0.12);
    box-sizing: border-box;
  }
  .cc-search-input:focus { outline: none; border-color: var(--color-gold); }
  .cc-suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 1000;
    background: #fff;
    border: 1px solid rgba(28,25,23,0.12);
    border-top: none;
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 200px;
    overflow-y: auto;
    box-shadow: 0 6px 20px rgba(28,25,23,0.1);
  }
  .cc-suggestions li {
    padding: 0.6rem 0.75rem;
    font-size: 0.74rem;
    color: var(--color-text-secondary);
    cursor: pointer;
    border-bottom: 1px solid rgba(28,25,23,0.05);
    line-height: 1.4;
  }
  .cc-suggestions li:hover { background: rgba(196,145,42,0.06); color: var(--color-text-primary); }
  .cc-loc-set {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    margin-top: 0.45rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: 1rem;
  }
  .cc-loc-set.is-set { color: var(--color-text-secondary); font-weight: 600; }

  .cc-map-hint {
    font-size: 0.62rem;
    color: var(--color-text-muted);
    text-align: center;
    padding: 0.4rem;
    background: rgba(28,25,23,0.03);
    border: 1px solid rgba(28,25,23,0.08);
    border-bottom: none;
    letter-spacing: 0.04em;
  }
  .cc-map-hint strong { color: var(--color-gold); }

  /* ─── Leaflet map ──────────────────────────────────────── */
  #cc-map {
    height: 500px;
    width: 100%;
    border: 1px solid rgba(28,25,23,0.12);
    margin-bottom: 1.5rem;
    z-index: 1;
  }

  /* ─── Results ──────────────────────────────────────────── */
  .cc-results {
    background: #fff;
    border: 1px solid rgba(28,25,23,0.1);
    overflow: hidden;
  }
  .cc-results-header {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    background: #1c1917;
    color: #f0ece4;
  }
  .cc-rh-cell {
    padding: 0.75rem 1rem;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .cc-rh-cell:first-child { color: var(--color-text-muted); }
  .cc-rh-work  { color: #c5a03c !important; }
  .cc-rh-home  { color: #7ec8e3 !important; }
  .cc-rh-prop  { color: #a8e6a3 !important; }

  .cc-rrow {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    border-bottom: 1px solid rgba(28,25,23,0.05);
  }
  .cc-rrow:last-child { border-bottom: none; }
  .cc-rcell {
    padding: 0.85rem 1rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    border-right: 1px solid rgba(28,25,23,0.05);
  }
  .cc-rcell:last-child { border-right: none; }
  .cc-rcell.label-cell {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0.03em;
  }
  .cc-rcell.val { font-weight: 600; color: var(--color-text-primary); }
  .cc-rcell.saving { color: #4a9e4a; font-weight: 700; }
  .cc-rcell.more   { color: #c0392b; font-weight: 600; }
  .cc-rcell.total-row { background: rgba(196,145,42,0.05); font-weight: 700; font-size: 0.88rem; color: var(--color-text-primary); }
  .cc-placeholder {
    text-align: center;
    padding: 3rem 2rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ─── Google Places autocomplete styling ─────────────── */
  .pac-container {
    border: 1px solid rgba(28,25,23,0.14);
    border-top: none;
    border-radius: 0;
    box-shadow: 0 6px 20px rgba(28,25,23,0.1);
    font-family: var(--font-sans);
  }
  .pac-item {
    padding: 0.5rem 0.75rem;
    font-size: 0.74rem;
    color: var(--color-text-secondary);
    border-top: 1px solid rgba(28,25,23,0.05);
    cursor: pointer;
  }
  .pac-item:hover, .pac-item-selected { background: rgba(196,145,42,0.06); }
  .pac-item-query { font-size: 0.76rem; color: var(--color-text-primary); }
  .pac-icon { display: none; }
  .pac-logo::after { display: none; }

  /* ─── Loading spinner ─────────────────────────────────── */
  .cc-loading {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 2px solid rgba(196,145,42,0.3);
    border-top-color: var(--color-gold);
    border-radius: 50%;
    animation: cc-spin 0.6s linear infinite;
    vertical-align: middle;
    margin-left: 0.5rem;
  }
  @keyframes cc-spin { to { transform: rotate(360deg); } }

  /* ─── Mobile ──────────────────────────────────────────── */
  @media (max-width: 860px) {
    .cc-locations { grid-template-columns: 1fr; }
    #cc-map { height: 340px; }
    .cc-vehicle-bar { gap: 1rem; }
    .cc-vsep { display: none; }
  }
  @media (max-width: 560px) {
    .cc-vinput { width: 58px; }
  }
</style>

<div class="cc-alert">
  <strong>The hidden cost of a longer commute.</strong> With Brisbane fuel above $2/litre, a property 10 km further from work can cost $1,500+ more per year just in fuel. Pin your work, current home, and a property you are considering to see the real comparison.
</div>

<!-- ── Vehicle & Fuel ──────────────────────────────────────────── -->
<div class="cc-vehicle-bar">
  <div class="cc-vfield">
    <label>Fuel $/L</label>
    <input class="cc-vinput" id="fuelPrice" type="number" value="2.60" min="0.5" max="5" step="0.01" />
  </div>
  <div class="cc-vsep"></div>
  <div class="cc-vfield" style="flex-wrap:wrap;gap:0.35rem;">
    <label style="width:100%;">Peak-hour fuel efficiency</label>
    <div class="cc-vpresets" id="effPresets">
      <button class="cc-vpreset" data-eff="8">Small car<br/><span style="opacity:0.6;font-size:0.55rem;">8 L/100</span></button>
      <button class="cc-vpreset" data-eff="11">Sedan<br/><span style="opacity:0.6;font-size:0.55rem;">11 L/100</span></button>
      <button class="cc-vpreset active" data-eff="12">SUV<br/><span style="opacity:0.6;font-size:0.55rem;">12 L/100</span></button>
      <button class="cc-vpreset" data-eff="16">Ute/4WD<br/><span style="opacity:0.6;font-size:0.55rem;">16 L/100</span></button>
    </div>
    <input class="cc-vinput" id="fuelEff" type="number" value="12" min="3" max="30" step="0.5" style="width:62px;" />
    <span style="font-size:0.7rem;color:var(--color-text-muted);">L/100km</span>
    <span style="font-size:0.62rem;color:var(--color-text-muted);width:100%;margin-top:0.1rem;">Peak-hour stop-start + A/C typically uses 20-40% more than manufacturer ratings.</span>
  </div>
  <div class="cc-vsep"></div>
  <div class="cc-vfield">
    <label>Days/week</label>
    <input class="cc-vinput" id="daysPerWeek" type="number" value="5" min="1" max="7" step="1" />
  </div>
  <div class="cc-vfield">
    <label>Weeks/year</label>
    <input class="cc-vinput" id="weeksPerYear" type="number" value="46" min="1" max="52" step="1" />
  </div>
</div>

<!-- ── Location Pickers ────────────────────────────────────────── -->
<div class="cc-locations">

  <div class="cc-loc-card work-card cc-active" id="locWork">
    <div class="cc-loc-header">
      <span class="cc-loc-dot"></span>
      <span class="cc-loc-label">Workplace</span>
    </div>
    <div class="cc-search-wrap">
      <input class="cc-search-input" id="searchWork" type="text" placeholder="Search work address..." />
    </div>
    <div class="cc-loc-set" id="setWork">Click card, then click map, or search above</div>
  </div>

  <div class="cc-loc-card home-card" id="locHome">
    <div class="cc-loc-header">
      <span class="cc-loc-dot"></span>
      <span class="cc-loc-label">Current Home</span>
    </div>
    <div class="cc-search-wrap">
      <input class="cc-search-input" id="searchHome" type="text" placeholder="Search current address..." />
    </div>
    <div class="cc-loc-set" id="setHome">Click card, then click map, or search above</div>
  </div>

  <div class="cc-loc-card prop-card" id="locProp">
    <div class="cc-loc-header">
      <span class="cc-loc-dot"></span>
      <span class="cc-loc-label">Property Considering</span>
    </div>
    <div class="cc-search-wrap">
      <input class="cc-search-input" id="searchProp" type="text" placeholder="Search property address..." />
    </div>
    <div class="cc-loc-set" id="setProp">Click card, then click map, or search above</div>
  </div>

</div>

<!-- ── Map ─────────────────────────────────────────────────────── -->
<div class="cc-map-hint">
  Placing: <strong id="mapModeLabel">Workplace</strong> &nbsp;·&nbsp; Click a location card above to switch &nbsp;·&nbsp; Click the map to drop a pin &nbsp;·&nbsp; Drag pins to adjust
</div>
<div id="cc-map"></div>

<!-- ── Results ─────────────────────────────────────────────────── -->
<div class="cc-results" id="ccResults">
  <div class="cc-placeholder" id="ccPlaceholder">
    Set at least your <strong>Workplace</strong> and one home location above to see your commute comparison.
  </div>
  <div id="ccTable" style="display:none;">
    <div class="cc-results-header">
      <div class="cc-rh-cell"></div>
      <div class="cc-rh-cell cc-rh-home" id="hdrHome">Current Home</div>
      <div class="cc-rh-cell cc-rh-prop" id="hdrProp">New Property</div>
    </div>

    <div class="cc-rrow">
      <div class="cc-rcell label-cell">Daily distance (return)</div>
      <div class="cc-rcell val" id="homeDist">-</div>
      <div class="cc-rcell val" id="propDist">-</div>
    </div>
    <div class="cc-rrow">
      <div class="cc-rcell label-cell">Daily drive time (return, peak)</div>
      <div class="cc-rcell val" id="homeTime">-</div>
      <div class="cc-rcell val" id="propTime">-</div>
    </div>
    <div class="cc-rrow">
      <div class="cc-rcell label-cell">Weekly fuel cost</div>
      <div class="cc-rcell val" id="homeFuelWk">-</div>
      <div class="cc-rcell val" id="propFuelWk">-</div>
    </div>
    <div class="cc-rrow">
      <div class="cc-rcell label-cell">Annual fuel cost</div>
      <div class="cc-rcell val" id="homeFuelYr">-</div>
      <div class="cc-rcell val" id="propFuelYr">-</div>
    </div>
    <div class="cc-rrow">
      <div class="cc-rcell label-cell">Hours per year commuting</div>
      <div class="cc-rcell val" id="homeHrsYr">-</div>
      <div class="cc-rcell val" id="propHrsYr">-</div>
    </div>
    <div class="cc-rrow">
      <div class="cc-rcell label-cell total-row">Annual difference</div>
      <div class="cc-rcell total-row" style="color:var(--color-text-muted);font-style:italic;">Baseline</div>
      <div class="cc-rcell total-row" id="propDiff">-</div>
    </div>
  </div>
</div>

<div style="margin-top:2rem;padding:1.5rem;background:#f7f5f0;border:1px solid rgba(28,25,23,0.08);">
  <h3 style="font-family:var(--font-serif);font-size:1rem;font-weight:400;color:#1c1917;margin-bottom:1rem;">Calculation Assumptions</h3>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:0.75rem;">
    <div style="font-size:0.72rem;color:#78716c;line-height:1.7;">
      <strong style="display:block;color:#1c1917;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Traffic data</strong>
      Drive times are fetched from Google Maps using Tuesday 8:00 am as the departure time, representing a typical peak-hour morning commute.
    </div>
    <div style="font-size:0.72rem;color:#78716c;line-height:1.7;">
      <strong style="display:block;color:#1c1917;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Return journey</strong>
      Daily distance and time shown are return trips (to work and back). Annual figures multiply the return trip by days per week x weeks per year (your inputs above).
    </div>
    <div style="font-size:0.72rem;color:#78716c;line-height:1.7;">
      <strong style="display:block;color:#1c1917;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Fuel cost formula</strong>
      Annual fuel = (one-way km x 2) / 100 x peak-hour fuel efficiency (L/100km) x fuel price ($/L) x days/week x weeks/year. Peak-hour figures are set higher than manufacturer ratings to account for stop-start driving and A/C load.
    </div>
    <div style="font-size:0.72rem;color:#78716c;line-height:1.7;">
      <strong style="display:block;color:#1c1917;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Fuel only</strong>
      This tool calculates fuel costs only. Tolls, parking, registration, insurance, depreciation and maintenance are not included.
    </div>
    <div style="font-size:0.72rem;color:#78716c;line-height:1.7;">
      <strong style="display:block;color:#1c1917;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Annual hours</strong>
      Hours per year = (one-way drive minutes x 2) / 60 x days/week x weeks/year.
    </div>
    <div style="font-size:0.72rem;color:#78716c;line-height:1.7;">
      <strong style="display:block;color:#1c1917;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Annual difference</strong>
      The "Annual difference" row shows the extra fuel cost of the New Property commute compared to your Current Home commute each year.
    </div>
    <div style="font-size:0.72rem;color:#78716c;line-height:1.7;">
      <strong style="display:block;color:#1c1917;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Default fuel price</strong>
      Defaults to $2.60/L (Brisbane unleaded, March 2026). Update this to the current bowser price for the most accurate estimate.
    </div>
    <div style="font-size:0.72rem;color:#78716c;line-height:1.7;">
      <strong style="display:block;color:#1c1917;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.2rem;">Estimates only</strong>
      Results are indicative. Actual fuel costs vary with driving style, traffic, vehicle condition and fuel price fluctuations.
    </div>
  </div>
</div>

</ToolLayout>

<script is:inline>
(function () {
  const GMAPS_KEY = 'AIzaSyD2sghjRZa7NJeUDKUm6_EHt_aAL0ntvzw';

  /* ── Load Google Maps JS ─────────────────────────────────── */
  function loadScript(src) {
    return new Promise(resolve => {
      const s = document.createElement('script');
      s.src = src;
      s.async = true;
      s.onload = resolve;
      document.head.appendChild(s);
    });
  }

  loadScript(`https://maps.googleapis.com/maps/api/js?key=${GMAPS_KEY}&libraries=places`).then(initTool);

  /* ── State ───────────────────────────────────────────────── */
  const coords = { work: null, home: null, prop: null };
  const routes = { home: null, prop: null };
  let activeMode = 'work';
  let map, markers = {}, dirRenderers = {};

  /* ── Helpers ─────────────────────────────────────────────── */
  const $ = id => document.getElementById(id);
  const num = (id, def) => { const v = parseFloat(document.getElementById(id)?.value); return isNaN(v) ? def : v; };
  const fmt$ = n => '$' + Math.round(n).toLocaleString('en-AU');
  const fmtKm = n => n.toFixed(1) + ' km';
  const fmtMin = n => n < 60 ? n + ' min' : Math.floor(n/60) + ' h ' + (n%60) + ' min';

  const modeColors = { work: '#c5a03c', home: '#3a8fa8', prop: '#4a9e4a' };
  const modeLabels = { work: 'Workplace', home: 'Current Home', prop: 'New Property' };

  /* ── Google Maps marker icons ────────────────────────────── */
  function makeIcon(color) {
    const svg = encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" width="28" height="38" viewBox="0 0 28 38">
      <path d="M14 0C6.27 0 0 6.27 0 14c0 9.33 14 24 14 24S28 23.33 28 14C28 6.27 21.73 0 14 0z" fill="${color}" filter="drop-shadow(0 2px 3px rgba(0,0,0,0.3))"/>
      <circle cx="14" cy="14" r="6" fill="white"/>
    </svg>`);
    return {
      url: `data:image/svg+xml;charset=UTF-8,${svg}`,
      scaledSize: new google.maps.Size(28, 38),
      anchor: new google.maps.Point(14, 38)
    };
  }

  /* ── Clean map style ─────────────────────────────────────── */
  const MAP_STYLE = [
    { elementType: 'geometry', stylers: [{ color: '#f5f4f0' }] },
    { elementType: 'labels.icon', stylers: [{ visibility: 'off' }] },
    { elementType: 'labels.text.fill', stylers: [{ color: '#57534e' }] },
    { elementType: 'labels.text.stroke', stylers: [{ color: '#f5f4f0' }] },
    { featureType: 'poi', stylers: [{ visibility: 'off' }] },
    { featureType: 'poi.park', stylers: [{ visibility: 'on' }] },
    { featureType: 'poi.park', elementType: 'geometry', stylers: [{ color: '#dde8d0' }] },
    { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#ffffff' }] },
    { featureType: 'road.arterial', elementType: 'geometry', stylers: [{ color: '#ede9e3' }] },
    { featureType: 'road.highway', elementType: 'geometry', stylers: [{ color: '#d4cfc8' }] },
    { featureType: 'road.highway', elementType: 'geometry.stroke', stylers: [{ color: '#c5bfb8' }] },
    { featureType: 'transit', stylers: [{ visibility: 'off' }] },
    { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#b8d4e8' }] },
    { featureType: 'water', elementType: 'labels.text.fill', stylers: [{ color: '#78a0b8' }] },
  ];

  /* ── Peak hour departure time (next Tuesday 8am local) ──── */
  function getNextPeakTime() {
    const d = new Date();
    const day = d.getDay(); // 0=Sun, 2=Tue
    const daysToTuesday = (2 - day + 7) % 7 || 7;
    d.setDate(d.getDate() + daysToTuesday);
    d.setHours(8, 0, 0, 0);
    return d;
  }

  /* ── Google Maps Distance Matrix routing ─────────────────── */
  function getRoute(from, to) {
    return new Promise(resolve => {
      const svc = new google.maps.DistanceMatrixService();
      svc.getDistanceMatrix({
        origins: [new google.maps.LatLng(from.lat, from.lng)],
        destinations: [new google.maps.LatLng(to.lat, to.lng)],
        travelMode: google.maps.TravelMode.DRIVING,
        drivingOptions: {
          departureTime: getNextPeakTime(),
          trafficModel: google.maps.TrafficModel.BEST_GUESS
        },
        unitSystem: google.maps.UnitSystem.METRIC
      }, (res, status) => {
        if (status !== 'OK') { resolve(null); return; }
        const el = res.rows[0]?.elements[0];
        if (!el || el.status !== 'OK') { resolve(null); return; }
        resolve({
          distKm: el.distance.value / 1000,
          durationMin: Math.round((el.duration_in_traffic || el.duration).value / 60)
        });
      });
    });
  }

  /* ── Google Places Autocomplete ──────────────────────────── */
  function setupAutocomplete(inputId, mode) {
    const input = $(inputId);
    if (!input) return;

    input.addEventListener('focus', () => setMode(mode));

    const ac = new google.maps.places.Autocomplete(input, {
      componentRestrictions: { country: 'au' },
      fields: ['geometry', 'formatted_address', 'name', 'address_components']
    });

    ac.addListener('place_changed', () => {
      const place = ac.getPlace();
      if (!place.geometry?.location) return;
      const lat = place.geometry.location.lat();
      const lng = place.geometry.location.lng();
      placeMarker(mode, lat, lng);
      const setEl = $({ work: 'setWork', home: 'setHome', prop: 'setProp' }[mode]);
      if (setEl) {
        const components = place.address_components || [];
        const suburb = (
          components.find(c => c.types.includes('locality')) ||
          components.find(c => c.types.includes('sublocality')) ||
          components.find(c => c.types.includes('neighborhood'))
        )?.long_name || (place.formatted_address || place.name || '').split(',')[0];
        setEl.textContent = suburb;
        setEl.classList.add('is-set');
      }
    });
  }

  /* ── Place / move a marker ───────────────────────────────── */
  function placeMarker(mode, lat, lng) {
    coords[mode] = { lat, lng };
    const pos = new google.maps.LatLng(lat, lng);

    if (markers[mode]) {
      markers[mode].setPosition(pos);
    } else {
      markers[mode] = new google.maps.Marker({
        map,
        position: pos,
        icon: makeIcon(modeColors[mode]),
        draggable: true,
        title: modeLabels[mode]
      });
      markers[mode].addListener('dragend', e => {
        coords[mode] = { lat: e.latLng.lat(), lng: e.latLng.lng() };
        updateSetLabel(mode, coords[mode].lat, coords[mode].lng);
        recalcRoutes();
      });
    }

    updateSetLabel(mode, lat, lng);
    recalcRoutes();
  }

  const geocoder = new google.maps.Geocoder();

  function updateSetLabel(mode, lat, lng) {
    const labelEl = $({ work: 'setWork', home: 'setHome', prop: 'setProp' }[mode]);
    const inputEl = $({ work: 'searchWork', home: 'searchHome', prop: 'searchProp' }[mode]);

    // Show short coords immediately as fallback
    if (labelEl) {
      labelEl.textContent = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
      labelEl.classList.add('is-set');
    }

    // Reverse geocode, 4 second timeout in case API is slow or not enabled
    let resolved = false;
    const fallbackTimer = setTimeout(() => {
      if (!resolved && labelEl) labelEl.textContent = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
    }, 4000);

    geocoder.geocode({ location: { lat, lng } }, (results, status) => {
      resolved = true;
      clearTimeout(fallbackTimer);
      if (status === 'OK' && results[0]) {
        const components = results[0].address_components;
        const suburb = (
          components.find(c => c.types.includes('locality')) ||
          components.find(c => c.types.includes('sublocality')) ||
          components.find(c => c.types.includes('neighborhood'))
        )?.long_name || results[0].formatted_address;
        if (labelEl) labelEl.textContent = suburb;
        if (inputEl) inputEl.value = results[0].formatted_address;
      }
    });
  }

  /* ── Mode selection ──────────────────────────────────────── */
  function setMode(mode) {
    activeMode = mode;
    $('mapModeLabel').textContent = modeLabels[mode];
    ['work', 'home', 'prop'].forEach(m => {
      const card = $({ work: 'locWork', home: 'locHome', prop: 'locProp' }[m]);
      if (card) card.classList.toggle('cc-active', m === mode);
    });
  }

  /* ── Draw route polyline on map ──────────────────────────── */
  function drawRoute(from, to, routeKey, color) {
    const dirService = new google.maps.DirectionsService();
    if (!dirRenderers[routeKey]) {
      dirRenderers[routeKey] = new google.maps.DirectionsRenderer({
        map,
        suppressMarkers: true,
        polylineOptions: { strokeColor: color, strokeWeight: 5, strokeOpacity: 0.75 }
      });
    }
    dirService.route({
      origin: new google.maps.LatLng(from.lat, from.lng),
      destination: new google.maps.LatLng(to.lat, to.lng),
      travelMode: google.maps.TravelMode.DRIVING,
      drivingOptions: {
        departureTime: getNextPeakTime(),
        trafficModel: google.maps.TrafficModel.BEST_GUESS
      }
    }, (result, status) => {
      if (status === 'OK') dirRenderers[routeKey].setDirections(result);
    });
  }

  function clearRoute(routeKey) {
    if (dirRenderers[routeKey]) {
      dirRenderers[routeKey].setMap(null);
      delete dirRenderers[routeKey];
    }
  }

  /* ── Fit map to all markers ──────────────────────────────── */
  function fitMapToBounds() {
    const pts = Object.values(coords).filter(Boolean);
    if (pts.length === 0) return;
    if (pts.length === 1) { map.setCenter({ lat: pts[0].lat, lng: pts[0].lng }); map.setZoom(14); return; }
    const bounds = new google.maps.LatLngBounds();
    pts.forEach(p => bounds.extend(new google.maps.LatLng(p.lat, p.lng)));
    map.fitBounds(bounds);
  }

  /* ── Recalculate routes and update table ─────────────────── */
  async function recalcRoutes() {
    const w = coords.work;

    // Clear routes if work not set
    if (!w) { clearRoute('home'); clearRoute('prop'); renderResults(); return; }

    // Draw route lines on map
    if (coords.home) drawRoute(coords.home, w, 'home', '#3a8fa8');
    else clearRoute('home');
    if (coords.prop) drawRoute(coords.prop, w, 'prop', '#4a9e4a');
    else clearRoute('prop');

    fitMapToBounds();

    // Fetch distance matrix data in parallel
    const [rHome, rProp] = await Promise.all([
      coords.home ? getRoute(coords.home, w) : Promise.resolve(null),
      coords.prop ? getRoute(coords.prop, w) : Promise.resolve(null)
    ]);

    routes.home = rHome;
    routes.prop = rProp;
    renderResults();
  }

  /* ── Render results table ────────────────────────────────── */
  function renderResults() {
    const fuelPrice   = num('fuelPrice', 2.60);
    const fuelEff     = num('fuelEff', 12);
    const days        = num('daysPerWeek', 5);
    const weeks       = num('weeksPerYear', 46);

    const hasWork = !!coords.work;
    const hasHome = !!routes.home;
    const hasProp = !!routes.prop;

    if (!hasWork || (!hasHome && !hasProp)) {
      $('ccPlaceholder').style.display = '';
      $('ccTable').style.display = 'none';
      return;
    }

    $('ccPlaceholder').style.display = 'none';
    $('ccTable').style.display = '';

    function fuelPerYear(distKm) {
      if (!distKm) return null;
      return (distKm * 2 / 100) * fuelEff * fuelPrice * days * weeks;
    }
    function fuelPerWeek(distKm) {
      if (!distKm) return null;
      return (distKm * 2 / 100) * fuelEff * fuelPrice * days;
    }
    function hrsPerYear(durMin) {
      if (!durMin) return null;
      return (durMin * 2 * days * weeks) / 60;
    }

    const setText = (id, v) => { const el = $(id); if (el) el.textContent = v; };
    const setClass = (id, cls) => { const el = $(id); if (el) { el.className = 'cc-rcell ' + cls; } };

    // Home row
    if (hasHome) {
      setText('homeDist', fmtKm(routes.home.distKm * 2));
      setText('homeTime', fmtMin(routes.home.durationMin * 2));
      setText('homeFuelWk', fmt$(fuelPerWeek(routes.home.distKm)));
      setText('homeFuelYr', fmt$(fuelPerYear(routes.home.distKm)));
      const hrs = hrsPerYear(routes.home.durationMin);
      setText('homeHrsYr', hrs.toFixed(0) + ' hrs');
    } else {
      ['homeDist','homeTime','homeFuelWk','homeFuelYr','homeHrsYr'].forEach(id => setText(id, '-'));
    }

    // Property row + diff
    if (hasProp) {
      setText('propDist', fmtKm(routes.prop.distKm * 2));
      setText('propTime', fmtMin(routes.prop.durationMin * 2));
      setText('propFuelWk', fmt$(fuelPerWeek(routes.prop.distKm)));
      setText('propFuelYr', fmt$(fuelPerYear(routes.prop.distKm)));
      const hrs = hrsPerYear(routes.prop.durationMin);
      setText('propHrsYr', hrs.toFixed(0) + ' hrs');

      // Diff vs home
      if (hasHome) {
        const diffFuel = fuelPerYear(routes.prop.distKm) - fuelPerYear(routes.home.distKm);
        const diffEl = $('propDiff');
        if (diffFuel > 0) {
          setText('propDiff', '+' + fmt$(diffFuel) + '/yr more');
          setClass('propDiff', 'cc-rcell total-row more');
        } else if (diffFuel < 0) {
          setText('propDiff', fmt$(Math.abs(diffFuel)) + '/yr saving');
          setClass('propDiff', 'cc-rcell total-row saving');
        } else {
          setText('propDiff', 'Same cost');
          setClass('propDiff', 'cc-rcell total-row');
        }
      } else {
        setText('propDiff', '-');
      }
    } else {
      ['propDist','propTime','propFuelWk','propFuelYr','propHrsYr','propDiff'].forEach(id => setText(id, '-'));
    }

    // Column headers with labels
    if (coords.home) $('hdrHome').textContent = $('searchHome').value.split(',')[0] || 'Current Home';
    if (coords.prop) $('hdrProp').textContent = $('searchProp').value.split(',')[0] || 'New Property';
  }

  /* ── Init map and wire up everything ────────────────────── */
  function initTool() {
    // Google Maps centred on Brisbane
    map = new google.maps.Map(document.getElementById('cc-map'), {
      center: { lat: -27.4698, lng: 153.0251 },
      zoom: 11,
      styles: MAP_STYLE,
      mapTypeControl: false,
      streetViewControl: false,
      fullscreenControl: false,
      clickableIcons: false
    });

    // Map click places active mode marker
    map.addListener('click', e => placeMarker(activeMode, e.latLng.lat(), e.latLng.lng()));

    // Location card clicks set mode
    $('locWork')?.addEventListener('click', () => setMode('work'));
    $('locHome')?.addEventListener('click', () => setMode('home'));
    $('locProp')?.addEventListener('click', () => setMode('prop'));

    // Google Places Autocomplete on each search box
    setupAutocomplete('searchWork', 'work');
    setupAutocomplete('searchHome', 'home');
    setupAutocomplete('searchProp', 'prop');

    // Vehicle efficiency presets
    document.querySelectorAll('#effPresets .cc-vpreset').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('fuelEff').value = btn.dataset.eff;
        document.querySelectorAll('#effPresets .cc-vpreset').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderResults();
      });
    });

    // Fuel/days/weeks inputs
    ['fuelPrice','fuelEff','daysPerWeek','weeksPerYear'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', renderResults);
    });
  }
})();
</script>
