  // ── Property summary (parcel + school catchments) ────────────────────
  const SCHOOL_BASE = 'https://spatial-gis.information.qld.gov.au/arcgis/rest/services/Society/SchoolsAndSchoolCatchments/MapServer';

  function haversineMetres(lat1: number, lon1: number, lat2: number, lon2: number): number {
    const R = 6371000;
    const f1 = lat1 * Math.PI / 180, f2 = lat2 * Math.PI / 180;
    const df = (lat2 - lat1) * Math.PI / 180, dl = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(df/2)**2 + Math.cos(f1) * Math.cos(f2) * Math.sin(dl/2)**2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  function generateParcelSVG(rings: number[][][], areaRaw: number): string {
    const coords = rings[0] || [];
    if (coords.length < 3) return '';
    const verts = coords.slice(0, -1);
    let minLon = Infinity, maxLon = -Infinity, minLat = Infinity, maxLat = -Infinity;
    verts.forEach(([lon, lat]: number[]) => {
      if (lon < minLon) minLon = lon; if (lon > maxLon) maxLon = lon;
      if (lat < minLat) minLat = lat; if (lat > maxLat) maxLat = lat;
    });
    const W = 320, H = 200, PAD = 30;
    const innerW = W - PAD * 2, innerH = H - PAD * 2;
    const cosLat = Math.cos(((minLat + maxLat) / 2) * Math.PI / 180);
    const lonRange = (maxLon - minLon) || 0.0001;
    const latRange = (maxLat - minLat) || 0.0001;
    const aspect = (lonRange * cosLat) / latRange;
    let dW = innerW, dH = innerH;
    if (aspect > innerW / innerH) dH = innerW / aspect; else dW = innerH * aspect;
    const ox = PAD + (innerW - dW) / 2, oy = PAD + (innerH - dH) / 2;
    const toXY = (lon: number, lat: number): [number, number] => [
      ox + (lon - minLon) / lonRange * dW,
      oy + (maxLat - lat) / latRange * dH,
    ];
    const pts = verts.map(([lon, lat]: number[]) => toXY(lon, lat).join(',')).join(' ');
    let labels = '';
    for (let i = 0; i < coords.length - 1; i++) {
      const [lon1, lat1] = coords[i], [lon2, lat2] = coords[i + 1];
      const len = haversineMetres(lat1, lon1, lat2, lon2);
      if (len < 1) continue;
      const [x1, y1] = toXY(lon1, lat1), [x2, y2] = toXY(lon2, lat2);
      const mx = (x1 + x2) / 2, my = (y1 + y2) / 2;
      let angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI;
      if (Math.abs(angle) > 90) angle += 180;
      const txt = (Math.round(len * 10) / 10) + 'm';
      const hw = txt.length * 3.8 + 4, hh = 7;
      labels += '<g transform="rotate(' + angle + ',' + mx + ',' + my + ')">' +
        '<rect x="' + (mx - hw) + '" y="' + (my - hh) + '" width="' + (hw * 2) + '" height="' + (hh * 2) + '" rx="2" fill="rgba(10,8,6,0.82)"/>' +
        '<text x="' + mx + '" y="' + my + '" text-anchor="middle" dominant-baseline="middle" font-size="9" font-weight="700" font-family="sans-serif" fill="#ffffff">' + txt + '</text>' +
        '</g>';
    }
    let sx = 0, sy = 0;
    verts.forEach(([lon, lat]: number[]) => { const [x, y] = toXY(lon, lat); sx += x; sy += y; });
    const cx = sx / verts.length, cy = sy / verts.length;
    return '<svg width="100%" viewBox="0 0 ' + W + ' ' + H + '" xmlns="http://www.w3.org/2000/svg" style="display:block;">' +
      '<polygon points="' + pts + '" fill="rgba(196,145,42,0.12)" stroke="#c4912a" stroke-width="2" stroke-linejoin="round"/>' +
      labels +
      '<text x="' + cx + '" y="' + cy + '" text-anchor="middle" dominant-baseline="middle" font-size="10" font-weight="600" font-family="sans-serif" fill="rgba(28,25,23,0.35)">' + areaRaw + ' m²</text>' +
      '</svg>';
  }

  function buildAIPrompt(): string {
    const d = _lastCardData;
    const z = _lastZone;
    if (!d && !z) return '';
    const addr = d?.address || _lastAddress || 'this Brisbane property';
    let p = 'I am researching ' + addr + ' in Brisbane. A property map tool has returned the following information. Please explain in plain English what this means for me as a buyer: what matters, what to watch out for, and what I should investigate before purchasing.\n\n';
    if (d?.area) p += 'BLOCK SIZE\n' + d.area + (d.lotplan ? ' (' + d.lotplan + ')' : '') + '\n\n';
    if (z) {
      p += 'ZONING (BCC City Plan 2014)\n' + (z.code ? z.code + ': ' : '') + z.officialLabel;
      if (z.height) p += ' | Height limit: ' + z.height;
      if (z.summary) p += '\n' + z.summary;
      p += '\n\n';
    }
    p += 'FLOOD OVERLAYS (BCC City Plan)\n' + (d?.floods || 'No flood overlays at this location.') + '\n\n';
    if (d?.primary || d?.secondary) {
      p += 'SCHOOL CATCHMENTS\n';
      if (d?.primary) p += 'Primary: ' + d.primary + '\n';
      if (d?.secondary) p += 'Secondary: ' + d.secondary + '\n';
    }
    return p.trim();
  }

  function openAI(base: string) {
    const prompt = buildAIPrompt();
    if (!prompt) return;
    window.open(base + encodeURIComponent(prompt), '_blank', 'noopener');
  }

  function showAIWidget() {
    const w = document.getElementById('pm-ai-widget');
    if (w) w.style.display = 'block';
  }

  function hideAIWidget() {
    const w = document.getElementById('pm-ai-widget');
    if (w) w.style.display = 'none';
  }

  function showParcelDimensions(rings: number[][][], _areaM2: number) {
    const L = (window as any).L;
    if (parcelDimLayer) { map.removeLayer(parcelDimLayer); parcelDimLayer = null; }
    if (!rings || !rings.length) return;
    parcelDimLayer = L.layerGroup();
    const coords = rings[0] || [];
    if (coords.length < 3) { parcelDimLayer.addTo(map); return; }

    const latlngs = coords.map(([lon, lat]: number[]) => [lat, lon]);
    L.polygon(latlngs, {
      color: '#e53e3e', weight: 2.5, opacity: 0.9,
      fill: true, fillColor: '#e53e3e', fillOpacity: 0.08,
    }).addTo(parcelDimLayer);

    parcelDimLayer.addTo(map);
  }

  async function queryParcel(lat: number, lon: number) {
    const params = new URLSearchParams({
      geometry: JSON.stringify({ x: lon, y: lat, spatialReference: { wkid: 4326 } }),
      geometryType: 'esriGeometryPoint', inSR: '4326',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: 'LOTPLAN,HOUSE_NUMBER,CORRIDOR_NAME,SUBURB,LOT_AREA',
      returnGeometry: 'true', outSR: '4326',
      resultRecordCount: '1', f: 'json',
    });
    const data = await fetch(`${SVC.propertyBoundary}/query?${params}`).then(r => r.json());
    return (data.features || [])[0] || null;
  }

  async function queryFloodOverlays(lat: number, lon: number, rings?: number[][][]) {
    const usePolygon = rings && rings.length > 0;
    const params = new URLSearchParams({
      geometry: usePolygon
        ? JSON.stringify({ rings, spatialReference: { wkid: 4326 } })
        : JSON.stringify({ x: lon, y: lat, spatialReference: { wkid: 4326 } }),
      geometryType: usePolygon ? 'esriGeometryPolygon' : 'esriGeometryPoint', inSR: '4326',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: 'OVL2_DESC,OVL2_CAT', returnGeometry: 'false', f: 'json',
    });
    const qs = params.toString();
    const overland = await fetch(`${FLOOD_SVC.floodOverland}/query?${qs}`).then(r => r.json()).catch(() => null);
    const found: {desc: string; cat: string; key: string}[] = [];
    if (overland?.features?.length) found.push({ desc: overland.features[0].attributes.OVL2_DESC, cat: overland.features[0].attributes.OVL2_CAT, key: 'floodOverland' });
    return found;
  }

  async function queryCatchments(lat: number, lon: number) {
    const params = new URLSearchParams({
      geometry: JSON.stringify({ x: lon, y: lat, spatialReference: { wkid: 4326 } }),
      geometryType: 'esriGeometryPoint', inSR: '4326',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: 'centre_name', returnGeometry: 'false', f: 'json',
    });
    const qs = params.toString();
    const [p, s] = await Promise.all([
      fetch(`${SCHOOL_BASE}/1/query?${qs}`).then(r => r.json()).catch(() => null),
      fetch(`${SCHOOL_BASE}/3/query?${qs}`).then(r => r.json()).catch(() => null),
    ]);
    return {
      primary:   (p?.features?.[0]?.attributes?.centre_name as string) || null,
      secondary: (s?.features?.[0]?.attributes?.centre_name as string) || null,
    };
  }

