        }).addTo(layers[key]);
      })
      .catch((err: any) => { if (err.name === 'AbortError') return; });
  }

  // ── Decode AGOL quantized Esri-JSON features into GeoJSON ─────────────
  // AGOL `quantizationParameters` returns rings as integer pixel offsets
  // (first point absolute, rest delta-encoded). Convert back to lat/lon at
  // the original polygon precision modulo one screen pixel of rounding.
  function quantizedRingsToGeometry(rings: number[][][], xmin: number, ymax: number, tol: number) {
    const decoded = rings.map(ring => {
      const out: number[][] = [];
      let cx = 0, cy = 0;
      for (let i = 0; i < ring.length; i++) {
        cx += ring[i][0]; cy += ring[i][1];
        out.push([xmin + cx * tol, ymax - cy * tol]);
      }
      return out;
    });
    if (decoded.length === 1) return { type: 'Polygon', coordinates: decoded };
    // Group outer rings + their holes. Esri convention: outer = clockwise
    // in geographic coords → shoelace sum > 0 with our formulation.
    const signedArea = (r: number[][]) => {
      let s = 0;
      for (let i = 0; i < r.length - 1; i++) s += (r[i+1][0] - r[i][0]) * (r[i+1][1] + r[i][1]);
      return s;
    };
    const polys: number[][][][] = [];
    let outer: number[][] | null = null;
    let holes: number[][][] = [];
    for (const r of decoded) {
      if (signedArea(r) > 0) {
        if (outer) polys.push([outer, ...holes]);
        outer = r; holes = [];
      } else if (outer) {
        holes.push(r);
      } else {
        polys.push([r]);
      }
    }
    if (outer) polys.push([outer, ...holes]);
    if (polys.length === 1) return { type: 'Polygon', coordinates: polys[0] };
    return { type: 'MultiPolygon', coordinates: polys };
  }

  function esriQuantizedToGeoJSON(esri: any, xmin: number, ymax: number, tol: number) {
    return {
      type: 'FeatureCollection',
      features: (esri.features || []).map((f: any) => ({
        type: 'Feature',
        properties: f.attributes || {},
        geometry: quantizedRingsToGeometry(f.geometry?.rings || [], xmin, ymax, tol),
      })),
    };
  }

  // ── Load one flood overlay layer ─────────────────────────────────────
  // Uses AGOL `quantizationParameters` so polygon boundaries are pixel-perfect
  // at the current zoom. Without it, a full-precision query for the visible
  // viewport blows past AGOL's 40 MB transfer limit and the response is truncated.
  function loadFlood(key: string) {
    if (!active[key]) { floodLayers[key].clearLayers(); return; }
    if (map.getZoom() < 13) { floodLayers[key].clearLayers(); return; }
    if (floodAborts[key]) floodAborts[key].abort();
    floodAborts[key] = new AbortController();

    const b = map.getBounds();
    const sw = b.getSouthWest(), ne = b.getNorthEast();
    const xmin = sw.lng, ymin = sw.lat, xmax = ne.lng, ymax = ne.lat;
    // 1 pixel in degrees latitude at this zoom (constant for any latitude).
    // Using the same value for X tolerance is acceptable — minor anisotropy
    // at Brisbane latitude is sub-pixel after rendering.
    const tol = 180 / (256 * Math.pow(2, map.getZoom()));
    const quant = {
      mode: 'view', originPosition: 'upperLeft', tolerance: tol,
      extent: { xmin, ymin, xmax, ymax, spatialReference: { wkid: 4326 } },
    };
    const params = new URLSearchParams({
      geometry: `${xmin},${ymin},${xmax},${ymax}`,
      geometryType: 'esriGeometryEnvelope',
      inSR: '4326', outSR: '4326',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: 'OVL2_DESC,OVL2_CAT',
      returnGeometry: 'true',
      quantizationParameters: JSON.stringify(quant),
      resultRecordCount: '4000', f: 'json',
    });

    fetch(`${FLOOD_SVC[key]}/query?${params}`, { signal: floodAborts[key].signal })
      .then(r => r.json())
      .then(esri => {
        if (esri?.error) return;
        const geo = esriQuantizedToGeoJSON(esri, xmin, ymax, tol);
        floodLayers[key].clearLayers();
        (window as any).L.geoJSON(geo, {
          renderer: canvasRenderer,
          style(f: any) {
            const cat = (f.properties?.OVL2_CAT || '') as string;
            const fc = FLOOD_COLORS[cat] || { fill: '#3060c0', stroke: '#4070d0', fillOpacity: 0.20 };
            return {
              color: fc.stroke, weight: 0.8, opacity: 0.7,
              fillColor: fc.fill, fillOpacity: fc.fillOpacity,
              dashArray: key === 'floodOverland' ? '4 3' : undefined,
            };
          },
          onEachFeature(f: any, layer: any) {
            layer.on('click', (e: any) => {
              (window as any).L.DomEvent.stopPropagation(e);
              dropPin(e.latlng.lat, e.latlng.lng);
              updateSummaryCard(e.latlng.lat, e.latlng.lng);
              showFloodResult(key, f.properties || {});
            });
          },
        }).addTo(floodLayers[key]);
      })
      .catch((err: any) => { if (err.name === 'AbortError') return; });
  }

  // ── Load one school catchment layer ──────────────────────────────────
  // QLD DoE service supports f=geojson directly. maxAllowableOffset trims
  // detail at low zoom so we keep payload modest across the whole map area.
  function loadCatchment(key: string) {
    if (!active[key]) { catchmentLayers[key].clearLayers(); return; }
    if (map.getZoom() < 12) { catchmentLayers[key].clearLayers(); return; }
    if (catchmentAborts[key]) catchmentAborts[key].abort();
    catchmentAborts[key] = new AbortController();

    const b = map.getBounds();
    const sw = b.getSouthWest(), ne = b.getNorthEast();
    const z = map.getZoom();
    const offset = z >= 16 ? 0 : z >= 14 ? 0.00005 : z >= 12 ? 0.0002 : 0.0005;

    const params = new URLSearchParams({
      geometry: `${sw.lng},${sw.lat},${ne.lng},${ne.lat}`,
      geometryType: 'esriGeometryEnvelope',
      inSR: '4326', outSR: '4326',
      spatialRel: 'esriSpatialRelIntersects',
      outFields: 'centre_name',
      returnGeometry: 'true',
      maxAllowableOffset: String(offset),
      resultRecordCount: '2000',
      f: 'geojson',
    });

    fetch(`${CATCHMENT_SVC[key]}/query?${params}`, { signal: catchmentAborts[key].signal })
      .then(r => r.json())
      .then(geo => {
        catchmentLayers[key].clearLayers();
        const style = CATCHMENT_STYLE[key];
        (window as any).L.geoJSON(geo, {
          renderer: canvasRenderer,
          style: () => ({
            color: style.stroke, weight: 1.6, opacity: 0.75,
            fillColor: style.fill, fillOpacity: style.fillOpacity,
          }),
          onEachFeature(f: any, layer: any) {
            const name = f?.properties?.centre_name || 'Unknown catchment';
            const tier = CATCHMENT_LABEL[key];
            layer.bindTooltip(`${name} (${tier})`, { sticky: true, direction: 'top', opacity: 0.9 });
            layer.on('click', (e: any) => {
              (window as any).L.DomEvent.stopPropagation(e);
              dropPin(e.latlng.lat, e.latlng.lng);
              updateSummaryCard(e.latlng.lat, e.latlng.lng);
              showCatchmentResult(key, f.properties || {});
            });
          },
        }).addTo(catchmentLayers[key]);
      })
      .catch((err: any) => { if (err.name === 'AbortError') return; });
  }

