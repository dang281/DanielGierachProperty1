<div class="pm-shell">

  <p class="pm-eduline">
    <strong>Educational use only</strong> BCC and QUU open data. Always verify zoning with Brisbane City Council and commission a Dial Before You Dig (1100) search before any excavation or development decision.
  </p>

  <div class="pm-search-sticky">
    <div class="pm-search-bar">
      <div id="pm-search-wrap">
        <input type="text" id="pm-search" placeholder="Enter address" autocomplete="off" inputmode="search" enterkeyhint="search" />
        <div id="pm-autocomplete" style="display:none;"></div>
      </div>
      <button id="pm-search-btn">Search</button>
      <button id="pm-gps-btn" title="Use my location" aria-label="Use my location">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/><circle cx="12" cy="12" r="9" stroke-opacity="0.3"/></svg>
      </button>
    </div>
  </div>

  <div class="pm-map-wrap">
    <div id="pm-map"></div>

    <!-- First-load guidance -->
    <div id="pm-guide" role="status" aria-live="polite">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l10 6-10 6L2 8l10-6z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      <p>Search an address above, or tap any block to see its zone, flood risk, school catchments, and dimensions.</p>
      <button id="pm-guide-dismiss">Start exploring</button>
    </div>

    <!-- Status pill (top-left) -->
    <div id="pm-status">Click any feature or search an address.</div>

    <!-- Layers panel + compass (top-right, combined) -->
    <div class="pm-control pm-control-tr">
      <button class="pm-layer-toggle" id="pm-layer-toggle" aria-expanded="false" aria-controls="pm-layer-panel">
        <svg width="14" height="14" viewBox="0 0 36 36" fill="none" aria-hidden="true">
          <polygon points="18,4 21,18 18,15 15,18" fill="#c4912a"/>
          <polygon points="18,32 21,18 18,21 15,18" fill="rgba(28,25,23,0.3)"/>
          <polygon points="32,18 18,15 21,18 18,21" fill="rgba(28,25,23,0.2)"/>
          <polygon points="4,18 18,15 15,18 18,21" fill="rgba(28,25,23,0.2)"/>
          <circle cx="18" cy="18" r="2.5" fill="rgba(28,25,23,0.6)"/>
        </svg>
        Layers
        <svg class="pm-toggle-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="pm-layer-panel" id="pm-layer-panel">

        <!-- Zoning -->
        <p class="pm-layer-group-head">Zoning (BCC)</p>
        <label class="pm-layer-row">
          <input type="checkbox" data-layer="zoning" id="pm-zoning-cb" checked />
          <span class="pm-swatch">
            <svg width="24" height="14" viewBox="0 0 24 14" style="flex-shrink:0"><rect x="0" y="0" width="6" height="14" fill="#6a8f5a"/><rect x="6" y="0" width="6" height="14" fill="#d4843c"/><rect x="12" y="0" width="6" height="14" fill="#7a5acd"/><rect x="18" y="0" width="6" height="14" fill="#2a8c9c" opacity="0.7"/></svg>
          </span>
          <span class="pm-layer-name">Zone overlay
            <span class="pm-layer-hint">City Plan 2014 zones</span>
          </span>
        </label>
        <div class="pm-zone-sub" id="pm-zone-sub">
          <div class="pm-opacity-row">
            <span class="pm-opacity-label">Opacity <span id="pm-opacity-val">65%</span></span>
            <input type="range" id="pm-opacity-slider" min="0" max="100" step="5" value="65" class="pm-opacity-slider" />
          </div>
          <button class="pm-legend-btn" id="pm-legend-btn" aria-expanded="false">
            Zone types
            <svg class="pm-toggle-arrow" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div id="pm-legend-list" style="display:none;"></div>
        </div>

        <!-- Cadastre -->
        <p class="pm-layer-group-head" style="border-top:1px solid rgba(28,25,23,0.07);padding-top:0.6rem;">Cadastre (BCC)</p>
        <label class="pm-layer-row">
          <input type="checkbox" data-layer="propertyBoundary" checked />
          <span class="pm-swatch"><span class="pm-swatch-line" style="background:#9e8c6a;height:1px;border-top:1px dashed #9e8c6a;"></span></span>
          <span class="pm-layer-name">Property boundaries
            <span class="pm-layer-hint">Cadastral parcel outlines</span>
          </span>
        </label>

        <!-- Infrastructure (collapsible) -->
        <button class="pm-infra-toggle" id="pm-infra-toggle" aria-expanded="false" aria-controls="pm-infra-panel">
          Infrastructure
          <span style="font-size:0.5rem;font-weight:600;letter-spacing:0.1em;color:rgba(28,25,23,0.35);text-transform:none;margin-left:0.3rem;">(stormwater, water, sewer)</span>
          <svg class="pm-toggle-arrow" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="pm-infra-panel">

          <p class="pm-layer-group-head" style="padding-top:0.2rem;">Stormwater (BCC)</p>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="stormPipe" checked />
            <span class="pm-swatch"><span class="pm-swatch-line" style="background:#2a8c9c;"></span></span>
            <span class="pm-layer-name">Stormwater pipes
              <span class="pm-layer-hint">Underground drainage pipes</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="stormManhole" />
            <span class="pm-swatch"><span class="pm-swatch-dot" style="background:#1f6f7d;"></span></span>
            <span class="pm-layer-name">Stormwater manholes
              <span class="pm-layer-hint">Access chambers and junctions</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="gully" checked />
            <span class="pm-swatch"><span class="pm-swatch-dot" style="background:#d77b32;"></span></span>
            <span class="pm-layer-name">Gullies / kerb inlets
              <span class="pm-layer-hint">Where runoff enters the underground network</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="surfaceDrain" />
            <span class="pm-swatch"><span class="pm-swatch-line-dash" style="color:#4dadb8;"></span></span>
            <span class="pm-layer-name">Surface drains
              <span class="pm-layer-hint">Overland flow paths and open drains</span>
            </span>
          </label>

          <p class="pm-layer-group-head" style="border-top:1px solid rgba(28,25,23,0.07);padding-top:0.6rem;">Water &amp; Sewer (QUU)</p>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="sewerMain" checked />
            <span class="pm-swatch"><span class="pm-swatch-line" style="background:#8a6e2f;"></span></span>
            <span class="pm-layer-name">Sewer mains
              <span class="pm-layer-hint">Gravity sewer running underground</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="waterMain" checked />
            <span class="pm-swatch"><span class="pm-swatch-line" style="background:#2c7fc4;"></span></span>
            <span class="pm-layer-name">Water mains
              <span class="pm-layer-hint">Pressure mains supplying drinking water</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="sewerService" checked />
            <span class="pm-swatch"><span class="pm-swatch-line" style="background:#b8904a;opacity:0.7;"></span></span>
            <span class="pm-layer-name">Sewer connections
              <span class="pm-layer-hint">Individual property sewer laterals</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="waterService" checked />
            <span class="pm-swatch"><span class="pm-swatch-line" style="background:#6fb5e0;opacity:0.7;"></span></span>
            <span class="pm-layer-name">Water connections
              <span class="pm-layer-hint">Individual property water service lines</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="sewerManhole" />
            <span class="pm-swatch"><span class="pm-swatch-dot" style="background:#6c5320;"></span></span>
            <span class="pm-layer-name">Sewer manholes
              <span class="pm-layer-hint">Access chambers along sewer mains</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="hydrant" />
            <span class="pm-swatch"><span class="pm-swatch-dot" style="background:#c43a3a;"></span></span>
            <span class="pm-layer-name">Hydrants
              <span class="pm-layer-hint">Fire hydrants on the water network</span>
            </span>
          </label>

        </div>

        <!-- School catchments (collapsible) -->
        <button class="pm-infra-toggle" id="pm-schools-toggle" aria-expanded="false" aria-controls="pm-schools-panel">
          School catchments
          <span style="font-size:0.5rem;font-weight:600;letter-spacing:0.1em;color:rgba(28,25,23,0.35);text-transform:none;margin-left:0.3rem;">(state primary / secondary)</span>
          <svg class="pm-toggle-arrow" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="pm-schools-panel">
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="catchmentPrimary" />
            <span class="pm-swatch"><span style="display:block;width:18px;height:10px;border-radius:2px;background:rgba(8,145,178,0.12);border:1.5px solid #0891b2;"></span></span>
            <span class="pm-layer-name">Primary catchments
              <span class="pm-layer-hint">State primary school enrolment boundaries</span>
            </span>
          </label>
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="catchmentSecondary" />
            <span class="pm-swatch"><span style="display:block;width:18px;height:10px;border-radius:2px;background:rgba(124,58,237,0.12);border:1.5px solid #7c3aed;"></span></span>
            <span class="pm-layer-name">Secondary catchments
              <span class="pm-layer-hint">State high school enrolment boundaries</span>
            </span>
          </label>
        </div>

        <!-- Other (collapsible) -->
        <button class="pm-infra-toggle" id="pm-other-toggle" aria-expanded="false" aria-controls="pm-other-panel">
          Other
          <span style="font-size:0.5rem;font-weight:600;letter-spacing:0.1em;color:rgba(28,25,23,0.35);text-transform:none;margin-left:0.3rem;">(flood overlays)</span>
          <svg class="pm-toggle-arrow" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="pm-other-panel">
          <label class="pm-layer-row">
            <input type="checkbox" data-layer="floodOverland" />
            <span class="pm-swatch"><span style="display:block;width:18px;height:10px;border-radius:2px;background:#0096c8;opacity:0.5;border:1px solid rgba(0,200,240,0.5);border-style:dashed;"></span></span>
            <span class="pm-layer-name">Overland flow area
              <span class="pm-layer-hint">Surface water flow paths during major rainfall</span>
            </span>
          </label>
        </div>

      </div>
    </div>

