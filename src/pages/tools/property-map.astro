  // ── Load all visible ──────────────────────────────────────────────────
  function loadVisible() {
    const s = document.getElementById('pm-status')!;
    const z = map.getZoom();

    if (active.zoning) {
      if (z >= 13) loadZoning();
      else zoningLayer.clearLayers();
    }

    // Flood overlays load at zoom 13+ (matches zoning; at lower zooms the bbox
    // spans the entire flood region and AGOL returns thousands of features).
    Object.keys(FLOOD_SVC).forEach(k => {
      if (active[k]) { if (z >= 13) loadFlood(k); else floodLayers[k].clearLayers(); }
    });

    // School catchments load at zoom 12+ since the polygons are large and
    // useful for orientation when zoomed slightly out.
    Object.keys(CATCHMENT_SVC).forEach(k => {
      if (active[k]) { if (z >= 12) loadCatchment(k); else catchmentLayers[k].clearLayers(); }
    });

    if (z < 14) {
      Object.keys(SVC).forEach(k => layers[k].clearLayers());
      if (z < 13 || !active.zoning) {
        s.textContent = 'Zoom in to load zones (13+) and infrastructure (14+).';
      } else {
        s.textContent = 'Zones loaded. Zoom to 14+ for infrastructure.';
      }
      return;
    }

    dismissGuide();
    s.textContent = 'Loading assets...';
    Object.keys(SVC).forEach(loadOne);
    setTimeout(() => { if (map.getZoom() >= 14) s.textContent = 'Assets loaded. Click any feature.'; }, 700);
  }

  // ── Zone identify (server-side point-in-polygon) ──────────────────────
  function identifyZone(lat: number, lon: number) {
    const s = document.getElementById('pm-status')!;
    s.textContent = 'Identifying zone...';

    function queryZone(distance: number) {
      const params = new URLSearchParams({
        geometry: JSON.stringify({ x: lon, y: lat, spatialReference: { wkid: 4326 } }),
        geometryType: 'esriGeometryPoint',
        inSR: '4326',
        spatialRel: 'esriSpatialRelIntersects',
        outFields: 'ZONE_CODE,ZONE_PREC_NO,LVL1_ZONE,LVL2_ZONE,ZONE_PREC,ZONE_PREC_DESC',
        returnGeometry: 'false', f: 'json',
      });
      if (distance > 0) { params.set('distance', String(distance)); params.set('units', 'esriSRUnit_Meter'); }
      return fetch(`${ZONING_URL}/query?${params}`).then(r => r.json());
    }

    queryZone(0)
      .then(d => {
        if (d.features && d.features.length) return { d, buffered: false };
        return queryZone(25).then(d2 => ({ d: d2, buffered: true }));
      })
      .then(({ d, buffered }: any) => {
        const f = d.features && d.features[0];
        if (f && f.attributes) {
          showZoneFromAttributes(f.attributes);
          s.textContent = buffered ? 'Nearest parcel shown.' : 'Zone identified.';
        } else {
          s.textContent = 'No zone found here. Try clicking directly on a parcel.';
        }
        updateBCCLink(lat, lon);
      })
      .catch(() => { s.textContent = 'Zone data unavailable. Use the BCC CityPlan link.'; });
  }

  // ── Show zone result from attributes ─────────────────────────────────
  function showZoneFromAttributes(p: Record<string,any>) {
    const code = (p.ZONE_CODE || '').toUpperCase();
    const family = zoneFamily(code) || matchZone(p.LVL2_ZONE) || matchZone(p.LVL1_ZONE) || 'SP';
    const z = ZONES[family];
    const officialLabel = p.ZONE_PREC_DESC || p.LVL2_ZONE || p.LVL1_ZONE || code;
    const swatchColor = colorFor(p).hex;

    // Store zone data so the summary card below can show full detail
    _lastZone = {
      code, officialLabel, family, swatchColor,
      height:    z ? z.height    : '',
      summary:   z ? z.summary   : officialLabel,
      bccHref:   'https://cityplan.brisbane.qld.gov.au',
    };
    refreshZoneSection();

    // Compact drawer: just code + name, point user to below
    const el = document.getElementById('pm-result')!;
    el.className = `mode-zone zone-${family.toLowerCase()}`;
    el.classList.add('open');
    document.getElementById('pm-result-eyebrow')!.textContent = _lastAddress || 'Zone identified';
    document.getElementById('pm-result-body')!.innerHTML =
      '<div style="display:flex;align-items:center;gap:0.6rem;">' +
        '<div style="width:12px;height:12px;border-radius:3px;flex-shrink:0;border:1px solid rgba(255,255,255,0.2);background:' + swatchColor + ';"></div>' +
        '<p style="font-size:0.9rem;font-family:Georgia,serif;font-weight:400;color:rgba(28,25,23,0.9);margin:0;line-height:1.25;">' + (code ? code + ': ' + officialLabel : officialLabel) + '</p>' +
      '</div>' +
      '<p style="font-size:0.6rem;color:rgba(28,25,23,0.3);margin:0.4rem 0 0;font-style:italic;">Full details in Property Details below the map</p>';
    updateBCCLink(0, 0);
  }

  // ── Populate the zone section inside the already-rendered summary card ─
  function refreshZoneSection() {
    const zoneDiv = document.getElementById('pm-summary-zone');
    if (!zoneDiv || !_lastZone) return;
    const z = _lastZone;
    zoneDiv.innerHTML =
      '<div style="margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid rgba(28,25,23,0.08);">' +
        '<p style="font-size:0.58rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin:0 0 0.55rem;">Zoning (BCC City Plan)</p>' +
        '<div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.4rem;">' +
          '<div style="width:14px;height:14px;border-radius:3px;flex-shrink:0;border:1px solid rgba(255,255,255,0.2);background:' + z.swatchColor + ';"></div>' +
          '<p style="font-family:Georgia,serif;font-size:1rem;font-weight:400;color:rgba(28,25,23,0.9);line-height:1.25;margin:0;">' + (z.code ? z.code + ': ' + z.officialLabel : z.officialLabel) + '</p>' +
        '</div>' +
        (z.height ? '<p style="font-size:0.66rem;font-weight:700;letter-spacing:0.08em;color:#c4912a;margin:0 0 0.45rem;">' + z.height + '</p>' : '') +
        (z.summary ? '<p style="font-size:0.78rem;color:rgba(28,25,23,0.65);line-height:1.65;margin:0 0 0.45rem;">' + z.summary + '</p>' : '') +
        '<a id="pm-bcc-link-el" href="' + z.bccHref + '" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.6rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#c4912a;text-decoration:none;">' +
          'Verify on BCC CityPlan ' +
          '<svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>' +
        '</a>' +
      '</div>';
  }


  function updateBCCLink(lat: number, lon: number) {
    const link = document.getElementById('pm-bcc-link-el');
    if (link && lat !== 0) link.setAttribute('href', `https://cityplan.brisbane.qld.gov.au/#@${lon},${lat},16z`);
  }

  // ── Show asset result ─────────────────────────────────────────────────
  function showAssetResult(key: string, attrs: Record<string,any>) {
    const el = document.getElementById('pm-result')!;
    el.className = `mode-asset kind-${key}`;
    el.classList.add('open');
    document.getElementById('pm-result-eyebrow')!.textContent = TITLES[key] || key;

