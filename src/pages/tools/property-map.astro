        <p style="font-size:0.84rem;color:rgba(28,25,23,0.7);line-height:1.65;margin-bottom:0.65rem;padding-bottom:0.65rem;border-bottom:1px solid rgba(28,25,23,0.09);">${INTERPRETATIONS[key] || ''}</p>
