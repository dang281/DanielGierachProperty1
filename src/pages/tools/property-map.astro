      .map(([k, v]: [string,string]) => `
        <dt style="font-size:0.6rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(28,25,23,0.38);align-self:center;">${k}</dt>
        <dd style="color:rgba(28,25,23,0.78);margin:0;">${esc(v)}</dd>`)
      .join('');

    if (key === 'propertyBoundary') {
      const a2 = attrs;
      const addrLine = [a2.HOUSE_NUMBER && a2.CORRIDOR_NAME ? `${a2.HOUSE_NUMBER} ${a2.CORRIDOR_NAME}` : (a2.CORRIDOR_NAME || a2.HOUSE_NUMBER || ''), a2.SUBURB].filter(Boolean).join(', ');
      const areaLine = a2.LOT_AREA ? `${(+a2.LOT_AREA).toFixed(0)} m²` : '';
      document.getElementById('pm-result-body')!.innerHTML = `
        <h3 style="font-family:Georgia,serif;font-size:1rem;font-weight:400;color:rgba(28,25,23,0.9);line-height:1.25;margin-bottom:0.3rem;">${esc(addrLine || a2.LOTPLAN || 'Parcel selected')}</h3>
        ${areaLine ? `<p style="font-size:0.76rem;color:rgba(28,25,23,0.5);margin:0 0 0.25rem;">${areaLine}</p>` : ''}
        ${a2.LOTPLAN ? `<p style="font-size:0.65rem;color:rgba(28,25,23,0.32);margin:0 0 0.4rem;">Lot/Plan ${a2.LOTPLAN}</p>` : ''}
        <p style="font-size:0.65rem;color:rgba(28,25,23,0.28);margin:0;font-style:italic;">Full details loading below map...</p>
