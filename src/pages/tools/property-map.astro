    card.style.display = 'block';
    card.innerHTML =
      '<div style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:1.25rem 1.5rem;">' +
        '<div id="pm-summary-zone"></div>' +
        '<p style="font-size:0.75rem;color:rgba(28,25,23,0.33);margin:0;">Looking up property details...</p>' +
      '</div>';

    queryParcel(lat, lon).catch(() => null).then((parcel: any) => {
      // Show dimension overlay immediately — don't wait for floods/catchments
      const rings: number[][][] | undefined = parcel?.geometry?.rings;
      const a0 = parcel?.attributes || {};
      const area0 = a0.LOT_AREA ? Math.round(+a0.LOT_AREA) : 0;
      if (rings?.length && area0) showParcelDimensions(rings, area0);
      // Update address + eyebrow immediately from parcel data
      const n0 = a0.HOUSE_NUMBER || '', s0 = a0.CORRIDOR_NAME || '', sb0 = a0.SUBURB || '';
      const addrEarly = [n0 && s0 ? `${n0} ${s0}` : (s0 || n0), sb0].filter(Boolean).join(', ') || searchAddr || '';
      if (addrEarly) {
        _lastAddress = addrEarly;
        const eyebrow = document.getElementById('pm-result-eyebrow');
        const resultEl = document.getElementById('pm-result');
        if (eyebrow && resultEl?.classList.contains('mode-zone')) eyebrow.textContent = addrEarly;
      }
      return Promise.all([
        Promise.resolve(parcel),
        queryCatchments(lat, lon).catch(() => ({ primary: null as string|null, secondary: null as string|null })),
        queryFloodOverlays(lat, lon, rings).catch(() => [] as {desc:string;cat:string;key:string}[]),
      ]);
    }).then(([parcel, catchments, floods]) => {
      const a = parcel?.attributes || {};
      const num = a.HOUSE_NUMBER || '', street = a.CORRIDOR_NAME || '', suburb = a.SUBURB || '';
      const addrFromParcel = [num && street ? `${num} ${street}` : (street || num), suburb].filter(Boolean).join(', ');
      const addr = addrFromParcel || searchAddr || '';
      if (addr) {
        _lastAddress = addr;
        const eyebrow = document.getElementById('pm-result-eyebrow');
        const resultEl = document.getElementById('pm-result');
        if (eyebrow && resultEl?.classList.contains('mode-zone')) eyebrow.textContent = addr;
      }
      const lotInfo = a.LOTPLAN ? `Lot/Plan ${a.LOTPLAN}` : '';
      const areaRaw = a.LOT_AREA ? Math.round(+a.LOT_AREA) : 0;
      const areaM2 = areaRaw ? `${areaRaw} m²` : '';
      const svgStr = (parcel?.geometry?.rings?.length && areaRaw) ? generateParcelSVG(parcel.geometry.rings, areaRaw) : '';

      card.innerHTML = `
        <div style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:1.25rem 1.5rem;">
          <div id="pm-summary-zone"></div>
          <div id="pm-summary-grid">
            <div>
              <p style="font-size:0.58rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin:0 0 0.25rem;">Property</p>
              ${addr ? `<p style="font-size:0.92rem;font-family:Georgia,serif;color:rgba(28,25,23,0.9);margin:0 0 0.4rem;line-height:1.3;">${addr}</p>` : ''}
              ${lotInfo ? `<p style="font-size:0.7rem;color:rgba(28,25,23,0.38);margin:0 0 0.15rem;">${lotInfo}</p>` : ''}
              ${areaM2 ? `<p style="font-size:0.76rem;color:rgba(28,25,23,0.58);margin:0 0 0.6rem;">${areaM2}</p>` : ''}
              ${svgStr ? `<div style="background:rgba(28,25,23,0.03);border:1px solid rgba(196,145,42,0.18);border-radius:4px;padding:0.35rem;display:block;margin-top:0.5rem;">${svgStr}</div>` : ''}
              ${!addr && !lotInfo && !areaM2 ? `<p style="font-size:0.78rem;color:rgba(28,25,23,0.3);margin:0;">No parcel data at this point.</p>` : ''}
            </div>
            <div>
              <p style="font-size:0.58rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin:0 0 0.25rem;">School catchments</p>
              ${catchments.primary ? `
                <p style="font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(28,25,23,0.32);margin:0 0 0.1rem;">Primary</p>
                <p style="font-size:0.8rem;color:rgba(28,25,23,0.78);margin:0 0 0.55rem;line-height:1.3;">${catchments.primary}</p>` : ''}
              ${catchments.secondary ? `
                <p style="font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(28,25,23,0.32);margin:0 0 0.1rem;">Secondary</p>
                <p style="font-size:0.8rem;color:rgba(28,25,23,0.78);margin:0;line-height:1.3;">${catchments.secondary}</p>` : ''}
              ${!catchments.primary && !catchments.secondary ? `<p style="font-size:0.78rem;color:rgba(28,25,23,0.25);margin:0;">No state school catchment found.</p>` : ''}
            </div>
          </div>
          <p style="margin-top:0.8rem;font-size:0.62rem;color:rgba(28,25,23,0.2);border-top:1px solid rgba(28,25,23,0.07);padding-top:0.65rem;line-height:1.55;">
            School catchments: Queensland DoE open data. Block dimensions approximate. Always verify before any purchase decision.
          </p>
        </div>`;
      // Zone data may already be available (if identifyZone resolved first) or arrive later via refreshZoneSection
      refreshZoneSection();

      // Populate AI widget data and show it
      const floodText = (floods as {desc:string;cat:string;key:string}[]).length
        ? (floods as {desc:string;cat:string;key:string}[]).map(f => f.desc).join('; ')
        : '';
      _lastCardData = {
        address: addr,
        lotplan: lotInfo,
        area: areaM2,
        floods: floodText,
        primary: catchments.primary || '',
        secondary: catchments.secondary || '',
      };
      showAIWidget();
    });
  }


  function dropPin(lat: number, lon: number) {
    if (pinMarker) map.removeLayer(pinMarker);
    pinMarker = (window as any).L.marker([lat, lon], {
      icon: (window as any).L.divIcon({
        className: '',
        html: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="36" viewBox="0 0 28 36"><path d="M14 0C6.27 0 0 6.27 0 14c0 9.63 14 22 14 22S28 23.63 28 14C28 6.27 21.73 0 14 0zm0 20a6 6 0 1 1 0-12 6 6 0 0 1 0 12z" fill="#c5a03c" stroke="#fff" stroke-width="1.5"/></svg>`,
        iconSize: [28, 36], iconAnchor: [14, 36],
      }),
    }).addTo(map);
  }

  function flyAndIdentify(lat: number, lon: number, address?: string) {
    dropPin(lat, lon);
    map.setView([lat, lon], 18);
    if (active.zoning) setTimeout(() => identifyZone(lat, lon), 400);
    updateBCCLink(lat, lon);
    updateSummaryCard(lat, lon, address);
  }

  async function doSearch() {
    const v = (document.getElementById('pm-search') as HTMLInputElement).value.trim();
    if (!v) return;
    const s = document.getElementById('pm-status')!;
    const btn = document.getElementById('pm-search-btn') as HTMLButtonElement;
    s.textContent = 'Locating address...';
    btn.disabled = true;
    dismissGuide();
    document.getElementById('pm-autocomplete')!.style.display = 'none';
    try {
      const { lat, lon } = await geocode(v);
      flyAndIdentify(lat, lon, v);
    } catch {
      s.textContent = 'Address not found. Add the suburb (e.g. 12 Main St, Camp Hill).';
    }
    btn.disabled = false;
  }

  function dismissGuide() {
    document.getElementById('pm-guide')?.classList.add('hidden');
    try { localStorage.setItem('pm-onboarded', '1'); } catch {}
  }

  // ── Wire up controls ───────────────────────────────────────────────────
  function wireUpControls() {
    const search = document.getElementById('pm-search') as HTMLInputElement;
    document.getElementById('pm-search-btn')!.addEventListener('click', doSearch);
    search.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
      if (e.key === 'Escape') document.getElementById('pm-autocomplete')!.style.display = 'none';
    });
    search.addEventListener('input', () => {
      clearTimeout(acDebounce);
      const q = search.value.trim();
      if (q.length < 3) { document.getElementById('pm-autocomplete')!.style.display = 'none'; return; }
      acDebounce = setTimeout(() => suggestions(q).then(renderSuggestions), 130);
    });
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target as Element).closest('#pm-search-wrap'))
        document.getElementById('pm-autocomplete')!.style.display = 'none';
    });

    // GPS button
    const gpsBtn = document.getElementById('pm-gps-btn') as HTMLButtonElement | null;
    if (gpsBtn) {
      gpsBtn.addEventListener('click', () => {
        if (!navigator.geolocation) {
          document.getElementById('pm-status')!.textContent = 'Geolocation not supported.';
          return;
        }
        document.getElementById('pm-status')!.textContent = 'Getting your location...';
        gpsBtn.disabled = true; gpsBtn.classList.add('locating');
        navigator.geolocation.getCurrentPosition(
          pos => { gpsBtn.disabled = false; gpsBtn.classList.remove('locating'); dismissGuide(); flyAndIdentify(pos.coords.latitude, pos.coords.longitude); },
          () => { gpsBtn.disabled = false; gpsBtn.classList.remove('locating'); document.getElementById('pm-status')!.textContent = 'Location denied. Try searching by address.'; },
          { timeout: 10000 }
        );
      });
    }

    document.getElementById('pm-guide-dismiss')?.addEventListener('click', dismissGuide);
    try { if (localStorage.getItem('pm-onboarded')) dismissGuide(); } catch {}

    // Layers panel toggle
    const toggle = document.getElementById('pm-layer-toggle')!;
    const panel  = document.getElementById('pm-layer-panel')!;
    toggle.addEventListener('click', () => {
      const open = panel.classList.toggle('open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // Infrastructure collapse toggle
    const infraBtn   = document.getElementById('pm-infra-toggle')!;
    const infraPanel = document.getElementById('pm-infra-panel')!;
    infraBtn.addEventListener('click', () => {
      const open = infraPanel.classList.toggle('open');
      infraBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // Other (flood overlays) collapse toggle
    const otherBtn   = document.getElementById('pm-other-toggle')!;
    const otherPanel = document.getElementById('pm-other-panel')!;
    otherBtn.addEventListener('click', () => {
      const open = otherPanel.classList.toggle('open');
      otherBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // School catchments collapse toggle
    const schoolsBtn   = document.getElementById('pm-schools-toggle')!;
    const schoolsPanel = document.getElementById('pm-schools-panel')!;
    schoolsBtn.addEventListener('click', () => {
      const open = schoolsPanel.classList.toggle('open');
      schoolsBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // Pro mode: auto-expand the Other panel so the overland toggle is visible
    if (active.floodOverland) {
      otherPanel.classList.add('open');
      otherBtn.setAttribute('aria-expanded', 'true');
    }

    // Layer checkboxes (infrastructure)
    panel.querySelectorAll<HTMLInputElement>('input[data-layer]').forEach(cb => {
      // Sync checkbox UI to active state (handles pro-mode overrides)
      if (cb.dataset.layer! in active) cb.checked = active[cb.dataset.layer!];
      cb.addEventListener('change', () => {
        const k = cb.dataset.layer!;
        if (k === 'zoning') {
          active.zoning = cb.checked;
          const zoneSub = document.getElementById('pm-zone-sub')!;
          zoneSub.style.display = cb.checked ? '' : 'none';
          if (cb.checked) { zoningLayer.addTo(map); loadZoning(); }
          else map.removeLayer(zoningLayer);
          return;
        }
        active[k] = cb.checked;
        if (k in floodLayers) {
          if (active[k]) { floodLayers[k].addTo(map); loadFlood(k); }
          else map.removeLayer(floodLayers[k]);
        } else if (k in catchmentLayers) {
          if (active[k]) { catchmentLayers[k].addTo(map); loadCatchment(k); }
          else map.removeLayer(catchmentLayers[k]);
        } else {
          if (active[k]) { layers[k].addTo(map); loadOne(k); }
          else map.removeLayer(layers[k]);
        }
      });
    });

    // Opacity slider
    document.getElementById('pm-opacity-slider')?.addEventListener('input', function(this: HTMLInputElement) {
      const val = parseInt(this.value);
      document.getElementById('pm-opacity-val')!.textContent = val + '%';
      overlayOpacity = val / 100;
      // Refresh zoning layer styles
      zoningLayer.eachLayer((child: any) => {
        if (child.eachLayer) {
          child.eachLayer((p: any) => { if (p.setStyle && p.feature) p.setStyle(zoneStyleFor(p.feature)); });
        }
      });
    });

    // Zone legend toggle
    const legendBtn = document.getElementById('pm-legend-btn')!;
    const legendList = document.getElementById('pm-legend-list')!;
    legendBtn.addEventListener('click', () => {
      const open = legendList.style.display === 'none';
      legendList.style.display = open ? 'block' : 'none';
      legendBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // Result close
    document.getElementById('pm-result-close')!.addEventListener('click', () => {
      document.getElementById('pm-result')!.classList.remove('open');
    });

    // AI assistant buttons
    document.getElementById('pm-ai-chatgpt')?.addEventListener('click', () => openAI('https://chatgpt.com/?q='));
    document.getElementById('pm-ai-claude')?.addEventListener('click', () => openAI('https://claude.ai/new?q='));
    document.getElementById('pm-ai-gemini')?.addEventListener('click', () => openAI('https://gemini.google.com/app?q='));
    document.getElementById('pm-ai-perplexity')?.addEventListener('click', () => openAI('https://www.perplexity.ai/?q='));

    // Share button
    const shareBtn = document.getElementById('pm-share-btn') as HTMLButtonElement | null;
    if (shareBtn) {
      shareBtn.addEventListener('click', () => {
        const c = map.getCenter();
        const z = map.getZoom();
        const url = `${location.origin}${location.pathname}?lat=${c.lat.toFixed(5)}&lng=${c.lng.toFixed(5)}&z=${z}`;
        const reset = () => { shareBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg> Copy map link'; shareBtn.classList.remove('copied'); };
        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(() => { shareBtn.textContent = 'Copied!'; shareBtn.classList.add('copied'); setTimeout(reset, 2200); }).catch(() => prompt('Copy:', url));
        } else { prompt('Copy:', url); }
      });
    }

    // Prevent page zoom when pinching the map on iOS
    const metaVp = document.querySelector('meta[name="viewport"]') as HTMLMetaElement | null;
    const mapEl = document.getElementById('pm-map');
    if (metaVp && mapEl) {
      mapEl.addEventListener('touchstart', () => { metaVp.content = 'width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no'; }, { passive: true });
      mapEl.addEventListener('touchend',   () => { metaVp.content = 'width=device-width, initial-scale=1'; }, { passive: true });
      mapEl.addEventListener('touchcancel',() => { metaVp.content = 'width=device-width, initial-scale=1'; }, { passive: true });
    }

    // Auto-fade status pill after stable messages
    const status = document.getElementById('pm-status')!;
    let fadeTimer: any;
    new MutationObserver(() => {
      clearTimeout(fadeTimer);
      status.style.opacity = '1';
      if (/loaded|identified/i.test(status.textContent || ''))
        fadeTimer = setTimeout(() => { status.style.opacity = '0'; }, 1800);
    }).observe(status, { childList: true, characterData: true, subtree: true });
  }

  function whenLeafletReady() {
    if ((window as any).L) initMap();
    else requestAnimationFrame(whenLeafletReady);
  }
  whenLeafletReady();

  // When the mobile nav menu closes, the map shell is restored from display:none.
  // Call invalidateSize so Leaflet recalculates tile bounds for the visible area.
  window.addEventListener('resize', () => {
    if (map && document.body.classList.contains('nav-menu-open') === false) {
      map.invalidateSize();
    }
  });
})();
</script>

</ToolLayout>
