---
import ToolLayout from '../../layouts/ToolLayout.astro';
import bccZoneColors from '../../data/bcc-zone-colors.json';

const legendGroups = [
  { label: 'Residential', items: [
    { short: 'CR',  name: 'Character Residential',          color: '#6a8f5a', height: 'Up to 8.5 m (2 storeys)' },
    { short: 'LDR', name: 'Low Density Residential',        color: '#b8a84a', height: 'Up to 9.5 m (2 storeys)' },
    { short: 'LMR', name: 'Low-Medium Density Residential', color: '#d4843c', height: 'Up to 3 storeys (~15 m)' },
    { short: 'MDR', name: 'Medium Density Residential',     color: '#c05a2a', height: 'Up to 5 storeys (~15 m)' },
    { short: 'HDR', name: 'High Density Residential',       color: '#9a2a1a', height: '10+ storeys (site-specific)' },
  ]},
  { label: 'Mixed Use & Centres', items: [
    { short: 'MU',  name: 'Mixed Use',                      color: '#7a5acd', height: 'Up to 5 storeys typical' },
    { short: 'NC',  name: 'Neighbourhood Centre',           color: '#5a7acd', height: 'Up to 3-4 storeys' },
    { short: 'LC',  name: 'Local Centre',                   color: '#3a5aad', height: 'Up to 4-5 storeys' },
    { short: 'DC',  name: 'District Centre',                color: '#2a3a8d', height: 'Up to 8+ storeys' },
    { short: 'PC',  name: 'Principal Centre',               color: '#1a1a6d', height: 'Unrestricted / site-specific' },
  ]},
  { label: 'Open Space & Environment', items: [
    { short: 'OS',  name: 'Open Space',                     color: '#3a9a5a', height: 'Low structures only' },
    { short: 'CN',  name: 'Conservation',                   color: '#1a6a3a', height: 'Minimal' },
  ]},
  { label: 'Industry & Special', items: [
    { short: 'LII', name: 'Low Impact Industry',            color: '#7a9ab8', height: 'Up to 9.5 m' },
    { short: 'SP',  name: 'Special Purpose',                color: '#888888', height: 'Site-specific' },
    { short: 'RU',  name: 'Rural',                          color: '#b8a07a', height: 'Low' },
  ]},
];
---

<ToolLayout
  title="Brisbane Property Map"
  tool="Property Map"
  phase="Buyer Tools"
  description="Zoning, stormwater, water and sewer on one map. Look up any Brisbane address to see BCC City Plan zones, drainage easements and QUU infrastructure constraints."
  manifest="/manifest-property-map.webmanifest"
  ogImage="/img/og-property-map.png"
>

<style>
  .pm-shell { max-width: 1400px; margin: 0 auto; padding: 1.25rem 1rem 3rem; }
  @media (min-width: 1024px) { .pm-shell { padding: 1.5rem 2rem 4rem; } }
  @media (max-width: 768px) {
    .pm-shell { padding: 0.75rem 0.75rem 2rem; }
    .pm-eduline { font-size: 0.64rem; padding: 0.4rem 0.7rem; }
    .pm-eduline strong { font-size: 0.58rem; }
  }

  .pm-eduline {
    margin-bottom: 0.6rem;
    padding: 0.5rem 0.85rem;
    background: rgba(196,145,42,0.07);
    border-left: 3px solid var(--color-gold);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: rgba(28,25,23,0.55);
    line-height: 1.4;
  }
  .pm-eduline strong {
    font-weight: 800; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--color-gold);
    font-size: 0.62rem; margin-right: 0.4rem;
  }

  /* ── Search bar ────────────────────────────────────────────────────── */
  .pm-search-bar { display: flex; gap: 0.4rem; margin-bottom: 0.85rem; }
  #pm-search-wrap { position: relative; flex: 1; }
  #pm-search {
    width: 100%; font-family: var(--font-sans); font-size: 1rem;
    padding: 0.95rem 1.1rem;
    border: 1px solid rgba(28,25,23,0.18);
    background: #ffffff; color: #1c1917;
    outline: none; transition: border-color 0.2s, box-shadow 0.2s;
  }
  #pm-search:focus {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(196,145,42,0.15);
  }
  #pm-search::placeholder { color: #a8a29e; }
  #pm-search-btn {
    padding: 0 1.5rem; background: var(--color-gold); color: #0a0806;
    font-family: var(--font-sans); font-size: 0.7rem; font-weight: 800;
    letter-spacing: 0.1em; text-transform: uppercase;
    border: none; cursor: pointer; white-space: nowrap; transition: background 0.2s;
  }
  #pm-search-btn:hover { background: #d4af4a; }
  #pm-search-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  #pm-gps-btn {
    flex-shrink: 0; width: 46px;
    background: #f5f2eb;
    border: 1px solid rgba(28,25,23,0.12);
    color: rgba(28,25,23,0.5); cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: color 0.2s, background 0.2s;
  }
  #pm-gps-btn:hover { color: var(--color-gold); background: rgba(196,145,42,0.08); }
  #pm-gps-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  #pm-gps-btn.locating { color: var(--color-gold); }

  #pm-autocomplete {
    position: absolute; top: 100%; left: 0; right: 0;
    background: #ffffff;
    border: 1px solid rgba(28,25,23,0.12); border-top: none;
    z-index: 1100; max-height: 240px; overflow-y: auto;
    box-shadow: 0 8px 28px rgba(0,0,0,0.12);
  }
  .pm-ac-item {
    padding: 0.85rem 1rem; font-size: 0.85rem;
    color: rgba(28,25,23,0.88); cursor: pointer;
    border-bottom: 1px solid rgba(28,25,23,0.08); line-height: 1.4;
    min-height: 44px; display: flex; align-items: center;
  }
  .pm-ac-item:last-child { border-bottom: none; }
  .pm-ac-item:hover, .pm-ac-item:active { background: rgba(196,145,42,0.1); }

  /* ── Mobile sticky search ──────────────────────────────────────────── */
  @media (max-width: 640px) {
    .pm-search-sticky {
      position: sticky; top: 72px; z-index: 1010;
      background: #f7f5f0;
      padding: 0.6rem 0 0.5rem;
      margin: 0 -0.75rem;
      padding-left: 0.75rem; padding-right: 0.75rem;
      border-bottom: 1px solid rgba(28,25,23,0.08);
      box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    }
    .pm-search-bar { margin-bottom: 0; }
    #pm-search { font-size: 16px; height: 48px; padding: 0 0.9rem; }
    #pm-search-btn { height: 48px; padding: 0 1rem; font-size: 0.68rem; }
    #pm-gps-btn { width: 48px; height: 48px; }
    .pm-ac-item { padding: 1rem; min-height: 48px; font-size: 0.92rem; }
    .pm-eduline { display: none; }
    #pm-map { height: calc(100svh - 133px) !important; }
    .leaflet-top.leaflet-left { top: auto !important; bottom: 68px !important; }
  }

  /* ── Map shell ─────────────────────────────────────────────────────── */
  .pm-map-wrap { position: relative; }
  #pm-map {
    height: 700px; width: 100%;
    border: 1px solid rgba(28,25,23,0.1);
    touch-action: none; overscroll-behavior: contain;
  }
  @media (max-width: 768px) {
    #pm-map { height: calc(100svh - 140px); min-height: 420px; touch-action: none; overscroll-behavior: contain; }
    .leaflet-control-zoom a {
      width: 44px !important; height: 44px !important;
      line-height: 44px !important; font-size: 1.2rem !important;
    }
  }

  /* ── Floating controls ─────────────────────────────────────────────── */
  .pm-control {
    position: absolute; z-index: 1200;
    background: rgba(242,239,233,0.97);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(28,25,23,0.12);
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .pm-control-tr { top: 12px; right: 12px; }

  #pm-status {
    position: absolute; top: 12px; left: 50px; z-index: 500;
    background: rgba(242,239,233,0.95);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(28,25,23,0.1);
    padding: 0.45rem 0.85rem;
    font-size: 0.72rem; color: rgba(28,25,23,0.55);
    line-height: 1.4; max-width: 280px;
    pointer-events: none; transition: opacity 0.3s;
  }
  @media (max-width: 768px) {
    #pm-status { left: 58px; right: 12px; max-width: none; font-size: 0.66rem; padding: 0.4rem 0.65rem; }
  }

  /* ── Layer toggle button ───────────────────────────────────────────── */
  .pm-layer-toggle {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.55rem 0.85rem;
    background: transparent; border: none; cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: rgba(28,25,23,0.78);
  }
  .pm-layer-toggle:hover { background: rgba(196,145,42,0.1); }
  .pm-layer-toggle .pm-toggle-arrow { transition: transform 0.2s; opacity: 0.5; }
  .pm-layer-toggle[aria-expanded="true"] .pm-toggle-arrow { transform: rotate(180deg); }

  .pm-layer-panel {
    display: none; border-top: 1px solid rgba(28,25,23,0.09);
    width: 300px; padding: 0.4rem 0 0.7rem;
    max-height: 75vh; overflow-y: auto;
  }
  .pm-layer-panel.open { display: block; }

  /* Mobile: full-width bottom sheet */
  @media (max-width: 640px) {
    .pm-control-tr {
      position: fixed !important;
      top: auto !important;
      bottom: calc(78px + env(safe-area-inset-bottom)) !important;
      right: 0; left: 0; z-index: 1200;
      border-top: 1px solid rgba(28,25,23,0.12);
      box-shadow: 0 -4px 20px rgba(0,0,0,0.12);
    }
    .pm-layer-toggle { width: 100%; justify-content: center; padding: 0.75rem 1rem; font-size: 0.72rem; }
    .pm-layer-panel {
      width: 100%; display: none;
      grid-template-columns: 1fr;
      max-height: 50vh; overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 0.5rem 0.75rem 0.75rem;
    }
    .pm-layer-row { min-height: 44px; }
    .pm-layer-panel.open { display: grid; }
    .pm-layer-group-head { grid-column: 1 / -1; }
    .pm-zone-sub { grid-column: 1 / -1; }
    .pm-layer-row { padding: 0.55rem 0.4rem; }
    .pm-layer-row input { width: 18px; height: 18px; }
    #pm-result {
      position: fixed !important;
      left: 12px; right: 12px;
      bottom: calc(126px + env(safe-area-inset-bottom));
      width: auto !important; max-width: none !important;
      max-height: 42vh; overflow-y: auto;
    }
  }

  .pm-layer-group-head {
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 800; letter-spacing: 0.18em;
    text-transform: uppercase; color: rgba(196,145,42,0.8);
    padding: 0.55rem 0.6rem 0.25rem;
  }
  .pm-infra-toggle {
    display: flex; align-items: center; gap: 0.4rem; width: 100%;
    font-family: var(--font-sans); font-size: 0.58rem; font-weight: 800;
    letter-spacing: 0.18em; text-transform: uppercase; color: rgba(196,145,42,0.8);
    padding: 0.55rem 0.6rem 0.25rem; background: none; border: none; cursor: pointer;
    border-top: 1px solid rgba(28,25,23,0.07);
  }
  .pm-infra-toggle:hover { color: rgba(196,145,42,1); }
  .pm-infra-toggle .pm-toggle-arrow { margin-left: auto; opacity: 0.5; transition: transform 0.2s; }
  .pm-infra-toggle[aria-expanded="true"] .pm-toggle-arrow { transform: rotate(180deg); }
  #pm-infra-panel { display: none; }
  #pm-infra-panel.open { display: contents; }
  #pm-other-panel { display: none; }
  #pm-other-panel.open { display: contents; }
  #pm-schools-panel { display: none; }
  #pm-schools-panel.open { display: contents; }
  .pm-layer-row {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.45rem 0.6rem;
    cursor: pointer; user-select: none; transition: background 0.15s;
  }
  .pm-layer-row:hover { background: rgba(196,145,42,0.07); }
  .pm-layer-row input { accent-color: var(--color-gold); cursor: pointer; }
  .pm-swatch { width: 24px; height: 14px; flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; }
  .pm-swatch-line { width: 24px; height: 3px; }
  .pm-swatch-line-dash { width: 24px; height: 3px; background-image: repeating-linear-gradient(90deg, currentColor 0, currentColor 5px, transparent 5px, transparent 9px); }
  .pm-swatch-dot { width: 9px; height: 9px; border-radius: 50%; border: 1.5px solid rgba(28,25,23,0.25); box-shadow: 0 0 0 1px rgba(0,0,0,0.1); }
  .pm-layer-name {
    font-family: var(--font-sans);
    font-size: 0.74rem; font-weight: 600;
    color: rgba(28,25,23,0.88); line-height: 1.3; flex: 1;
  }
  .pm-layer-hint {
    display: block; font-weight: 400;
    font-size: 0.66rem; color: rgba(28,25,23,0.38); margin-top: 0.1rem;
  }

  /* ── Zone sub-controls (opacity + legend) ──────────────────────────── */
  .pm-zone-sub {
    padding: 0 0.6rem 0.5rem 2.1rem;
    border-bottom: 1px solid rgba(28,25,23,0.07);
    margin-bottom: 0.25rem;
  }
  .pm-opacity-row {
    display: flex; align-items: center; gap: 0.55rem;
    margin-bottom: 0.4rem;
  }
  .pm-opacity-label {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: rgba(28,25,23,0.38);
    white-space: nowrap; flex-shrink: 0;
  }
  #pm-opacity-val { color: rgba(196,145,42,0.9); }
  .pm-opacity-slider { flex: 1; accent-color: var(--color-gold); cursor: pointer; height: 3px; }
  .pm-legend-btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    background: transparent; border: 1px solid rgba(28,25,23,0.1); cursor: pointer;
    font-family: var(--font-sans); font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(28,25,23,0.5); padding: 0.3rem 0.65rem;
    transition: color 0.15s, border-color 0.15s;
  }
  .pm-legend-btn:hover { color: rgba(196,145,42,0.9); border-color: rgba(196,145,42,0.3); }
  .pm-legend-btn .pm-toggle-arrow { transition: transform 0.2s; }
  .pm-legend-btn[aria-expanded="true"] .pm-toggle-arrow { transform: rotate(180deg); }
  #pm-legend-list {
    margin-top: 0.35rem;
    max-height: 200px; overflow-y: auto;
  }
  .pm-legend-row {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 0; cursor: pointer; transition: opacity 0.15s;
  }
  .pm-legend-row:hover { opacity: 0.8; }
  .pm-zone-swatch {
    width: 12px; height: 12px; border-radius: 2px; flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.15);
  }
  .pm-legend-code {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 800; letter-spacing: 0.04em;
    color: rgba(28,25,23,0.78); flex-shrink: 0; min-width: 28px;
  }
  .pm-legend-name {
    font-size: 0.66rem; color: rgba(28,25,23,0.5); line-height: 1.3; flex: 1;
  }

  /* ── First-load guide ──────────────────────────────────────────────── */
  #pm-guide {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 599;
    background: rgba(242,239,233,0.97);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(28,25,23,0.12);
    box-shadow: 0 8px 36px rgba(0,0,0,0.15);
    padding: 1.75rem 2rem; text-align: center;
    width: min(300px, calc(100% - 3rem));
    transition: opacity 0.35s, transform 0.35s;
  }
  #pm-guide svg { color: var(--color-gold); margin: 0 auto 0.85rem; display: block; }
  #pm-guide p { font-family: var(--font-sans); font-size: 0.82rem; color: rgba(28,25,23,0.65); line-height: 1.65; margin-bottom: 1.1rem; }
  #pm-guide-dismiss {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: var(--color-gold); color: #0a0806;
    font-family: var(--font-sans); font-size: 0.65rem; font-weight: 800;
    letter-spacing: 0.1em; text-transform: uppercase;
    border: none; cursor: pointer; padding: 0.6rem 1.35rem;
    transition: background 0.2s;
  }
  #pm-guide-dismiss:hover { background: #d4af4a; }
  #pm-guide.hidden { opacity: 0; pointer-events: none; transform: translate(-50%, calc(-50% + 8px)); }

  /* ── Result drawer ─────────────────────────────────────────────────── */
  #pm-result {
    position: absolute; left: 14px; bottom: 14px; z-index: 600;
    background: rgba(242,239,233,0.98);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border-left: 3px solid var(--color-gold);
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    padding: 0 1.15rem 1rem; max-width: 440px;
    width: calc(100% - 28px);
    transform: translate3d(0, calc(100% + 24px), 0);
    transition: transform 0.28s cubic-bezier(0.2,0.7,0.2,1), border-left-color 0.2s;
    visibility: hidden; overflow: hidden;
  }
  #pm-result.open { transform: translate3d(0,0,0); visibility: visible; }
  @media (min-width: 768px) { #pm-result { width: 440px; } }

  /* Zone mode border colors */
  #pm-result.mode-zone.zone-cr  { border-left-color: #6a8f5a; }
  #pm-result.mode-zone.zone-ldr { border-left-color: #b8a84a; }
  #pm-result.mode-zone.zone-lmr { border-left-color: #d4843c; }
  #pm-result.mode-zone.zone-mdr { border-left-color: #c05a2a; }
  #pm-result.mode-zone.zone-hdr { border-left-color: #9a2a1a; }
  #pm-result.mode-zone.zone-mu  { border-left-color: #7a5acd; }
  #pm-result.mode-zone.zone-nc  { border-left-color: #5a7acd; }
  #pm-result.mode-zone.zone-lc  { border-left-color: #3a5aad; }
  #pm-result.mode-zone.zone-dc  { border-left-color: #2a3a8d; }
  #pm-result.mode-zone.zone-pc  { border-left-color: #1a1a6d; }
  #pm-result.mode-zone.zone-os  { border-left-color: #3a9a5a; }
  #pm-result.mode-zone.zone-cn  { border-left-color: #1a6a3a; }
  #pm-result.mode-zone.zone-sp  { border-left-color: #888888; }
  #pm-result.mode-zone.zone-lii { border-left-color: #7a9ab8; }
  #pm-result.mode-zone.zone-ru  { border-left-color: #b8a07a; }

  /* Asset mode border colors */
  #pm-result.mode-asset.kind-propertyBoundary { border-left-color: #9e8c6a; }
  #pm-result.mode-asset.kind-stormPipe    { border-left-color: #2a8c9c; }
  #pm-result.mode-asset.kind-stormManhole { border-left-color: #1f6f7d; }
  #pm-result.mode-asset.kind-gully        { border-left-color: #d77b32; }
  #pm-result.mode-asset.kind-surfaceDrain { border-left-color: #4dadb8; }
  #pm-result.mode-asset.kind-sewerMain    { border-left-color: #8a6e2f; }
  #pm-result.mode-asset.kind-sewerService { border-left-color: #b8904a; }
  #pm-result.mode-asset.kind-sewerManhole { border-left-color: #6c5320; }
  #pm-result.mode-asset.kind-waterMain    { border-left-color: #2c7fc4; }
  #pm-result.mode-asset.kind-waterService { border-left-color: #6fb5e0; }
  #pm-result.mode-asset.kind-hydrant      { border-left-color: #c43a3a; }

  /* Asset header tints */
  #pm-result.mode-asset.kind-propertyBoundary .pm-result-head { background: rgba(158,140,106,0.14); }
  #pm-result.mode-asset.kind-stormPipe    .pm-result-head { background: rgba(42,140,156,0.14); }
  #pm-result.mode-asset.kind-stormManhole .pm-result-head { background: rgba(31,111,125,0.14); }
  #pm-result.mode-asset.kind-gully        .pm-result-head { background: rgba(215,123,50,0.14); }
  #pm-result.mode-asset.kind-surfaceDrain .pm-result-head { background: rgba(77,173,184,0.14); }
  #pm-result.mode-asset.kind-sewerMain    .pm-result-head { background: rgba(138,110,47,0.16); }
  #pm-result.mode-asset.kind-sewerService .pm-result-head { background: rgba(184,144,74,0.12); }
  #pm-result.mode-asset.kind-sewerManhole .pm-result-head { background: rgba(108,83,32,0.16); }
  #pm-result.mode-asset.kind-waterMain    .pm-result-head { background: rgba(44,127,196,0.14); }
  #pm-result.mode-asset.kind-waterService .pm-result-head { background: rgba(111,181,224,0.1); }
  #pm-result.mode-asset.kind-hydrant      .pm-result-head { background: rgba(196,58,58,0.14); }

  .pm-result-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 0.5rem; margin: 0 -1.15rem 0.7rem;
    padding: 0.7rem 1.15rem;
    border-bottom: 1px solid rgba(28,25,23,0.07);
    transition: background 0.2s;
  }
  .pm-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: rgba(28,25,23,0.45);
  }
  /* Zone mode eyebrow uses gold */
  #pm-result.mode-zone .pm-eyebrow { color: rgba(196,145,42,0.8); }
  .pm-close {
    background: transparent; border: none; cursor: pointer;
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    color: rgba(28,25,23,0.35); padding: 0;
    transition: color 0.15s, background 0.15s;
  }
  .pm-close:hover { color: rgba(28,25,23,0.85); background: rgba(28,25,23,0.06); }

  /* Zone result body styles */
  .pm-zone-name-row { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0.4rem; }
  .pm-zone-dot { width: 14px; height: 14px; border-radius: 3px; flex-shrink: 0; border: 1px solid rgba(255,255,255,0.15); }
