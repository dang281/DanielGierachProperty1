---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Instant Valuation"
  description="Get an indicative value for your Brisbane property in minutes based on recent comparable sales in Daniel's key markets."
  tool="Instant Valuation"
  phase="Seller Tools"
>
  <div class="max-w-2xl mx-auto pt-8">

    <!-- Step indicator -->
    <div class="flex items-center gap-0 mb-8" id="step-indicator">
      {[1,2,3].map((s, i) => (
        <div class="flex items-center flex-1">
          <div class={`step-dot`} data-step={s} style={`width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;letter-spacing:0.05em;border:2px solid ${s === 1 ? 'var(--color-gold)' : 'rgba(72,72,72,0.3)'};color:${s === 1 ? 'var(--color-gold)' : 'var(--color-text-muted)'};flex-shrink:0;transition:all 0.3s;`}>
            {s}
          </div>
          {i < 2 && <div class="step-line" data-line={s} style={`flex:1;height:2px;background:${s < 1 ? 'var(--color-gold)' : 'rgba(72,72,72,0.2)'};transition:background 0.3s;`}></div>}
        </div>
      ))}
    </div>

    <!-- Step 1: Property details -->
    <div id="step-1">
      <div style="background:var(--color-surface-3);padding:2rem;margin-bottom:1.5rem;">
        <span class="eyebrow" style="display:block;margin-bottom:1rem;">Step 1</span>
        <h2 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;color:var(--color-text-primary);margin-bottom:1.5rem;">Tell us about your property</h2>

        <div class="flex flex-col gap-4">
          <div>
            <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">Suburb</label>
            <select id="suburb" class="obs-select" style="width:100%;">
              <option value="">Select a suburb...</option>
              <option value="balmoral">Balmoral</option>
              <option value="belmont">Belmont</option>
              <option value="brisbane-cbd">Brisbane CBD</option>
              <option value="bulimba">Bulimba</option>
              <option value="camp-hill">Camp Hill</option>
              <option value="cannon-hill">Cannon Hill</option>
              <option value="carina">Carina</option>
              <option value="carina-heights">Carina Heights</option>
              <option value="carindale">Carindale</option>
              <option value="coorparoo">Coorparoo</option>
              <option value="east-brisbane">East Brisbane</option>
              <option value="fortitude-valley">Fortitude Valley</option>
              <option value="greenslopes">Greenslopes</option>
              <option value="hawthorne">Hawthorne</option>
              <option value="hemmant">Hemmant</option>
              <option value="holland-park">Holland Park</option>
              <option value="holland-park-west">Holland Park West</option>
              <option value="kangaroo-point">Kangaroo Point</option>
              <option value="morningside">Morningside</option>
              <option value="mt-gravatt">Mt Gravatt</option>
              <option value="mt-gravatt-east">Mt Gravatt East</option>
              <option value="murarrie">Murarrie</option>
              <option value="new-farm">New Farm</option>
              <option value="norman-park">Norman Park</option>
              <option value="seven-hills">Seven Hills</option>
              <option value="tarragindi">Tarragindi</option>
              <option value="teneriffe">Teneriffe</option>
              <option value="tingalpa">Tingalpa</option>
              <option value="upper-mount-gravatt">Upper Mount Gravatt</option>
              <option value="woolloongabba">Woolloongabba</option>
            </select>
          </div>

          <div>
            <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">Property Type</label>
            <div class="grid grid-cols-3 gap-2">
              {['House', 'Unit / Apt', 'Terrace'].map((t, i) => (
                <label style="cursor:pointer;text-align:center;">
                  <input type="radio" name="prop-type" value={t.toLowerCase().replace(' / ', '-')} checked={i === 0} style="display:none;" />
                  <div class={`ptype-label`} style={`padding:0.75rem;background:var(--color-surface-4);font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-text-primary);border:2px solid ${i === 0 ? 'var(--color-gold)' : 'transparent'};transition:all 0.2s;`}>
                    {t}
                  </div>
                </label>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-3 gap-4">
            <div>
              <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">Bedrooms</label>
              <select id="bedrooms" class="obs-select">
                {[1,2,3,4,5].map(n => <option value={n} selected={n === 3}>{n}{n === 5 ? '+' : ''}</option>)}
              </select>
            </div>
            <div>
              <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">Bathrooms</label>
              <select id="bathrooms" class="obs-select">
                {[1,2,3,4].map(n => <option value={n} selected={n === 2}>{n}{n === 4 ? '+' : ''}</option>)}
              </select>
            </div>
            <div>
              <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">Car Spaces</label>
              <select id="carspaces" class="obs-select">
                {[0,1,2,3].map(n => <option value={n} selected={n === 1}>{n}{n === 3 ? '+' : ''}</option>)}
              </select>
            </div>
          </div>

          <button id="next-1" class="btn-gold" style="width:100%;justify-content:center;margin-top:0.5rem;">
            Continue →
          </button>
        </div>
      </div>
    </div>

    <!-- Step 2: Property condition -->
    <div id="step-2" style="display:none;">
      <div style="background:var(--color-surface-3);padding:2rem;margin-bottom:1.5rem;">
        <span class="eyebrow" style="display:block;margin-bottom:1rem;">Step 2</span>
        <h2 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;color:var(--color-text-primary);margin-bottom:1.5rem;">Property condition & features</h2>

        <div class="flex flex-col gap-5">
          <div>
            <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Condition</label>
            <div class="flex flex-col gap-2">
              {['As-is / needs work', 'Average / liveable', 'Well-maintained', 'Renovated / updated', 'Brand new / prestige finish'].map((c, i) => (
                <label style="cursor:pointer;display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1rem;background:var(--color-surface-4);">
                  <input type="radio" name="condition" value={i} checked={i === 2} style="accent-color:var(--color-gold);cursor:pointer;" />
                  <span style="font-size:0.85rem;color:var(--color-text-secondary);">{c}</span>
                </label>
              ))}
            </div>
          </div>

          <div>
            <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Premium Features</label>
            <div class="grid grid-cols-2 gap-2">
              {['Water / river views', 'North-facing aspect', 'Swimming pool', 'Large land / garden', 'Recent renovation', 'Double lock-up garage'].map(f => (
                <label style="cursor:pointer;display:flex;align-items:center;gap:0.6rem;padding:0.65rem 0.75rem;background:var(--color-surface-4);">
                  <input type="checkbox" data-feature={f} style="accent-color:var(--color-gold);cursor:pointer;" />
                  <span style="font-size:0.75rem;color:var(--color-text-secondary);">{f}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="flex gap-3">
            <button id="back-1" class="btn-outline-gold" style="flex:1;justify-content:center;">← Back</button>
            <button id="next-2" class="btn-gold" style="flex:2;justify-content:center;">Continue →</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 3: Lead gate + result -->
    <div id="step-3" style="display:none;">
      <div style="background:var(--color-surface-3);padding:2rem;margin-bottom:1.5rem;">
        <span class="eyebrow" style="display:block;margin-bottom:1rem;">Step 3</span>
        <h2 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;color:var(--color-text-primary);margin-bottom:0.5rem;">Almost there</h2>
        <p style="font-size:0.85rem;color:var(--color-text-secondary);margin-bottom:1.5rem;line-height:1.7;">Enter your details to receive your estimated property value and a tailored market report.</p>

        <form method="POST" action="https://formspree.io/f/xnjgedwp" class="flex flex-col gap-4">
          <input type="hidden" name="_next" value="https://www.danielgierach.com/thank-you" />
          <input type="hidden" name="_subject" value="New valuation request — danielgierach.com" />
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">First Name</label>
              <input type="text" id="fname" name="first_name" placeholder="First Name" class="obs-input form-field" style="width:100%;" />
            </div>
            <div>
              <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">Last Name</label>
              <input type="text" id="lname" name="last_name" placeholder="Last Name" class="obs-input form-field" style="width:100%;" />
            </div>
          </div>
          <div>
            <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">Email</label>
            <input type="email" id="email" name="email" placeholder="jane@example.com" class="obs-input form-field" style="width:100%;" />
          </div>
          <div>
            <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.5rem;">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="04xx xxx xxx" class="obs-input form-field" style="width:100%;" />
          </div>

          <div class="flex gap-3">
            <button type="button" id="back-2" class="btn-outline-gold" style="flex:1;justify-content:center;">← Back</button>
            <button type="button" id="get-valuation" class="btn-gold" style="flex:2;justify-content:center;">Get My Valuation →</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Result -->
    <div id="result" style="display:none;">
      <div style="background:var(--color-surface-3);padding:2.5rem;text-align:center;margin-bottom:1.5rem;">
        <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">Estimated Value Range</p>
        <p id="val-low-high" style="font-family:var(--font-serif);font-size:2.5rem;font-weight:400;color:var(--color-text-primary);line-height:1.1;margin-bottom:0.75rem;"></p>
        <p id="val-mid" style="font-size:1rem;color:var(--color-text-secondary);margin-bottom:0.5rem;"></p>
        <p id="val-suburb" style="font-size:0.8rem;color:var(--color-text-muted);">Based on recent comparable sales in your suburb.</p>
      </div>

      <div style="background:rgba(255,221,121,0.06);border:1px solid rgba(255,221,121,0.2);padding:2rem;">
        <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.5rem;">Want a precise appraisal?</p>
        <p style="font-size:0.85rem;color:var(--color-text-secondary);margin-bottom:1.25rem;line-height:1.7;">This is an automated estimate. For an accurate, obligation-free appraisal from Dan with a full comparable sales report, book below.</p>
        <a href="/appraisal" class="btn-gold" style="justify-content:center;display:inline-flex;">Book a Free Appraisal →</a>
      </div>
    </div>

  </div>
</ToolLayout>

<script>
  const MEDIAN: Record<string, { house: number; unit: number; terrace: number }> = {
    'balmoral':          { house: 1900000, unit: 720000,  terrace: 1550000 },
    'belmont':           { house: 870000,  unit: 480000,  terrace: 740000  },
    'brisbane-cbd':      { house: 1800000, unit: 750000,  terrace: 1500000 },
    'bulimba':           { house: 1750000, unit: 685000,  terrace: 1400000 },
    'camp-hill':         { house: 1380000, unit: 630000,  terrace: 1150000 },
    'cannon-hill':       { house: 1150000, unit: 580000,  terrace: 950000  },
    'carina':            { house: 920000,  unit: 510000,  terrace: 780000  },
    'carina-heights':    { house: 870000,  unit: 480000,  terrace: 740000  },
    'carindale':         { house: 910000,  unit: 500000,  terrace: 760000  },
    'coorparoo':         { house: 1320000, unit: 610000,  terrace: 1100000 },
    'east-brisbane':     { house: 1450000, unit: 650000,  terrace: 1200000 },
    'fortitude-valley':  { house: 1600000, unit: 690000,  terrace: 1350000 },
    'greenslopes':       { house: 1100000, unit: 560000,  terrace: 920000  },
    'hawthorne':         { house: 1620000, unit: 660000,  terrace: 1300000 },
    'hemmant':           { house: 820000,  unit: 460000,  terrace: 700000  },
    'holland-park':      { house: 1000000, unit: 540000,  terrace: 850000  },
    'holland-park-west': { house: 980000,  unit: 530000,  terrace: 830000  },
    'kangaroo-point':    { house: 1520000, unit: 710000,  terrace: 1300000 },
    'morningside':       { house: 1280000, unit: 620000,  terrace: 1050000 },
    'mt-gravatt':        { house: 970000,  unit: 530000,  terrace: 820000  },
    'mt-gravatt-east':   { house: 920000,  unit: 510000,  terrace: 780000  },
    'murarrie':          { house: 950000,  unit: 520000,  terrace: 800000  },
    'new-farm':          { house: 2100000, unit: 780000,  terrace: 1700000 },
    'norman-park':       { house: 1350000, unit: 600000,  terrace: 1100000 },
    'seven-hills':       { house: 1200000, unit: 560000,  terrace: 1000000 },
    'tarragindi':        { house: 980000,  unit: 530000,  terrace: 840000  },
    'teneriffe':         { house: 2200000, unit: 800000,  terrace: 1750000 },
    'tingalpa':          { house: 850000,  unit: 490000,  terrace: 720000  },
    'upper-mount-gravatt':{ house: 950000, unit: 520000,  terrace: 810000  },
    'woolloongabba':     { house: 1250000, unit: 620000,  terrace: 1050000 },
  };

  function goToStep(n: number) {
    [1,2,3].forEach(s => {
      (document.getElementById(`step-${s}`) as HTMLElement).style.display = s === n ? 'block' : 'none';
    });

    // Update step indicators
    document.querySelectorAll('.step-dot').forEach(dot => {
      const s = Number((dot as HTMLElement).dataset.step);
      (dot as HTMLElement).style.borderColor = s <= n ? 'var(--color-gold)' : 'rgba(72,72,72,0.3)';
      (dot as HTMLElement).style.color       = s <= n ? 'var(--color-gold)' : 'var(--color-text-muted)';
    });
    document.querySelectorAll('.step-line').forEach(line => {
      const s = Number((line as HTMLElement).dataset.line);
      (line as HTMLElement).style.background = s < n ? 'var(--color-gold)' : 'rgba(72,72,72,0.2)';
    });
  }

  document.getElementById('next-1')!.addEventListener('click', () => {
    if (!(document.getElementById('suburb') as HTMLSelectElement).value) {
      alert('Please select a suburb.');
      return;
    }
    goToStep(2);
  });

  document.getElementById('back-1')!.addEventListener('click', () => goToStep(1));
  document.getElementById('next-2')!.addEventListener('click', () => goToStep(3));
  document.getElementById('back-2')!.addEventListener('click', () => goToStep(2));

  document.getElementById('get-valuation')!.addEventListener('click', () => {
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    if (!email) { alert('Please enter your email.'); return; }

    const suburb   = (document.getElementById('suburb') as HTMLSelectElement).value;
    const propType = (document.querySelector('input[name="prop-type"]:checked') as HTMLInputElement).value;
    const beds     = Number((document.getElementById('bedrooms') as HTMLSelectElement).value);
    const condition= Number((document.querySelector('input[name="condition"]:checked') as HTMLInputElement).value);
    const features = document.querySelectorAll('input[data-feature]:checked').length;

    const medians = MEDIAN[suburb] || { house: 2000000, unit: 900000, terrace: 1500000 };
    let base = propType.includes('unit') ? medians.unit : propType.includes('terrace') ? medians.terrace : medians.house;

    // Adjust for beds
    const bedAdj = (beds - 3) * 0.08;
    base *= (1 + bedAdj);

    // Condition multiplier (0-4 → -10% to +20%)
    const condMult = [0.90, 0.95, 1.00, 1.10, 1.20][condition];
    base *= condMult;

    // Premium features (+3% each)
    base *= (1 + features * 0.03);

    const low  = Math.round(base * 0.92 / 10000) * 10000;
    const high = Math.round(base * 1.08 / 10000) * 10000;
    const mid  = Math.round(base / 10000) * 10000;

    const fmt = (n: number) => n >= 1000000 ? `$${(n/1000000).toFixed(2)}M` : `$${(n/1000).toFixed(0)}K`;

    document.getElementById('val-low-high')!.textContent = `${fmt(low)} – ${fmt(high)}`;
    document.getElementById('val-mid')!.textContent = `Mid-point estimate: ${fmt(mid)}`;
    document.getElementById('val-suburb')!.textContent = `Based on recent comparable sales in ${suburb.charAt(0).toUpperCase() + suburb.slice(1).replace('-', ' ')}.`;

    // Hide step 3, show result
    (document.getElementById('step-3') as HTMLElement).style.display = 'none';
    (document.getElementById('result') as HTMLElement).style.display = 'block';
  });

  // Property type radio style
  document.querySelectorAll('input[name="prop-type"]').forEach(r => {
    r.addEventListener('change', () => {
      document.querySelectorAll('.ptype-label').forEach(l => (l as HTMLElement).style.borderColor = 'transparent');
      const lbl = (r as HTMLInputElement).closest('label')?.querySelector('.ptype-label') as HTMLElement;
      if (lbl) lbl.style.borderColor = 'var(--color-gold)';
    });
  });

  // Green tick validation
  document.querySelectorAll<HTMLInputElement>('.form-field').forEach(input => {
    const wrap = document.createElement('div');
    wrap.className = 'field-wrap';
    input.parentNode!.insertBefore(wrap, input);
    wrap.appendChild(input);

    const tick = document.createElement('span');
    tick.className = 'field-tick';
    tick.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
    wrap.appendChild(tick);

    input.addEventListener('blur', () => {
      if (input.value.trim() && input.checkValidity()) {
        input.classList.add('valid');
        tick.classList.add('show');
      } else {
        input.classList.remove('valid');
        tick.classList.remove('show');
      }
    });
    input.addEventListener('focus', () => {
      input.classList.remove('valid');
      tick.classList.remove('show');
    });
  });
</script>
