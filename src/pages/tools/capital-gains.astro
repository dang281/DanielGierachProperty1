      <table class="pr-table">
        <tr><td>Purchase price</td><td class="pr-val" id="pr-pp"></td></tr>
        <tr><td>Purchase date</td><td class="pr-val" id="pr-pd"></td></tr>
        <tr><td>Sale price</td><td class="pr-val" id="pr-sp"></td></tr>
