  <!-- Row 2: Gain/Loss + Tax (2-col) -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:1rem;padding-top:0.85rem;border-top:1px solid #f0ece4;">

    <div id="pr-gain-block">
      <span class="pr-section-title" id="pr-gain-title">Estimated Capital Gain</span>
      <table class="pr-table" id="pr-gain-table"></table>
