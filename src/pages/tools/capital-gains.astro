  </div>

  <!-- Row 3: Net Proceeds highlight -->
  <div style="margin-top:1rem;padding-top:0.85rem;border-top:1px solid #f0ece4;display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start;">

    <div>
      <span class="pr-section-title">Net Proceeds After Tax</span>
      <table class="pr-table" id="pr-proceeds-table" style="margin-bottom:0.5rem;"></table>
      <div style="padding:0.6rem 0.85rem;background:#faf8f4;border-left:3px solid #c5a03c;margin-top:0.25rem;">
        <div style="font-family:system-ui,sans-serif;font-size:6pt;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#78716c;">Estimated Net Proceeds</div>
        <div style="font-family:Georgia,serif;font-size:14pt;font-weight:400;color:#c5a03c;line-height:1.2;" id="pr-net-proceeds"></div>
        <div style="font-family:system-ui,sans-serif;font-size:6.5pt;color:#78716c;margin-top:0.15rem;" id="pr-effective-rate"></div>
      </div>
    </div>

    <!-- Budget scenario comparison (shown if relevant) -->
    <div id="pr-compare-block" style="display:none;">
      <span class="pr-section-title">Budget Scenario Comparison</span>
      <table class="pr-table" id="pr-compare-table"></table>
    </div>

  </div>

  <!-- Assumptions -->
  <div style="margin-top:0.9rem;padding-top:0.75rem;border-top:1.5px solid #e5e0d8;">
    <span class="pr-section-title">Assumptions and Important Notes</span>
    <ul id="pr-assumptions" style="margin:0.3rem 0 0;padding-left:1rem;font-family:system-ui,sans-serif;font-size:6.5pt;color:#57534e;line-height:1.7;column-count:2;column-gap:1.5rem;"></ul>
