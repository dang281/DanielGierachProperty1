<script>
(function () {

  /* ─────────────────────────────────────────────────────────────
     HELPERS
  ───────────────────────────────────────────────────────────── */
  const getEl   = (id: string) => document.getElementById(id);
  const getInp  = (id: string) => getEl(id) as HTMLInputElement | null;
  const getSel  = (id: string) => getEl(id) as HTMLSelectElement | null;
  const numVal  = (id: string, fallback = 0): number => {
    const v = parseFloat(getInp(id)?.value || '');
    return isNaN(v) || v < 0 ? fallback : v;
  };
  const selVal  = (id: string): string => getSel(id)?.value || '';
  const setText = (id: string, t: string) => { const el = getEl(id); if (el) el.textContent = t; };
  const show    = (id: string) => { const el = getEl(id); if (el) el.style.display = 'block'; };
  const hide    = (id: string) => { const el = getEl(id); if (el) el.style.display = 'none'; };
  const showFlex = (id: string) => { const el = getEl(id); if (el) el.style.display = 'flex'; };
  const fmt     = (n: number) => '$' + Math.round(Math.abs(n)).toLocaleString('en-AU');
  const fmtNeg  = (n: number) => n < 0 ? '(' + fmt(n) + ')' : fmt(n);

  /* ─────────────────────────────────────────────────────────────
     TAX FUNCTIONS — 2024-25 Australian rates
  ───────────────────────────────────────────────────────────── */

  /** Individual resident income tax including LITO */
  function residentTax(income: number): number {
    if (income <= 0) return 0;
    let tax = 0;
    if      (income <= 18200)  tax = 0;
    else if (income <= 45000)  tax = (income - 18200) * 0.19;
    else if (income <= 135000) tax = 5092 + (income - 45000) * 0.325;
    else if (income <= 190000) tax = 34205 + (income - 135000) * 0.37;
    else                       tax = 54805 + (income - 190000) * 0.45;
    // Low Income Tax Offset (LITO) 2024-25
    let lito = 0;
    if      (income <= 37500)  lito = 700;
    else if (income <= 45000)  lito = 700 - (income - 37500) * 0.05;
    else if (income <= 66667)  lito = 325 - (income - 45000) * 0.015;
    return Math.max(0, tax - lito);
  }

  /** Non-resident individual income tax (no free threshold, no LITO) */
  function nonResidentTax(income: number): number {
    if (income <= 0) return 0;
    if      (income <= 135000) return income * 0.325;
    else if (income <= 190000) return 43875 + (income - 135000) * 0.37;
    else                       return 64225 + (income - 190000) * 0.45;
  }

  /** Medicare levy for Australian residents (2024-25 thresholds) */
  function medicare(income: number): number {
    if (income <= 0) return 0;
    if (income < 26000) return 0;
    if (income < 32500) return (income - 26000) * 0.10;
    return income * 0.02;
  }

  /* ─────────────────────────────────────────────────────────────
     HOLD PERIOD
  ───────────────────────────────────────────────────────────── */
  function holdDays(buyStr: string, sellStr: string): number {
    const b = new Date(buyStr), s = new Date(sellStr);
    if (isNaN(b.getTime()) || isNaN(s.getTime())) return 0;
    return Math.floor((s.getTime() - b.getTime()) / 86400000);
  }

  function holdYears(buyStr: string, sellStr: string): number {
    const b = new Date(buyStr), s = new Date(sellStr);
    if (isNaN(b.getTime()) || isNaN(s.getTime())) return 0;
    return (s.getFullYear() - b.getFullYear()) + (s.getMonth() - b.getMonth()) / 12;
  }

  function holdLabel(days: number): string {
    if (days <= 0) return '—';
    const y = Math.floor(days / 365), m = Math.floor((days % 365) / 30);
    const parts: string[] = [];
    if (y > 0) parts.push(y + (y === 1 ? ' year' : ' years'));
    if (m > 0) parts.push(m + (m === 1 ? ' month' : ' months'));
    return parts.join(', ') || `${days} days`;
  }

  /* ─────────────────────────────────────────────────────────────
     MAIN RESIDENCE EXEMPTION
     Simplified model of s.118-110 to s.118-192 ITAA 1997.
     Returns: exempt fraction (0-1), status, and a note string.
  ───────────────────────────────────────────────────────────── */
  function mainResExemption(
    mrStatus: string,
    everRented: string,
    rentedYrs: number,
    holdYrs: number,
    movedBack: string,
    onlyMainRes: string
  ): { fraction: number; status: string; note: string } {

    if (mrStatus === 'no') {
      return { fraction: 0, status: 'none', note: '' };
    }

    if (everRented === 'no') {
      // Never rented, used as main residence throughout — full exemption likely
      return {
        fraction: 1,
        status: 'full',
        note: 'The property appears to qualify for a full main residence exemption. No CGT should be payable, subject to confirming all eligibility criteria with a tax adviser.'
      };
    }

    // Property was rented at some point
    const safeFraction = holdYrs > 0 ? Math.min(rentedYrs / holdYrs, 1) : 0;
    const investFraction = safeFraction;
    const exemptFraction = 1 - investFraction;

    if (rentedYrs <= 6 && onlyMainRes === 'yes') {
      if (movedBack === 'yes') {
        // Classic absence rule scenario — potentially full exemption
        return {
          fraction: 1,
          status: 'absence_full',
          note: `The 6-year absence rule (s.118-145 ITAA 1997) may apply, potentially preserving the full main residence exemption even though the property was rented. This requires that no other dwelling was treated as your main residence during the absence, and that you moved back before selling. This estimate assumes full exemption. Seek advice to confirm.`
        };
      } else {
        // Rented for <= 6 years but did not move back — partial, but absence rule may still help
        return {
          fraction: exemptFraction,
          status: 'partial_absence',
          note: `A partial main residence exemption has been estimated based on the proportion of time the property was your main residence (${Math.round(exemptFraction * 100)}%). The 6-year absence rule may provide additional relief depending on your circumstances. This estimate requires professional review.`
        };
      }
    }

    if (rentedYrs > 6) {
      // Rented for more than 6 years — partial exemption, absence rule exceeded
      return {
        fraction: exemptFraction,
        status: 'partial',
        note: `A partial main residence exemption has been estimated at ${Math.round(exemptFraction * 100)}% based on the proportion of ownership during which the property was your main residence. The property was rented for more than 6 years, which exceeds the absence rule limit. Seek advice to confirm the correct exempt fraction.`
      };
    }

    // Rented <= 6 years, not the only main res
    return {
      fraction: exemptFraction,
      status: 'partial',
      note: `A partial main residence exemption has been estimated at ${Math.round(exemptFraction * 100)}%. As you may have had another main residence during this period, the absence rule may not apply. Seek advice from a tax adviser.`
    };
  }

  /* ─────────────────────────────────────────────────────────────
     MAIN CALCULATION
  ───────────────────────────────────────────────────────────── */
  function calc() {
    const purchasePrice = numVal('purchasePrice');
    const salePrice     = numVal('salePrice');
    const purchaseDate  = getInp('purchaseDate')?.value || '';
    const saleDateVal   = getInp('saleDate')?.value || '';
    const ownership     = selVal('ownershipType');
    const resident      = selVal('taxResident') === 'yes';
    const ownerShare    = ownership === 'joint' ? numVal('ownerShare', 50) / 100 : 1.0;
    const otherIncome   = numVal('otherIncome');
    const priorLosses   = numVal('priorLosses');
    const discountPct   = numVal('discountSlider', 50) / 100;

    // Cost base components
    const stampDuty     = numVal('stampDuty');
    const legalBuying   = numVal('legalBuying');
    const inspection    = numVal('inspection');
    const improvements  = numVal('improvements');
    const agentFee      = numVal('agentFee');
    const legalSelling  = numVal('legalSelling');
    const otherSelling  = numVal('otherSelling');
    const holdInterest  = numVal('holdInterest');
    const holdRates     = numVal('holdRates');
    const holdLandTax   = numVal('holdLandTax');
    const holdInsurance = numVal('holdInsurance');
    const holdBodyCorp  = numVal('holdBodyCorp');
    const holdOther     = numVal('holdOther');

    // Main residence inputs
    const mrStatus      = selVal('mainResStatus');
    const mrEverRented  = selVal('mrEverRented');
    const mrRentedYrs   = numVal('mrRentedYears', 0);
    const mrMovedBack   = selVal('mrMovedBack');
    const mrOnlyMainRes = selVal('mrOnlyMainRes');

    // Date validation
    const days = holdDays(purchaseDate, saleDateVal);
    const yrs  = holdYears(purchaseDate, saleDateVal);
    const dateError = getEl('dateWarning');
    if (days < 0) {
      if (dateError) dateError.style.display = 'block';
      return;
    }
    if (dateError) dateError.style.display = 'none';

    const over12 = days >= 366; // strictly more than 12 months

    /* ── Apply ownership share ── */
    const myPurchasePrice = purchasePrice * ownerShare;
    const mySalePrice     = salePrice * ownerShare;

    /* ── Cost base ── */
    const acquisitionCosts = stampDuty + legalBuying + inspection;
    const sellingCosts     = agentFee + legalSelling + otherSelling;
    const holdingCosts     = holdInterest + holdRates + holdLandTax + holdInsurance + holdBodyCorp + holdOther;
    const totalCostBase    = (myPurchasePrice) + (acquisitionCosts + improvements + holdingCosts) * ownerShare + sellingCosts * ownerShare;

    /* ── Gross gain / loss ── */
    const grossAmount = mySalePrice - totalCostBase;
    const isLoss = grossAmount < 0;

    /* ── Determine if discount applies ── */
    const isCompany  = ownership === 'company';
    const isSmsf     = ownership === 'smsf';
    const isTrust    = ownership === 'trust';
    const isJoint    = ownership === 'joint';
    const isIndividualType = !isCompany && !isSmsf;
    // Non-residents are not entitled to the CGT discount on Australian real property (post-2012)
    const discountApplicable = over12 && isIndividualType && resident;
    const effectiveDiscount  = discountApplicable ? discountPct : (isSmsf && over12 ? 1/3 : 0);

    /* ── Main residence ── */
    const { fraction: mrFraction, status: mrResultStatus, note: mrNote } =
      mainResExemption(mrStatus, mrEverRented, mrRentedYrs, yrs, mrMovedBack, mrOnlyMainRes);
    const isFullExempt = mrFraction >= 1 && !isLoss && grossAmount > 0;
    const mrExemptAmt  = !isLoss ? grossAmount * mrFraction : 0;
    const gainAfterMR  = Math.max(0, grossAmount - mrExemptAmt);

    /* ── Capital losses offset ── */
    const lossesApplied     = Math.min(priorLosses, gainAfterMR);
    const gainAfterLosses   = gainAfterMR - lossesApplied;

    /* ── CGT discount ── */
    const discountAmt = gainAfterLosses * effectiveDiscount;
    const netGain     = gainAfterLosses - discountAmt;

    /* ── Tax calculation ── */
    let taxOnGain  = 0;
    let medOnGain  = 0;
    let totalCGT   = 0;
    let taxBefore  = 0;
    let taxAfter   = 0;
    let medBefore  = 0;
    let medAfter   = 0;

    if (!isLoss && !isFullExempt && netGain > 0) {
      if (isCompany) {
        // Company: 30% flat (note: 25% for base rate, but we use 30% as conservative default)
        taxOnGain = netGain * 0.30;
        totalCGT  = taxOnGain;
      } else if (isSmsf) {
        // SMSF accumulation: 15% on two-thirds of gain (one-third discount already applied)
        taxOnGain = netGain * 0.15;
        totalCGT  = taxOnGain;
      } else if (isTrust) {
        // Show gain only — trust distributes to beneficiaries
        // For comparison panel, estimate as if individual
        taxBefore = resident ? residentTax(otherIncome) : nonResidentTax(otherIncome);
        taxAfter  = resident ? residentTax(otherIncome + netGain) : nonResidentTax(otherIncome + netGain);
        taxOnGain = Math.max(0, taxAfter - taxBefore);
        if (resident) {
          medBefore = medicare(otherIncome);
          medAfter  = medicare(otherIncome + netGain);
          medOnGain = Math.max(0, medAfter - medBefore);
        }
        totalCGT = 0; // Trust doesn't pay — shown as note
      } else {
        // Individual or joint
        taxBefore = resident ? residentTax(otherIncome) : nonResidentTax(otherIncome);
        taxAfter  = resident ? residentTax(otherIncome + netGain) : nonResidentTax(otherIncome + netGain);
        taxOnGain = Math.max(0, taxAfter - taxBefore);
        if (resident) {
          medBefore = medicare(otherIncome);
          medAfter  = medicare(otherIncome + netGain);
          medOnGain = Math.max(0, medAfter - medBefore);
        }
        totalCGT = taxOnGain + medOnGain;
      }
    }

    /* ── Net proceeds ── */
    const netProceeds = mySalePrice - (sellingCosts * ownerShare) - totalCGT;
    const effectiveRate = grossAmount > 0 ? (totalCGT / grossAmount) * 100 : 0;

    /* ── Budget comparison at 50% (current law) ── */
    let totalCGT50 = 0;
    if (!isLoss && !isFullExempt && !isCompany && !isSmsf && !isTrust && gainAfterLosses > 0) {
      const disc50    = (over12 && resident) ? 0.50 : 0;
      const net50     = gainAfterLosses * (1 - disc50);
      const t50After  = resident ? residentTax(otherIncome + net50) : nonResidentTax(otherIncome + net50);
      const t50Before = resident ? residentTax(otherIncome) : nonResidentTax(otherIncome);
      const m50       = resident ? Math.max(0, medicare(otherIncome + net50) - medicare(otherIncome)) : 0;
      totalCGT50 = Math.max(0, t50After - t50Before) + m50;
    }

    /* ═══════════════════════════════════════════════════════════
       UPDATE DOM
    ═══════════════════════════════════════════════════════════ */

    // Hold period badge
    setText('holdPeriod', holdLabel(days));
    const badge = getEl('discountBadge');
    if (badge) {
      if (isLoss) {
        badge.textContent = 'Capital Loss';
        badge.className = 'cg-badge loss';
      } else if (isFullExempt) {
        badge.textContent = 'Exempt';
        badge.className = 'cg-badge exempt';
      } else if (discountApplicable) {
        badge.textContent = `${Math.round(discountPct * 100)}% Discount`;
        badge.className = 'cg-badge eligible';
      } else if (isSmsf && over12) {
        badge.textContent = '⅓ Discount (SMSF)';
        badge.className = 'cg-badge eligible';
      } else {
        badge.textContent = over12 ? 'No Discount' : 'Under 12 Months';
        badge.className = 'cg-badge ineligible';
      }
    }

    let holdNoteStr = '';
    if (days === 0) {
      holdNoteStr = 'Enter your purchase and sale dates above.';
    } else if (!over12) {
      holdNoteStr = 'Held less than 12 months. CGT discount does not apply.';
    } else if (isCompany) {
      holdNoteStr = 'Companies do not receive the CGT discount regardless of hold period.';
    } else if (!resident) {
      holdNoteStr = 'Non-residents are not entitled to the CGT discount on Australian real property.';
    } else if (isSmsf) {
      holdNoteStr = 'Held over 12 months. One-third SMSF discount applied (effective 10%).';
    } else {
      holdNoteStr = `Held over 12 months. ${Math.round(discountPct * 100)}% CGT discount applies to net gain.`;
    }
    setText('holdNote', holdNoteStr);

    // Show correct state panel
    if (isLoss) {
      hide('gainPanel'); hide('exemptPanel'); show('lossPanel'); show('taxPanel'); show('proceedsPanel');
      setText('r-lossAmt', fmt(grossAmount) + ' capital loss');
      hide('taxIndividualSection'); hide('taxTrustSection'); hide('taxCompanySection'); hide('taxSmsfSection');
      const totalCgtRowEl = getEl('totalCgtRow');
      if (totalCgtRowEl) totalCgtRowEl.style.display = 'none';
      setText('r-totalCGT', '$0');
      setText('r-netProceeds', fmt(mySalePrice - sellingCosts * ownerShare));
      setText('r-effectiveRate', 'No CGT payable on a capital loss.');
      setText('r-marginalNote', '');
    } else if (isFullExempt) {
      hide('gainPanel'); show('exemptPanel'); hide('lossPanel'); show('taxPanel'); show('proceedsPanel');
      const exemptMsgEl = getEl('r-exemptMsg');
      if (exemptMsgEl) {
        exemptMsgEl.textContent = mrResultStatus === 'absence_full'
          ? 'Full exemption likely (absence rule)'
          : 'Full main residence exemption likely';
      }
      setText('r-exemptSub', mrNote || 'CGT may not apply to this transaction.');
      const noteEl = getEl('r-exemptNote');
      if (noteEl) noteEl.textContent = mrNote;
      hide('taxIndividualSection'); hide('taxTrustSection'); hide('taxCompanySection'); hide('taxSmsfSection');
      const totalCgtRowEl = getEl('totalCgtRow');
      if (totalCgtRowEl) totalCgtRowEl.style.display = 'none';
      setText('r-totalCGT', '$0');
      setText('r-netProceeds', fmt(mySalePrice - sellingCosts * ownerShare));
      setText('r-effectiveRate', 'Main residence exemption. No CGT estimated.');
      setText('r-marginalNote', '');
    } else {
      show('gainPanel'); hide('exemptPanel'); hide('lossPanel'); show('taxPanel'); show('proceedsPanel');

      // Gain panel
      setText('r-salePrice', fmt(mySalePrice));
      setText('r-costBase', '(' + fmt(totalCostBase) + ')');
      setText('r-grossGain', fmt(grossAmount));

      const mrRow = getEl('mrExemptRow');
      if (mrRow) {
        mrRow.style.display = mrExemptAmt > 0 ? 'flex' : 'none';
        setText('mrExemptLabel', mrFraction < 1
          ? `Less: partial main residence (${Math.round(mrFraction * 100)}%)`
          : 'Less: main residence exemption');
        setText('r-mrExempt', '(' + fmt(mrExemptAmt) + ')');
      }

      const prLossRow = getEl('priorLossRow');
      if (prLossRow) {
        prLossRow.style.display = lossesApplied > 0 ? 'flex' : 'none';
        setText('r-priorApplied', '(' + fmt(lossesApplied) + ')');
      }

      const gainBeforeRow = getEl('gainBeforeDiscountRow');
      if (gainBeforeRow) {
        gainBeforeRow.style.display = (lossesApplied > 0 || mrExemptAmt > 0) && discountAmt > 0 ? 'flex' : 'none';
        setText('r-gainBeforeDiscount', fmt(gainAfterLosses));
      }

      const discRow = getEl('discountRow');
      if (discRow) {
        discRow.style.display = discountAmt > 0 ? 'flex' : 'none';
        const discPctLabel = isSmsf ? '⅓ SMSF discount' : `${Math.round(effectiveDiscount * 100)}% CGT discount`;
        setText('discountLabel', `Less: ${discPctLabel}`);
        setText('r-discountAmt', '(' + fmt(discountAmt) + ')');
      }

      setText('r-netGain', fmt(netGain));

      // Tax panel — show correct section
      hide('taxIndividualSection'); hide('taxTrustSection'); hide('taxCompanySection'); hide('taxSmsfSection');
      const totalCgtRowEl = getEl('totalCgtRow');
      if (totalCgtRowEl) totalCgtRowEl.style.display = 'flex';

      if (isCompany) {
        show('taxCompanySection');
        setText('r-companyGain', fmt(netGain));
        setText('r-companyTax', fmt(taxOnGain));
        setText('r-totalCGT', fmt(totalCGT));
      } else if (isSmsf) {
        show('taxSmsfSection');
        setText('r-smsfGain', fmt(netGain));
        setText('r-smsfTax', fmt(taxOnGain));
        setText('r-totalCGT', fmt(totalCGT));
      } else if (isTrust) {
        show('taxTrustSection');
        setText('r-trustGain', fmt(netGain));
        setText('r-totalCGT', '—');
        if (totalCgtRowEl) totalCgtRowEl.style.display = 'none';
      } else {
        show('taxIndividualSection');
        setText('r-otherIncome', fmt(otherIncome));
        setText('r-addGain', fmt(netGain));
        setText('r-totalIncome', fmt(otherIncome + netGain));
        setText('r-taxBefore', fmt(taxBefore));
        setText('r-taxAfter', fmt(taxAfter));
        setText('r-taxOnGain', fmt(taxOnGain));
        const medRow = getEl('medicareRow');
        if (medRow) medRow.style.display = resident ? 'flex' : 'none';
        setText('r-medicare', fmt(medOnGain));
        setText('r-totalCGT', fmt(totalCGT));
      }

      // Net proceeds
      setText('r-netProceeds', fmt(netProceeds));
      setText('r-effectiveRate',
        !isTrust && grossAmount > 0
          ? `Effective rate on gross gain: ${effectiveRate.toFixed(1)}%`
          : grossAmount > 0 ? 'Trust: tax depends on distribution.' : ''
      );

      // Marginal rate note
      if (!isCompany && !isSmsf && !isTrust && netGain > 0) {
        const marginalIncome = otherIncome + netGain;
        let margRate = 0;
        if (resident) {
          if      (marginalIncome <= 18200)  margRate = 0;
          else if (marginalIncome <= 45000)  margRate = 19;
          else if (marginalIncome <= 135000) margRate = 32.5;
          else if (marginalIncome <= 190000) margRate = 37;
          else                               margRate = 45;
        } else {
          margRate = marginalIncome <= 135000 ? 32.5 : marginalIncome <= 190000 ? 37 : 45;
        }
        setText('r-marginalNote', `Top marginal rate applied: ${margRate}%${resident ? ' + Medicare' : ''}`);
      } else {
        setText('r-marginalNote', '');
      }
    }

    // Budget comparison
    const cmpBlock = getEl('compareBlock');
    const showCompare = !isLoss && !isFullExempt && !isCompany && !isSmsf && !isTrust
      && Math.round(discountPct * 100) !== 50 && grossAmount > 0;
    if (cmpBlock) cmpBlock.style.display = showCompare ? 'block' : 'none';
    if (showCompare) {
      setText('r-compareCurrent', fmt(totalCGT50));
      setText('r-compareNew', fmt(totalCGT));
      setText('r-compareLabel', `${Math.round(discountPct * 100)}% Discount`);
      const diff = totalCGT - totalCGT50;
      const diffEl = getEl('r-compareDiff');
      if (diffEl) {
        if (Math.abs(diff) < 10) {
          diffEl.textContent = 'No material change';
          diffEl.style.color = 'var(--color-text-muted)';
        } else if (diff > 0) {
          diffEl.textContent = '+' + fmt(diff) + ' more tax';
          diffEl.style.color = '#c0392b';
        } else {
          diffEl.textContent = fmt(diff) + ' less tax';
          diffEl.style.color = '#4a9e4a';
        }
      }
    }

    // Mobile bar
    if (!isLoss && !isTrust) {
      setText('cg-mob-cgt', fmt(totalCGT));
    } else if (isTrust) {
      setText('cg-mob-cgt', 'See note');
    } else {
      setText('cg-mob-cgt', 'No CGT');
    }
    setText('cg-mob-net', fmt(isLoss ? mySalePrice - sellingCosts * ownerShare : netProceeds));

    // Dynamic assumptions
    buildAssumptions({ ownership, resident, mrResultStatus, mrFraction, over12, discountApplicable, isLoss, isFullExempt, ownerShare, isJoint, mrNote });
  }

  /* ─────────────────────────────────────────────────────────────
     DYNAMIC ASSUMPTIONS PANEL
  ───────────────────────────────────────────────────────────── */
  function buildAssumptions(ctx: {
    ownership: string; resident: boolean; mrResultStatus: string;
    mrFraction: number; over12: boolean; discountApplicable: boolean;
    isLoss: boolean; isFullExempt: boolean; ownerShare: number;
    isJoint: boolean; mrNote: string;
  }) {
    const notes: string[] = [
      'This estimate is for general guidance only and does not constitute tax advice.',
      'Uses 2024-25 Australian individual marginal tax rates and the Low Income Tax Offset.',
    ];

    if (!ctx.resident) notes.push('Non-residents are not entitled to the 50% CGT discount on Australian real property sales.');
    if (ctx.ownership === 'company') notes.push('Companies are taxed at 30% (25% for base rate entities). No CGT discount applies.');
    if (ctx.ownership === 'trust') notes.push('Discretionary trusts may pass the CGT discount through to individual beneficiaries. Tax outcomes depend on how the gain is distributed.');
    if (ctx.ownership === 'smsf') notes.push('SMSFs in accumulation phase receive a one-third discount. In pension phase, CGT may not apply. SMSF tax rules are complex. Seek specialist advice.');
    if (ctx.isJoint) notes.push(`Your ${Math.round(ctx.ownerShare * 100)}% ownership share has been applied throughout. Each co-owner declares their own share on their individual return.`);
    if (ctx.mrFraction > 0 && ctx.mrFraction < 1) notes.push('A partial main residence exemption has been estimated based on time the property was your main residence. The ATO uses days, not years. The actual exempt fraction may differ. Seek advice.');
    if (ctx.mrResultStatus === 'absence_full' || ctx.mrResultStatus === 'partial_absence') notes.push('The 6-year absence rule may affect your outcome. This requires the property to have been your main residence before the absence, and that you did not treat another dwelling as your main residence during that period.');
    if (ctx.isFullExempt) notes.push('A full main residence exemption appears to apply. Confirm with a tax adviser that all eligibility conditions are met before assuming no CGT is payable.');
    if (ctx.isLoss) notes.push('Capital losses must be recorded on your tax return even though no CGT is payable. They can only offset capital gains, not ordinary income.');
    notes.push('Transfer duty uses Queensland OSR standard rates. First home buyer concessions, foreign investor duty, and other QLD concessions are not automatically applied. Adjust the transfer duty figure if applicable.');
    notes.push('QLD land tax applies to investment properties above $600,000 (individuals) or $350,000 (companies and trustees). Your principal place of residence is generally exempt from QLD land tax.');
    notes.push('This estimate does not account for depreciation recapture, previous CGT events, or foreign resident capital gains withholding (FRCGW). Always seek advice from a registered tax agent or accountant before making decisions.');

    const list = getEl('assumptionsList');
    if (!list) return;
    list.innerHTML = notes.map(n => `<li>${n}</li>`).join('');
  }

  /* ─────────────────────────────────────────────────────────────
     CONDITIONAL FIELD VISIBILITY
  ───────────────────────────────────────────────────────────── */
  function handleOwnership() {
    const v = selVal('ownershipType');
    const row = getEl('ownerShareRow');
    if (row) row.style.display = v === 'joint' ? 'flex' : 'none';
    // Disable discount slider for company
    const slider = getEl('discountSlider') as HTMLInputElement;
    const discBlock = getEl('cg-discount-block') || document.querySelector('.cg-discount-block');
    if (v === 'company') {
      if (slider) slider.disabled = true;
      if (discBlock) (discBlock as HTMLElement).style.opacity = '0.4';
    } else {
      if (slider) slider.disabled = false;
      if (discBlock) (discBlock as HTMLElement).style.opacity = '1';
    }
    calc();
  }

  function handleMainRes() {
    const v = selVal('mainResStatus');
    const followUp = getEl('mrFollowUp');
    if (followUp) followUp.style.display = v === 'yes' ? 'block' : 'none';
    calc();
  }

  function handleMrRented() {
    const v = selVal('mrEverRented');
    const detail = getEl('mrRentedDetail');
    if (detail) detail.style.display = v === 'yes' ? 'block' : 'none';
    calc();
  }

  /* ─────────────────────────────────────────────────────────────
     HOLDING COSTS TOGGLE
  ───────────────────────────────────────────────────────────── */
  const holdingToggle = getEl('holdingToggle');
  const holdingSection = getEl('holdingSection');
  let holdingOpen = false;
  holdingToggle?.addEventListener('click', () => {
    holdingOpen = !holdingOpen;
    if (holdingSection) holdingSection.style.display = holdingOpen ? 'block' : 'none';
    const chevron = holdingToggle.querySelector('.cg-toggle-chevron');
    if (chevron) chevron.classList.toggle('open', holdingOpen);
    const btnSpan = holdingToggle.querySelector('span');
    if (btnSpan) btnSpan.textContent = holdingOpen ? '- Holding Costs (optional)' : '+ Holding Costs (optional)';
  });

  /* ─────────────────────────────────────────────────────────────
     DISCOUNT SLIDER AND PRESETS
  ───────────────────────────────────────────────────────────── */
  const slider  = getEl('discountSlider') as HTMLInputElement;
  const display = getEl('discountDisplay');

  function setDiscount(v: number) {
    if (slider) slider.value = String(v);
    if (display) display.textContent = v + '%';
    document.querySelectorAll<HTMLElement>('.cg-preset').forEach(p => {
      p.classList.toggle('active', p.dataset.val === String(v));
    });
    calc();
  }

  slider?.addEventListener('input', () => {
    const v = parseInt(slider.value);
    if (display) display.textContent = v + '%';
    document.querySelectorAll<HTMLElement>('.cg-preset').forEach(p => {
      p.classList.toggle('active', p.dataset.val === String(v));
    });
    calc();
  });

  document.querySelectorAll<HTMLElement>('.cg-preset').forEach(p => {
    p.addEventListener('click', () => setDiscount(parseInt(p.dataset.val || '50')));
  });

  /* ─────────────────────────────────────────────────────────────
     QLD TRANSFER DUTY AUTO-CALCULATOR
     Source: Queensland Revenue Office standard rates (2024-25)
     Residential property — standard dutiable value scale
  ───────────────────────────────────────────────────────────── */
  function qldTransferDuty(value: number): number {
    if (value <= 5000)    return 0;
    if (value <= 75000)   return Math.ceil((value - 5000) / 100) * 1.50;
    if (value <= 540000)  return 1050 + Math.ceil((value - 75000) / 100) * 3.50;
    if (value <= 1000000) return 17325 + Math.ceil((value - 540000) / 100) * 4.50;
    return 38025 + Math.ceil((value - 1000000) / 100) * 5.75;
  }

  getEl('calcDutyBtn')?.addEventListener('click', () => {
    const price = numVal('purchasePrice');
    if (!price) return;
    const duty = Math.round(qldTransferDuty(price));
    const dutyInput = getInp('stampDuty');
    if (dutyInput) {
      dutyInput.value = String(duty);
      // Brief highlight to confirm the change
      dutyInput.style.borderColor = '#c5a03c';
      setTimeout(() => { dutyInput.style.borderColor = ''; }, 1200);
    }
    const note = getEl('dutyCalcNote');
    if (note) {
      note.textContent = `Calculated: $${duty.toLocaleString('en-AU')} based on QLD standard rates for $${price.toLocaleString('en-AU')}. Adjust below if a FHB concession or other concession applied.`;
      note.style.display = 'block';
    }
    calc();
  });

  /* ─────────────────────────────────────────────────────────────
     DEFAULT SALE DATE (TODAY)
  ───────────────────────────────────────────────────────────── */
  const sdEl = getEl('saleDate') as HTMLInputElement;
  if (sdEl && !sdEl.value) sdEl.value = new Date().toISOString().split('T')[0];

  /* ─────────────────────────────────────────────────────────────
     MOBILE BAR VISIBILITY
  ───────────────────────────────────────────────────────────── */
  function checkLayout() {
    const bar = getEl('cg-mobile-bar');
    if (bar) bar.style.display = window.innerWidth < 900 ? 'flex' : 'none';
  }
  window.addEventListener('resize', checkLayout);
  checkLayout();

  /* ─────────────────────────────────────────────────────────────
     EVENT WIRING
  ───────────────────────────────────────────────────────────── */
  const inputIds = [
    'purchasePrice','purchaseDate','salePrice','saleDate',
    'stampDuty','legalBuying','inspection','improvements',
    'agentFee','legalSelling','otherSelling',
    'holdInterest','holdRates','holdLandTax','holdInsurance','holdBodyCorp','holdOther',
    'otherIncome','ownerShare','priorLosses','mrRentedYears'
  ];
  inputIds.forEach(id => {
    getEl(id)?.addEventListener('input', calc);
    getEl(id)?.addEventListener('change', calc);
  });

  ['ownershipType','taxResident'].forEach(id => getEl(id)?.addEventListener('change', handleOwnership));
  getEl('mainResStatus')?.addEventListener('change', handleMainRes);
  getEl('mrEverRented')?.addEventListener('change', handleMrRented);
  ['mrMovedBack','mrOnlyMainRes'].forEach(id => getEl(id)?.addEventListener('change', calc));

  /* ─────────────────────────────────────────────────────────────
     PRINT REPORT
  ───────────────────────────────────────────────────────────── */
  function fmtDate(str: string): string {
    const d = new Date(str);
    return isNaN(d.getTime()) ? '—' : d.toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function rowHtml(label: string, val: string, cls = ''): string {
    return `<tr class="${cls}"><td>${label}</td><td class="pr-val">${val}</td></tr>`;
  }

  function buildPrintReport() {
    const ownership   = selVal('ownershipType');
    const ownerShare  = ownership === 'joint' ? numVal('ownerShare', 50) / 100 : 1.0;
    const resident    = selVal('taxResident') === 'yes';
    const mrStatus    = selVal('mainResStatus');

    // Header date
    setText('pr-prepared-date', new Date().toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' }));

    // Property details
    setText('pr-pp',   fmt(numVal('purchasePrice') * ownerShare) + (ownership === 'joint' ? ` (${Math.round(ownerShare * 100)}% share)` : ''));
    setText('pr-pd',   fmtDate(getInp('purchaseDate')?.value || ''));
    setText('pr-sp',   fmt(numVal('salePrice') * ownerShare) + (ownership === 'joint' ? ` (${Math.round(ownerShare * 100)}% share)` : ''));
    setText('pr-sd',   fmtDate(getInp('saleDate')?.value || ''));
    setText('pr-hold', getEl('holdPeriod')?.textContent || '—');
    const ownerLabels: Record<string, string> = { individual: 'Individual', joint: 'Joint Individuals', trust: 'Discretionary Trust', company: 'Company (Pty Ltd)', smsf: 'SMSF' };
    setText('pr-own',  ownerLabels[ownership] || ownership);
    setText('pr-res',  resident ? 'Australian resident' : 'Non-resident');
    const mrLabels: Record<string, string> = { no: 'No (investment only)', yes: 'Main residence' };
    setText('pr-mr',   mrLabels[mrStatus] || mrStatus);

    // Cost base table
    const costItems: Array<[string, number]> = [
      ['Purchase price',             numVal('purchasePrice')],
      ['Transfer duty (QLD)',        numVal('stampDuty')],
      ['Conveyancing (buying)',       numVal('legalBuying')],
      ['Building and pest inspection', numVal('inspection')],
      ['Capital improvements',       numVal('improvements')],
      ['Agent commission',           numVal('agentFee')],
      ['Conveyancing (selling)',      numVal('legalSelling')],
      ['Other selling costs',        numVal('otherSelling')],
    ];
    const holdTotal = numVal('holdInterest') + numVal('holdRates') + numVal('holdLandTax') + numVal('holdInsurance') + numVal('holdBodyCorp') + numVal('holdOther');
    if (holdTotal > 0) costItems.push(['Holding costs (not previously claimed)', holdTotal]);

    let totalCostBase = 0;
    const cbEl = getEl('pr-costbase-table');
    if (cbEl) {
      cbEl.innerHTML = costItems.filter(([, v]) => v > 0).map(([l, v]) => {
        const share = v * ownerShare;
        totalCostBase += share;
        return rowHtml(l, fmt(share));
      }).join('') + rowHtml('Total cost base', fmt(totalCostBase), 'pr-total');
    }

    // Gain table — read from live result DOM
    const gainEl = getEl('pr-gain-table');
    const lossPanel = getEl('lossPanel');
    const exemptPanel = getEl('exemptPanel');
    const isLoss     = lossPanel?.style.display !== 'none';
    const isExempt   = exemptPanel?.style.display !== 'none';

    if (isLoss) {
      setText('pr-gain-title', 'Outcome: Capital Loss');
      if (gainEl) gainEl.innerHTML = rowHtml('Estimated capital loss', getEl('r-lossAmt')?.textContent || '—', 'pr-loss') + rowHtml('CGT payable', '$0', 'pr-total');
    } else if (isExempt) {
      setText('pr-gain-title', 'Main Residence Exemption');
      if (gainEl) gainEl.innerHTML = rowHtml(getEl('r-exemptMsg')?.textContent || 'Full exemption', getEl('r-exemptSub')?.textContent || '', '') + rowHtml('CGT payable', '$0', 'pr-total');
    } else {
      setText('pr-gain-title', 'Estimated Capital Gain');
      if (gainEl) {
        const rows = [rowHtml('Sale proceeds', getEl('r-salePrice')?.textContent || '—')];
        rows.push(rowHtml('Less: total cost base', getEl('r-costBase')?.textContent || '—', 'pr-deduct'));
        rows.push(rowHtml('Gross capital gain', getEl('r-grossGain')?.textContent || '—', 'pr-total'));
        const mrRow = getEl('mrExemptRow');
        if (mrRow?.style.display !== 'none') rows.push(rowHtml(getEl('mrExemptLabel')?.textContent || 'Main residence exemption', getEl('r-mrExempt')?.textContent || '—', 'pr-deduct'));
        const prRow = getEl('priorLossRow');
        if (prRow?.style.display !== 'none') rows.push(rowHtml('Less: prior year losses', getEl('r-priorApplied')?.textContent || '—', 'pr-deduct'));
        const discRow = getEl('discountRow');
        if (discRow?.style.display !== 'none') rows.push(rowHtml(getEl('discountLabel')?.textContent || 'CGT discount', getEl('r-discountAmt')?.textContent || '—', 'pr-deduct'));
        rows.push(rowHtml('Net taxable capital gain', getEl('r-netGain')?.textContent || '—', 'pr-total'));
        gainEl.innerHTML = rows.join('');
      }
    }

    // Tax section
    const taxEl = getEl('pr-tax-content');
    if (taxEl) {
      if (ownership === 'trust') {
        taxEl.innerHTML = `<p style="font-family:system-ui,sans-serif;font-size:7pt;color:#57534e;line-height:1.65;margin:0;">A discretionary trust may pass the CGT discount to individual beneficiaries. Tax depends on distribution. Estimated net capital gain: <strong>${getEl('r-trustGain')?.textContent || '—'}</strong>. Seek accountant advice on distribution strategy.</p>`;
      } else if (ownership === 'company') {
        taxEl.innerHTML = `<table class="pr-table">${rowHtml('Net gain (no CGT discount)', getEl('r-companyGain')?.textContent || '—')}${rowHtml('Tax at 30% (company rate)', getEl('r-companyTax')?.textContent || '—', 'pr-total')}</table>`;
      } else if (ownership === 'smsf') {
        taxEl.innerHTML = `<table class="pr-table">${rowHtml('Net gain (one-third discount)', getEl('r-smsfGain')?.textContent || '—')}${rowHtml('Estimated tax at 15% (accumulation)', getEl('r-smsfTax')?.textContent || '—', 'pr-total')}</table>`;
      } else if (isLoss || isExempt) {
        taxEl.innerHTML = `<p style="font-family:system-ui,sans-serif;font-size:7pt;color:#57534e;margin:0;">${isLoss ? 'No CGT is payable on a capital loss.' : 'No CGT payable — main residence exemption applies.'}</p>`;
      } else {
        const rows = [
          rowHtml('Other taxable income', getEl('r-otherIncome')?.textContent || '—'),
          rowHtml('Plus: net capital gain', getEl('r-addGain')?.textContent || '—'),
          rowHtml('Total taxable income', getEl('r-totalIncome')?.textContent || '—', 'pr-total'),
          rowHtml('Income tax (before gain)', getEl('r-taxBefore')?.textContent || '-'),
          rowHtml('Income tax (with gain)', getEl('r-taxAfter')?.textContent || '-'),
          rowHtml('Tax attributable to gain', getEl('r-taxOnGain')?.textContent || '—', 'pr-total'),
        ];
        if (resident) rows.push(rowHtml('Medicare levy on gain', getEl('r-medicare')?.textContent || '—'));
        rows.push(rowHtml('Total estimated CGT payable', getEl('r-totalCGT')?.textContent || '—', 'pr-total'));
        taxEl.innerHTML = `<table class="pr-table">${rows.join('')}</table>`;
      }
    }

    // Net proceeds
    const procEl = getEl('pr-proceeds-table');
    if (procEl) {
      const sellingCosts = (numVal('agentFee') + numVal('legalSelling') + numVal('otherSelling')) * ownerShare;
      const cgt = isLoss || isExempt ? '$0' : (getEl('r-totalCGT')?.textContent || '—');
      procEl.innerHTML = [
        rowHtml('Sale proceeds', fmt(numVal('salePrice') * ownerShare)),
        rowHtml('Less: selling costs', '(' + fmt(sellingCosts) + ')', 'pr-deduct'),
        rowHtml('Less: estimated CGT', '(' + (isLoss || isExempt ? '0' : (getEl('r-totalCGT')?.textContent?.replace(/[$,]/g, '') || '0')) + ')', 'pr-deduct'),
      ].join('');
    }
    setText('pr-net-proceeds', getEl('r-netProceeds')?.textContent || '—');
    setText('pr-effective-rate', getEl('r-effectiveRate')?.textContent || '');

    // Budget comparison
    const cmpBlock = getEl('pr-compare-block');
    const mainCmpBlock = getEl('compareBlock');
    if (cmpBlock && mainCmpBlock?.style.display !== 'none') {
      cmpBlock.style.display = 'block';
      const cmpEl = getEl('pr-compare-table');
      if (cmpEl) {
        cmpEl.innerHTML = [
          rowHtml('Current law (50% discount)', getEl('r-compareCurrent')?.textContent || '—'),
          rowHtml(getEl('r-compareLabel')?.textContent || 'Selected rate', getEl('r-compareNew')?.textContent || '—', 'pr-total'),
          rowHtml('Difference', getEl('r-compareDiff')?.textContent || '—'),
        ].join('');
      }
    } else if (cmpBlock) {
      cmpBlock.style.display = 'none';
    }

    // Assumptions — clone from live list
    const srcList = getEl('assumptionsList');
    const prList  = getEl('pr-assumptions');
    if (srcList && prList) {
      prList.innerHTML = Array.from(srcList.children)
        .map(li => `<li>${li.textContent}</li>`)
        .join('');
    }
  }

  getEl('printBtn')?.addEventListener('click', () => {
    buildPrintReport();
    window.print();
  });

  /* ─────────────────────────────────────────────────────────────
     INITIAL RENDER
  ───────────────────────────────────────────────────────────── */
  calc();

})();
</script>

