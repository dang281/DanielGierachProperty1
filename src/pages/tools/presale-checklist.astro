        <p class="print-contact-line"><strong>Email</strong> daniel.gierach@raywhite.com</p>
      </div>
      <div>
        <p class="print-contact-name">Conrad Leisemann</p>
        <p class="print-contact-role">Lead Agent · Ray White Collective</p>
        <p class="print-contact-line"><strong>Phone</strong> 0403 978 813</p>
        <p class="print-contact-line"><strong>Email</strong> conrad.leisemann@raywhite.com</p>
      </div>
