---
import ToolLayout from '../../layouts/ToolLayout.astro';

const sections = [
  {
    id: 'kerb',
    label: 'Kerb Appeal',
    color: '#c4912a',
    items: [
      { id: 'k1', priority: 'High',   cost: '$200-$600',    task: 'Mow, edge and fertilise lawns. Remove weeds from garden beds and replace dead plants.' },
      { id: 'k2', priority: 'High',   cost: '$300-$1,500',  task: 'Pressure wash driveway, pathways, and exterior walls. First impressions begin at the kerb.' },
      { id: 'k3', priority: 'High',   cost: '$500-$3,000',  task: 'Touch up or repaint the front fence, gate, and letterbox. Peeling paint signals neglect immediately.' },
      { id: 'k4', priority: 'Medium', cost: '$0-$300',      task: 'Replace or repaint the front door. A bold, fresh front door is a proven ROI item.' },
      { id: 'k5', priority: 'Medium', cost: '$150-$500',    task: 'Clean all exterior windows inside and out. Dull glass dulls presentation.' },
      { id: 'k6', priority: 'Low',    cost: '$100-$400',    task: 'Add potted plants or a small garden bed at the front entry to soften and welcome.' },
    ],
  },
  {
    id: 'repairs',
    label: 'Repairs & Maintenance',
    color: '#8b6f47',
    items: [
      { id: 'r1', priority: 'High',   cost: '$100-$500',    task: 'Fix all dripping taps, running toilets, and leaking showerheads. Buyers notice water damage and assume worse.' },
      { id: 'r2', priority: 'High',   cost: '$200-$800',    task: 'Repair or replace damaged flyscreens, door handles, locks, and hinges. Rattling and sticking is a turn-off.' },
      { id: 'r3', priority: 'High',   cost: '$300-$1,200',  task: 'Fill and touch up all wall cracks, scuffs, and nail holes. Repaint in the original colour where needed.' },
      { id: 'r4', priority: 'High',   cost: '$200-$600',    task: 'Replace broken light globes and faulty switches. Every light should work during inspections.' },
      { id: 'r5', priority: 'Medium', cost: '$150-$500',    task: 'Re-grout and reseal bathrooms and kitchen tiles. Stained grout reads as old and unclean.' },
      { id: 'r6', priority: 'Medium', cost: '$500-$2,000',  task: 'Service air conditioning units and replace filters. Buyers will test them.' },
      { id: 'r7', priority: 'Medium', cost: '$200-$800',    task: 'Fix any sagging gutters, blocked downpipes, or visible roof damage. These flag in building reports.' },
      { id: 'r8', priority: 'Low',    cost: '$300-$1,500',  task: 'Sand and oil timber decking or verandah floorboards if weathered. Adds significant perceived value to prewar homes.' },
    ],
  },
  {
    id: 'clean',
    label: 'Cleaning & Declutter',
    color: '#3a8fa8',
    items: [
      { id: 'c1', priority: 'High',   cost: '$400-$1,200',  task: 'Hire a professional cleaner for a full deep clean: oven, bathrooms, skirting boards, ceiling fans, and inside cupboards.' },
      { id: 'c2', priority: 'High',   cost: '$0',           task: 'Remove at least 30% of furniture and personal items. Less furniture makes rooms feel larger. Buyers need to see the space, not your belongings.' },
      { id: 'c3', priority: 'High',   cost: '$0-$200',      task: 'Clear all bench tops in kitchen and bathroom. Every item on a bench reduces perceived bench space.' },
      { id: 'c4', priority: 'High',   cost: '$150-$400',    task: 'Clean the oven, range hood filter, and dishwasher. Buyers open these during inspections.' },
      { id: 'c5', priority: 'Medium', cost: '$0',           task: 'Remove all family photos, religious items, and personal memorabilia. Buyers need to see themselves in the home.' },
      { id: 'c6', priority: 'Medium', cost: '$200-$500',    task: 'Have carpets professionally steam cleaned. Odour and visible staining are among the top buyer objections.' },
      { id: 'c7', priority: 'Low',    cost: '$0',           task: 'Clear the garage to at minimum half capacity. A crammed garage reads as not enough storage.' },
    ],
  },
  {
    id: 'style',
    label: 'Staging & Styling',
    color: '#4a9e4a',
    items: [
      { id: 's1', priority: 'High',   cost: '$1,500-$5,000', task: 'Engage a professional property stylist for key rooms (living, master bedroom, dining). Styled homes consistently achieve 5-10% above comparable unstyled properties.' },
      { id: 's2', priority: 'High',   cost: '$200-$600',     task: 'Replace tired or mismatched cushions, throws, and soft furnishings in the living areas with neutral, contemporary pieces.' },
      { id: 's3', priority: 'High',   cost: '$100-$400',     task: 'Add fresh white towels to bathrooms and a new bath mat. Replace soap dispensers with matching sets.' },
      { id: 's4', priority: 'Medium', cost: '$150-$500',     task: 'Place a large bunch of fresh flowers or a potted plant in the living room and kitchen for photography and open homes.' },
      { id: 's5', priority: 'Medium', cost: '$0-$300',       task: 'Ensure all window furnishings are clean and in working order. Stick to open, light-filtering blinds for photography.' },
      { id: 's6', priority: 'Low',    cost: '$200-$800',     task: 'Upgrade kitchen handles, tapware, or bathroom accessories if dated. Small hardware changes read as renovation.' },
    ],
  },
  {
    id: 'legal',
    label: 'Documentation & Compliance',
    color: '#8a7acd',
    items: [
      { id: 'l1', priority: 'High',   cost: '$400-$800',    task: 'Engage a solicitor or conveyancer to prepare the contract of sale and vendor disclosure documents before launch.' },
      { id: 'l2', priority: 'High',   cost: '$300-$600',    task: 'Obtain a building and pest inspection report. Identifying issues before launch lets you address them on your terms, not the buyer\'s.' },
      { id: 'l3', priority: 'High',   cost: '$0',           task: 'Gather all council approvals for any structures (decks, sheds, pergolas, carports) built since purchase. Unapproved structures must be disclosed.' },
      { id: 'l4', priority: 'High',   cost: '$40-$80',      task: 'Obtain a current smoke alarm compliance certificate. This is a legal requirement for all QLD property sales.' },
      { id: 'l5', priority: 'Medium', cost: '$50-$150',     task: 'Obtain a pool safety certificate if applicable. Required before contract in QLD (or within 90 days of settlement for buyers).' },
      { id: 'l6', priority: 'Medium', cost: '$0',           task: 'Locate your current rates notices, water accounts, and any body corporate records. Buyers will request these.' },
      { id: 'l7', priority: 'Low',    cost: '$0',           task: 'Obtain your most recent land tax notice if applicable. Useful for buyers doing their due diligence.' },
    ],
  },
];
---

<ToolLayout
  title="Pre-Sale Preparation Checklist"
  tool="Pre-Sale Checklist"
  phase="Seller Tools"
  description="A complete pre-sale preparation checklist for Brisbane homeowners. Prioritised tasks, cost estimates, and what to do before your property goes to market."
  resourceSlug="complete-home-selling-checklist"
>

<style>
  /* ── Mobile-first base ─────────────────────────────────────── */

  /* Progress card: compact horizontal band */
  #progress-ring-container {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
    background: var(--color-surface-3);
    border: 1px solid rgba(28,25,23,0.08);
    border-radius: 6px;
  }
  #prog-svg { width: 44px; height: 44px; flex-shrink: 0; }
  .prog-text {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text-primary);
    line-height: 1.2;
  }
  #prog-label {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
    line-height: 1.3;
  }

  /* Print button: icon-only square on mobile, expands to label on desktop */
  #print-btn {
    width: 40px; height: 40px;
    padding: 0;
    border: 1px solid rgba(28,25,23,0.18);
    background: white;
    color: #78716c;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 6px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    flex-shrink: 0;
  }
  #print-btn:hover { color: var(--color-gold); border-color: var(--color-gold); }
  #print-btn-label {
    /* Hidden visually on mobile; accessible via aria-label on the button */
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  /* Section header (collapsible) */
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.7rem 0.85rem; cursor: pointer;
    border: 1px solid rgba(28,25,23,0.1);
    transition: background 0.15s;
    user-select: none;
  }
  .section-header:hover, .section-header:active { background: rgba(28,25,23,0.02); }
  .section-label {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text-primary);
    line-height: 1.2;
  }
  .section-count {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-left: 0.55rem;
  }
  .chevron { transition: transform 0.2s; flex-shrink: 0; }
  .chevron.open { transform: rotate(180deg); }

  /* Checklist items: compact, task-first layout */
  .section-items { display: none; }
  .section-items.open { display: block; }

  .checklist-item {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.7rem;
    align-items: start;
    padding: 0.65rem 0.85rem;
    border: 1px solid rgba(28,25,23,0.06);
    border-top: none;
    transition: background 0.15s;
    cursor: pointer;
  }
  .checklist-item:hover, .checklist-item:active { background: rgba(28,25,23,0.02); }
  .checklist-item.done { background: rgba(74,158,74,0.04); }
  .checklist-item.done .item-task { text-decoration: line-through; color: var(--color-text-muted); }

  .custom-cb {
    width: 18px; height: 18px;
    border: 1.5px solid rgba(28,25,23,0.3);
    flex-shrink: 0; margin-top: 2px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s, border-color 0.15s;
    border-radius: 3px;
  }
  .checklist-item.done .custom-cb {
    background: #4a9e4a; border-color: #4a9e4a;
  }

  .item-body { min-width: 0; }
  .item-task {
    font-size: 0.82rem;
    color: var(--color-text-primary);
    line-height: 1.45;
    margin-bottom: 0.25rem;
  }
  .item-meta {
    display: flex; align-items: center; gap: 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.3;
  }
  .item-meta .meta-sep { opacity: 0.45; }
  .item-pri-High   { color: #a03030; }
  .item-pri-Medium { color: #8a6010; }
  .item-pri-Low    { color: #78716c; }

  /* Daniel CTA: condensed on mobile */
  .daniel-cta {
    padding: 1rem 1.1rem;
    background: rgba(196,145,42,0.06);
    border-left: 3px solid var(--color-gold);
    margin-top: 0.5rem;
    border-radius: 0 4px 4px 0;
  }
  .daniel-cta-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--color-text-primary);
    margin-bottom: 0.35rem;
  }
  .daniel-cta-body {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin-bottom: 0.65rem;
  }
  .daniel-cta-link {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    text-decoration: none;
  }

  /* ── Desktop bump (≥640px) ─────────────────────────────────── */
  @media (min-width: 640px) {
    #progress-ring-container {
      gap: 1.25rem;
      padding: 1.25rem 1.5rem;
    }
    #prog-svg { width: 56px; height: 56px; }
    .prog-text { font-size: 1.25rem; }
    #prog-label { font-size: 0.8rem; }

    #print-btn {
      width: auto; height: auto;
      padding: 0.55rem 1rem;
      gap: 0.4rem;
      font-family: var(--font-sans);
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
    }
    #print-btn-label {
      position: static; width: auto; height: auto;
      padding: 0; margin: 0; overflow: visible;
      clip: auto; white-space: normal;
    }

    .section-header { padding: 0.9rem 1.15rem; }
    .section-label { font-size: 1.05rem; }

    .checklist-item { padding: 0.85rem 1.15rem; column-gap: 0.9rem; }
    .item-task { font-size: 0.88rem; line-height: 1.6; }
    .item-meta { font-size: 0.62rem; }

    .daniel-cta { padding: 1.5rem; }
    .daniel-cta-title { font-size: 1.05rem; }
    .daniel-cta-body { font-size: 0.85rem; }
  }

  /* ── Hide ToolLayout's sticky bottom CTA on this tool ──────── */
  /* Checklist users are working through tasks; the call-Daniel bar steals
     vertical space and breaks the flow. Footer CTA still covers that path. */
  :global(#tool-sticky-cta) { display: none !important; }

  @media print {
    /* Force-expand all sections so every task prints */
    .section-items { display: block !important; }
    .chevron { display: none !important; }

    /* Compact, paper-friendly checklist rows */
    .checklist-section { page-break-inside: auto; margin-bottom: 0.4rem; }
    .section-header {
      padding: 0.45rem 0.65rem !important;
      page-break-after: avoid;
      border: 1px solid #000 !important;
      background: white !important;
    }
    .checklist-item {
      padding: 0.3rem 0.65rem !important;
      gap: 0.6rem !important;
      page-break-inside: avoid;
      border: 1px solid #ccc !important;
      border-top: none !important;
    }
    .checklist-item.done { background: white !important; }
    .checklist-item.done .item-task {
      text-decoration: line-through;
      color: #555 !important;
    }
    .item-task { font-size: 0.78rem !important; line-height: 1.45 !important; }

    /* Black-ink-only checkboxes; filled when complete */
    .custom-cb {
      width: 14px !important; height: 14px !important;
      border: 1.5px solid #000 !important;
      background: white !important;
    }
    .checklist-item.done .custom-cb {
      background: #000 !important;
      border-color: #000 !important;
    }
    .checklist-item.done .check-icon { display: block !important; }

    /* Priority + cost meta line: black ink for print */
    .item-meta { font-size: 0.6rem !important; color: #000 !important; }
    .item-meta .item-pri-High,
    .item-meta .item-pri-Medium,
    .item-meta .item-pri-Low { color: #000 !important; font-weight: 800 !important; }

    /* Progress summary stays as a header band on page 1 */
    #progress-ring-container {
      padding: 0.6rem 0.9rem !important;
      border: 1px solid #000 !important;
      gap: 1rem !important;
      background: white !important;
      page-break-after: avoid;
    }
    #progress-ring-container p { color: #000 !important; }
  }
</style>


<div style="display:flex;flex-direction:column;gap:1.5rem;">

  <!-- Progress summary -->
  <div id="progress-ring-container">
    <svg id="prog-svg" viewBox="0 0 64 64">
      <circle cx="32" cy="32" r="26" fill="none" stroke="rgba(28,25,23,0.1)" stroke-width="5"/>
      <circle id="prog-circle" cx="32" cy="32" r="26" fill="none" stroke="#c4912a" stroke-width="5"
        stroke-dasharray="163.4" stroke-dashoffset="163.4"
        stroke-linecap="round" transform="rotate(-90 32 32)"
        style="transition:stroke-dashoffset 0.4s;"/>
    </svg>
    <div>
      <p class="prog-text">
        <span id="done-count">0</span> / <span id="total-count">0</span> tasks complete
      </p>
      <p id="prog-label">Tick items off as you go.</p>
    </div>
    <button id="print-btn" type="button" class="no-print" aria-label="Print">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      <span id="print-btn-label">Print</span>
    </button>
  </div>

  <!-- Sections -->
  {sections.map(section => (
    <div class="checklist-section" data-section={section.id}>
      <div class="section-header" data-toggle={section.id}
        style={`border-left:3px solid ${section.color};`}>
        <div>
          <span class="section-label">{section.label}</span>
          <span class="section-count" data-section={section.id}>0/{section.items.length}</span>
        </div>
        <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#78716c" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="section-items open" id={`items-${section.id}`}>
        {section.items.map(item => (
          <div class="checklist-item" data-id={item.id} data-section={section.id}>
            <div class="custom-cb">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="check-icon" style="display:none;">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div class="item-body">
              <p class="item-task">{item.task}</p>
              <p class={`item-meta`}>
                <span class={`item-pri-${item.priority}`}>{item.priority}</span>
                <span class="meta-sep">&middot;</span>
                <span>{item.cost}</span>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <!-- Daniel CTA -->
  <div class="daniel-cta no-print">
    <p class="daniel-cta-title">Not sure where to start?</p>
    <p class="daniel-cta-body">Daniel walks through your property before it goes to market, prioritises what will actually move the needle, and tells you what not to spend money on. Free, no obligation.</p>
    <a href="/contact" data-cta="tool_to_contact" class="daniel-cta-link">Book a Pre-Sale Walk Through &rarr;</a>
  </div>

</div>

<script>
  // Build total count
  const allItems = document.querySelectorAll<HTMLElement>('.checklist-item');
  const totalEl  = document.getElementById('total-count')!;
  const doneEl   = document.getElementById('done-count')!;
  const progCircle = document.getElementById('prog-circle')!;
  const progLabel  = document.getElementById('prog-label')!;
  const circumference = 163.4;
  totalEl.textContent = String(allItems.length);

  const labels = ['Tick items off as you go.', 'Getting started!', 'Making progress.', 'Over halfway there.', 'Almost ready to list!', 'All done, time to go to market!'];

  function updateProgress() {
    const done  = document.querySelectorAll('.checklist-item.done').length;
    const total = allItems.length;
    const pct   = total > 0 ? done / total : 0;
    doneEl.textContent = String(done);
    progCircle.style.strokeDashoffset = String(circumference * (1 - pct));
    const idx = Math.min(Math.floor(pct * 5), 5);
    progLabel.textContent = labels[idx];

    // Update section counts
    document.querySelectorAll<HTMLElement>('[data-section]').forEach(el => {
      if (!el.classList.contains('checklist-section')) {
        const sec  = el.dataset.section!;
        const secDone  = document.querySelectorAll(`.checklist-item.done[data-section="${sec}"]`).length;
        const secTotal = document.querySelectorAll(`.checklist-item[data-section="${sec}"]`).length;
        if (el.classList.contains('section-count')) {
          el.textContent = `${secDone}/${secTotal}`;
          el.style.color = secDone === secTotal && secTotal > 0 ? '#4a9e4a' : 'var(--color-text-muted)';
        }
      }
    });
  }

  // Toggle items
  allItems.forEach(item => {
    item.addEventListener('click', () => {
      item.classList.toggle('done');
      const icon = item.querySelector<SVGElement>('.check-icon')!;
      icon.style.display = item.classList.contains('done') ? 'block' : 'none';
      updateProgress();
    });
  });

  // Toggle sections
  document.querySelectorAll<HTMLElement>('[data-toggle]').forEach(header => {
    header.addEventListener('click', () => {
      const id     = header.dataset.toggle!;
      const items  = document.getElementById(`items-${id}`)!;
      const chev   = header.querySelector<SVGElement>('.chevron')!;
      items.classList.toggle('open');
      chev.classList.toggle('open');
    });
  });

  updateProgress();

  // Print / share button: window.print() is unreliable on iOS browsers
  // (Chrome and Firefox on iOS silently no-op). Web Share opens the native
  // OS share sheet which exposes Print, Save to PDF, Email, Copy, etc.
  const printBtn = document.getElementById('print-btn');
  const printBtnLabel = document.getElementById('print-btn-label');
  const isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
  const hasShare = typeof (navigator as any).share === 'function';

  if (printBtn && printBtnLabel && isMobile && hasShare) {
    printBtnLabel.textContent = 'Save / share';
  }

  printBtn?.addEventListener('click', async (e) => {
    e.preventDefault();
    if (isMobile && hasShare) {
      try {
        await (navigator as any).share({
          title: 'Pre-Sale Preparation Checklist',
          text: `${doneEl.textContent}/${totalEl.textContent} tasks complete. Brisbane pre-sale checklist by Daniel Gierach.`,
          url: location.href,
        });
        return;
      } catch (err: any) {
        if (err?.name === 'AbortError') return;
        // fall through to window.print() if share failed for any other reason
      }
    }
    window.print();
  });
</script>

<!-- Appraisal CTA -->
<div style="margin-top:3rem;background:var(--color-surface-3);padding:2.5rem;border-left:3px solid var(--color-gold);">
  <p style="font-size:0.62rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">Ready to take the next step?</p>
  <h2 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:var(--color-text-primary);margin-bottom:0.75rem;line-height:1.3;">Working through the checklist? Get a professional opinion on what to prioritise.</h2>
  <p style="font-size:0.88rem;font-weight:300;line-height:1.75;color:var(--color-text-secondary);margin-bottom:1.5rem;">Every property is different. Before you spend on renovations, a professional walkthrough helps identify what actually moves buyers in your street, and what you can skip. No obligation, no sales pitch.</p>
  <a href="/walkthrough" data-cta="tool_to_walkthrough" style="font-family:var(--font-sans);font-size:0.82rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;background:var(--color-gold);color:#1c1917;padding:0.85rem 2rem;text-decoration:none;display:inline-block;">Book a Free Walkthrough</a>
</div>


<!-- Related guide -->
<div style="margin-top:1.25rem;padding:1rem 1.25rem;background:var(--color-surface-1);border-left:2px solid rgba(196,145,42,0.4);">
  <p style="font-size:0.8rem;color:var(--color-text-secondary);line-height:1.7;margin:0;">
    Want more context? Read the full guide:
    <a href="/insights/how-to-prepare-your-home-for-sale-brisbane" style="color:var(--color-gold);font-weight:600;">How to Prepare Your Home for Sale in Brisbane &rarr;</a>
  </p>
</div>
</ToolLayout>
