---
import ToolLayout from '../../layouts/ToolLayout.astro';

const sections = [
  {
    id: 'kerb',
    label: 'Kerb Appeal',
    color: '#c4912a',
    items: [
      { id: 'k1', priority: 'High', task: 'Mow, edge and fertilise lawns. Remove weeds from garden beds and replace dead plants.' },
      { id: 'k2', priority: 'High', task: 'Pressure wash driveway, pathways, and exterior walls. First impressions begin at the kerb.' },
      { id: 'k3', priority: 'High', task: 'Touch up or repaint the front fence, gate, and letterbox. Peeling paint signals neglect immediately.' },
      { id: 'k4', priority: 'Medium', task: 'Replace or repaint the front door. A bold, fresh front door is a proven ROI item.' },
      { id: 'k5', priority: 'Medium', task: 'Clean all exterior windows inside and out. Dull glass dulls presentation.' },
      { id: 'k6', priority: 'Low', task: 'Add potted plants or a small garden bed at the front entry to soften and welcome.' },
    ],
  },
  {
    id: 'repairs',
    label: 'Repairs & Maintenance',
    color: '#8b6f47',
    items: [
      { id: 'r1', priority: 'High', task: 'Fix all dripping taps, running toilets, and leaking showerheads. Buyers notice water damage and assume worse.' },
      { id: 'r2', priority: 'High', task: 'Repair or replace damaged flyscreens, door handles, locks, and hinges. Rattling and sticking is a turn-off.' },
      { id: 'r3', priority: 'High', task: 'Fill and touch up all wall cracks, scuffs, and nail holes. Repaint in the original colour where needed.' },
      { id: 'r4', priority: 'High', task: 'Replace broken light globes and faulty switches. Every light should work during inspections.' },
      { id: 'r5', priority: 'Medium', task: 'Re-grout and reseal bathrooms and kitchen tiles. Stained grout reads as old and unclean.' },
      { id: 'r6', priority: 'Medium', task: 'Service air conditioning units and replace filters. Buyers will test them.' },
      { id: 'r7', priority: 'Medium', task: 'Fix any sagging gutters, blocked downpipes, or visible roof damage. These flag in building reports.' },
      { id: 'r8', priority: 'Low', task: 'Sand and oil timber decking or verandah floorboards if weathered. Adds significant perceived value to prewar homes.' },
    ],
  },
  {
    id: 'clean',
    label: 'Cleaning & Declutter',
    color: '#3a8fa8',
    items: [
      { id: 'c1', priority: 'High', task: 'Hire a professional cleaner for a full deep clean: oven, bathrooms, skirting boards, ceiling fans, and inside cupboards.' },
      { id: 'c2', priority: 'High', task: 'Remove at least 30% of furniture and personal items. Less furniture makes rooms feel larger. Buyers need to see the space, not your belongings.' },
      { id: 'c3', priority: 'High', task: 'Clear all bench tops in kitchen and bathroom. Every item on a bench reduces perceived bench space.' },
      { id: 'c4', priority: 'High', task: 'Clean the oven, range hood filter, and dishwasher. Buyers open these during inspections.' },
      { id: 'c5', priority: 'Medium', task: 'Remove all family photos, religious items, and personal memorabilia. Buyers need to see themselves in the home.' },
      { id: 'c6', priority: 'Medium', task: 'Have carpets professionally steam cleaned. Odour and visible staining are among the top buyer objections.' },
      { id: 'c7', priority: 'Low', task: 'Clear the garage to at minimum half capacity. A crammed garage reads as not enough storage.' },
    ],
  },
  {
    id: 'style',
    label: 'Staging & Styling',
    color: '#4a9e4a',
    items: [
      { id: 's1', priority: 'High', task: 'Engage a professional property stylist for key rooms (living, master bedroom, dining). Styled homes consistently achieve 5-10% above comparable unstyled properties.' },
      { id: 's2', priority: 'High', task: 'Replace tired or mismatched cushions, throws, and soft furnishings in the living areas with neutral, contemporary pieces.' },
      { id: 's3', priority: 'High', task: 'Add fresh white towels to bathrooms and a new bath mat. Replace soap dispensers with matching sets.' },
      { id: 's4', priority: 'Medium', task: 'Place a large bunch of fresh flowers or a potted plant in the living room and kitchen for photography and open homes.' },
      { id: 's5', priority: 'Medium', task: 'Ensure all window furnishings are clean and in working order. Stick to open, light-filtering blinds for photography.' },
      { id: 's6', priority: 'Low', task: 'Upgrade kitchen handles, tapware, or bathroom accessories if dated. Small hardware changes read as renovation.' },
    ],
  },
  {
    id: 'legal',
    label: 'Documentation & Compliance',
    color: '#8a7acd',
    items: [
      { id: 'l1', priority: 'High', task: 'Engage a solicitor or conveyancer to prepare the contract of sale and vendor disclosure documents before launch.' },
      { id: 'l2', priority: 'High', task: 'Obtain a building and pest inspection report. Identifying issues before launch lets you address them on your terms, not the buyer\'s.' },
      { id: 'l3', priority: 'High', task: 'Gather all council approvals for any structures (decks, sheds, pergolas, carports) built since purchase. Unapproved structures must be disclosed.' },
      { id: 'l4', priority: 'High', task: 'Obtain a current smoke alarm compliance certificate. This is a legal requirement for all QLD property sales.' },
      { id: 'l5', priority: 'Medium', task: 'Obtain a pool safety certificate if applicable. Required before contract in QLD (or within 90 days of settlement for buyers).' },
      { id: 'l6', priority: 'Medium', task: 'Locate your current rates notices, water accounts, and any body corporate records. Buyers will request these.' },
      { id: 'l7', priority: 'Low', task: 'Obtain your most recent land tax notice if applicable. Useful for buyers doing their due diligence.' },
    ],
  },
];
---

<ToolLayout
  title="Pre-Sale Preparation Checklist"
  tool="Pre-Sale Checklist"
  phase="Seller Tools"
  description="A complete pre-sale preparation checklist for Brisbane homeowners. Tick tasks off as you go. Progress saves automatically."
  resourceSlug="complete-home-selling-checklist"
  manifest="/manifest-presale-checklist.webmanifest"
  appleTouchIcon="/apple-touch-icon-checklist.png"
  appleWebAppTitle="Checklist"
>

<style>
  /* ── Mobile-first base ─────────────────────────────────────── */

  /* Progress card: compact horizontal band */
  #progress-ring-container {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
    background: var(--color-surface-3);
    border: 1px solid rgba(28,25,23,0.08);
    border-radius: 6px;
  }
  #prog-svg { width: 44px; height: 44px; flex-shrink: 0; }
  .prog-text {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text-primary);
    line-height: 1.2;
  }
  #prog-label {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
    line-height: 1.3;
  }

  /* Print button: icon-only square on mobile, expands to label on desktop */
  #print-btn {
    width: 40px; height: 40px;
    padding: 0;
    border: 1px solid rgba(28,25,23,0.18);
    background: white;
    color: #78716c;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 6px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    flex-shrink: 0;
  }
  #print-btn:hover { color: var(--color-gold); border-color: var(--color-gold); }
  #print-btn-label {
    /* Hidden visually on mobile; accessible via aria-label on the button */
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  /* Section header (collapsible) */
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.7rem 0.85rem; cursor: pointer;
    border: 1px solid rgba(28,25,23,0.1);
    transition: background 0.15s;
    user-select: none;
  }
  .section-header:hover, .section-header:active { background: rgba(28,25,23,0.02); }
  .section-label {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text-primary);
    line-height: 1.2;
  }
  .section-count {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-left: 0.55rem;
  }
  .chevron { transition: transform 0.2s; flex-shrink: 0; }
  .chevron.open { transform: rotate(180deg); }

  /* Checklist items: compact, task-first layout */
  .section-items { display: none; }
  .section-items.open { display: block; }

  .checklist-item {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.7rem;
    align-items: start;
    padding: 0.65rem 0.85rem;
    border: 1px solid rgba(28,25,23,0.06);
    border-top: none;
    transition: background 0.15s;
    cursor: pointer;
  }
  .checklist-item:hover, .checklist-item:active { background: rgba(28,25,23,0.02); }
  .checklist-item.done { background: rgba(74,158,74,0.04); }
  .checklist-item.done .item-task { text-decoration: line-through; color: var(--color-text-muted); }

  .custom-cb {
    width: 18px; height: 18px;
    border: 1.5px solid rgba(28,25,23,0.3);
    flex-shrink: 0; margin-top: 2px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s, border-color 0.15s;
    border-radius: 3px;
  }
  .checklist-item.done .custom-cb {
    background: #4a9e4a; border-color: #4a9e4a;
  }

  .item-body { min-width: 0; }
  .item-task {
    font-size: 0.82rem;
    color: var(--color-text-primary);
    line-height: 1.45;
    margin-bottom: 0.25rem;
  }
  .item-meta {
    display: flex; align-items: center; gap: 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.3;
  }
  .item-meta .meta-sep { opacity: 0.45; }
  .item-pri-High   { color: #a03030; }
  .item-pri-Medium { color: #8a6010; }
  .item-pri-Low    { color: #78716c; }

  /* Daniel CTA: condensed on mobile */
  .daniel-cta {
    padding: 1rem 1.1rem;
    background: rgba(196,145,42,0.06);
    border-left: 3px solid var(--color-gold);
    margin-top: 0.5rem;
    border-radius: 0 4px 4px 0;
  }
  .daniel-cta-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--color-text-primary);
    margin-bottom: 0.35rem;
  }
  .daniel-cta-body {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin-bottom: 0.65rem;
  }
  .daniel-cta-link {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    text-decoration: none;
  }

  /* ── Desktop bump (≥640px) ─────────────────────────────────── */
  @media (min-width: 640px) {
    #progress-ring-container {
      gap: 1.25rem;
      padding: 1.25rem 1.5rem;
    }
    #prog-svg { width: 56px; height: 56px; }
    .prog-text { font-size: 1.25rem; }
    #prog-label { font-size: 0.8rem; }

    #print-btn {
      width: auto; height: auto;
      padding: 0.55rem 1rem;
      gap: 0.4rem;
      font-family: var(--font-sans);
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
    }
    #print-btn-label {
      position: static; width: auto; height: auto;
      padding: 0; margin: 0; overflow: visible;
      clip: auto; white-space: normal;
    }

    .section-header { padding: 0.9rem 1.15rem; }
    .section-label { font-size: 1.05rem; }

    .checklist-item { padding: 0.85rem 1.15rem; column-gap: 0.9rem; }
    .item-task { font-size: 0.88rem; line-height: 1.6; }
    .item-meta { font-size: 0.62rem; }

    .daniel-cta { padding: 1.5rem; }
    .daniel-cta-title { font-size: 1.05rem; }
    .daniel-cta-body { font-size: 0.85rem; }
  }

  /* ── Hide ToolLayout's sticky bottom CTA on this tool ──────── */
  /* Checklist users are working through tasks; the call-Daniel bar steals
     vertical space and breaks the flow. Footer CTA still covers that path. */
  :global(#tool-sticky-cta) { display: none !important; }

  /* ── Restore notice (when state is loaded from URL / storage) ─ */
  #restore-notice {
    margin-top: 0.5rem;
    padding: 0.55rem 0.85rem;
    background: rgba(74,158,74,0.08);
    border: 1px solid rgba(74,158,74,0.18);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 0.65rem;
    font-size: 0.7rem;
    color: var(--color-text-secondary);
  }
  #restore-notice button {
    background: transparent; border: none; cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    transition: color 0.2s, background 0.2s;
  }
  #restore-notice button:hover { color: #a03030; background: rgba(160,48,48,0.05); }

  /* ── Save to phone (PWA install) button + help ───────────────── */
  #pwa-install-bar {
    margin-top: 0.5rem;
    padding: 0;
    border: 1px dashed rgba(196,145,42,0.35);
    border-radius: 6px;
    background: rgba(196,145,42,0.04);
    overflow: hidden;
  }
  #pwa-install-btn {
    width: 100%;
    display: flex; align-items: center; justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-gold);
    transition: background 0.2s;
  }
  #pwa-install-btn:hover, #pwa-install-btn:active { background: rgba(196,145,42,0.08); }
  #pwa-install-btn svg { flex-shrink: 0; }
  #pwa-install-help {
    border-top: 1px dashed rgba(196,145,42,0.25);
    padding: 0.85rem 1rem;
    font-size: 0.72rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    background: rgba(196,145,42,0.02);
  }
  #pwa-install-help strong {
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 800;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-gold);
    display: block;
    margin-bottom: 0.4rem;
  }
  #pwa-install-help ol {
    padding-left: 1.1rem;
    margin: 0;
  }
  #pwa-install-help li { margin-bottom: 0.25rem; }
  #pwa-install-help kbd {
    display: inline-block;
    background: rgba(28,25,23,0.08);
    border: 1px solid rgba(28,25,23,0.15);
    padding: 0.05rem 0.4rem;
    border-radius: 3px;
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  @media print {
    /* Force-expand all sections so every task prints */
    .section-items { display: block !important; }
    .chevron { display: none !important; }

    /* Compact, paper-friendly checklist rows */
    .checklist-section { page-break-inside: auto; margin-bottom: 0.4rem; }
    .section-header {
      padding: 0.45rem 0.65rem !important;
      page-break-after: avoid;
      border: 1px solid #000 !important;
      background: white !important;
    }
    .checklist-item {
      padding: 0.3rem 0.65rem !important;
      gap: 0.6rem !important;
      page-break-inside: avoid;
      border: 1px solid #ccc !important;
      border-top: none !important;
    }
    .checklist-item.done { background: white !important; }
    .checklist-item.done .item-task {
      text-decoration: line-through;
      color: #555 !important;
    }
    .item-task { font-size: 0.78rem !important; line-height: 1.45 !important; }

    /* Black-ink-only checkboxes; filled when complete */
    .custom-cb {
      width: 14px !important; height: 14px !important;
      border: 1.5px solid #000 !important;
      background: white !important;
    }
    .checklist-item.done .custom-cb {
      background: #000 !important;
      border-color: #000 !important;
    }
    .checklist-item.done .check-icon { display: block !important; }

    /* Priority + cost meta line: black ink for print */
    .item-meta { font-size: 0.6rem !important; color: #000 !important; }
    .item-meta .item-pri-High,
    .item-meta .item-pri-Medium,
    .item-meta .item-pri-Low { color: #000 !important; font-weight: 800 !important; }

    /* Progress summary stays as a header band on page 1 */
    #progress-ring-container {
      padding: 0.6rem 0.9rem !important;
      border: 1px solid #000 !important;
      gap: 1rem !important;
      background: white !important;
      page-break-after: avoid;
    }
    #progress-ring-container p { color: #000 !important; }
  }
</style>


<div style="display:flex;flex-direction:column;gap:1.5rem;">

  <!-- Progress summary -->
  <div id="progress-ring-container">
    <svg id="prog-svg" viewBox="0 0 64 64">
      <circle cx="32" cy="32" r="26" fill="none" stroke="rgba(28,25,23,0.1)" stroke-width="5"/>
      <circle id="prog-circle" cx="32" cy="32" r="26" fill="none" stroke="#c4912a" stroke-width="5"
        stroke-dasharray="163.4" stroke-dashoffset="163.4"
        stroke-linecap="round" transform="rotate(-90 32 32)"
        style="transition:stroke-dashoffset 0.4s;"/>
    </svg>
    <div>
      <p class="prog-text">
        <span id="done-count">0</span> / <span id="total-count">0</span> tasks complete
      </p>
      <p id="prog-label">Tick items off as you go.</p>
    </div>
    <button id="print-btn" type="button" class="no-print" aria-label="Print">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      <span id="print-btn-label">Print</span>
    </button>
  </div>

  <!-- Restore notice (shown when in-progress state is loaded) -->
  <div id="restore-notice" class="no-print" hidden>
    <span><strong style="color:#4a9e4a;">Picked up where you left off.</strong> Your progress saves automatically.</span>
    <button id="restore-clear" type="button">Reset</button>
  </div>

  <!-- Save to phone (PWA install) -->
  <div id="pwa-install-bar" class="no-print" hidden>
    <button id="pwa-install-btn" type="button" aria-expanded="false" aria-controls="pwa-install-help">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
      <span id="pwa-install-label">Save to my phone</span>
    </button>
    <div id="pwa-install-help" hidden></div>
  </div>

  <!-- Sections -->
  {sections.map(section => (
    <div class="checklist-section" data-section={section.id}>
      <div class="section-header" data-toggle={section.id}
        style={`border-left:3px solid ${section.color};`}>
        <div>
          <span class="section-label">{section.label}</span>
          <span class="section-count" data-section={section.id}>0/{section.items.length}</span>
        </div>
        <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#78716c" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="section-items open" id={`items-${section.id}`}>
        {section.items.map(item => (
          <div class="checklist-item" data-id={item.id} data-section={section.id}>
            <div class="custom-cb">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="check-icon" style="display:none;">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div class="item-body">
              <p class="item-task">{item.task}</p>
              <p class={`item-meta`}>
                <span class={`item-pri-${item.priority}`}>{item.priority}</span>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <!-- Daniel CTA -->
  <div class="daniel-cta no-print">
    <p class="daniel-cta-title">Not sure where to start?</p>
    <p class="daniel-cta-body">Daniel walks through your property before it goes to market, prioritises what will actually move the needle, and tells you what not to spend money on. Free, no obligation.</p>
    <a href="/contact" data-cta="tool_to_contact" class="daniel-cta-link">Book a Pre-Sale Walk Through &rarr;</a>
  </div>

</div>

<script>
  // Build total count
  const allItems = document.querySelectorAll<HTMLElement>('.checklist-item');
  const totalEl  = document.getElementById('total-count')!;
  const doneEl   = document.getElementById('done-count')!;
  const progCircle = document.getElementById('prog-circle')!;
  const progLabel  = document.getElementById('prog-label')!;
  const circumference = 163.4;
  totalEl.textContent = String(allItems.length);

  const labels = ['Tick items off as you go.', 'Getting started!', 'Making progress.', 'Over halfway there.', 'Almost ready to list!', 'All done, time to go to market!'];

  function updateProgress() {
    const done  = document.querySelectorAll('.checklist-item.done').length;
    const total = allItems.length;
    const pct   = total > 0 ? done / total : 0;
    doneEl.textContent = String(done);
    progCircle.style.strokeDashoffset = String(circumference * (1 - pct));
    const idx = Math.min(Math.floor(pct * 5), 5);
    progLabel.textContent = labels[idx];

    // Update section counts
    document.querySelectorAll<HTMLElement>('[data-section]').forEach(el => {
      if (!el.classList.contains('checklist-section')) {
        const sec  = el.dataset.section!;
        const secDone  = document.querySelectorAll(`.checklist-item.done[data-section="${sec}"]`).length;
        const secTotal = document.querySelectorAll(`.checklist-item[data-section="${sec}"]`).length;
        if (el.classList.contains('section-count')) {
          el.textContent = `${secDone}/${secTotal}`;
          el.style.color = secDone === secTotal && secTotal > 0 ? '#4a9e4a' : 'var(--color-text-muted)';
        }
      }
    });
  }

  // ── Persistence ────────────────────────────────────────────────
  // Done state is mirrored to:
  //   1. localStorage (silent autosave per browser)
  //   2. URL hash       (so shared links restore in-progress state)
  // On load, URL wins if present, else localStorage.
  const STORAGE_KEY = 'presale-checklist-done-v1';
  const done = new Set<string>();

  function loadInitialState(): Set<string> {
    const m = location.hash.match(/done=([^&]*)/);
    if (m) {
      const ids = decodeURIComponent(m[1]).split(',').filter(Boolean);
      return new Set(ids);
    }
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) return new Set(JSON.parse(raw));
    } catch {}
    return new Set();
  }

  function persist() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify([...done])); } catch {}
    const ids = [...done];
    const newHash = ids.length ? `#done=${ids.join(',')}` : '';
    const url = location.pathname + location.search + newHash;
    history.replaceState(null, '', url);
  }

  function setItemDone(item: HTMLElement, isDone: boolean) {
    item.classList.toggle('done', isDone);
    const icon = item.querySelector<SVGElement>('.check-icon')!;
    icon.style.display = isDone ? 'block' : 'none';
  }

  // Restore on load
  const initial = loadInitialState();
  let restoredCount = 0;
  allItems.forEach(item => {
    const id = item.dataset.id!;
    if (initial.has(id)) {
      done.add(id);
      setItemDone(item, true);
      restoredCount++;
    }
  });
  if (restoredCount > 0) {
    const notice = document.getElementById('restore-notice');
    if (notice) notice.hidden = false;
  }
  // Make sure URL reflects current state even if we loaded from localStorage
  persist();

  // Toggle items
  allItems.forEach(item => {
    item.addEventListener('click', () => {
      const id = item.dataset.id!;
      const nowDone = !item.classList.contains('done');
      setItemDone(item, nowDone);
      if (nowDone) done.add(id); else done.delete(id);
      persist();
      updateProgress();
    });
  });

  // Reset button
  document.getElementById('restore-clear')?.addEventListener('click', () => {
    if (!confirm('Clear your checklist progress?')) return;
    allItems.forEach(item => setItemDone(item, false));
    done.clear();
    persist();
    updateProgress();
    const notice = document.getElementById('restore-notice');
    if (notice) notice.hidden = true;
  });

  // Toggle sections
  document.querySelectorAll<HTMLElement>('[data-toggle]').forEach(header => {
    header.addEventListener('click', () => {
      const id     = header.dataset.toggle!;
      const items  = document.getElementById(`items-${id}`)!;
      const chev   = header.querySelector<SVGElement>('.chevron')!;
      items.classList.toggle('open');
      chev.classList.toggle('open');
    });
  });

  updateProgress();

  // Print / share button: window.print() is unreliable on iOS browsers
  // (Chrome and Firefox on iOS silently no-op). Web Share opens the native
  // OS share sheet which exposes Print, Save to PDF, Email, Copy, etc.
  const printBtn = document.getElementById('print-btn');
  const printBtnLabel = document.getElementById('print-btn-label');
  const isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
  const hasShare = typeof (navigator as any).share === 'function';

  if (printBtn && printBtnLabel && isMobile && hasShare) {
    printBtnLabel.textContent = 'Save / share';
  }

  printBtn?.addEventListener('click', async (e) => {
    e.preventDefault();
    if (isMobile && hasShare) {
      try {
        // location.href already includes the #done=... hash from persist(),
        // so the shared link restores in-progress state when the recipient opens it.
        await (navigator as any).share({
          title: 'Pre-Sale Preparation Checklist',
          text: `${doneEl.textContent}/${totalEl.textContent} tasks complete. Brisbane pre-sale checklist by Daniel Gierach.`,
          url: location.href,
        });
        return;
      } catch (err: any) {
        if (err?.name === 'AbortError') return;
        // fall through to window.print() if share failed for any other reason
      }
    }
    window.print();
  });

  // ── PWA install ("Save to my phone") ──────────────────────────
  // Different paths per platform. Hidden when already installed (standalone).
  const ua = navigator.userAgent;
  const isStandalone =
    window.matchMedia('(display-mode: standalone)').matches ||
    (window.navigator as any).standalone === true;
  const isIOS = /iPad|iPhone|iPod/.test(ua);
  const isInIGWebview = /Instagram|FBAN|FBAV|FB_IAB/.test(ua);
  const isAndroidChrome = /Android/.test(ua) && /Chrome/.test(ua) && !/EdgA|OPR|SamsungBrowser/.test(ua);

  const installBar   = document.getElementById('pwa-install-bar');
  const installBtn   = document.getElementById('pwa-install-btn');
  const installHelp  = document.getElementById('pwa-install-help');
  const installLabel = document.getElementById('pwa-install-label');

  // Android beforeinstallprompt — captured early so we can fire it on demand.
  let deferredPrompt: any = null;
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
  });

  function showInstallBar() {
    if (installBar) installBar.hidden = false;
  }

  function helpFor(platform: 'ios-safari' | 'ios-webview' | 'android-chrome' | 'android-generic' | 'desktop'): string {
    if (platform === 'ios-safari') {
      return `<strong>Add to your iPhone home screen</strong>
        <ol>
          <li>Tap the Share icon <kbd>&#9650;</kbd> at the bottom of Safari.</li>
          <li>Scroll down and tap <kbd>Add to Home Screen</kbd>.</li>
          <li>Tap <kbd>Add</kbd>. The checklist opens like an app, and progress is saved.</li>
        </ol>`;
    }
    if (platform === 'ios-webview') {
      return `<strong>Open in Safari to save</strong>
        <ol>
          <li>Tap the <kbd>&hellip;</kbd> menu at the top of this in-app browser.</li>
          <li>Tap <kbd>Open in Safari</kbd> (or copy the link and paste into Safari).</li>
          <li>In Safari, tap Share &rarr; <kbd>Add to Home Screen</kbd>.</li>
        </ol>`;
    }
    if (platform === 'android-chrome') {
      return `<strong>Add to your home screen</strong>
        <ol>
          <li>Tap the <kbd>&#8942;</kbd> menu in Chrome.</li>
          <li>Tap <kbd>Install app</kbd> (or <kbd>Add to Home screen</kbd>).</li>
          <li>Confirm. The checklist opens like an app and progress is saved.</li>
        </ol>`;
    }
    if (platform === 'android-generic') {
      return `<strong>Add to your home screen</strong>
        <ol>
          <li>Tap your browser's menu (usually <kbd>&#8942;</kbd> or <kbd>&#9776;</kbd>).</li>
          <li>Tap <kbd>Add to Home screen</kbd> or <kbd>Install</kbd>.</li>
          <li>Confirm. The shortcut opens this checklist with your progress.</li>
        </ol>`;
    }
    return `<strong>Bookmark for easy access</strong>
      <ol>
        <li>Press <kbd>Ctrl</kbd> + <kbd>D</kbd> (or <kbd>&#8984;</kbd> + <kbd>D</kbd> on Mac) to bookmark.</li>
        <li>Your progress saves to this browser automatically. Reopen the bookmark any time to continue.</li>
      </ol>`;
  }

  function detectPlatform(): 'ios-safari' | 'ios-webview' | 'android-chrome' | 'android-generic' | 'desktop' {
    if (isIOS) return isInIGWebview ? 'ios-webview' : 'ios-safari';
    if (/Android/.test(ua)) return isAndroidChrome ? 'android-chrome' : 'android-generic';
    return 'desktop';
  }

  if (!isStandalone) {
    showInstallBar();
    installBtn?.addEventListener('click', async () => {
      const platform = detectPlatform();
      // Android Chrome: trigger native install if the prompt was captured
      if (platform === 'android-chrome' && deferredPrompt) {
        try {
          deferredPrompt.prompt();
          await deferredPrompt.userChoice;
          deferredPrompt = null;
          return;
        } catch {
          // fall through to instructions
        }
      }
      // Toggle the instructions panel
      if (installHelp) {
        const open = installHelp.hidden;
        if (open && !installHelp.innerHTML.trim()) {
          installHelp.innerHTML = helpFor(platform);
        }
        installHelp.hidden = !open;
        installBtn?.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
    });
    // Once installed, hide the bar permanently for this session
    window.addEventListener('appinstalled', () => {
      if (installBar) installBar.hidden = true;
    });
    // Shorter label on small phones to keep it on one line
    if (window.innerWidth < 360 && installLabel) {
      installLabel.textContent = 'Save to phone';
    }
  }
</script>

