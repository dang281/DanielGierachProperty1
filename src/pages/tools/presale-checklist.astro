---
import ToolLayout from '../../layouts/ToolLayout.astro';

const sections = [
  {
    id: 'kerb',
    numeral: '1',
    label: 'Kerb Appeal',
    sub: 'What buyers see before they open the door.',
    color: '#b98229',
    items: [
      { id: 'k1', priority: 'High', task: 'Mow, edge and fertilise lawns. Remove weeds from garden beds and replace dead plants.' },
      { id: 'k2', priority: 'High', task: 'Pressure wash driveway, pathways, and exterior walls. First impressions begin at the kerb.' },
      { id: 'k3', priority: 'High', task: 'Touch up or repaint the front fence, gate, and letterbox. Peeling paint signals neglect immediately.' },
      { id: 'k4', priority: 'Medium', task: 'Replace or repaint the front door. A bold, fresh front door is a proven ROI item.' },
      { id: 'k5', priority: 'Medium', task: 'Clean all exterior windows inside and out. Dull glass dulls presentation.' },
      { id: 'k6', priority: 'Low', task: 'Add potted plants or a small garden bed at the front entry to soften and welcome.' },
    ],
  },
  {
    id: 'repairs',
    numeral: '2',
    label: 'Repairs & Maintenance',
    sub: 'The building-report items that turn buyers cautious.',
    color: '#8b6f47',
    items: [
      { id: 'r1', priority: 'High', task: 'Fix all dripping taps, running toilets, and leaking showerheads. Buyers notice water damage and assume worse.' },
      { id: 'r2', priority: 'High', task: 'Repair or replace damaged flyscreens, door handles, locks, and hinges. Rattling and sticking is a turn-off.' },
      { id: 'r3', priority: 'High', task: 'Fill and touch up all wall cracks, scuffs, and nail holes. Repaint in the original colour where needed.' },
      { id: 'r4', priority: 'High', task: 'Replace broken light globes and faulty switches. Every light should work during inspections.' },
      { id: 'r5', priority: 'Medium', task: 'Re-grout and reseal bathrooms and kitchen tiles. Stained grout reads as old and unclean.' },
      { id: 'r6', priority: 'Medium', task: 'Service air conditioning units and replace filters. Buyers will test them.' },
      { id: 'r7', priority: 'Medium', task: 'Fix any sagging gutters, blocked downpipes, or visible roof damage. These flag in building reports.' },
      { id: 'r8', priority: 'Low', task: 'Sand and oil timber decking or verandah floorboards if weathered. Adds significant perceived value to prewar homes.' },
    ],
  },
  {
    id: 'clean',
    numeral: '3',
    label: 'Cleaning & Declutter',
    sub: 'Less is more. Buyers need to see the space, not you.',
    color: '#6b7a5a',
    items: [
      { id: 'c1', priority: 'High', task: 'Hire a professional cleaner for a full deep clean: oven, bathrooms, skirting boards, ceiling fans, and inside cupboards.' },
      { id: 'c2', priority: 'High', task: 'Remove at least 30% of furniture and personal items. Less furniture makes rooms feel larger. Buyers need to see the space, not your belongings.' },
      { id: 'c3', priority: 'High', task: 'Clear all bench tops in kitchen and bathroom. Every item on a bench reduces perceived bench space.' },
      { id: 'c4', priority: 'High', task: 'Clean the oven, range hood filter, and dishwasher. Buyers open these during inspections.' },
      { id: 'c5', priority: 'Medium', task: 'Remove all family photos, religious items, and personal memorabilia. Buyers need to see themselves in the home.' },
      { id: 'c6', priority: 'Medium', task: 'Have carpets professionally steam cleaned. Odour and visible staining are among the top buyer objections.' },
      { id: 'c7', priority: 'Low', task: 'Clear the garage to at minimum half capacity. A crammed garage reads as not enough storage.' },
    ],
  },
  {
    id: 'style',
    numeral: '4',
    label: 'Staging & Styling',
    sub: 'The 5 to 10% edge that professional styling delivers.',
    color: '#a06b3a',
    items: [
      { id: 's1', priority: 'High', task: 'Engage a professional property stylist for key rooms (living, master bedroom, dining). Styled homes consistently achieve 5-10% above comparable unstyled properties.' },
      { id: 's2', priority: 'High', task: 'Replace tired or mismatched cushions, throws, and soft furnishings in the living areas with neutral, contemporary pieces.' },
      { id: 's3', priority: 'High', task: 'Add fresh white towels to bathrooms and a new bath mat. Replace soap dispensers with matching sets.' },
      { id: 's4', priority: 'Medium', task: 'Place a large bunch of fresh flowers or a potted plant in the living room and kitchen for photography and open homes.' },
      { id: 's5', priority: 'Medium', task: 'Ensure all window furnishings are clean and in working order. Stick to open, light-filtering blinds for photography.' },
      { id: 's6', priority: 'Low', task: 'Upgrade kitchen handles, tapware, or bathroom accessories if dated. Small hardware changes read as renovation.' },
    ],
  },
  {
    id: 'legal',
    numeral: '5',
    label: 'Documentation & Compliance',
    sub: 'What your solicitor and buyer will ask for.',
    color: '#6b4610',
    items: [
      { id: 'l1', priority: 'High', task: 'Engage a solicitor or conveyancer to prepare the contract of sale and vendor disclosure documents before launch.' },
      { id: 'l2', priority: 'High', task: 'Obtain a building and pest inspection report. Identifying issues before launch lets you address them on your terms, not the buyer\'s.' },
      { id: 'l3', priority: 'High', task: 'Gather all council approvals for any structures (decks, sheds, pergolas, carports) built since purchase. Unapproved structures must be disclosed.' },
      { id: 'l4', priority: 'High', task: 'Obtain a current smoke alarm compliance certificate. This is a legal requirement for all QLD property sales.' },
      { id: 'l5', priority: 'Medium', task: 'Obtain a pool safety certificate if applicable. Required before contract in QLD (or within 90 days of settlement for buyers).' },
      { id: 'l6', priority: 'Medium', task: 'Locate your current rates notices, water accounts, and any body corporate records. Buyers will request these.' },
      { id: 'l7', priority: 'Low', task: 'Obtain your most recent land tax notice if applicable. Useful for buyers doing their due diligence.' },
    ],
  },
];
---

<!-- GieMann palette retint (surfaces, gold, ink, header, sticky bar) -->

<style is:global>
  /* ════════════════════════════════════════════
     ON-PAGE TOC · article-style right rail
  ════════════════════════════════════════════ */
  #page-toc {
    position: fixed;
    top: 50%;
    right: 1.5rem;
    transform: translateY(-50%);
    width: 260px;
    max-height: 70vh;
    overflow-y: auto;
    padding: 1.25rem 1.35rem;
    background: rgba(242,234,212,0.94);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(107,70,16,0.15);
    border-radius: 14px;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 12px 30px rgba(107,70,16,0.10);
    z-index: 40;
  }
  .page-toc-title {
    font-family: var(--font-serif);
    font-variant-caps: all-small-caps;
    font-weight: 400;
    font-size: 0.95rem;
    letter-spacing: 0.18em;
    color: #6b4610;
    margin: 0 0 1rem;
    font-variation-settings: "opsz" 14;
  }
  #page-toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  #page-toc-list a {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    column-gap: 0.6rem;
    padding: 0.5rem 0.6rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.18s ease;
  }
  #page-toc-list a:hover { background: rgba(185,130,41,0.08); }
  #page-toc-list a.is-active { background: rgba(185,130,41,0.14); }
  .toc-dot {
    width: 10px; height: 10px;
    border: 1.5px solid rgba(107,70,16,0.4);
    border-radius: 50%;
    flex-shrink: 0;
    background: transparent;
    transition: background 0.18s, border-color 0.18s;
  }
  .toc-dot.is-partial {
    background: radial-gradient(circle at 30% 50%, #b98229 45%, transparent 45%);
    border-color: #b98229;
  }
  .toc-dot.is-done {
    background: #b98229;
    border-color: #b98229;
  }
  .toc-numeral {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 500;
    color: #6b4610;
    min-width: 18px;
    text-align: center;
    font-variant-numeric: lining-nums tabular-nums;
    font-variation-settings: "opsz" 20;
  }
  .toc-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(25,24,23,0.72);
    line-height: 1.3;
  }
  #page-toc-list a.is-active .toc-label {
    color: #191817;
    font-weight: 700;
  }
  .toc-count {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: rgba(25,24,23,0.42);
    font-variant-numeric: tabular-nums lining-nums;
  }
  #page-back-to-top {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 46px; height: 46px;
    border: 1px solid rgba(107,70,16,0.35);
    border-radius: 50%;
    background: #f2ead4;
    color: #6b4610;
    cursor: pointer;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(107,70,16,0.14);
    transition: background 0.18s, transform 0.18s;
  }
  #page-back-to-top:hover { background: #ede2c5; transform: translateY(-2px); }
  @media (max-width: 1279px) {
    #page-toc { display: none !important; }
    /* Move back-to-top above the sticky call bar on mobile */
    #page-back-to-top { bottom: 6rem; }
  }
  /* Reserve a right gutter for the fixed TOC so it never overlaps content */
  @media (min-width: 1280px) {
    html .tool-content > .max-w-\[1400px\],
    html .tool-header > .max-w-\[1400px\] {
      padding-right: 320px !important;
    }
  }
  @media (min-width: 1440px) {
    /* Slightly wider gutter on very large screens keeps the rail off content */
    html .tool-content > .max-w-\[1400px\],
    html .tool-header > .max-w-\[1400px\] {
      padding-right: 340px !important;
    }
  }

  /* Print: force white paper background even after our GieMann retint */
  @media print {
    html, body { background: #ffffff !important; }
    html .tool-header {
      background: #ffffff !important;
      border-bottom: 1px solid #000 !important;
    }
    html .tool-title { color: #000 !important; }
    html .tool-desc { display: none !important; }
    html .tool-header .eyebrow { color: #000 !important; font-size: 0.55rem !important; }
    html #site-header { display: none !important; }
    html .tool-header .max-w-\[1400px\]::after { display: none !important; }
  }

  /* ── Magazine mode ──────────────────────────────────────────
     Daniel wants the checklist to read like the magazine pages: no
     "Daniel Gierach" site wordmark, no Home / Tools / Pre-Sale breadcrumb.
     hideNav={true} on the ToolLayout call drops the site nav server-side;
     this hides the tool-level breadcrumb the layout still renders. */
  html .tool-breadcrumb { display: none !important; }

  /* Stop the page drifting left/right (felt "loose" on mobile). */
  html, body { overflow-x: hidden; }

  /* Installed-app (standalone) view: drop the full marketing footer: social
     row, nav links, suburb list, office block, legal. Sticky Message / Call
     bar stays. Media query covers modern iOS/Android; the .app-standalone
     class (added in the page script) is the fallback for older iOS. */
  @media (display-mode: standalone) { html body footer { display: none !important; } }
  html.app-standalone footer { display: none !important; }

  /* Tool header · flat warm cream, subtle bottom hairline. Site header is
     gone, so collapse the top padding that used to clear the fixed nav. */
  html .tool-header {
    position: relative;
    background: #e6d9bd !important;
    border-bottom: 1px solid rgba(107,70,16,0.14) !important;
    padding-top: 2.5rem !important;
  }
  @media (max-width: 640px) {
    html .tool-header { padding-top: 1.25rem !important; }
  }
  html .tool-breadcrumb a,
  html .tool-breadcrumb span:not([style*="color:var(--color-gold)"]) {
    color: rgba(25,24,23,0.55) !important;
  }
  html .tool-header .eyebrow {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-variant-caps: all-small-caps !important;
    text-transform: none !important;
    font-size: 1.05rem !important;
    letter-spacing: 0.22em !important;
    color: #6b4610 !important;
    font-weight: 400 !important;
    font-variation-settings: "opsz" 14;
    margin-bottom: 1.25rem !important;
  }
  html .tool-title {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-weight: 300 !important;
    font-size: clamp(2.4rem, 5.2vw, 4rem) !important;
    line-height: 1.05 !important;
    letter-spacing: -0.028em !important;
    color: #191817 !important;
    font-variation-settings: "opsz" 144;
    margin-bottom: 1.25rem !important;
  }
  html .tool-desc {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-style: italic;
    font-size: 1.1rem !important;
    line-height: 1.55 !important;
    color: rgba(25,24,23,0.65) !important;
    font-weight: 400;
    font-variation-settings: "opsz" 24;
    max-width: 620px !important;
  }
  /* Gold ornament under the title */
  html .tool-header .max-w-\[1400px\]::after {
    content: '';
    display: block;
    width: 100%;
    max-width: 220px;
    height: 1px;
    margin: 1.5rem 0 0;
    background: linear-gradient(90deg, rgba(107,70,16,0.55), transparent);
  }
</style>

<ToolLayout
  title="Pre-Sale Preparation Checklist"
  tool="Pre-Sale Checklist"
  phase="Seller Tools"
  description="A complete pre-sale preparation checklist for Brisbane homeowners. Tick tasks off as you go. Progress saves automatically."
  hideToolCta={true}
  hideFooterCta={true}
  hideNav={true}
  magazineFooter={true}
  manifest="/manifest-presale-checklist.webmanifest"
  appleTouchIcon="/apple-touch-icon-checklist.png"
  appleWebAppTitle="Checklist"
>

<style>
  /* ── Mobile-first base ─────────────────────────────────────── */

  /* Progress card: flat white with deeper drop shadow for lift */
  #progress-ring-container {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 1.35rem;
    background: #ffffff;
    border: 1px solid rgba(107,70,16,0.14);
    border-radius: 16px;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.06),
      0 12px 32px rgba(107,70,16,0.12);
  }
  #prog-svg { width: 52px; height: 52px; flex-shrink: 0; }
  .prog-text {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: #191817;
    line-height: 1.15;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 32;
  }
  #done-count, #total-count { font-variant-numeric: tabular-nums lining-nums; }
  #prog-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.82rem;
    color: rgba(25,24,23,0.6);
    margin-top: 0.2rem;
    line-height: 1.3;
    font-variation-settings: "opsz" 14;
  }

  /* Print button: icon-only square on mobile, expands to label on desktop */
  #print-btn {
    width: 40px; height: 40px;
    padding: 0;
    border: 1px solid rgba(107,70,16,0.28);
    background: #ffffff;
    color: #6b4610;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 10px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    flex-shrink: 0;
  }
  #print-btn:hover { color: #b98229; border-color: #b98229; background: #faf3dc; }
  #print-btn-label {
    /* Hidden visually on mobile; accessible via aria-label on the button */
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  /* Ornamental section divider between sections */
  .section-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    max-width: 320px;
    margin: 2rem auto 1.5rem;
  }
  .section-ornament .ornament-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(107,70,16,0.4), transparent);
  }
  .section-ornament .ornament-mark {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: #b98229;
    line-height: 1;
  }

  /* Section header (collapsible) · editorial chapter with accent tint */
  .section-header {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    column-gap: 1.25rem;
    align-items: center;
    padding: 1.35rem 1.4rem;
    cursor: pointer;
    background: #ffffff;
    border: 1px solid rgba(107,70,16,0.14);
    border-left: 5px solid var(--section-accent, #b98229);
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 6px 22px rgba(107,70,16,0.07);
    transition: background 0.15s, box-shadow 0.2s;
    user-select: none;
  }
  /* Faint accent tint bleeding from the coloured left border */
  .section-header::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 140px;
    background: linear-gradient(90deg, color-mix(in srgb, var(--section-accent, #b98229) 8%, transparent), transparent);
    pointer-events: none;
    border-top-left-radius: 10px;
  }
  .section-header > * { position: relative; z-index: 1; }
  .section-header:hover, .section-header:active {
    background: #faf3dc;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 10px 28px rgba(107,70,16,0.14);
  }
  .section-numeral {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: 2.4rem;
    line-height: 0.9;
    color: var(--section-accent, #b98229);
    letter-spacing: -0.02em;
    min-width: 48px;
    text-align: center;
    font-variant-numeric: lining-nums;
    font-variation-settings: "opsz" 96;
  }
  @media (min-width: 640px) {
    .section-numeral { font-size: 2.75rem; min-width: 56px; }
  }
  .section-titles { min-width: 0; }
  .section-title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .section-label {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    color: #191817;
    line-height: 1.2;
    letter-spacing: -0.015em;
    font-variation-settings: "opsz" 32;
  }
  @media (min-width: 640px) {
    .section-label { font-size: 1.5rem; }
  }
  .section-count {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums lining-nums;
  }
  .section-sub {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.88rem;
    color: rgba(25,24,23,0.58);
    line-height: 1.4;
    margin: 0.25rem 0 0;
    font-variation-settings: "opsz" 14;
  }
  .chevron { transition: transform 0.2s; flex-shrink: 0; align-self: center; }
  .chevron.open { transform: rotate(180deg); }

  /* Checklist items: compact, task-first layout */
  .section-items { display: none; }
  .section-items.open { display: block; }

  .checklist-item {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.7rem;
    align-items: start;
    padding: 0.7rem 1rem;
    background: #ffffff;
    border: 1px solid rgba(107,70,16,0.08);
    border-top: none;
    transition: background 0.15s;
    cursor: pointer;
  }
  .checklist-item:last-child {
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
  }
  .checklist-item:hover, .checklist-item:active { background: #faf3dc; }
  .checklist-item.done { background: rgba(185,130,41,0.06); }
  .checklist-item.done .item-task { text-decoration: line-through; color: var(--color-text-muted); }

  .custom-cb {
    width: 18px; height: 18px;
    border: 1.5px solid rgba(107,70,16,0.35);
    flex-shrink: 0; margin-top: 2px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s, border-color 0.15s;
    border-radius: 4px;
  }
  .checklist-item.done .custom-cb {
    background: #b98229; border-color: #b98229;
  }

  .item-body { min-width: 0; }
  .item-task {
    font-size: 0.82rem;
    color: var(--color-text-primary);
    line-height: 1.45;
    margin-bottom: 0.25rem;
  }
  .item-meta {
    display: flex; align-items: center; gap: 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.3;
  }
  .item-meta .meta-sep { opacity: 0.45; }
  .item-pri-High   { color: #7a3030; }
  .item-pri-Medium { color: #6b4610; }
  .item-pri-Low    { color: rgba(25,24,23,0.5); }

  /* Daniel CTA: warm gold wash, italic title */
  .daniel-cta {
    padding: 1.25rem 1.25rem;
    background: linear-gradient(180deg, rgba(185,130,41,0.14) 0%, rgba(185,130,41,0.04) 100%);
    border: 1px solid rgba(185,130,41,0.28);
    border-left: 3px solid #b98229;
    margin-top: 0.75rem;
    border-radius: 0 12px 12px 0;
    box-shadow: 0 1px 0 rgba(255,255,255,0.5) inset, 0 6px 18px rgba(107,70,16,0.05);
  }
  .daniel-cta-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--color-text-primary);
    margin-bottom: 0.35rem;
  }
  .daniel-cta-body {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin-bottom: 0.65rem;
  }
  .daniel-cta-link {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    text-decoration: none;
  }

  /* ── Desktop bump (≥640px) ─────────────────────────────────── */
  @media (min-width: 640px) {
    #progress-ring-container {
      gap: 1.25rem;
      padding: 1.25rem 1.5rem;
    }
    #prog-svg { width: 56px; height: 56px; }
    .prog-text { font-size: 1.25rem; }
    #prog-label { font-size: 0.8rem; }

    #print-btn {
      width: auto; height: auto;
      padding: 0.55rem 1rem;
      gap: 0.4rem;
      font-family: var(--font-sans);
