<!-- ══ JAVASCRIPT ══════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  /* ── Helpers ─────────────────────────────────────────────────── */

  function parseNum(str: string): number {
    return parseFloat((str || '0').replace(/[^0-9.-]/g, '')) || 0;
  }

  function fmt(n: number, decimals: number = 0): string {
    if (isNaN(n)) return '$0';
    const abs = Math.abs(n);
    const formatted = abs.toLocaleString('en-AU', {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals,
    });
    return (n < 0 ? '-$' : '$') + formatted;
  }

  function fmtPlain(n: number): string {
    return fmt(Math.abs(n));
  }

  /* Allow only digits in $ inputs, format on blur */
  function bindDollarInput(id: string, onUpdate: () => void) {
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (!el) return;
    el.addEventListener('input', function () {
      onUpdate();
    });
    el.addEventListener('blur', function () {
      const val = parseNum(el.value);
      el.value = val > 0 ? val.toLocaleString('en-AU') : '0';
      onUpdate();
    });
  }

  function bindSelect(id: string, onUpdate: () => void) {
    const el = document.getElementById(id) as HTMLSelectElement | null;
    if (!el) return;
    el.addEventListener('change', onUpdate);
  }

  function setText(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  function show(id: string, visible: boolean) {
    const el = document.getElementById(id);
    if (el) el.style.display = visible ? '' : 'none';
  }

  function setClass(id: string, className: string, add: boolean) {
    const el = document.getElementById(id);
    if (!el) return;
    if (add) el.classList.add(className);
    else el.classList.remove(className);
  }


  /* ════════════════════════════════════════════
     SECTION 1: NEGATIVE GEARING
  ════════════════════════════════════════════ */

  function calcNG() {
    const numProps = parseInt((document.getElementById('ng-num-props') as HTMLSelectElement).value, 10) || 1;
    const income   = parseNum((document.getElementById('ng-income') as HTMLInputElement).value);
    const expenses = parseNum((document.getElementById('ng-expenses') as HTMLInputElement).value);
    const taxRate  = parseFloat((document.getElementById('ng-tax-rate') as HTMLSelectElement).value) || 0;

    const netLoss = income - expenses; // negative = loss
    const totalLoss = Math.max(-netLoss, 0); // loss amount (positive number)

    /* Display position */
    setText('ng-disp-income',   fmt(income));
    setText('ng-disp-expenses', fmt(expenses));
    setText('ng-disp-net',      fmt(netLoss));

    const netLabel = document.getElementById('ng-net-label');
    if (netLabel) {
      if (netLoss < 0) {
        netLabel.textContent = 'Negatively geared';
        netLabel.style.color = 'var(--color-gold)';
      } else if (netLoss === 0) {
        netLabel.textContent = 'Neutral cash flow';
        netLabel.style.color = 'var(--color-text-muted)';
      } else {
        netLabel.textContent = 'Positively geared';
        netLabel.style.color = '#4a9e4a';
      }
    }

    /* Current law: full loss offsets personal income */
    const curBenefit = totalLoss * taxRate;
    const curOop     = totalLoss - curBenefit;

    /* 2-property cap: losses from 3rd+ property quarantined */
    let capLoss = 0;
    if (numProps <= 2) {
      capLoss = totalLoss; // no change
    } else {
      /* assume losses split evenly across all properties */
      const lossPerProp = numProps > 0 ? totalLoss / numProps : 0;
      capLoss = lossPerProp * 2; // only first 2 properties deductible
    }
    const capBenefit = capLoss * taxRate;
    const capOop     = totalLoss - capBenefit;

    /* Full abolition: no personal income offset */
    const abolBenefit = 0;
    const abolOop     = totalLoss;

    /* Update columns */
    setText('ng-cur-benefit',  fmt(curBenefit));
    const curOopEl = document.getElementById('ng-cur-oop');
    if (curOopEl) curOopEl.textContent = 'Net cost: ' + fmt(curOop) + ' / yr';

    setText('ng-cap-benefit',  fmt(capBenefit));
    const capOopEl = document.getElementById('ng-cap-oop');
    if (capOopEl) {
      capOopEl.textContent = 'Net cost: ' + fmt(capOop) + ' / yr';
      capOopEl.className = 'fb-col-diff' + (capBenefit < curBenefit ? ' worse' : ' same');
    }

    setText('ng-abol-benefit', fmt(abolBenefit));
    const abolOopEl = document.getElementById('ng-abol-oop');
    if (abolOopEl) abolOopEl.textContent = 'Net cost: ' + fmt(abolOop) + ' / yr';

    /* Summary lines */
    const diffCap  = curBenefit - capBenefit;
    const diffAbol = curBenefit - abolBenefit;

    setText('ng-sum-cur',       fmt(curBenefit));
    setText('ng-sum-cap',       fmt(capBenefit));
    setText('ng-sum-diff-cap',  diffCap > 0 ? '-' + fmtPlain(diffCap) + ' less benefit' : 'No change');
    setText('ng-sum-diff-abol', fmtPlain(diffAbol) + ' / year more');

    /* No-impact note */
    show('ng-note-no-impact', numProps <= 2);
  }

  bindDollarInput('ng-income',   calcNG);
  bindDollarInput('ng-expenses', calcNG);
  bindSelect('ng-num-props', calcNG);
  bindSelect('ng-tax-rate',  calcNG);
  calcNG();


  /* ════════════════════════════════════════════
     SECTION 2: CGT
  ════════════════════════════════════════════ */

  function calcCGT() {
    const purchase = parseNum((document.getElementById('cgt-purchase') as HTMLInputElement).value);
    const sale     = parseNum((document.getElementById('cgt-sale') as HTMLInputElement).value);
    const timing   = (document.getElementById('cgt-timing') as HTMLSelectElement).value;
    const yearsStr = (document.getElementById('cgt-held') as HTMLSelectElement).value;
    const years    = parseInt(yearsStr, 10) || 0;
    const taxRate  = parseFloat((document.getElementById('cgt-tax-rate') as HTMLSelectElement).value) || 0;

    const totalGain = sale - purchase;
    setText('cgt-disp-gain', fmt(totalGain));

    /* Show/hide timing notes */
    show('cgt-timing-note', timing === 'pre');
    show('cgt-post-note',   timing === 'post');

    /* Under 12 months: no discount */
    const noDiscount = years < 1;
    show('cgt-no-discount', noDiscount && totalGain > 0);

    /* Inflation indexation (Option C): indexed cost base using 3% CPI per year */
    const INFLATION_RATE = 0.03;
    const indexedCostBase  = purchase * Math.pow(1 + INFLATION_RATE, years);
    const indexedGain      = Math.max(sale - indexedCostBase, 0);

    const zeroText = 'CGT payable: $0';

    if (totalGain <= 0) {
      setText('cgt-cur-taxable', fmt(0));
      setText('cgt-a-taxable',   fmt(0));
      setText('cgt-b-taxable',   fmt(0));
      setText('cgt-c-taxable',   fmt(0));
      [document.getElementById('cgt-cur-tax'), document.getElementById('cgt-a-tax'),
       document.getElementById('cgt-b-tax'),  document.getElementById('cgt-c-tax')]
        .forEach(el => { if (el) el.textContent = zeroText; });
      ['cgt-sum-cur','cgt-sum-a','cgt-sum-b','cgt-sum-c',
       'cgt-sum-diff-a','cgt-sum-diff-b','cgt-sum-diff-c']
        .forEach(id => setText(id, '$0'));
      return;
    }

    let curTaxable: number;
    let aTaxable: number;
    let bTaxable: number;
    let cTaxable: number; // inflation indexation

    if (noDiscount) {
      curTaxable = totalGain;
      aTaxable   = totalGain;
      bTaxable   = totalGain;
      cTaxable   = totalGain; // no indexation benefit if held under 12 months
    } else if (timing === 'post') {
      curTaxable = totalGain * 0.50;
      aTaxable   = totalGain * 0.75;
      bTaxable   = totalGain * 0.67;
      cTaxable   = indexedGain; // full indexation applies
    } else {
      /* Pre-budget purchase: gains split 50/50 for grandfathering estimate */
      const prePortion  = totalGain * 0.5;
      const postPortion = totalGain * 0.5;

      curTaxable = totalGain * 0.50;
      aTaxable   = (prePortion * 0.50) + (postPortion * 0.75);
      bTaxable   = (prePortion * 0.50) + (postPortion * 0.67);
      /* Option C: pre-budget portion keeps 50% discount; post-budget portion uses indexation.
         For the post-budget portion, apply half the indexed gain as an approximation. */
      const postIndexedGain = Math.max((sale - indexedCostBase) * 0.5, 0);
      cTaxable = (prePortion * 0.50) + postIndexedGain;
    }

    const curTax = curTaxable * taxRate;
    const aTax   = aTaxable   * taxRate;
    const bTax   = bTaxable   * taxRate;
    const cTax   = cTaxable   * taxRate;

    setText('cgt-cur-taxable', fmt(curTaxable));
    setText('cgt-a-taxable',   fmt(aTaxable));
    setText('cgt-b-taxable',   fmt(bTaxable));
    setText('cgt-c-taxable',   fmt(cTaxable));

    const curTaxEl = document.getElementById('cgt-cur-tax');
    const aTaxEl   = document.getElementById('cgt-a-tax');
    const bTaxEl   = document.getElementById('cgt-b-tax');
    const cTaxEl   = document.getElementById('cgt-c-tax');

    if (curTaxEl) curTaxEl.textContent = 'CGT payable: ' + fmt(curTax);
    if (aTaxEl) {
      aTaxEl.textContent = 'CGT payable: ' + fmt(aTax);
      aTaxEl.className   = 'fb-col-diff' + (aTax > curTax ? ' worse' : ' same');
    }
    if (bTaxEl) {
      bTaxEl.textContent = 'CGT payable: ' + fmt(bTax);
      bTaxEl.className   = 'fb-col-diff' + (bTax > curTax ? ' worse' : ' same');
    }
    if (cTaxEl) {
      cTaxEl.textContent = 'CGT payable: ' + fmt(cTax) + (years > 0 ? ' (' + years + ' yr hold)' : '');
      cTaxEl.className   = 'fb-col-diff' + (cTax > curTax ? ' worse' : cTax < curTax ? ' same' : ' same');
    }

    const diffA = aTax - curTax;
    const diffB = bTax - curTax;
    const diffC = cTax - curTax;

    setText('cgt-sum-cur',    fmt(curTax));
    setText('cgt-sum-a',      fmt(aTax));
    setText('cgt-sum-b',      fmt(bTax));
    setText('cgt-sum-c',      fmt(cTax));
    setText('cgt-sum-diff-a', diffA > 0 ? '+' + fmtPlain(diffA) + ' more tax' : 'No change');
    setText('cgt-sum-diff-b', diffB > 0 ? '+' + fmtPlain(diffB) + ' more tax' : 'No change');
    setText('cgt-sum-diff-c', diffC > 0 ? '+' + fmtPlain(diffC) + ' more tax' : diffC < 0 ? fmtPlain(Math.abs(diffC)) + ' less tax' : 'No change');
  }

  bindDollarInput('cgt-purchase', calcCGT);
  bindDollarInput('cgt-sale',     calcCGT);
  bindSelect('cgt-timing',        calcCGT);
  bindSelect('cgt-held',          calcCGT);
  bindSelect('cgt-tax-rate',      calcCGT);
  calcCGT();


  /* ════════════════════════════════════════════
     SECTION 3: HELP TO BUY
  ════════════════════════════════════════════ */

  function calcH2B() {
    const income     = parseNum((document.getElementById('h2b-income') as HTMLInputElement).value);
    const applicants = parseInt((document.getElementById('h2b-applicants') as HTMLSelectElement).value, 10) || 1;
    const price      = parseNum((document.getElementById('h2b-price') as HTMLInputElement).value);
    const deposit    = parseNum((document.getElementById('h2b-deposit') as HTMLInputElement).value);
    const propType   = (document.getElementById('h2b-prop-type') as HTMLSelectElement).value;
    const isFHB      = (document.getElementById('h2b-fhb') as HTMLInputElement).checked;

    const incomeCap    = applicants === 1 ? 100000 : 160000;
    const govtPct      = propType === 'new' ? 0.40 : 0.30;
    const minDeposit   = price * 0.02;

    const failReasons: string[] = [];

    if (income > incomeCap) {
      failReasons.push(
        'Income of ' + fmt(income) + ' exceeds the cap of ' + fmt(incomeCap) +
        ' for ' + (applicants === 1 ? 'singles' : 'couples') + '.'
      );
    }
    if (!isFHB) {
      failReasons.push('You must be a first home buyer or not currently own property.');
    }
    if (deposit < minDeposit) {
      failReasons.push(
        'Deposit of ' + fmt(deposit) + ' is below the minimum 2% required (' + fmt(minDeposit) + ').'
      );
    }

    const isEligible = failReasons.length === 0;

    show('h2b-eligible-block',   isEligible);
    show('h2b-ineligible-block', !isEligible);

    if (!isEligible) {
      const failEl = document.getElementById('h2b-fail-reasons');
      if (failEl) {
        failEl.innerHTML = failReasons
          .map(r => '<div class="fb-warn" style="margin-bottom:0.5rem;">' + r + '</div>')
          .join('');
      }
      return;
    }

    /* Eligible: compute figures */
    const govtContrib = price * govtPct;
    const loanAmt     = price - deposit - govtContrib;
    const loanSafe    = Math.max(loanAmt, 0);

    /* Monthly P&I repayment at 6% over 30 years */
    const monthlyRate = 0.06 / 12;
    const numPayments = 30 * 12;
    let monthlyRepay = 0;
    if (loanSafe > 0 && monthlyRate > 0) {
      monthlyRepay = loanSafe * (monthlyRate * Math.pow(1 + monthlyRate, numPayments)) /
                     (Math.pow(1 + monthlyRate, numPayments) - 1);
    }

    const badgeEl = document.getElementById('h2b-badge');
    if (badgeEl) badgeEl.textContent = 'Likely eligible';

    setText('h2b-r-price',    fmt(price));
    setText('h2b-r-govt',     fmt(govtContrib) + ' (' + Math.round(govtPct * 100) + '%)');
    setText('h2b-r-deposit',  fmt(deposit));
    setText('h2b-r-loan',     fmt(loanSafe));
    setText('h2b-r-repayment', fmt(monthlyRepay, 0) + ' / month');

    show('h2b-deposit-warn', deposit < minDeposit);
  }

  bindDollarInput('h2b-income',   calcH2B);
  bindDollarInput('h2b-price',    calcH2B);
  bindDollarInput('h2b-deposit',  calcH2B);
  bindSelect('h2b-applicants',    calcH2B);
  bindSelect('h2b-prop-type',     calcH2B);

  const h2bFhb = document.getElementById('h2b-fhb');
  if (h2bFhb) h2bFhb.addEventListener('change', calcH2B);

  calcH2B();

})();
</script>

