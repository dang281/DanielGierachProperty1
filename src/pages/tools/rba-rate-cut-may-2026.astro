---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Federal Budget Rate Impact Calculator: May 2026"
  tool="Federal Budget Rate Impact Calculator"
  phase="Buyer"
  description="The RBA hiked to 4.35% on 5 May. The Federal Budget lands 12 May. See how further rate changes affect your repayments across owner-occupier, investor, SMSF and company loans."
>

<style>
  .rba-input {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(28,25,23,0.2);
    background: #fff;
    color: #1c1917;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .rba-input:focus { border-color: var(--color-gold); }

  .seg-btn {
    flex: 1;
    padding: 0.65rem 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: #f9f7f4;
    color: #78716c;
    border: 1px solid rgba(28,25,23,0.15);
    border-right: none;
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
  }
  .seg-btn:last-child { border-right: 1px solid rgba(28,25,23,0.15); }
  .seg-btn.active { background: #c4912a; color: #fff; border-color: #c4912a; z-index: 1; }

  .result-table { width: 100%; border-collapse: collapse; }
  .result-table th {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #78716c;
    background: #f9f7f4;
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid rgba(28,25,23,0.1);
  }
  .result-table td {
    font-size: 0.83rem;
    color: #1c1917;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgba(28,25,23,0.07);
    vertical-align: middle;
  }
  .result-table tr:last-child td { border-bottom: none; }
  .result-table tr.baseline-row td { background: rgba(196,145,42,0.05); font-weight: 700; }
  .result-table tr.hike-row td { background: rgba(192,57,43,0.03); }

  .pill {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 2px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .pill-up   { background: rgba(192,57,43,0.1); color: #c0392b; }
  .pill-down { background: rgba(39,174,96,0.12); color: #1a7a42; }
  .pill-base { background: rgba(28,25,23,0.07); color: #78716c; }

  .vehicle-card {
    border: 1px solid rgba(28,25,23,0.1);
    background: #fff;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    cursor: pointer;
  }
  .vehicle-card.active-card { border-color: #c4912a; background: rgba(196,145,42,0.04); }
</style>

<div style="display:flex;flex-direction:column;gap:2rem;max-width:900px;">

  <!-- Context banner -->
  <div style="background:#0a0806;color:#f0ece4;padding:1.25rem 1.5rem;display:flex;gap:1.5rem;flex-wrap:wrap;">
    <div style="display:flex;flex-direction:column;gap:0.15rem;min-width:110px;">
      <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;">RBA: 5 May</span>
      <span style="font-family:var(--font-serif);font-size:1.4rem;color:#f0ece4;line-height:1.1;">4.35%</span>
      <span style="font-size:0.72rem;color:rgba(240,236,228,0.55);">Cash rate (hiked +0.25%)</span>
    </div>
    <div style="width:1px;background:rgba(240,236,228,0.12);flex-shrink:0;"></div>
    <div style="display:flex;flex-direction:column;gap:0.15rem;min-width:110px;">
      <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;">Federal Budget: 12 May</span>
      <span style="font-size:0.83rem;color:rgba(240,236,228,0.8);line-height:1.5;">A stimulatory budget could keep pressure on inflation, supporting further hikes. Use this tool to see what each scenario means for your loan.</span>
    </div>
  </div>

  <!-- Inputs -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.25rem;">
    <div>
      <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Loan Balance ($)</label>
      <input id="rc-loan" class="rba-input" type="number" value="650000" min="50000" max="5000000" step="10000" />
    </div>
    <div>
      <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Your Current Rate (%)</label>
      <input id="rc-rate" class="rba-input" type="number" value="6.55" min="2" max="15" step="0.01" />
      <p style="font-size:0.68rem;color:#a8a29e;margin-top:0.3rem;">Typical variable: ~6.55% owner-occ, ~6.80% investor</p>
    </div>
    <div>
      <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Remaining Term (years)</label>
      <input id="rc-term" class="rba-input" type="number" value="27" min="1" max="30" step="1" />
    </div>
  </div>

  <!-- Loan type -->
  <div>
    <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Loan Type</p>
    <div style="display:flex;">
      <button class="seg-btn active" data-loan="pi">Principal &amp; Interest</button>
      <button class="seg-btn" data-loan="io">Interest Only</button>
    </div>
  </div>

  <!-- Borrower type -->
  <div>
    <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.75rem;">Borrower Type</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0.75rem;">

      <div class="vehicle-card active-card" data-vehicle="owner" tabindex="0">
        <span style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#c4912a;">Owner-Occupier</span>
        <span style="font-size:0.8rem;color:#1c1917;margin-top:0.15rem;">Home loan</span>
        <span style="font-size:0.72rem;color:#78716c;">No tax deduction on interest</span>
      </div>

      <div class="vehicle-card" data-vehicle="investor" tabindex="0">
        <span style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#78716c;">Investor</span>
        <span style="font-size:0.8rem;color:#1c1917;margin-top:0.15rem;">Individual name</span>
        <span style="font-size:0.72rem;color:#78716c;">Interest is tax-deductible</span>
      </div>

      <div class="vehicle-card" data-vehicle="smsf" tabindex="0">
        <span style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#78716c;">SMSF</span>
        <span style="font-size:0.8rem;color:#1c1917;margin-top:0.15rem;">Super fund (LRBA)</span>
        <span style="font-size:0.72rem;color:#78716c;">15% tax in accumulation</span>
      </div>

      <div class="vehicle-card" data-vehicle="company" tabindex="0">
        <span style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#78716c;">Company / Trust</span>
        <span style="font-size:0.8rem;color:#1c1917;margin-top:0.15rem;">Corporate borrower</span>
        <span style="font-size:0.72rem;color:#78716c;">25% tax rate</span>
      </div>

    </div>
  </div>

  <!-- Marginal rate (investor only) -->
  <div id="tax-row" style="display:none;">
    <label style="display:block;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Marginal Tax Rate</label>
    <div style="display:flex;">
      <button class="seg-btn" data-tax="0.19">19%</button>
      <button class="seg-btn active" data-tax="0.325">32.5%</button>
      <button class="seg-btn" data-tax="0.37">37%</button>
      <button class="seg-btn" data-tax="0.45">45%</button>
    </div>
    <p style="font-size:0.72rem;color:#78716c;margin-top:0.4rem;">Higher rates increase your deductible interest, partially offsetting the cost. Your real after-tax impact is shown below.</p>
  </div>

  <!-- Results table -->
  <div style="background:#fff;border:1px solid rgba(28,25,23,0.1);overflow:hidden;">
    <div style="padding:1rem 1.5rem;border-bottom:1px solid rgba(28,25,23,0.08);background:#f9f7f4;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
      <p style="font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;margin:0;">Rate Change Scenarios</p>
      <p id="results-label" style="font-size:0.78rem;color:#1c1917;margin:0;"></p>
    </div>
    <div style="overflow-x:auto;">
      <table class="result-table">
        <thead>
          <tr>
            <th>Scenario</th>
            <th>Rate</th>
            <th>Monthly Repayment</th>
            <th>Change vs Now</th>
            <th id="col-aftertax" style="display:none;">After-Tax Impact</th>
            <th>Annual Impact</th>
          </tr>
        </thead>
        <tbody id="results-body"></tbody>
      </table>
    </div>
  </div>

  <!-- Summary cards -->
  <div id="summary-cards" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;"></div>

  <!-- Context callout -->
  <div style="background:rgba(196,145,42,0.05);border-left:3px solid #c4912a;padding:1rem 1.25rem;">
    <p style="font-size:0.8rem;color:#1c1917;line-height:1.75;margin:0;">
      <strong>Why the budget matters for rates:</strong> A stimulatory budget with increased spending, new first home buyer incentives, or cost-of-living payments adds demand to the economy and can keep inflation elevated. That gives the RBA less room to pause, let alone cut. Westpac is forecasting the cash rate could reach 4.85% by August 2026.
    </p>
  </div>

  <p style="font-size:0.72rem;color:#a8a29e;line-height:1.6;">
    Illustrative only. Assumes your lender passes on rate changes in full. After-tax figures are estimates based on the marginal rate selected and assume full interest deductibility. Speak to a mortgage broker or financial adviser before making decisions.
  </p>

</div>

<script>
  let loanType: 'pi' | 'io' = 'pi';
  let vehicle: 'owner' | 'investor' | 'smsf' | 'company' = 'owner';
  let marginalTax = 0.325;

  // Scenarios: negative = rate cut, positive = rate hike
  const SCENARIOS = [
    { label: 'Rates fall 0.50%', bps: -0.50 },
    { label: 'Rates fall 0.25%', bps: -0.25 },
    { label: 'Current rate (baseline)', bps: 0 },
    { label: 'One more hike (+0.25%)', bps: 0.25 },
    { label: 'Two more hikes (+0.50%)', bps: 0.50 },
    { label: 'Three more hikes (+0.75%)', bps: 0.75 },
  ];

  function fmt(n: number) {
    return '$' + Math.round(Math.abs(n)).toLocaleString('en-AU');
  }

  function calcPI(principal: number, annualRate: number, termYears: number): number {
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    if (r === 0) return principal / n;
    return principal * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
  }

  function calcIO(principal: number, annualRate: number): number {
    return principal * (annualRate / 100) / 12;
  }

  function taxRate(): number {
    if (vehicle === 'owner') return 0;
    if (vehicle === 'smsf') return 0.15;
    if (vehicle === 'company') return 0.25;
    return marginalTax;
  }

  function render() {
    const loan     = parseFloat((document.getElementById('rc-loan') as HTMLInputElement).value) || 650000;
    const baseRate = parseFloat((document.getElementById('rc-rate') as HTMLInputElement).value) || 6.55;
    const term     = parseInt((document.getElementById('rc-term') as HTMLInputElement).value) || 27;

    const tr = taxRate();
    const showAT = tr > 0;

    document.getElementById('col-aftertax')!.style.display = showAT ? 'table-cell' : 'none';

    const vehicleLabel: Record<string, string> = {
      owner:    'Owner-Occupier',
      investor: `Investor, individual (${(marginalTax * 100).toFixed(0)}% marginal rate)`,
      smsf:     'SMSF accumulation (15% tax)',
      company:  'Company or trust (25% tax)',
    };
    document.getElementById('results-label')!.textContent =
      vehicleLabel[vehicle] + ', ' + (loanType === 'io' ? 'Interest Only' : 'P&I');

    const baseRepay = loanType === 'io'
      ? calcIO(loan, baseRate)
      : calcPI(loan, baseRate, term);

    const tbody = document.getElementById('results-body')!;
    tbody.innerHTML = '';

    SCENARIOS.forEach(({ label, bps }) => {
      const newRate   = Math.max(0.01, baseRate + bps);
      const repay     = loanType === 'io' ? calcIO(loan, newRate) : calcPI(loan, newRate, term);
      const diff      = repay - baseRepay;     // positive = more expensive
      const isBase    = bps === 0;
      const isHike    = bps > 0;

      // After-tax: for investors, interest is deductible so extra cost is offset by tax saving
      // Effective after-tax change = diff * (1 - taxRate) for hikes, diff * (1 - taxRate) for cuts (less deduction)
      const afterTaxDiff = diff * (1 - tr);
      const annualImpact = (tr > 0 ? afterTaxDiff : diff) * 12;

      const tr_el = document.createElement('tr');
      if (isBase) tr_el.className = 'baseline-row';
      else if (isHike) tr_el.className = 'hike-row';

      let changePill = '';
      if (isBase) {
        changePill = `<span class="pill pill-base">Baseline</span>`;
      } else if (diff > 0) {
        changePill = `<span class="pill pill-up">+${fmt(diff)}/mo</span>`;
      } else {
        changePill = `<span class="pill pill-down">-${fmt(diff)}/mo</span>`;
      }

      let atCell = '';
      if (showAT) {
        if (isBase) {
          atCell = `<td style="display:table-cell;color:#78716c;font-size:0.8rem;">Baseline</td>`;
        } else {
          const atStr = afterTaxDiff > 0 ? `+${fmt(afterTaxDiff)}/mo` : `-${fmt(afterTaxDiff)}/mo`;
          const atClass = afterTaxDiff > 0 ? 'pill-up' : 'pill-down';
          atCell = `<td style="display:table-cell;"><span class="pill ${atClass}">${atStr}</span><span style="font-size:0.68rem;color:#78716c;display:block;margin-top:2px;">after ${(tr*100).toFixed(0)}% tax</span></td>`;
        }
      }

      let annualStr = '';
      if (isBase) {
        annualStr = `<span style="color:#78716c;">-</span>`;
      } else if (annualImpact > 0) {
        annualStr = `<strong style="color:#c0392b;">+${fmt(annualImpact)}/yr</strong>`;
      } else {
        annualStr = `<strong style="color:#1a7a42;">-${fmt(annualImpact)}/yr</strong>`;
      }

      tr_el.innerHTML = `
        <td>${isBase ? `<strong>${label}</strong>` : label}</td>
        <td><strong>${newRate.toFixed(2)}%</strong></td>
        <td>${fmt(repay)}<span style="font-size:0.72rem;color:#78716c;">/mo</span></td>
        <td>${changePill}</td>
        ${atCell}
        <td>${annualStr}</td>
      `;
      tbody.appendChild(tr_el);
    });

    // Summary cards
    const wrap = document.getElementById('summary-cards')!;
    wrap.innerHTML = '';
    [
      { bps: 0.25, label: 'One more hike', color: '#c0392b', sign: '+' },
      { bps: 0.50, label: 'Two more hikes', color: '#c0392b', sign: '+' },
      { bps: -0.25, label: 'One cut (if any)', color: '#1a7a42', sign: '-' },
    ].forEach(({ bps, label, color, sign }) => {
      const newRate = Math.max(0.01, baseRate + bps);
      const repay   = loanType === 'io' ? calcIO(loan, newRate) : calcPI(loan, newRate, term);
      const diff    = repay - baseRepay;
      const net     = tr > 0 ? diff * (1 - tr) : diff;
      const card    = document.createElement('div');
      card.style.cssText = 'background:#fff;border:1px solid rgba(28,25,23,0.1);padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:0.25rem;';
      card.innerHTML = `
        <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;color:#78716c;">${label}</span>
        <span style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:${color};">${sign}${fmt(net * 12)}/yr</span>
        <span style="font-size:0.75rem;color:#78716c;">${sign}${fmt(net)}/month${tr > 0 ? ' after tax' : ''}</span>
      `;
      wrap.appendChild(card);
    });
  }

  // Loan type
  document.querySelectorAll<HTMLButtonElement>('[data-loan]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-loan]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      loanType = btn.dataset.loan as 'pi' | 'io';
      render();
    });
  });

  // Vehicle cards
  document.querySelectorAll<HTMLElement>('[data-vehicle]').forEach(card => {
    const activate = () => {
      document.querySelectorAll<HTMLElement>('[data-vehicle]').forEach(c => {
        c.classList.remove('active-card');
        const lbl = c.querySelector<HTMLElement>('span:first-child');
        if (lbl) lbl.style.color = '#78716c';
      });
      card.classList.add('active-card');
      const lbl = card.querySelector<HTMLElement>('span:first-child');
      if (lbl) lbl.style.color = '#c4912a';
      vehicle = card.dataset.vehicle as typeof vehicle;
      document.getElementById('tax-row')!.style.display = vehicle === 'investor' ? 'block' : 'none';
      render();
    };
    card.addEventListener('click', activate);
    card.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') activate(); });
  });

  // Tax rate
  document.querySelectorAll<HTMLButtonElement>('[data-tax]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-tax]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      marginalTax = parseFloat(btn.dataset.tax!);
      render();
    });
  });

  ['rc-loan', 'rc-rate', 'rc-term'].forEach(id => {
    document.getElementById(id)!.addEventListener('input', render);
  });

  render();
</script>

</ToolLayout>
