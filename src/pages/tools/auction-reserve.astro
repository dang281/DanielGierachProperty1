---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Auction Reserve-Setting Framework"
  description="Structured framework for setting your auction reserve. Weighs registered bidders, pre-auction interest, comp median and campaign signals."
  tool="Reserve Setting"
  phase="Seller Tools"
  resourceSlug="auction-day-playbook"
>
<div class="grid grid-cols-1 lg:grid-cols-5 gap-8 pt-8">

  <div class="lg:col-span-3 flex flex-col gap-6">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Price Guide Low</label>
        <input type="number" id="low" value="1400000" class="obs-input" style="font-size:1rem;" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Price Guide High</label>
        <input type="number" id="high" value="1550000" class="obs-input" style="font-size:1rem;" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Comp Median (90 days)</label>
        <input type="number" id="comp" value="1480000" class="obs-input" style="font-size:1rem;" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Registered Bidders</label>
        <input type="number" id="bidders" value="3" min="0" max="20" class="obs-input" style="font-size:1rem;" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Highest Pre-Auction Offer</label>
        <input type="number" id="pre" value="0" class="obs-input" style="font-size:1rem;" placeholder="0 if none" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Callbacks in Final Week</label>
        <input type="number" id="callbacks" value="2" min="0" class="obs-input" style="font-size:1rem;" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Building &amp; Pest Reports Pulled</label>
        <input type="number" id="bps" value="3" min="0" class="obs-input" style="font-size:1rem;" />
      </div>
      <div style="background:var(--color-surface-3);padding:1.5rem;">
        <label style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);display:block;margin-bottom:0.75rem;">Campaign Weeks Run</label>
        <input type="number" id="weeks" value="4" min="2" max="8" class="obs-input" style="font-size:1rem;" />
      </div>
    </div>

  </div>

  <div class="lg:col-span-2">
    <div style="background:var(--color-surface-3);border-radius:14px;padding:2rem;position:sticky;top:6rem;">
      <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:var(--color-text-primary);margin-bottom:1rem;border-bottom:1px solid rgba(72,72,72,0.2);padding-bottom:0.75rem;">
        Reserve Recommendation
      </h2>
      <div style="padding:1.25rem;background:rgba(255,221,121,0.08);border-left:3px solid var(--color-gold);">
        <p id="rec-label" style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.3rem;">Recommended</p>
        <p id="reserve" style="font-family:var(--font-serif);font-size:1.8rem;color:var(--color-gold);line-height:1;"></p>
        <p id="explain" style="font-size:0.85rem;color:var(--color-text-secondary);line-height:1.6;margin-top:0.75rem;"></p>
      </div>
      <div id="outcomes" style="margin-top:1rem;"></div>
      <p style="font-size:0.7rem;color:var(--color-text-muted);margin-top:1rem;line-height:1.6;">
        Framework output. Final reserve is decided on auction morning with your agent, factoring qualitative signals the tool cannot see.
      </p>
      <a href="/walkthrough" data-cta="tool_to_walkthrough" class="btn-gold" style="width:100%;margin-top:1rem;justify-content:center;">Discuss Your Reserve</a>
    </div>
  </div>

</div>

  <!-- Appraisal CTA -->
  <div style="margin-top:3rem;background:var(--color-surface-3);padding:2.5rem;border-left:3px solid var(--color-gold);">
    <p style="font-size:0.62rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">Auction day approaching?</p>
    <h2 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:var(--color-text-primary);margin-bottom:0.75rem;line-height:1.3;">Setting the reserve is one of the most important decisions in your campaign.</h2>
    <p style="font-size:0.88rem;font-weight:300;line-height:1.75;color:var(--color-text-secondary);margin-bottom:1.5rem;">Get it wrong in either direction and you leave money on the table or pass in unnecessarily. I have sold at auction across Brisbane's inner east for years and I am happy to talk through your specific signals before auction morning. No obligation.</p>
    <a href="/walkthrough" data-cta="tool_to_walkthrough" style="font-family:var(--font-sans);font-size:0.82rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;background:var(--color-gold);color:#191817;padding:0.85rem 2rem;text-decoration:none;display:inline-block;border-radius:8px;">Talk Through Your Reserve</a>
  </div>

<!-- Related guide -->
<div style="margin-top:1.25rem;padding:1rem 1.25rem;background:var(--color-surface-1);border-left:2px solid rgba(185,130,41,0.4);">
  <p style="font-size:0.8rem;color:var(--color-text-secondary);line-height:1.7;margin:0;">
    Want more context? Read the full guide:
    <a href="/insights/selling-by-auction-brisbane" style="color:var(--color-gold);font-weight:600;">Selling by Auction in Brisbane &rarr;</a>
  </p>
</div>
</ToolLayout>

<script>
  const fmt = (n: number) => '$' + Math.round(n).toLocaleString();

  function calc() {
    const low = Number((document.getElementById('low') as HTMLInputElement).value) || 0;
    const high = Number((document.getElementById('high') as HTMLInputElement).value) || 0;
    const comp = Number((document.getElementById('comp') as HTMLInputElement).value) || 0;
    const bidders = Number((document.getElementById('bidders') as HTMLInputElement).value) || 0;
    const pre = Number((document.getElementById('pre') as HTMLInputElement).value) || 0;
    const callbacks = Number((document.getElementById('callbacks') as HTMLInputElement).value) || 0;
    const bps = Number((document.getElementById('bps') as HTMLInputElement).value) || 0;

    let demandScore = 0;
    if (bidders >= 4) demandScore += 2; else if (bidders >= 2) demandScore += 1;
    if (pre >= low) demandScore += 2; else if (pre > 0) demandScore += 1;
    if (callbacks >= 3) demandScore += 1;
    if (bps >= 4) demandScore += 1;

    let reserve = comp;
    let explain = '';
    let floor = comp * 0.97;
    let stretch = comp * 1.08;

    if (demandScore >= 5) {
      reserve = low;
      explain = 'Strong demand signals (bidders, pre-auction activity, callbacks). Set reserve at the low end of the guide to put it on the market early and let competition do the work.';
      stretch = high * 1.05;
    } else if (demandScore >= 3) {
      reserve = (low + comp) / 2;
      explain = 'Moderate demand. Reserve at midpoint between guide low and comp median. Enough room for the market to find the price without passing in on a technicality.';
    } else if (demandScore >= 1) {
      reserve = Math.min(low, comp) * 0.98;
      explain = 'Thin demand. Reserve needs to reflect the buyers actually in the room. Below guide low, at or slightly under the comp median, to hold the auction rather than pass in.';
      floor = comp * 0.94;
    } else {
      reserve = comp * 0.94;
      explain = 'Very thin demand (no registered bidders, no pre-auction activity). Reserve should be set to hold the auction open. Plan for passing in and post-auction negotiation with the reserve moving down.';
      floor = comp * 0.90;
    }

    document.getElementById('reserve')!.textContent = fmt(reserve);
    document.getElementById('explain')!.textContent = explain;
    document.getElementById('outcomes')!.innerHTML = `
      <div style="display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid rgba(72,72,72,0.15);">
        <span style="font-size:0.78rem;color:var(--color-text-muted);">Pass-in threshold</span>
        <span style="font-size:0.8rem;font-weight:600;color:var(--color-text-primary);">${fmt(floor)}</span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:0.5rem 0;">
        <span style="font-size:0.78rem;color:var(--color-text-muted);">Stretch outcome</span>
        <span style="font-size:0.8rem;font-weight:600;color:var(--color-text-primary);">${fmt(stretch)}</span>
      </div>
    `;
  }

  document.querySelectorAll('input').forEach(el => el.addEventListener('input', calc));
  calc();
</script>
