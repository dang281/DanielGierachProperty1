---
import Layout from '../../layouts/Layout.astro';

const tools = [
  { href: '/tools/valuation',          label: 'Instant Valuation',             desc: 'Get an indicative value for your property in minutes.',                                                      phase: 'Seller',   cta: 'Estimate My Home' },
  { href: '/tools/selling-costs',      label: 'Selling Cost Calculator',        desc: 'See your estimated net proceeds after all selling costs.',                                                   phase: 'Seller',   cta: 'Calculate Costs' },
  { href: '/tools/renovation-roi',     label: 'Renovation ROI',                 desc: 'Which renovations add the most value before you sell?',                                                      phase: 'Seller',   cta: 'Check ROI' },
  { href: '/tools/equity-calculator',  label: 'Home Equity Calculator',         desc: 'See how much equity you hold and how much you could access or take to your next purchase.',                 phase: 'Seller',   cta: 'Calculate Equity' },
  { href: '/tools/stamp-duty',         label: 'Stamp Duty Calculator',          desc: 'QLD transfer duty, first home buyer concessions & full upfront costs.',                                      phase: 'Buyer',    cta: 'Calculate Duty' },
  { href: '/tools/mortgage',           label: 'Mortgage Calculator',            desc: 'Weekly, fortnightly or monthly repayments + amortisation chart.',                                           phase: 'Buyer',    cta: 'Calculate Repayments' },
  { href: '/tools/borrowing-power',    label: 'Borrowing Power Calculator',     desc: 'Estimate how much you can borrow based on income, expenses, and dependants.',                               phase: 'Buyer',    cta: 'Calculate Power' },
  { href: '/tools/suburb-match',       label: 'Suburb Match Quiz',              desc: 'Answer 8 questions to find your ideal Brisbane inner east suburb.',                                          phase: 'Buyer',    cta: 'Find My Suburb' },
  { href: '/tools/flood-risk',         label: 'Flood Risk Checker',             desc: 'Understand BCC flood zones, 2011/2022 event risk & insurance implications.',                               phase: 'Buyer',    cta: 'Check Risk' },
  { href: '/tools/property-compare',   label: 'Property Comparison',            desc: 'Compare up to 4 properties side-by-side on all key metrics.',                                              phase: 'Buyer',    cta: 'Compare Properties' },
  { href: '/tools/school-catchment',   label: 'School Catchment Map',           desc: 'Find state and private schools near any address. Search by radius and filter by school type.',             phase: 'Buyer',    cta: 'Find Schools' },
  { href: '/tools/zoning-map',         label: 'Brisbane Zoning Map',            desc: 'Look up BCC CityPlan 2014 zoning for any address. Character, LMR, MDR and more explained.',               phase: 'Buyer',    cta: 'Check Zoning' },
  { href: '/tools/rent-vs-buy',        label: 'Rent vs Buy Analyser',           desc: 'Am I better off renting or buying? Break-even year, 10-year wealth comparison.',                           phase: 'Buyer',    cta: 'Compare Options' },
  { href: '/tools/investment-yield',   label: 'Investment Yield',               desc: 'Gross & net yield, cash flow, 10-year capital growth projection.',                                         phase: 'Investor', cta: 'Calculate Yield' },
  { href: '/tools/dcf',                label: 'Property DCF Analyser',          desc: 'Full discounted cash flow model. NPV, IRR, year-by-year cashflow, equity build and net returns.',          phase: 'Investor', cta: 'Analyse Investment' },
  { href: '/tools/negative-gearing',   label: 'Negative Gearing Calculator',    desc: 'See your real after-tax cost of investment property. Tax offset based on your income bracket.',           phase: 'Investor', cta: 'Calculate Saving' },
  { href: '/tools/portfolio-builder',  label: 'Portfolio Builder',              desc: 'Model owning 2–3 properties. Combined equity, cashflow and net worth over time.',                          phase: 'Investor', cta: 'Build Portfolio' },
  { href: '/tools/smsf-calculator',    label: 'SMSF Property Calculator',       desc: 'Can you buy this property in your super fund? Affordability check, tax comparison & LRBA rules.',         phase: 'Investor', cta: 'Check SMSF' },
  { href: '/tools/heatmap',            label: 'Price Heatmap',                  desc: 'Visual suburb-by-suburb median price and growth map.',                                                      phase: 'Market',   cta: 'Explore Map' },
];

const phaseColors: Record<string, string> = {
  Seller:   '#f5d07a',
  Buyer:    '#7ec8e3',
  Investor: '#a8e6a3',
  Market:   '#c8c6c8',
};
---

<Layout title="Property Tools & Calculators | Daniel Gierach Property" description="Free property tools and calculators for Brisbane buyers and sellers. Mortgage calculator, stamp duty, selling costs, borrowing power and more - inner-east Brisbane.">

<!-- Hero -->
<section class="relative min-h-[40vh] flex items-center overflow-hidden" style="background:#0a0806;">
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1920&q=80&fm=webp&auto=format"
      alt="Brisbane property"
      class="w-full h-full object-cover"
      style="filter:grayscale(8%) brightness(0.4);"
    />
    <div class="absolute inset-0" style="background:linear-gradient(120deg,rgba(10,8,6,0.7) 0%,rgba(10,8,6,0.3) 100%);"></div>
  </div>
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-8 lg:px-12 pt-32 pb-16">
    <span class="eyebrow mb-4 reveal" style="display:block;color:#f5d07a;">Resources</span>
    <h1 class="reveal" data-delay="80"
      style="font-family:var(--font-serif);font-size:clamp(2.5rem,5vw,4rem);font-weight:400;color:#f0ece4;letter-spacing:-0.02em;line-height:1.1;margin-bottom:0.75rem;">
      Property Tools<br/><em style="font-style:italic;color:#f5d07a;">&amp; Calculators.</em>
    </h1>
    <p class="reveal" data-delay="160"
      style="font-size:0.95rem;color:rgba(240,236,228,0.6);max-width:48ch;line-height:1.8;">
      Free tools to help you buy, sell, or invest smarter across Brisbane's inner east.
    </p>
  </div>
</section>

<!-- Tools Grid -->
<section style="background:var(--color-base);padding:5rem 0 7rem;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">

    <!-- Filter Toggles -->
    <div id="filter-bar" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:2.5rem;">
      {(['All', 'Buyer', 'Seller', 'Investor', 'Market'] as const).map(phase => (
        <button
          data-filter={phase}
          style={`font-size:0.62rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;padding:0.5rem 1.1rem;border:1.5px solid;cursor:pointer;transition:all 0.18s;background:${phase === 'All' ? '#1c1917' : 'transparent'};color:${phase === 'All' ? '#f0ece4' : '#78716c'};border-color:${phase === 'All' ? '#1c1917' : 'rgba(28,25,23,0.2)'};`}
        >
          {phase}
        </button>
      ))}
    </div>

    <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {tools.map((tool, i) => (
        <a href={tool.href}
          class="tool-card reveal"
          data-phase={tool.phase}
          data-delay={i * 40}
          style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:2rem 2rem 1.75rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.2s,border-color 0.2s,transform 0.2s;position:relative;overflow:hidden;"
          onmouseover="this.style.background='#f2efe9';this.style.borderColor='rgba(196,145,42,0.35)';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.transform='translateY(0)'"
        >
          <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:${phaseColors[tool.phase]};opacity:0.8;`}></div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding-top:0.25rem;">
            <span style={`font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:${phaseColors[tool.phase]};`}>
              {tool.phase}
            </span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(28,25,23,0.35)" stroke-width="1.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
          <div>
            <h2 style="font-family:var(--font-serif);font-size:1.15rem;font-weight:400;color:#1c1917;margin-bottom:0.5rem;line-height:1.2;">
              {tool.label}
            </h2>
            <p style="font-size:0.8rem;color:#78716c;line-height:1.75;">
              {tool.desc}
            </p>
          </div>
          <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;margin-top:auto;">
            {tool.cta} →
          </span>
        </a>
      ))}
    </div>

    <!-- Empty state -->
    <p id="no-tools" style="display:none;text-align:center;padding:3rem 0;font-size:0.9rem;color:#78716c;">No tools in this category.</p>

  </div>
</section>

<!-- Property Report CTA -->
<section style="background:#f2efe9;padding:4rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div class="reveal" style="padding:2.5rem;background:rgba(196,145,42,0.06);border:1px solid rgba(196,145,42,0.2);display:flex;flex-direction:column;align-items:center;text-align:center;gap:1rem;">
      <p style="font-family:var(--font-serif);font-size:1.1rem;font-style:italic;color:#1c1917;">What is your property worth?</p>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;">Get an instant digital property report, powered by Ray White, no obligation.</p>
      <a href="/appraisal" class="btn-gold">
        Get My Free Property Report
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

</Layout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('#filter-bar button');
  const cards = document.querySelectorAll<HTMLElement>('.tool-card');
  const noTools = document.getElementById('no-tools') as HTMLElement;

  const activeStyle = { bg: '#1c1917', color: '#f0ece4', border: '#1c1917' };
  const inactiveStyle = { bg: 'transparent', color: '#78716c', border: 'rgba(28,25,23,0.2)' };

  function applyFilter(phase: string) {
    // Update button styles
    btns.forEach(btn => {
      const isActive = btn.dataset.filter === phase;
      btn.style.background   = isActive ? activeStyle.bg    : inactiveStyle.bg;
      btn.style.color        = isActive ? activeStyle.color : inactiveStyle.color;
      btn.style.borderColor  = isActive ? activeStyle.border: inactiveStyle.border;
    });

    // Show/hide cards
    let visible = 0;
    cards.forEach(card => {
      const match = phase === 'All' || card.dataset.phase === phase;
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    noTools.style.display = visible === 0 ? 'block' : 'none';
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter!));
  });

  applyFilter('All');
</script>
