---
import Layout from '../../layouts/Layout.astro';

const tools = [
  { href: '/tools/valuation',      icon: 'home',      label: 'Instant Valuation',       desc: 'Get an indicative value for your property in minutes.',             phase: 'Seller', cta: 'Estimate My Home' },
  { href: '/tools/selling-costs',  icon: 'dollar',    label: 'Selling Cost Calculator', desc: 'See your estimated net proceeds after all selling costs.',           phase: 'Seller', cta: 'Calculate Costs' },
  { href: '/tools/stamp-duty',     icon: 'receipt',   label: 'Stamp Duty Calculator',   desc: 'QLD transfer duty, first home buyer concessions & full upfront costs.',  phase: 'Buyer',  cta: 'Calculate Duty' },
  { href: '/tools/mortgage',       icon: 'chart',     label: 'Mortgage Calculator',     desc: 'Weekly, fortnightly or monthly repayments + amortisation chart.',   phase: 'Buyer',  cta: 'Calculate Repayments' },
  { href: '/tools/investment-yield', icon: 'yield',   label: 'Investment Yield',        desc: 'Gross & net yield, cash flow, 10-year capital growth projection.',   phase: 'Investor', cta: 'Calculate Yield' },
  { href: '/tools/renovation-roi', icon: 'hammer',    label: 'Renovation ROI',          desc: 'Which renovations add the most value before you sell?',             phase: 'Seller', cta: 'Check ROI' },
  { href: '/tools/suburb-match',   icon: 'quiz',      label: 'Suburb Match Quiz',       desc: 'Answer 8 questions to find your ideal Brisbane inner east suburb.',  phase: 'Buyer',  cta: 'Find My Suburb' },
  { href: '/tools/flood-risk',     icon: 'flood',     label: 'Flood Risk Checker',      desc: 'Understand BCC flood zones, 2011/2022 event risk & insurance implications.', phase: 'Buyer', cta: 'Check Risk' },
  { href: '/tools/property-compare', icon: 'compare', label: 'Property Comparison',     desc: 'Compare up to 4 properties side-by-side on all key metrics.',       phase: 'Buyer',  cta: 'Compare Properties' },
  { href: '/tools/heatmap',        icon: 'map',       label: 'Price Heatmap',           desc: 'Visual suburb-by-suburb median price and growth map.',              phase: 'Market', cta: 'Explore Map' },
];

const phaseColors: Record<string, string> = {
  Seller: '#ffdd79',
  Buyer: '#7ec8e3',
  Investor: '#a8e6a3',
  Market: '#c8c6c8',
};
---

<Layout title="Property Tools & Calculators | Daniel Gierach Property">

  <div style="background:var(--color-surface-1);padding-top:8rem;padding-bottom:3rem;border-bottom:1px solid rgba(72,72,72,0.15);">
    <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
      <span class="eyebrow mb-4" style="display:block;">Resources</span>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3rem);font-weight:400;color:var(--color-text-primary);letter-spacing:-0.01em;line-height:1.1;">
        Property Tools & Calculators
      </h1>
      <p style="font-size:0.9rem;color:var(--color-text-secondary);margin-top:0.75rem;max-width:52ch;line-height:1.75;">
        Free tools to help you buy, sell, or invest smarter in Brisbane's inner east and south.
      </p>
    </div>
  </div>

  <div style="background:var(--color-base);padding:4rem 0 6rem;">
    <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {tools.map((tool) => (
          <a href={tool.href}
            style="background:var(--color-surface-3);padding:2rem;display:flex;flex-direction:column;gap:1rem;transition:background 0.25s,transform 0.25s;text-decoration:none;"
            onmouseover="this.style.background='var(--color-surface-4)';this.style.transform='translateY(-3px)'"
            onmouseout="this.style.background='var(--color-surface-3)';this.style.transform='translateY(0)'"
          >
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;">
              <span style={`font-size:0.55rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:${phaseColors[tool.phase] || '#ffdd79'};background:rgba(255,221,121,0.08);padding:0.25rem 0.6rem;flex-shrink:0;`}>
                {tool.phase}
              </span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
            <div>
              <h2 style="font-family:var(--font-serif);font-size:1.2rem;font-weight:400;color:var(--color-text-primary);margin-bottom:0.5rem;">
                {tool.label}
              </h2>
              <p style="font-size:0.8rem;color:var(--color-text-muted);line-height:1.7;">
                {tool.desc}
              </p>
            </div>
            <span style="font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-gold);margin-top:auto;">
              {tool.cta} →
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
