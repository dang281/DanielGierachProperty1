---
import LandingLayout from '../layouts/LandingLayout.astro';

const services = [
  {
    href: '/buyers',
    title: 'Off-market & pre-market access',
    desc: 'See homes before they hit realestate.com.au.',
    icon: 'key',
  },
  {
    href: '/tools/property-map',
    title: 'Brisbane Property Map',
    desc: 'Zoning, infrastructure and school catchments.',
    icon: 'map',
  },
];

const articles = [
  {
    href: '/insights/buyers-agents-when-to-engage-brisbane-inner-east/?nav=off',
    title: 'When to engage a buyer’s agent',
    desc: 'What a buyer’s agent actually does, and when it’s worth it in the inner east.',
    icon: 'users',
  },
  {
    href: '/insights/mortgage-broker-vs-bank-direct-brisbane-property-buyers?nav=off',
    title: 'Mortgage broker vs going bank-direct',
    desc: 'Which route gets Brisbane buyers a better outcome and why.',
    icon: 'coins',
  },
  {
    href: '/insights/aml-changes-real-estate-brisbane-1-july-2026?nav=off',
    title: 'New AML rules from 1 July 2026',
    desc: 'What changes for buyers and sellers.',
    icon: 'shield',
  },
  {
    href: '/insights/seller-disclosure-obligations-queensland?nav=off',
    title: 'Seller disclosure obligations in Queensland',
    desc: 'What a vendor must (and should) tell a buyer.',
    icon: 'doc',
  },
];

const agents = [
  {
    name: 'Daniel Gierach',
    slug: 'daniel-gierach',
    photo: '/img/daniel-headshot-tight.jpg',
    phone: '0412 523 821',
    tel: '+61412523821',
    email: 'daniel.gierach@raywhite.com',
    handle: 'dgierach',
    instagramUrl: 'https://www.instagram.com/dgierach/',
    ctaKey: 'daniel',
  },
  {
    name: 'Conrad Leisemann',
    slug: 'conrad-leisemann',
    photo: '/img/conrad-headshot.jpg',
    phone: '0403 978 813',
    tel: '+61403978813',
    email: 'conrad.leisemann@raywhite.com',
    handle: 'connie_leisemann',
    instagramUrl: 'https://www.instagram.com/connie_leisemann/',
    ctaKey: 'conrad',
  },
];

const supportTeam = [
  { slug: 'samantha-squires', name: 'Samantha Squires', role: 'Operations Manager', photo: '/img/samantha-squires-headshot.jpg' },
];
---

<LandingLayout
  title="Helping You Buy | Daniel Gierach & Conrad Leisemann"
  description="Buyer-focused tools and access from Daniel Gierach and Conrad Leisemann at Ray White Bulimba. Off-market and pre-market homes, the Brisbane Property Map, and the latest insights for inner-east buyers."
>

<style>
  :root {
    --bg: #0a0806;
    --bg-soft: #100c08;
    --card: #15110d;
    --card-hover: #1c1612;
    --line: rgba(240, 236, 228, 0.07);
    --line-strong: rgba(196, 145, 42, 0.32);
    --line-glow: rgba(196, 145, 42, 0.5);
    --text: #f2efe9;
    --text-mute: rgba(242, 239, 233, 0.5);
    --text-soft: rgba(242, 239, 233, 0.78);
    --gold: #c4912a;
    --gold-bright: #d4a23a;
    --gold-soft: rgba(196, 145, 42, 0.85);
  }

  body { background: var(--bg); color: var(--text); position: relative; }

  .hero-bg {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 380px;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 92%;
    filter: grayscale(12%) brightness(0.62) contrast(1.05);
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(196,145,42,0.1) 0%, rgba(196,145,42,0) 70%),
      linear-gradient(
        180deg,
        rgba(10,8,6,0.55) 0%,
        rgba(10,8,6,0.5) 28%,
        rgba(10,8,6,0.7) 55%,
        rgba(10,8,6,0.88) 80%,
        var(--bg) 100%
      );
  }
  @media (min-width: 640px) { .hero-bg { height: 420px; } }

  .shell {
    max-width: 480px;
    margin: 0 auto;
    padding: 1.5rem 1.15rem 2.5rem;
    min-height: 100svh;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 640px) {
    .shell { padding: 2rem 1.5rem 3rem; }
  }

  .header { text-align: center; margin-bottom: 1.5rem; }

  .agency-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.56rem; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold-soft);
    margin-bottom: 0.5rem;
  }

  .team-title {
    font-family: var(--font-serif);
    font-size: 1.25rem; font-weight: 400;
    font-style: italic;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 1.4rem;
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
  }

  .agents {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 0;
  }
  @media (min-width: 480px) { .agents { gap: 1.5rem; } }

  .agent {
    display: flex; flex-direction: column; align-items: center;
    min-width: 0;
  }

  .avatar {
    width: 76px; height: 76px;
    border-radius: 14px;
    object-fit: cover; object-position: center 35%;
    display: block;
    margin: 0 0 0.5rem;
    border: 1.5px solid rgba(197, 160, 60, 0.55);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.55), 0 0 0 4px rgba(196, 145, 42, 0.05);
  }
  @media (min-width: 480px) { .avatar { width: 88px; height: 88px; } }

  .name {
    font-family: var(--font-serif);
    font-size: 1rem; font-weight: 700;
    line-height: 1.15; letter-spacing: 0.005em;
    margin-bottom: 0.3rem;
    min-height: 2.4em;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    text-shadow: 0 1px 12px rgba(0,0,0,0.65), 0 1px 2px rgba(0,0,0,0.5);
  }
  @media (min-width: 480px) { .name { font-size: 1.15rem; min-height: 1.3em; } }

  .contact-line {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.1rem;
    font-family: var(--font-sans);
    font-size: 0.7rem; font-weight: 700;
    line-height: 1.25;
    margin-bottom: 0.15rem;
    text-shadow: 0 1px 8px rgba(0,0,0,0.6), 0 1px 2px rgba(0,0,0,0.45);
  }
  @media (min-width: 480px) { .contact-line { font-size: 0.78rem; } }
  .contact-line a { color: var(--gold); text-decoration: none; transition: color 0.2s; white-space: nowrap; }
  .contact-line a:hover { color: var(--gold-bright); }
  .contact-line .sep { display: none; }
  .handle-text { color: rgba(242,239,233,0.78); font-weight: 600; }
  .handle-text a { color: rgba(242,239,233,0.78); }
  .handle-text a:hover { color: var(--gold); }

  .email {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 500;
    line-height: 1.25;
    word-break: break-all;
    text-shadow: 0 1px 6px rgba(0,0,0,0.55);
    padding: 0 0.25rem;
    margin: 0;
  }
  @media (min-width: 480px) { .email { font-size: 0.66rem; word-break: normal; } }
  .email a {
    color: rgba(242,239,233,0.85); text-decoration: none;
    transition: color 0.2s;
  }
  .email a:hover { color: var(--gold); }

  .agent-info-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.3rem;
    margin-top: 0.65rem;
    padding: 0.4rem 0.75rem;
    background: rgba(196, 145, 42, 0.08);
    border: 1px solid rgba(196, 145, 42, 0.35);
    border-radius: 8px;
    font-family: var(--font-sans);
    font-size: 0.52rem; font-weight: 800;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    white-space: nowrap;
  }
  @media (min-width: 480px) { .agent-info-btn { font-size: 0.55rem; padding: 0.45rem 0.9rem; } }
  .agent-info-btn:hover {
    background: rgba(196, 145, 42, 0.18);
    border-color: var(--gold);
    color: var(--gold-bright);
  }

  /* ── Wider team (support staff, sits below Daniel + Conrad) ───── */
  .wider-team-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.56rem; font-weight: 800;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--text-mute);
    text-align: center;
    margin-top: 1.5rem; margin-bottom: 0.85rem;
  }
  .wider-team {
    display: flex;
    justify-content: center;
    gap: 0.7rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 480px) { .wider-team { gap: 1rem; } }
  .wt-card {
    display: flex; flex-direction: column; align-items: center;
    padding: 0.9rem 0.5rem 0.85rem;
    background: rgba(15, 11, 7, 0.55);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(196, 145, 42, 0.18);
    border-radius: 8px;
    transition: background 0.18s, border-color 0.18s;
    flex: 1 1 0;
    min-width: 0;
    max-width: 200px;
  }
  .wt-card:hover { background: rgba(20, 14, 9, 0.75); border-color: rgba(196, 145, 42, 0.4); }
  .wt-avatar {
    width: 60px; height: 60px;
    border-radius: 10px;
    object-fit: cover; object-position: center 22%;
    border: 1px solid rgba(197, 160, 60, 0.45);
    margin-bottom: 0.6rem;
  }
  @media (min-width: 480px) { .wt-avatar { width: 70px; height: 70px; border-radius: 12px; } }
  .wt-name {
    font-family: var(--font-serif);
    font-size: 0.78rem; font-weight: 700;
    line-height: 1.2;
    text-align: center;
    margin-bottom: 0.2rem;
    color: var(--text);
    text-shadow: 0 1px 8px rgba(0,0,0,0.55);
    min-height: 2.4em;
    display: flex; align-items: center;
  }
  @media (min-width: 480px) { .wt-name { font-size: 0.88rem; min-height: 1.2em; } }
  .wt-role {
    font-family: var(--font-sans);
    font-size: 0.5rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gold-soft);
    text-align: center;
    margin-bottom: 0.7rem;
    line-height: 1.3;
    min-height: 2.6em;
    display: flex; align-items: center; justify-content: center;
  }
  @media (min-width: 480px) { .wt-role { font-size: 0.55rem; } }
  .wt-info-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.3rem;
    padding: 0.5rem 0.8rem;
    background: rgba(196, 145, 42, 0.08);
    border: 1px solid rgba(196, 145, 42, 0.35);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.5rem; font-weight: 800;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    white-space: nowrap;
  }
  @media (min-width: 480px) { .wt-info-btn { font-size: 0.55rem; padding: 0.5rem 0.9rem; } }
  .wt-info-btn:hover {
    background: rgba(196, 145, 42, 0.18);
    border-color: var(--gold);
    color: var(--gold-bright);
  }

  /* ── The Collective call-out band ─────────────────────────────── */
  .collective-band {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    margin: 0.75rem 0 1.75rem;
    background:
      linear-gradient(135deg, rgba(196,145,42,0.08) 0%, rgba(196,145,42,0) 55%),
      var(--bg-soft);
    border: 1px solid rgba(196,145,42,0.3);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, transform 0.2s;
  }
  .collective-band:hover, .collective-band:focus-visible {
    border-color: var(--gold);
    transform: translateY(-1px);
  }
  .cb-body { flex: 1; min-width: 0; }
  .cb-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 800;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.3rem;
  }
  .cb-title {
    font-family: var(--font-serif);
    font-size: 1.02rem; font-weight: 400;
    line-height: 1.25;
    margin: 0 0 0.25rem;
  }
  .cb-desc {
    font-size: 0.72rem; line-height: 1.4;
    color: var(--text-mute);
    margin: 0;
  }
  .cb-arrow {
    color: var(--gold-soft);
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }
  .collective-band:hover .cb-arrow {
    color: var(--gold);
    transform: translateX(2px);
  }

  .section { margin-bottom: 1.5rem; }
  .section-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 800;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-mute);
    margin-bottom: 0.7rem; padding-left: 0.2rem;
  }

  .card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.95rem;
    background:
      linear-gradient(135deg, rgba(196,145,42,0.04) 0%, rgba(196,145,42,0) 60%),
      var(--card);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.95rem 1.05rem;
    text-decoration: none;
    color: var(--text);
    margin-bottom: 0.55rem;
    transition: background 0.2s, border-color 0.2s, transform 0.18s;
    position: relative;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px; background: var(--gold);
    opacity: 0.6;
    transition: opacity 0.2s, width 0.2s;
  }
  .card:hover, .card:focus-visible {
    background:
      linear-gradient(135deg, rgba(196,145,42,0.08) 0%, rgba(196,145,42,0.01) 60%),
      var(--card-hover);
    border-color: var(--line-strong);
    transform: translateY(-1px);
  }
  .card:hover::before { opacity: 1; width: 3px; }
  .card:active { transform: translateY(0); }

  .card-icon {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(196, 145, 42, 0.1);
    border: 1px solid rgba(196, 145, 42, 0.18);
    border-radius: 50%;
    color: var(--gold-bright);
    flex-shrink: 0;
  }

  .card-body { min-width: 0; }
  .card-title {
    font-family: var(--font-serif);
    font-size: 1rem; font-weight: 400;
    line-height: 1.2;
    margin-bottom: 0.2rem;
  }
  .card-desc {
    font-size: 0.7rem; line-height: 1.4;
    color: var(--text-soft);
  }
  .card-arrow {
    color: var(--text-mute);
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .card:hover .card-arrow {
    color: var(--gold);
    transform: translateX(2px);
  }

  .acard {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 0.95rem;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 4px;
    text-decoration: none;
    color: var(--text);
    margin-bottom: 0.45rem;
    transition: background 0.2s, border-color 0.2s;
  }
  .acard:hover, .acard:focus-visible {
    background: var(--bg-soft);
    border-color: var(--line-strong);
  }
  .acard-icon {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    color: var(--gold-soft);
    flex-shrink: 0;
  }
  .acard-body { min-width: 0; }
  .acard-title {
    font-family: var(--font-serif);
    font-size: 0.88rem; font-weight: 400;
    line-height: 1.25;
    margin-bottom: 0.15rem;
  }
  .acard-desc {
    font-size: 0.66rem; line-height: 1.35;
    color: var(--text-mute);
  }

  .browse-all {
    display: inline-flex; align-items: center; gap: 0.35rem;
    margin-top: 0.4rem; padding: 0.3rem 0.2rem;
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 800;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold); text-decoration: none;
    transition: color 0.18s;
  }
  .browse-all:hover { color: var(--gold-bright); }

  .final {
    background:
      linear-gradient(135deg, rgba(196,145,42,0.15) 0%, rgba(196,145,42,0.04) 100%);
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    padding: 1.75rem 1.25rem;
    margin-top: 1.5rem;
    text-align: center;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
  .final > * { margin: 0; }
  .final-title {
    font-family: var(--font-serif);
    font-size: 0.98rem; font-weight: 400; line-height: 1.3;
  }
  .final-sub {
    font-size: 0.7rem; line-height: 1.5;
    color: var(--text-soft);
  }
  .btn-gold {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.75rem 1.25rem;
    background: var(--gold); color: var(--bg);
    font-family: var(--font-sans);
    font-size: 0.66rem; font-weight: 800;
    letter-spacing: 0.14em; text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s, transform 0.18s;
  }
  .btn-gold:hover { background: var(--gold-bright); transform: translateY(-1px); }

  .contact-row {
    display: flex; justify-content: center; gap: 1.25rem;
    margin-top: 1.25rem; padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
  .contact-row a {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--text-mute); text-decoration: none;
    transition: color 0.18s;
  }
  .contact-row a:hover { color: var(--gold); }

  .legal {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.56rem; color: var(--text-mute);
    line-height: 1.5;
    opacity: 0.85;
  }
</style>

<div class="hero-bg" aria-hidden="true">
  <img
    src="/_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Ff0e3-H3512351-202426677__1779329460-52623-AMY9140.jpg&w=1080&q=65"
    srcset="
      /_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Ff0e3-H3512351-202426677__1779329460-52623-AMY9140.jpg&w=640&q=65 640w,
      /_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Ff0e3-H3512351-202426677__1779329460-52623-AMY9140.jpg&w=1080&q=65 1080w,
      /_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Ff0e3-H3512351-202426677__1779329460-52623-AMY9140.jpg&w=1440&q=65 1440w
    "
    sizes="(max-width: 640px) 100vw, 1440px"
    alt=""
    fetchpriority="high"
  />
</div>

<div class="shell">

  <header class="header">
    <p class="agency-eyebrow">Ray White &middot; The Collective &middot; Bulimba</p>
    <p class="team-title">Helping You Buy</p>

    <div class="agents">
      {agents.map(a => (
        <div class="agent">
          <img src={a.photo} alt={a.name} class="avatar" width="88" height="88" loading="eager" />
          <div class="name">{a.name}</div>
          <p class="contact-line">
            <a href={`tel:${a.tel}`} data-cta={`helping_you_buy_call_${a.ctaKey}`}>{a.phone}</a>
            <span class="sep">&middot;</span>
            <span class="handle-text"><a href={a.instagramUrl} target="_blank" rel="noopener">@{a.handle}</a></span>
          </p>
          <p class="email"><a href={`mailto:${a.email}`} data-cta={`helping_you_buy_email_${a.ctaKey}`}>{a.email}</a></p>
          <a href={`/team/${a.slug}`} class="agent-info-btn" data-cta={`helping_you_buy_more_${a.ctaKey}`}>
            More info
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>

    <p class="wider-team-label">Supported by</p>
    <div class="wider-team">
      {supportTeam.map(m => (
        <div class="wt-card">
          <img src={m.photo} alt={m.name} class="wt-avatar" width="70" height="70" loading="lazy" />
          <div class="wt-name">{m.name}</div>
          <div class="wt-role">{m.role}</div>
          <a href={`/team/${m.slug}`} class="wt-info-btn" data-cta={`helping_you_buy_team_${m.slug}`}>
            More info
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </header>

