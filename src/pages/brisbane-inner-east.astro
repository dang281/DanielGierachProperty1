---
import Layout from '../layouts/Layout.astro';
import ResourceCTA from '../components/ResourceCTA.astro';
---

<Layout
  title="Real Estate Agent Brisbane Inner East | Daniel Gierach"
  description="Daniel Gierach is a specialist real estate agent in Brisbane's inner east: Bulimba, Hawthorne, Balmoral, Morningside, Camp Hill, Cannon Hill, Carina and 50+ suburbs. Free appraisal: 0412 523 821."
>

<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Real Estate Agent Brisbane Inner East | Daniel Gierach",
  "description": "Daniel Gierach is a specialist real estate agent in Brisbane's inner east, selling homes across Bulimba, Hawthorne, Balmoral, Morningside, Camp Hill, Norman Park, Cannon Hill, Carina and surrounding suburbs.",
  "url": "https://danielgierach.com/brisbane-inner-east",
  "author": { "@id": "https://danielgierach.com/#person" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://danielgierach.com" },
      { "@type": "ListItem", "position": 2, "name": "Brisbane Inner East", "item": "https://danielgierach.com/brisbane-inner-east" }
    ]
  }
})}</script>
<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who is the best real estate agent in Brisbane's inner east?",
      "acceptedAnswer": { "@type": "Answer", "text": "Daniel Gierach at Ray White Bulimba is a specialist real estate agent in Brisbane's inner east, with deep expertise across Bulimba, Hawthorne, Balmoral, Morningside, Norman Park, Camp Hill, Cannon Hill, Carina, Coorparoo, East Brisbane, Seven Hills and surrounding suburbs. Contact: 0412 523 821 or danielgierach.com." }
    },
    {
      "@type": "Question",
      "name": "What suburbs are in Brisbane's inner east?",
      "acceptedAnswer": { "@type": "Answer", "text": "Brisbane's inner east includes Bulimba, Hawthorne, Balmoral, Morningside, East Brisbane, Norman Park, Camp Hill, Cannon Hill, Carina, Carina Heights, Coorparoo, Carindale, Seven Hills, Murarrie, Tingalpa, Greenslopes, Woolloongabba, Stones Corner, and surrounding suburbs within 10km of the Brisbane CBD on the eastern side." }
    },
    {
      "@type": "Question",
      "name": "How do I sell my home in Brisbane's inner east?",
      "acceptedAnswer": { "@type": "Answer", "text": "Contact Daniel Gierach at Ray White Bulimba for a free, no-obligation property appraisal. Daniel will walk through your home, review recent comparable sales in your suburb, and provide an honest price guide. Call 0412 523 821 or visit danielgierach.com/walkthrough." }
    },
    {
      "@type": "Question",
      "name": "Why is Brisbane's inner east a good area to buy or sell property?",
      "acceptedAnswer": { "@type": "Answer", "text": "Brisbane's inner east offers proximity to the CBD (most suburbs within 8km), strong long-term capital growth, lifestyle amenity including the Brisbane River, Clem Jones bikeway, and vibrant retail precincts. The area's housing mix of Queenslanders, post-war homes and new townhouses attracts diverse buyer pools, and Olympic infrastructure investment ahead of 2032 is strengthening demand." }
    }
  ]
})}</script>

<!-- ═══════════════════════════════════════════════
     SECTION 1: HERO
════════════════════════════════════════════════ -->
<section style="background:#f2ead4; color:#191817; padding: 100px 24px 80px;">
  <div style="max-width:880px; margin:0 auto; text-align:center;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1.25rem;">Brisbane Real Estate</p>
    <h1 style="font-family:var(--font-serif); font-size:clamp(2.4rem, 5vw, 4rem); font-weight:300; line-height:1.15; margin-bottom:1.5rem; color:#191817;">
      Real estate agent. Brisbane, all of it.
    </h1>
    <p style="font-family:var(--font-sans); font-size:1.05rem; font-weight:300; line-height:1.7; color:rgba(25,24,23,0.72); max-width:620px; margin:0 auto 2.5rem;">
      Daniel takes campaigns across Brisbane. His home patch is the inner east and south. The same documented method runs every campaign, anywhere in the city.
    </p>
    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
      <a href="/listings" class="btn-gold" style="font-family:var(--font-sans); font-size:0.85rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; background:#b98229; color:#191817; padding:0.85rem 2rem; text-decoration:none; display:inline-block;border-radius:8px;">View current listings</a>
      <a href="/get-an-appraisal" class="btn-gold" style="font-family:var(--font-sans); font-size:0.85rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; background:#b98229; color:#191817; padding:0.85rem 2rem; text-decoration:none; display:inline-block;border-radius:8px;">Request an appraisal</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 2: WHY THIS AREA
════════════════════════════════════════════════ -->
<section style="background:var(--color-base, #f2ead4); padding:80px 24px;">
  <div style="max-width:800px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1rem;">Local Expertise</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.8rem, 3.5vw, 2.8rem); font-weight:300; line-height:1.2; color:#191817; margin-bottom:1.75rem;">Deep knowledge of Brisbane's inner east.</h2>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.8; color:#4a4540; margin-bottom:1.25rem;">
      The inner east is not a single market. Ridge-street Camp Hill behaves differently to riverside Hawthorne, and a Queenslander in Norman Park attracts a different buyer pool to a townhouse in Coorparoo. I have been selling in this corridor for more than a decade. That means I know which buyers are active for your property right now, what they have been paying for comparable stock, and where the negotiation will actually be won.
    </p>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.8; color:#4a4540; margin-bottom:3rem;">
      Norman Park character homes, Hawthorne riverfronts, and Camp Hill family houses are three different campaigns with three different buyer pools. That is the level of specificity that separates a campaign that clears the market from one that sits.
    </p>
    <div style="display:flex; gap:1.5rem; flex-wrap:wrap;">
      <div style="flex:1; min-width:200px; background:#fff; padding:1.75rem; border-left:3px solid #b98229; border-radius:16px;">
        <p style="font-family:var(--font-serif); font-size:1.1rem; font-weight:400; color:#191817; margin-bottom:0.4rem;">Inner East Specialist</p>
        <p style="font-family:var(--font-sans); font-size:0.85rem; font-weight:300; color:#6b6560;">Actively selling across the inner east</p>
      </div>
      <div style="flex:1; min-width:200px; background:#fff; padding:1.75rem; border-left:3px solid #b98229; border-radius:16px;">
        <p style="font-family:var(--font-serif); font-size:1.1rem; font-weight:400; color:#191817; margin-bottom:0.4rem;">Qualified</p>
        <p style="font-family:var(--font-sans); font-size:0.85rem; font-weight:300; color:#6b6560;">Bachelor in Property Economics</p>
      </div>
      <div style="flex:1; min-width:200px; background:#fff; padding:1.75rem; border-left:3px solid #b98229; border-radius:16px;">
        <p style="font-family:var(--font-serif); font-size:1.1rem; font-weight:400; color:#191817; margin-bottom:0.4rem;">Ray White Bulimba</p>
        <p style="font-family:var(--font-sans); font-size:0.85rem; font-weight:300; color:#6b6560;">One of the area's most active offices</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
