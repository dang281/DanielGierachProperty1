---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Request an Appraisal | Daniel Gierach Property" description="Get a free property appraisal in Brisbane's inner east. Find out what your home is worth with an instant digital report, powered by Ray White Bulimba.">

<!-- ════════════════════════════════════════════
     FULL-VIEWPORT SPLIT LAYOUT
     Left: dark hero  |  Right: form
════════════════════════════════════════════ -->
<section style="display:grid;grid-template-columns:1fr 1fr;min-height:100dvh;" class="appraisal-split">

  <!-- ── LEFT: dark hero panel ── -->
  <div class="relative flex flex-col justify-center overflow-hidden" style="padding:8rem 4rem 4rem;">

    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=1920&q=85"
        alt="Brisbane inner-east property"
        class="w-full h-full object-cover"
        style="filter:grayscale(8%) brightness(0.45);"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background:linear-gradient(105deg,rgba(10,8,6,0.82) 0%,rgba(10,8,6,0.6) 55%,rgba(10,8,6,0.25) 100%);"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10">
      <span class="appraisal-hero-eyebrow eyebrow mb-5 reveal" style="display:block;color:#f5d07a;">Free Property Appraisal</span>

      <h1 class="reveal" data-delay="60"
        style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400;line-height:1.08;letter-spacing:-0.02em;color:#f0ece4;margin-bottom:1.25rem;">
        Know What Your<br/>
        <em style="font-style:italic;color:#f5d07a;">Property Is Worth.</em>
      </h1>

      <p class="appraisal-hero-desc reveal" data-delay="120"
        style="font-size:1rem;color:rgba(240,236,228,0.82);line-height:1.9;max-width:44ch;margin-bottom:2.75rem;">
        Get a precise, obligation-free appraisal backed by real buyer data and local market knowledge across Brisbane's inner east.
      </p>

      <!-- Contact details -->
      <div class="appraisal-hero-contacts reveal" data-delay="180" style="display:flex;flex-direction:column;gap:1.5rem;">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Phone</p>
          <a href="tel:+61412523821"
            style="font-family:var(--font-serif);font-size:1.25rem;font-weight:400;color:#ffffff;text-decoration:none;transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='#ffffff'">0412 523 821</a>
        </div>

        <div style="width:100%;height:1px;background:rgba(255,255,255,0.1);"></div>

        <div>
          <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Email</p>
          <a href="mailto:daniel.gierach@raywhite.com"
            style="font-family:var(--font-serif);font-size:1.25rem;font-weight:400;color:#ffffff;text-decoration:none;transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='#ffffff'">daniel.gierach@raywhite.com</a>
        </div>

        <div style="width:100%;height:1px;background:rgba(255,255,255,0.1);"></div>

        <div style="display:flex;gap:0.85rem;align-items:center;">
          <a href="https://www.instagram.com/dgierach/" target="_blank" rel="noopener" aria-label="Instagram"
            style="color:rgba(240,236,228,0.45);transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='rgba(240,236,228,0.45)'">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/danielgierach" target="_blank" rel="noopener" aria-label="LinkedIn"
            style="color:rgba(240,236,228,0.45);transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='rgba(240,236,228,0.45)'">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href="https://www.realestate.com.au/agent/daniel-gierach-3819232" target="_blank" rel="noopener" aria-label="realestate.com.au"
            style="opacity:0.45;transition:opacity 0.2s;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.45'">
            <img src="https://www.realestate.com.au/favicon.ico" width="24" height="24" alt="realestate.com.au" style="display:block;" />
          </a>
          <a href="https://share.google/WipmgyJnjC5nkhGwx" target="_blank" rel="noopener" aria-label="Google Business Profile"
            style="color:rgba(240,236,228,0.45);transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='rgba(240,236,228,0.45)'">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ── RIGHT: form panel ── -->
  <div class="flex flex-col justify-center overflow-y-auto" style="background:var(--color-surface-1);padding:8rem 4rem 4rem;">

    <div class="reveal" data-delay="80" style="max-width:480px;width:100%;">

      <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Request an Appraisal</p>
      <h2 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:#1c1917;line-height:1.2;margin-bottom:1.75rem;">
        Daniel will be in touch <em style="font-style:italic;">promptly.</em>
      </h2>

      <form method="POST" action="https://formspree.io/f/xnjgedwp" style="display:flex;flex-direction:column;gap:1rem;">
  <input type="hidden" name="_next" value="https://www.danielgierach.com/thank-you" />
  <input type="hidden" name="_subject" value="New appraisal request — danielgierach.com" />

        <!-- First Name + Last Name -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          <div>
            <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
              First Name <span style="color:#c4912a;">*</span>
            </label>
            <input type="text" name="first_name" required placeholder="First Name"
              class="obs-input form-field" autocomplete="given-name"
            />
          </div>
          <div>
            <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
              Last Name <span style="color:#c4912a;">*</span>
            </label>
            <input type="text" name="last_name" required placeholder="Last Name"
              class="obs-input form-field" autocomplete="family-name"
            />
          </div>
        </div>

        <!-- Phone -->
        <div>
          <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
            Phone <span style="color:#c4912a;">*</span>
          </label>
          <input type="tel" name="phone" required placeholder="04xx xxx xxx"
            class="obs-input form-field" autocomplete="tel"
          />
        </div>

        <!-- Property Address -->
        <div>
          <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
            Property Address <span style="color:#c4912a;">*</span>
          </label>
          <input type="text" name="property_address" required placeholder="e.g. 12 River Street, Bulimba 4171"
            class="obs-input form-field" autocomplete="street-address"
          />
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-gold"
          style="width:100%;justify-content:center;padding:1rem;margin-top:0.5rem;"
        >
          Request My Appraisal
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>

      </form>
    </div>
  </div>

</section>

<style>
  @media (max-width: 768px) {
    .appraisal-split {
      grid-template-columns: 1fr !important;
    }
    .appraisal-split > div:first-child {
      min-height: 0;
      padding: 6.5rem 1.75rem 4.5rem !important;
      justify-content: center;
    }
    .appraisal-split > div:last-child {
      padding: 3rem 2rem 4rem !important;
    }
    /* Hide eyebrow, description + contact details on mobile — headline only */
    .appraisal-hero-eyebrow,
    .appraisal-hero-desc,
    .appraisal-hero-contacts { display: none !important; }
  }
  input::placeholder { color: var(--color-text-muted); }


  input:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 1000px var(--color-surface-4) inset;
    -webkit-text-fill-color: #1c1917;
  }
</style>

<style is:global>
  body.appraisal-page #site-header {
    background: rgba(247,245,240,0.96) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid rgba(28,25,23,0.08) !important;
    box-shadow: 0 4px 24px rgba(28,25,23,0.08) !important;
  }
  body.appraisal-page #logo-name {
    color: var(--color-text-primary) !important;
  }
  body.appraisal-page #nav-links .nav-link-mono,
  body.appraisal-page #nav-cta .nav-link-mono {
    color: var(--color-text-secondary) !important;
  }
</style>

<script>
  document.body.classList.add('appraisal-page');

  // Field validation animation
  document.querySelectorAll<HTMLInputElement>('.form-field').forEach(input => {
    // Wrap in relative container and inject tick icon
    const wrap = document.createElement('div');
    wrap.className = 'field-wrap';
    input.parentNode!.insertBefore(wrap, input);
    wrap.appendChild(input);

    const tick = document.createElement('span');
    tick.className = 'field-tick';
    tick.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
    wrap.appendChild(tick);

    input.addEventListener('blur', () => {
      if (input.value.trim() && input.checkValidity()) {
        input.classList.add('valid');
        tick.classList.add('show');
      } else {
        input.classList.remove('valid');
        tick.classList.remove('show');
      }
    });

    input.addEventListener('focus', () => {
      input.classList.remove('valid');
      tick.classList.remove('show');
    });
  });

  const header = document.getElementById('site-header')!;
  const logoName = document.getElementById('logo-name')!;
  const navLinkEls = document.querySelectorAll<HTMLElement>('#nav-links .nav-link-mono, #nav-cta .nav-link-mono');

  header.classList.add('glass-nav');
  logoName.style.color = 'var(--color-text-primary)';
  navLinkEls.forEach(el => el.style.color = '');

  window.addEventListener('scroll', () => {
    setTimeout(() => {
      header.classList.add('glass-nav');
      header.style.boxShadow = '0 4px 24px rgba(28,25,23,0.1)';
      logoName.style.color = 'var(--color-text-primary)';
      navLinkEls.forEach(el => el.style.color = '');
    }, 0);
  });
</script>

</Layout>
