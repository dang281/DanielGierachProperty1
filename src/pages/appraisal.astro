---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Request an Appraisal | Daniel Gierach Property" description="Request a free, no-obligation property appraisal with Daniel Gierach, Brisbane Inner-East Property Sales Specialist.">

<!-- ════════════════════════════════════════════
     FULL-VIEWPORT SPLIT LAYOUT
     Left: dark hero  |  Right: form
════════════════════════════════════════════ -->
<section style="display:grid;grid-template-columns:1fr 1fr;min-height:100dvh;" class="appraisal-split">

  <!-- ── LEFT: dark hero panel ── -->
  <div class="relative flex flex-col justify-center overflow-hidden" style="padding:8rem 4rem 4rem;">

    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=1920&q=85"
        alt="Brisbane inner-east property"
        class="w-full h-full object-cover"
        style="filter:grayscale(8%) brightness(0.55);"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background:linear-gradient(150deg,rgba(10,8,6,0.55) 0%,rgba(10,8,6,0.25) 100%);"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10">
      <span class="eyebrow mb-5 reveal" style="display:block;color:#f5d07a;">Free Property Appraisal</span>

      <h1 class="reveal" data-delay="60"
        style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400;line-height:1.08;letter-spacing:-0.02em;color:#f0ece4;margin-bottom:1.25rem;">
        Know What Your<br/>
        <em style="font-style:italic;color:#f5d07a;">Property Is Worth.</em>
      </h1>

      <p class="reveal" data-delay="120"
        style="font-size:0.88rem;color:rgba(240,236,228,0.6);line-height:1.85;max-width:38ch;margin-bottom:2.5rem;">
        Get a precise, obligation-free appraisal backed by real buyer data and local market knowledge across Brisbane's inner east.
      </p>

      <!-- Contact details -->
      <div class="reveal" data-delay="180" style="display:flex;flex-direction:column;gap:1.25rem;">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.55rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(240,236,228,0.65);margin-bottom:0.3rem;">Phone</p>
          <a href="tel:+61412523821"
            style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;text-decoration:none;transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='#f0ece4'">0412 523 821</a>
          <p style="font-size:0.6rem;color:rgba(240,236,228,0.6);margin-top:0.15rem;letter-spacing:0.06em;">Available 7 days</p>
        </div>

        <div style="width:2.5rem;height:1px;background:rgba(255,255,255,0.12);"></div>

        <div>
          <p style="font-family:var(--font-sans);font-size:0.55rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(240,236,228,0.65);margin-bottom:0.3rem;">Email</p>
          <a href="mailto:daniel.gierach@raywhite.com"
            style="font-family:var(--font-sans);font-size:0.82rem;font-weight:500;color:#f0ece4;text-decoration:none;transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='#f0ece4'">daniel.gierach@raywhite.com</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ── RIGHT: form panel ── -->
  <div class="flex flex-col justify-center overflow-y-auto" style="background:var(--color-surface-1);padding:8rem 4rem 4rem;">

    <div class="reveal" data-delay="80" style="max-width:480px;width:100%;">

      <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Request an Appraisal</p>
      <h2 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:#1c1917;line-height:1.2;margin-bottom:1.75rem;">
        Daniel will be in touch <em style="font-style:italic;">promptly.</em>
      </h2>

      <form name="appraisal" method="POST" style="display:flex;flex-direction:column;gap:1rem;">

        <!-- First Name + Last Name -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          <div>
            <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
              First Name <span style="color:#c4912a;">*</span>
            </label>
            <input type="text" name="first_name" required placeholder="Daniel"
              class="obs-input"
              onfocus="this.style.borderColor='rgba(196,145,42,0.5)'"
              onblur="this.style.borderColor='rgba(28,25,23,0.18)'"
            />
          </div>
          <div>
            <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
              Last Name <span style="color:#c4912a;">*</span>
            </label>
            <input type="text" name="last_name" required placeholder="Gierach"
              class="obs-input"
              onfocus="this.style.borderColor='rgba(196,145,42,0.5)'"
              onblur="this.style.borderColor='rgba(28,25,23,0.18)'"
            />
          </div>
        </div>

        <!-- Phone -->
        <div>
          <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
            Phone <span style="color:#c4912a;">*</span>
          </label>
          <input type="tel" name="phone" required placeholder="04xx xxx xxx"
            class="obs-input"
            onfocus="this.style.borderColor='rgba(196,145,42,0.5)'"
            onblur="this.style.borderColor='rgba(28,25,23,0.18)'"
          />
        </div>

        <!-- Property Address -->
        <div>
          <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
            Property Address <span style="color:#c4912a;">*</span>
          </label>
          <input type="text" name="property_address" required placeholder="37 Example Road, Seven Hills 4170"
            class="obs-input"
            onfocus="this.style.borderColor='rgba(196,145,42,0.5)'"
            onblur="this.style.borderColor='rgba(28,25,23,0.18)'"
          />
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-gold"
          style="width:100%;justify-content:center;padding:1rem;margin-top:0.5rem;"
        >
          Request My Appraisal
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>

      </form>
    </div>
  </div>

</section>

<style>
  @media (max-width: 768px) {
    .appraisal-split {
      grid-template-columns: 1fr !important;
    }
    .appraisal-split > div:first-child {
      min-height: 50vh;
      padding: 7rem 2rem 3rem !important;
    }
    .appraisal-split > div:last-child {
      padding: 3rem 2rem 4rem !important;
    }
  }
  input::placeholder { color: var(--color-text-muted); }
  input:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 1000px var(--color-surface-4) inset;
    -webkit-text-fill-color: #1c1917;
  }
</style>

<style is:global>
  body.appraisal-page #site-header {
    background: rgba(247,245,240,0.96) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid rgba(28,25,23,0.08) !important;
    box-shadow: 0 4px 24px rgba(28,25,23,0.08) !important;
  }
  body.appraisal-page #logo-name {
    color: var(--color-text-primary) !important;
  }
  body.appraisal-page #nav-links .nav-link-mono,
  body.appraisal-page #nav-cta .nav-link-mono {
    color: var(--color-text-secondary) !important;
  }
</style>

<script>
  document.body.classList.add('appraisal-page');

  const header = document.getElementById('site-header')!;
  const logoName = document.getElementById('logo-name')!;
  const navLinkEls = document.querySelectorAll<HTMLElement>('#nav-links .nav-link-mono, #nav-cta .nav-link-mono');

  header.classList.add('glass-nav');
  logoName.style.color = 'var(--color-text-primary)';
  navLinkEls.forEach(el => el.style.color = '');

  window.addEventListener('scroll', () => {
    setTimeout(() => {
      header.classList.add('glass-nav');
      header.style.boxShadow = '0 4px 24px rgba(28,25,23,0.1)';
      logoName.style.color = 'var(--color-text-primary)';
      navLinkEls.forEach(el => el.style.color = '');
    }, 0);
  });
</script>

</Layout>
