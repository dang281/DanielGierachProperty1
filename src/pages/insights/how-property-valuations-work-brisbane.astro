const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between a bank valuation and an agent appraisal in Brisbane?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A bank valuation is a formal, paid assessment by a licensed valuer, commissioned by a lender to confirm how much they will lend against the property. It applies a conservative methodology and produces a legally recognised document. An agent appraisal is a free estimate of likely sale price in current market conditions, provided by a real estate agent using comparable sales. The two answer different questions and are used for different purposes. Bank valuations are typically 5 to 15 percent below what a well-run campaign achieves, because the valuer is estimating a standard market transaction, not the result of skilled negotiation and competitive bidding."
      }
    },
    {
      "@type": "Question",
      "name": "What factors affect my Brisbane property valuation most?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In Brisbane's inner suburbs, the five factors that consistently move the number are: land size and configuration, position within the street and micro-pocket (including flood status and proximity to parkland), renovation quality relative to comparable properties in the area, school catchment access, and aspect. Of these, land size and position are structural and cannot be changed. Renovation quality, presentation, and addressing maintenance issues before listing are within the seller's control and directly affect the comparable sales adjustments a valuer makes."
      }
    },
    {
      "@type": "Question",
      "name": "How can I support a higher valuation when selling my Brisbane home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most reliable things a seller can do are: address the maintenance issues that valuers use to discount (roof condition, stumps, retaining walls), ensure the renovation finish is competitive relative to recent comparables in the area, and provide your agent with recent comparable sales that support your price range. Cosmetic presentation matters for buyer competition but formal valuers weight condition and comparable evidence over styling. Your agent should be able to tell you specifically what the comparable sales say about preparation investment returns in your suburb."
      }
    },
    {
      "@type": "Question",
      "name": "How is the comparable sales method used to value Brisbane properties?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The comparable sales method identifies three to six recent sales of similar properties nearby, then adjusts each sale up or down for the differences between that sale and your property. Adjustments are made for land size, renovation level, aspect, flood status, school catchment, and recency. In Brisbane's inner east, where heritage overlays, school catchment boundaries, and flood mapping affect value at the street level, identifying genuinely comparable sales requires local knowledge that goes beyond matching bedroom and bathroom counts."
      }
    }
  ]
};
