const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a utility easement on a Brisbane property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A utility easement is a registered right held by a service authority such as Energex, Urban Utilities, Telstra or NBN Co to keep and access infrastructure on part of a private title. The most common forms in Brisbane are sewer main easements and stormwater drainage easements held by Brisbane City Council or Urban Utilities, overhead and underground high-voltage power easements held by Energex, and cable easements held by telecommunications carriers. The easement is registered on the title and runs with the land regardless of who owns it."
      }
    },
    {
      "@type": "Question",
      "name": "Do I have to disclose utility easements when selling a Brisbane property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Under the Property Law Act 2023, the Mandatory Seller Disclosure Statement and the contract must accurately reflect all title encumbrances, including utility easements. Your solicitor relies on a current title search to populate the contract. An undisclosed easement found by the buyer's solicitor at title search is grounds for the buyer to terminate, and depending on the size and impact of the easement may also be misleading conduct under Australian Consumer Law if it was concealed in marketing material."
      }
    },
    {
      "@type": "Question",
      "name": "Can I build over a sewer or stormwater easement on my Brisbane property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Generally no. Urban Utilities prohibits permanent structures over its sewer main easements without a build-over approval, which is rarely granted for habitable structures and only granted for non-habitable structures such as decks, carports or sheds under strict conditions. Brisbane City Council will not approve building work over a stormwater drainage easement. Light landscaping, lawn and removable structures are usually permitted. Existing structures built over an easement before the easement was registered may be tolerated but cannot be extended."
      }
    },
    {
      "@type": "Question",
      "name": "How much do utility easements affect a Brisbane property's sale price?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends entirely on the location and severity. A narrow sewer easement running along a side boundary that has no impact on the buildable area or yard usability typically has zero measurable price impact. A high-voltage Energex easement bisecting the front yard of a family home, or a large Urban Utilities trunk main easement consuming a third of the buildable site, can reduce buyer competition and pricing by ten to twenty percent against an otherwise comparable property. Inner-east Brisbane buyers are sophisticated and willing to pay fairly for a property with an easement they can live with, provided the disclosure is upfront and the impact is genuinely understood."
      }
    },
    {
      "@type": "Question",
      "name": "What documents should a Brisbane seller gather before listing a property with a utility easement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A current title search showing all registered easements, the registered easement plans showing the precise location and width of each easement on the lot, any build-over approvals or letters of consent from Energex, Urban Utilities or the carrier authority, the Dial Before You Dig response for the property, a copy of any survey or identification report that overlays easements on the site plan, and details of any structures, paving or landscaping that sit over an easement so the solicitor can advise on disclosure language. Engaging a solicitor at the listing stage rather than at the contract stage prevents most easement surprises."
      }
    }
  ]
};
