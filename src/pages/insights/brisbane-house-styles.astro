            </svg>
            <p style="font-family:var(--font-sans);font-size:0.68rem;text-align:center;color:#5a3a20;margin-top:0.6rem;font-weight:600;">1. Gable-roofed cottage</p>
          </div>

          <!-- Style 2: Pyramid-roofed house -->
          <div>
            <svg viewBox="0 0 200 165" style="width:100%;height:auto;display:block;" xmlns="http://www.w3.org/2000/svg">
              <line x1="5" y1="155" x2="195" y2="155" stroke="#3d2b1a" stroke-width="1.5" stroke-linecap="round"/>
              <!-- Stumps -->
              <line x1="38" y1="130" x2="38" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="68" y1="130" x2="68" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="100" y1="130" x2="100" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="132" y1="130" x2="132" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="162" y1="130" x2="162" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Floor -->
              <line x1="28" y1="130" x2="172" y2="130" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Main block (smaller, central) -->
              <rect x="62" y="85" width="76" height="45" fill="#f0ebe3" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Pyramid roof -->
