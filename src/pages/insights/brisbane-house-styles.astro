              <line x1="138" y1="85" x2="148" y2="92" stroke="#3d2b1a" stroke-width="1"/>
              <!-- Wrap-around verandah roof (lower, all sides visible from front) -->
              <polygon points="22,108 62,95 138,95 178,108" fill="#ddd0bf" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Verandah posts -->
              <line x1="32" y1="108" x2="32" y2="130" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="100" y1="108" x2="100" y2="130" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="168" y1="108" x2="168" y2="130" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Railing -->
              <line x1="32" y1="121" x2="168" y2="121" stroke="#3d2b1a" stroke-width="1"/>
              <!-- Windows -->
              <rect x="72" y="93" width="18" height="14" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="81" y1="93" x2="81" y2="107" stroke="#3d2b1a" stroke-width="0.75"/>
              <rect x="110" y="93" width="18" height="14" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="119" y1="93" x2="119" y2="107" stroke="#3d2b1a" stroke-width="0.75"/>
            </svg>
            <p style="font-family:var(--font-sans);font-size:0.68rem;text-align:center;color:#5a3a20;margin-top:0.6rem;font-weight:600;">2. Pyramid-roofed house</p>
          </div>

          <!-- Style 3: Short-ridge with encircling verandahs (two-storey) -->
          <div>
            <svg viewBox="0 0 200 165" style="width:100%;height:auto;display:block;" xmlns="http://www.w3.org/2000/svg">
              <line x1="5" y1="155" x2="195" y2="155" stroke="#3d2b1a" stroke-width="1.5" stroke-linecap="round"/>
              <!-- Stumps (short, this is two-storey so lower floor is main level) -->
              <line x1="45" y1="140" x2="45" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="100" y1="140" x2="100" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="155" y1="140" x2="155" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Two-storey main block -->
              <rect x="42" y="52" width="116" height="88" fill="#f0ebe3" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Mid-floor line -->
              <line x1="42" y1="97" x2="158" y2="97" stroke="#3d2b1a" stroke-width="1"/>
              <!-- Hip roof with short ridge -->
              <line x1="78" y1="30" x2="122" y2="30" stroke="#3d2b1a" stroke-width="2.5"/>
              <polygon points="32,52 78,30 122,30 168,52" fill="#ddd0bf" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Upper verandah (upper floor) -->
              <polygon points="22,72 42,65 158,65 178,72" fill="#ddd0bf" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="32" y1="72" x2="32" y2="97" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="100" y1="72" x2="100" y2="97" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="168" y1="72" x2="168" y2="97" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="32" y1="86" x2="168" y2="86" stroke="#3d2b1a" stroke-width="1"/>
              <!-- Lower verandah (ground floor) -->
              <polygon points="18,113 42,107 158,107 182,113" fill="#ddd0bf" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="28" y1="113" x2="28" y2="140" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="100" y1="113" x2="100" y2="140" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="172" y1="113" x2="172" y2="140" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="28" y1="128" x2="172" y2="128" stroke="#3d2b1a" stroke-width="1"/>
              <!-- Upper floor windows -->
              <rect x="55" y="57" width="18" height="14" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <rect x="127" y="57" width="18" height="14" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <!-- Lower floor windows -->
              <rect x="55" y="102" width="18" height="14" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <rect x="127" y="102" width="18" height="14" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
            </svg>
            <p style="font-family:var(--font-sans);font-size:0.68rem;text-align:center;color:#5a3a20;margin-top:0.6rem;font-weight:600;">3. Short-ridge with encircling verandahs</p>
          </div>

        </div>
      </div>

      <!-- ===================== FEDERATION ===================== -->
      <h2 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:var(--color-text-primary);">Federation period — 1890s to 1910s</h2>

      <p>The Federation era produced some of Brisbane's most admired residential architecture. Roof forms became more elaborate, and the defining characteristic is the bungalow roof: a surface that sweeps continuously from the ridge down over the verandah without any step or break between the two. Ornamental detail increased significantly, with decorative bargeboards, fretwork screens, leadlights above doors and windows, and timber or cast iron balustrading on verandahs. Asymmetry in the facade became fashionable, with projecting front rooms and bay windows breaking the flat plane of the earlier Colonial homes. Houses from this era in Bulimba, Hawthorne, and Balmoral consistently attract premium prices. Heritage overlays apply to many of the best examples.</p>

      <div style="background:#f4efe8;border:1px solid rgba(74,44,20,0.12);padding:2rem 1.5rem;margin:0.5rem 0;">
        <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#7a5030;margin-bottom:1.5rem;">Federation Period · 1890s–1910s</p>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;">

          <!-- Style 4: Bungalow-roofed house -->
          <div>
            <svg viewBox="0 0 200 165" style="width:100%;height:auto;display:block;" xmlns="http://www.w3.org/2000/svg">
              <line x1="5" y1="155" x2="195" y2="155" stroke="#3d2b1a" stroke-width="1.5" stroke-linecap="round"/>
              <!-- Stumps -->
              <line x1="40" y1="128" x2="40" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="80" y1="128" x2="80" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="120" y1="128" x2="120" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="160" y1="128" x2="160" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Floor -->
              <line x1="28" y1="128" x2="172" y2="128" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Walls -->
              <rect x="40" y="82" width="120" height="46" fill="#f0ebe3" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- BUNGALOW ROOF: key feature - one continuous surface from ridge to verandah edge, no step -->
              <polygon points="18,128 28,90 100,40 172,90 182,128" fill="#ddd0bf" stroke="#3d2b1a" stroke-width="1.5" stroke-linejoin="round"/>
              <!-- Line showing where main wall meets roof (inside the roof form) -->
              <line x1="28" y1="90" x2="172" y2="90" stroke="#3d2b1a" stroke-width="0.75" stroke-dasharray="3,2"/>
              <!-- Verandah posts (inside the roof form) -->
              <line x1="33" y1="105" x2="33" y2="128" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="167" y1="105" x2="167" y2="128" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Balustrade -->
              <line x1="33" y1="118" x2="167" y2="118" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="48" y1="118" x2="48" y2="128" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="63" y1="118" x2="63" y2="128" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="78" y1="118" x2="78" y2="128" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="122" y1="118" x2="122" y2="128" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="137" y1="118" x2="137" y2="128" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="152" y1="118" x2="152" y2="128" stroke="#3d2b1a" stroke-width="0.75"/>
              <!-- Windows -->
              <rect x="52" y="88" width="22" height="17" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="63" y1="88" x2="63" y2="105" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="52" y1="96" x2="74" y2="96" stroke="#3d2b1a" stroke-width="0.75"/>
              <rect x="126" y="88" width="22" height="17" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="137" y1="88" x2="137" y2="105" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="126" y1="96" x2="148" y2="96" stroke="#3d2b1a" stroke-width="0.75"/>
              <!-- Door with fanlight -->
              <rect x="89" y="92" width="22" height="36" fill="#e4ddd4" stroke="#3d2b1a" stroke-width="1"/>
              <path d="M89,98 Q100,91 111,98" fill="#cde5ef" stroke="#3d2b1a" stroke-width="0.75"/>
              <!-- Fretwork hint on verandah fascia -->
              <line x1="33" y1="97" x2="167" y2="97" stroke="#3d2b1a" stroke-width="0.5" stroke-dasharray="2,2"/>
            </svg>
            <p style="font-family:var(--font-sans);font-size:0.68rem;text-align:center;color:#5a3a20;margin-top:0.6rem;font-weight:600;">4. Bungalow-roofed house</p>
          </div>

          <!-- Style 5: Asymmetrical bungalow-roofed -->
          <div>
            <svg viewBox="0 0 200 165" style="width:100%;height:auto;display:block;" xmlns="http://www.w3.org/2000/svg">
              <line x1="5" y1="155" x2="195" y2="155" stroke="#3d2b1a" stroke-width="1.5" stroke-linecap="round"/>
              <!-- Stumps -->
              <line x1="32" y1="128" x2="32" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="65" y1="128" x2="65" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="105" y1="128" x2="105" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="155" y1="128" x2="155" y2="155" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Floor -->
              <line x1="22" y1="128" x2="172" y2="128" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Main block (right, set back slightly) -->
              <rect x="78" y="80" width="88" height="48" fill="#f0ebe3" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Projecting front room (left, forward) - key asymmetric feature -->
              <rect x="28" y="85" width="55" height="43" fill="#f0ebe3" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Main bungalow roof (continuous, covers main block) -->
              <polygon points="68,128 78,88 165,50 172,88 178,128" fill="#ddd0bf" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Projecting room roof (separate gable or hip) -->
              <polygon points="18,128 22,100 28,85 83,85 88,100 92,128" fill="#ddd0bf" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Porch between the two sections -->
              <line x1="83" y1="100" x2="83" y2="128" stroke="#3d2b1a" stroke-width="1.5"/>
              <line x1="68" y1="100" x2="68" y2="128" stroke="#3d2b1a" stroke-width="1.5"/>
              <!-- Railing on porch section -->
              <line x1="22" y1="115" x2="68" y2="115" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="83" y1="115" x2="92" y2="115" stroke="#3d2b1a" stroke-width="1"/>
              <!-- Windows on projecting room (bay) -->
              <rect x="33" y="91" width="16" height="15" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="41" y1="91" x2="41" y2="106" stroke="#3d2b1a" stroke-width="0.75"/>
              <rect x="52" y="91" width="16" height="15" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <!-- Windows on main block -->
              <rect x="95" y="86" width="20" height="16" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="105" y1="86" x2="105" y2="102" stroke="#3d2b1a" stroke-width="0.75"/>
              <rect x="133" y="86" width="20" height="16" fill="#cde5ef" stroke="#3d2b1a" stroke-width="1"/>
              <line x1="143" y1="86" x2="143" y2="102" stroke="#3d2b1a" stroke-width="0.75"/>
            </svg>
            <p style="font-family:var(--font-sans);font-size:0.68rem;text-align:center;color:#5a3a20;margin-top:0.6rem;font-weight:600;">5. Asymmetrical bungalow-roofed</p>
          </div>

          <!-- Style 6: Queen Anne style house -->
