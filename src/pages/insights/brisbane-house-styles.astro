              <line x1="63" y1="115" x2="63" y2="127" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="76" y1="115" x2="76" y2="127" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="125" y1="115" x2="125" y2="127" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="138" y1="115" x2="138" y2="127" stroke="#3d2b1a" stroke-width="0.75"/>
              <line x1="151" y1="115" x2="151" y2="127" stroke="#3d2b1a" stroke-width="0.75"/>
              <!-- Windows -->
