<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an off-market property in Brisbane?",
      "acceptedAnswer": { "@type": "Answer", "text": "An off-market property is one that is sold without being publicly listed on realestate.com.au or Domain. The agent presents the property directly to a small group of registered buyers. The transaction completes before any sign goes up or portal listing is created." }
    },
    {
      "@type": "Question",
      "name": "What is a pre-market property?",
      "acceptedAnswer": { "@type": "Answer", "text": "A pre-market property is one that has been prepared for sale but not yet publicly listed. The agent shares it with registered buyers in the days or weeks before the portal campaign launches. Buyers who are registered get first access and can make an offer before the wider market sees it." }
    },
    {
      "@type": "Question",
      "name": "How do I get access to off-market properties in Brisbane's inner east?",
      "acceptedAnswer": { "@type": "Answer", "text": "Register your buying criteria directly with a specialist agent who works that area. The agent matches your brief against properties as they become available and contacts you before anything is publicly listed. Daniel Gierach runs a buyer registration service specifically for Brisbane's inner east suburbs." }
