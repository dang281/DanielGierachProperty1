---
import Layout from '../../layouts/Layout.astro';

const clusterSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Contracts, Settlement and Legal Obligations",
  "description": "What Queensland property contracts contain, seller disclosure requirements, the settlement process, and when to engage a solicitor.",
  "url": "https://danielgierach.com/insights/contracts-and-settlement/",
  "author": { "@type": "Person", "name": "Daniel Gierach", "url": "https://danielgierach.com/about" }
};

const articles = [
  {
    slug: 'seller-disclosure-obligations-queensland',
    title: 'Seller Disclosure Obligations When Selling a House in Queensland',
    summary: 'What you must legally disclose when selling a house in Queensland under the Property Law Act 2023, including the Mandatory Seller Disclosure Statement, pool safety certificates, and smoke alarm compliance.',
  },
  {
    slug: 'understanding-the-contract',
    title: 'Understanding the REIQ Contract of Sale',
    summary: "The standard Queensland contract is straightforward once you know what to look for. Here's what every buyer and seller should understand before signing.",
  },
  {
    slug: 'fixtures-fittings-inclusions-property-sale-qld',
    title: 'Fixtures, Fittings and Inclusions When Selling a House in Queensland',
    summary: "What stays and what goes when you sell in Queensland? Understanding the fixture vs chattel distinction avoids disputes and contract complications at settlement.",
  },
  {
    slug: 'unconditional-offer',
    title: 'What Is an Unconditional Offer?',
    summary: "An unconditional offer is one of the most powerful tools in property and one of the most misunderstood. Here's what it means and when to use it.",
  },
  {
    slug: 'subject-to-finance-clause-queensland-sellers',
    title: 'Subject to Finance: What Sellers Need to Know in Queensland',
    summary: 'Most private treaty offers include a finance condition. Here is how it works, what happens if finance fails, and how to protect yourself during the conditional period.',
  },
  {
    slug: 'cooling-off-period-property-sale-queensland',
    title: 'Cooling Off Period When Selling in Queensland',
    summary: "How Queensland's 5-business-day cooling off period works for vendors, when it applies, and the buyer penalty for exercising it.",
  },
  {
    slug: 'pre-settlement-inspection-seller-guide-qld',
    title: "Pre-Settlement Inspection: A Seller's Guide for Queensland 2026",
    summary: 'What Queensland sellers need to know about the pre-settlement inspection, what buyers are checking, how to prepare, and how disputes are handled before settlement day.',
  },
  {
    slug: 'what-happens-at-settlement',
    title: 'What Happens at Settlement?',
    summary: "Settlement day can feel like a black box. Here's exactly what happens, who does what, and how to make sure nothing goes wrong at the last minute.",
  },
  {
    slug: 'what-happens-on-settlement-day-queensland',
    title: 'What Happens on Settlement Day When Selling in Queensland',
    summary: "Settlement day finalises your sale. Here's what happens in the lead-up, what your role is on the day, and what to do if something goes wrong.",
  },
  {
    slug: 'solicitor-vs-conveyancer-qld',
    title: 'Solicitor vs Conveyancer in Queensland: What Is the Difference?',
    summary: 'Both can handle your property settlement in Queensland. Here is what each does, what they cost, and when you genuinely need the full weight of a property solicitor.',
  },
  {
    slug: 'easements-property-brisbane-qld',
    title: 'Easements on Property in Brisbane: What Sellers Need to Know 2026',
    summary: 'A practical guide to easements on Brisbane properties in 2026, covering types of easements, disclosure obligations, how buyers react, and what sellers need to do before listing.',
  },
  {
    slug: 'conveyancing-cooling-off-period-exceptions-queensland-2026',
    title: 'Cooling-Off Period Exceptions in Queensland Property Contracts',
    summary: 'Cooling-off does not apply to every Queensland property contract. Here are the exceptions sellers should understand to avoid unexpected complications after an offer is accepted.',
  },
  {
    slug: 'settlement-statement-review-pre-settlement-seller-checklist',
    title: 'Settlement Statement Review: Pre-Settlement Seller Checklist',
    summary: 'The settlement statement is the document that decides exactly what hits your bank account. Here is how to read it, what to check, and what to do if something looks wrong.',
  },
  {
    slug: 'bushfire-risk-disclosure-selling-brisbane-property',
    title: 'Bushfire Risk Disclosure for Brisbane Property Sellers',
    summary: 'Bushfire mapping and disclosure obligations for Brisbane property sellers. Which inner east areas are affected, what sellers must disclose, and what to do before listing.',
  },
  {
    slug: 'easement-removal-covenant-discharge-brisbane-inner-east-selling',
    title: 'Easements and Covenants: Removing Them Before Selling',
    summary: 'Easements and restrictive covenants registered on your title can reduce your sale price. Here is how to assess whether removal is possible and what the process involves before listing.',
  },
  {
    slug: 'selling-during-divorce-separation-queensland-process',
    title: 'Selling the Family Home During Divorce or Separation in Queensland',
    summary: 'A practical guide to selling the family home during a separation or divorce in Queensland. The process, who has authority, and how to manage the campaign when co-owners have conflicting interests.',
  },
  {
    slug: 'selling-property-during-separation-divorce-queensland',
    title: 'Selling a Property During Separation or Divorce in Queensland',
    summary: 'A practical guide to selling property during or after a separation or divorce in Queensland, the legal process, who needs to consent, and how to manage negotiations.',
  },
  {
    slug: 'property-settlement-process-queensland-sellers',
    title: 'Property Settlement in Queensland: What Sellers Need to Know',
    summary: 'A step-by-step guide to the Queensland property settlement process: from accepted offer and finance clause through building and pest, going unconditional, and settlement day. Includes typical timeframes and what can go wrong.',
  },
  {
    slug: 'buyer-requested-cooling-off-period-extensions-brisbane',
    title: 'Buyer-Requested Cooling-Off Period Extensions in Brisbane',
    summary: 'A buyer asking to extend the standard 5-business-day cooling-off period is a request many Brisbane sellers face. Here is what it usually means, when to agree, when to push back, and how to protect your position.',
  },
  {
    slug: 'subject-to-sale-offers-brisbane-seller-guide',
    title: 'Handling Subject to Sale Offers as a Brisbane Seller',
    summary: 'Subject to sale offers tie your settlement to a buyer who has not yet sold. Here is how to evaluate them, protect your position with the right special conditions, and decide when to say no.',
  },
  {
    slug: 'property-sale-scams-fraud-brisbane-sellers-2026',
    title: 'Property Sale Scams and Fraud Brisbane Sellers Should Watch For in 2026',
    summary: 'Payment redirection at settlement, fake buyers, identity fraud and overquoting at appraisal are the scam patterns hitting Brisbane vendors in 2026. Here are the verification habits that defeat them.',
  },
  {
    slug: 'settlement-day-handover-keys-alarm-codes-manuals-brisbane',
    title: 'Brisbane Settlement Day Handover 2026: Keys, Alarm Codes, Manuals and What the Buyer Needs',
    summary: 'Settlement is the legal handover, but the physical handover is its own checklist. What Brisbane sellers must give the buyer, how the keys actually change hands, and the documentation that prevents a post-settlement phone call.',
  },
  {
    slug: 'brisbane-settlement-buyer-interstate-overseas-remote-handover-logistics',
    title: 'Brisbane Property Settlement When the Buyer Is Interstate or Overseas: Remote Handover Logistics',
    summary: 'What changes for Queensland sellers when the buyer cannot attend settlement in person. The key handover, the pre-settlement inspection, time zones, and the planning that turns a remote settlement into a clean one.',
  },
  {
    slug: 'selling-brisbane-property-to-smsf-buyer',
    title: 'Selling Your Brisbane Property to a SMSF Buyer: What Sellers Need to Know',
    summary: 'A Self-Managed Super Fund buyer brings unique contract and settlement quirks: bare trusts, LRBA finance timing, the trustee company on the contract, and what red flags can derail the deal.',
  },
  {
    slug: 'buyer-requests-fix-complete-work-before-settlement-brisbane-seller',
    title: "Buyer Requests to Fix or Complete Work Before Settlement: A Brisbane Seller's Guide",
    summary: 'Almost every Brisbane sale produces a buyer request between contract and settlement asking the seller to fix, finish or replace something. The contract baseline, the five categories of request, the four settlement-stage remedies, and when to push back.',
  },
  {
    slug: 'chain-settlements-brisbane-buyer-selling-another-property-same-day',
    title: 'Chain Settlements in Brisbane: When Your Buyer Is Selling Another Property on the Same Day',
    summary: "Your buyer needs the proceeds of their own sale to fund yours. How chain settlements work in Brisbane's inner east, the difference between a low-risk and high-risk chain, the four special conditions that protect a seller, and what to do when the chain breaks.",
  },
  {
    slug: 'lapsed-expired-building-approvals-brisbane-property-sellers',
    title: 'Lapsed or Expired Building Approvals on a Brisbane Property: What Sellers Should Disclose and How to Fix It',
    summary: 'Approval was issued. Work was started. The file was never closed. How lapsed and expired building approvals show up in Brisbane council searches, your Form 2 disclosure duty under the Property Law Act 2023, and the three paths to fixing the record before settlement.',
  },
  {
    slug: 'handling-buyer-remorse-after-contract-signing-brisbane',
    title: 'Handling Buyer Remorse After Contract Signing in a Brisbane Property Sale',
    summary: 'Almost every Brisbane buyer goes through a wobble in the first week after signing. How buyer remorse shows up under the Queensland contract, what your real exposure is during the five-business-day cooling-off window, and the practical steps that keep an anxious buyer at the settlement table.',
  },
];
---
<Layout title="Contracts, Settlement and Legal Obligations | Daniel Gierach Property" description="What Queensland property contracts contain, seller disclosure requirements, the settlement process, and when to engage a solicitor." schema={clusterSchema}>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <!-- Hero -->
  <div style="background:#0a0806;padding:8rem 0 3.5rem;">
    <div class="max-w-[1100px] mx-auto px-8">
      <a href="/insights" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(240,236,228,0.6);text-decoration:none;margin-bottom:2rem;transition:color 0.2s;"
        onmouseover="this.style.color='#f5d07a'" onmouseout="this.style.color='rgba(240,236,228,0.6)'">
        &larr; All Articles
      </a>
      <span style="display:block;font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#f5d07a;margin-bottom:1rem;">Topic Guide &middot; 27 Articles</span>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,5vw,3.25rem);font-weight:400;color:#f0ece4;line-height:1.12;letter-spacing:-0.02em;margin-bottom:1.5rem;">
        Contracts, Settlement and Legal Obligations
      </h1>
      <p style="font-size:1rem;color:rgba(240,236,228,0.6);line-height:1.8;max-width:58ch;">
        The contract and settlement phase is where Queensland's specific rules matter most. This guide covers seller disclosure obligations, what the REIQ contract actually says, how finance clauses and unconditional offers work, and exactly what happens on settlement day.
      </p>
    </div>
  </div>

  <!-- Article Grid -->
  <div style="padding:3.5rem 0 5rem;background:var(--color-base);">
    <div class="max-w-[1100px] mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {articles.map(a => (
          <a href={`/insights/${a.slug}`}
            style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:2rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.25s,border-color 0.25s,transform 0.3s,box-shadow 0.3s;position:relative;overflow:hidden;box-shadow:0 1px 4px rgba(28,25,23,0.05);"
            onmouseover="this.style.background='#f2efe9';this.style.borderColor='rgba(196,145,42,0.3)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(28,25,23,0.09)'"
            onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.transform='translateY(0)';this.style.boxShadow='0 1px 4px rgba(28,25,23,0.05)'"
          >
            <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#f5d07a;"></div>
            <div style="display:flex;align-items:center;padding-top:0.25rem;">
              <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:#f5d07a;display:inline-flex;align-items:center;gap:0.35rem;">
                <span style="width:5px;height:5px;border-radius:50%;background:#f5d07a;flex-shrink:0;"></span>
                Sellers
              </span>
            </div>
            <div style="flex:1;">
              <h2 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.75rem;">{a.title}</h2>
              <p style="font-size:0.82rem;color:#78716c;line-height:1.75;">{a.summary}</p>
            </div>
            <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;margin-top:auto;">Read Article &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div style="padding:4rem 0;background:#f7f5f0;border-top:1px solid rgba(28,25,23,0.08);">
    <div class="max-w-[1100px] mx-auto px-8" style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:1.25rem;">
      <p style="font-family:var(--font-serif);font-size:1.25rem;font-style:italic;color:#1c1917;">Questions about the contract process?</p>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;max-width:44ch;">Daniel walks every vendor through the contract and settlement process before listing. No surprises at exchange, no confusion on settlement day.</p>
      <a href="/get-an-appraisal" style="display:inline-flex;align-items:center;gap:0.6rem;padding:0.85rem 1.75rem;background:#c4912a;color:#fff;font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;"
        onmouseover="this.style.background='#a87824'" onmouseout="this.style.background='#c4912a'">
        Get a Free Appraisal
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

</article>

</Layout>
