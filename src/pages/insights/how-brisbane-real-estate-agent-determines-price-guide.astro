{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does a Brisbane real estate agent determine the price guide?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Brisbane real estate agent determines the price guide by analysing recent comparable sales: properties of the same type, similar land size, similar condition, and within the same suburb sold in the last three to six months. The agent adjusts for differences in bedroom and bathroom count, land area, car accommodation, renovation status, and position. The guide also reflects the intended method of sale, since auction campaigns typically advertise a guide below the expected sale price to attract buyer interest."
      }
    },
    {
      "@type": "Question",
      "name": "Is the price guide the same as the property's value?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. The price guide is the figure or range the agent publishes online to attract buyer interest. It is not a formal valuation, and for auction campaigns it is typically set below the seller's reserve. A formal bank valuation uses a different methodology and is produced by a licensed valuer, not the listing agent."
      }
    },
    {
      "@type": "Question",
      "name": "What should sellers ask their agent about the price guide?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sellers should ask their agent: which three comparable sales support this price guide, what adjustments have been made for the differences between those properties and mine, and what is the highest price you genuinely believe this property can achieve and why. An agent who cannot answer these questions clearly has not done the work."
      }
    }
  ]
