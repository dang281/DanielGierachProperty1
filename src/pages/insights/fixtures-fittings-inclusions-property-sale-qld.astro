---
import Layout from '../../layouts/Layout.astro';
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is included when you sell a house in Queensland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In Queensland, fixtures (items permanently attached to the property) are generally included in the sale unless explicitly excluded in the contract. This typically includes fitted floor coverings, built-in wardrobes, fixed light fittings, ceiling fans, window blinds and curtains on tracks, dishwashers, pool equipment, and TV antennas. Freestanding items (chattels) are not included unless listed. Sellers should review and specify any exclusions before signing."
      }
    },
    {
      "@type": "Question",
      "name": "Can I take light fittings when selling my house in Queensland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Light fittings are technically fixtures and are generally included in the sale. If you want to take a specific light fitting, such as a chandelier or a designer pendant, you must list it as an exclusion in the contract before it is signed. Removing a light fitting after signing without listing it as an exclusion is a breach of the contract and can trigger a dispute at the pre-settlement inspection."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a fixture and a chattel in a Queensland property sale?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A fixture is an item that is permanently attached to the property and cannot be removed without causing damage. Fixtures stay with the property on sale unless explicitly excluded. A chattel is a freestanding, portable item that belongs to the owner and is not included in the sale unless specifically listed as an inclusion. Examples of fixtures: built-in wardrobes, light fittings, dishwashers (plumbed in), pool equipment. Examples of chattels: fridge, washing machine, freestanding furniture, potted plants."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I remove something from the house before settlement in Queensland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Buyers have the right to conduct a pre-settlement inspection to confirm the property is in the same condition as at contract and all inclusions are present. If something that was included in the sale has been removed, the buyer can request that it be reinstated or seek a reduction in the purchase price as compensation. In serious cases, this can delay settlement. Removing included items without the buyer's agreement is a breach of the contract."
      }
    },
    {
      "@type": "Question",
      "name": "Can I take the dishwasher when I sell my house in Queensland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A plumbed-in dishwasher is generally considered a fixture and is included in the sale unless excluded in the contract. If you want to take it, list it as an exclusion before signing. Note that if you exclude the dishwasher, you cannot simply leave the cavity empty. You will either need to take it and cap the plumbing, or provide a replacement. Discuss this with your agent before the contract is prepared."
      }
    }
  ]
};
---
<Layout title="Fixtures, Fittings and Inclusions When Selling a House in Queensland | Daniel Gierach Property" description="What stays and what goes when you sell your Queensland home? Understanding the fixture and chattel distinction prevents last-minute disputes at settlement." schema={faqSchema}>

<article style="background:var(--color-surface-0);min-height:100vh;">

