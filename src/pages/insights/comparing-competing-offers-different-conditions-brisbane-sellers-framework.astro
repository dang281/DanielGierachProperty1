const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I compare two Brisbane property offers when one is higher but conditional and the other is lower but unconditional?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Convert each offer to a risk-adjusted figure before you compare. A 14-day finance clause from a buyer who already has pre-approval typically carries a 3 to 6 percent fall-over risk in the Brisbane inner east; a building and pest clause adds another 5 to 10 percent depending on the property's age and condition. Multiply each offer's headline price by the probability of settlement, then add the cost of running another 4 to 6 week campaign if the deal falls over (agent costs, marketing, holding costs and the price drift of relisting a property buyers know was previously contracted). The unconditional offer often wins on a risk-adjusted basis once the gap is under 2.5 percent of price."
      }
    },
    {
      "@type": "Question",
      "name": "What is the standard framework for evaluating competing offers in a Brisbane sale?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The framework is a five-column comparison: headline price, deposit (size and timing), conditions (finance, building and pest, due diligence, sunset, related sale), settlement date, and buyer profile (pre-approval status, motivation, prior failed deals). Each column converts to either a dollar figure or a probability adjustment. The buyer profile column is the one most sellers underweight and most experienced agents weight heavily, because it is the best predictor of whether the contract actually proceeds to settlement."
      }
    },
    {
      "@type": "Question",
      "name": "Can I accept the highest offer and use the others as backup in Queensland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Only one contract can be live at a time on a Queensland property. You cannot sign with Buyer A and simultaneously sign with Buyer B as a formal backup. What you can do is keep the unsuccessful buyers warm through your agent, ask whether they would consider a backup position with a clear understanding that it only activates if the primary contract terminates, and have their solicitor ready to move quickly if you need to pivot. Backup offers are useful in practice even though the formal contract layer is exclusive."
      }
    }
  ]
};
