---
import Layout from '../../layouts/Layout.astro';
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does it mean when a property passes in at auction in Brisbane?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A property passes in when bidding at auction does not reach the reserve price. The auctioneer announces the property is passed in, and the sale does not proceed. The property is not sold, and the vendor retains it. A pass-in is not the end of the campaign. Most properties that pass in at auction in Brisbane's inner east still sell, typically through post-auction negotiation with the highest registered bidder or by re-listing as private treaty."
      }
    },
    {
      "@type": "Question",
      "name": "What happens after a property passes in at auction in Brisbane?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "After a pass-in, the auctioneer typically offers the highest registered bidder the first right to negotiate with the vendor. This is not a legal right under the Property Occupations Act 2014 but is standard practice and is usually disclosed to bidders before the auction begins. If that negotiation does not result in a sale, the agent will approach other registered bidders and, if necessary, list the property by private treaty. Most properties that pass in sell within days or weeks of the auction."
      }
    },
    {
      "@type": "Question",
      "name": "Does passing in at auction hurt my chances of selling the property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A pass-in creates some momentum loss because the result is public. Buyers who were watching may interpret it as a signal that the vendor's price expectations exceeded what the market would pay. However, a pass-in also brings buyers off the sidelines who were reluctant to compete at auction. How damaging a pass-in is depends largely on how the agent manages the post-auction period. A well-handled negotiation in the days after the auction can still produce a strong result."
      }
    },
    {
      "@type": "Question",
      "name": "How do I avoid my property passing in at auction?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most reliable way to avoid a pass-in is to set the reserve at a level consistent with buyer feedback during the campaign and current comparable sales. Reserves set above what genuine buyer competition will support are the primary cause of pass-ins. Your agent should provide you with a clear view of buyer feedback after each open home and recommend a reserve range based on that evidence. Setting the reserve based on the price you want rather than the price buyers are prepared to pay is the most common mistake vendors make."
      }
    },
    {
      "@type": "Question",
      "name": "Can I accept an offer before the auction to avoid the risk of passing in?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can accept a pre-auction offer and proceed by private treaty before auction day. Whether to accept a pre-auction offer depends on whether the offer price is at or above what genuine auction competition is likely to produce. In a campaign with strong buyer interest, accepting a pre-auction offer may mean leaving money on the table. In a campaign with thin interest, a solid pre-auction offer may be worth accepting. Your agent should advise you on the dynamics of your specific campaign before you make this decision."
      }
    }
  ]
};
