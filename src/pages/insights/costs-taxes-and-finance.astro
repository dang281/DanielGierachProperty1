---
import Layout from '../../layouts/Layout.astro';

const clusterSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Property Costs, Taxes and Finance",
  "description": "What it costs to sell, how stamp duty and capital gains tax apply, and how finance and mortgages interact with a property sale in Brisbane.",
  "url": "https://danielgierach.com/insights/costs-taxes-and-finance/",
  "author": { "@type": "Person", "name": "Daniel Gierach", "url": "https://danielgierach.com/about" }
};

const articles = [
  {
    slug: 'cost-of-selling-house-brisbane',
    title: 'What Does It Cost to Sell a House in Brisbane?',
    summary: 'Selling a property in Brisbane costs more than most vendors expect. Here is a clear breakdown of agent commission, marketing, conveyancing, styling, and what capital gains means for your situation.',
    tag: 'Sellers',
  },
  {
    slug: 'capital-gains-tax-selling-home-brisbane',
    title: 'Capital Gains Tax When Selling Your Home in Brisbane 2026',
    summary: 'What Brisbane home sellers need to know about capital gains tax, the main residence exemption, the 50% CGT discount, and partial exemptions when selling in 2026.',
    tag: 'Sellers',
  },
  {
    slug: 'stamp-duty-queensland',
    title: "Stamp Duty in Queensland: What You'll Actually Pay",
    summary: "Transfer duty is one of the biggest upfront costs in property. Here's how it's calculated, what concessions are available, and how to budget for it.",
    tag: 'Buyers',
  },
  {
    slug: 'selling-house-with-mortgage-brisbane',
    title: 'Selling a House With a Mortgage in Brisbane 2026',
    summary: 'What Brisbane sellers need to know about mortgage discharge, net equity calculations, fixed-rate break costs, and how your lender fits into the settlement process.',
    tag: 'Sellers',
  },
  {
    slug: 'mortgage-broker',
    title: 'Which Mortgage Broker Should I Use?',
    summary: "Not all brokers are equal. Here's what to look for, what to ask, and the red flags that should send you elsewhere.",
    tag: 'Buyers',
  },
  {
    slug: 'first-home-buyer-help-history-and-current-options',
    title: 'Every First Home Buyer Grant and Scheme: History and Current Options',
    summary: 'A complete record of every Australian first home buyer grant, concession, and scheme from 2000 through to 2026, plus a clean summary of every option currently available and how to stack them.',
    tag: 'Buyers',
  },
  {
    slug: 'cgt-main-residence-exemption-verification-queensland-sellers',
    title: 'CGT Main Residence Exemption: What Sellers Must Prove',
    summary: 'Selling your main residence in Queensland and claiming the CGT exemption. What evidence proves the home was your main residence and what happens when the ATO asks.',
    tag: 'Sellers',
  },
  {
    slug: 'mortgage-broker-vs-bank-direct-brisbane-property-buyers',
    title: 'Mortgage Broker vs Bank Direct: A Brisbane Buyer\'s Guide',
    summary: 'Should you go to your bank or use a broker for your Brisbane property loan? Here is the practical comparison of cost, access to products, and service quality for Brisbane buyers.',
    tag: 'Buyers',
  },
  {
    slug: 'preparing-financial-position-before-listing-brisbane-seller',
    title: 'Preparing Your Financial Position Before Listing in Brisbane',
    summary: 'The financial work before listing matters as much as the property preparation. Here is the complete checklist for Brisbane sellers to get their financial position sorted before going to market.',
    tag: 'Sellers',
  },
  {
    slug: 'free-property-calculators-brisbane-sellers',
    title: 'Free Property Calculators Every Brisbane Home Seller Should Use',
    summary: 'Eight free calculators that Brisbane sellers should run before they list. From net proceeds to CGT timing, here is how to use each one and why the numbers matter.',
    tag: 'Sellers',
  },
  {
    slug: 'real-estate-agent-fees-commissions-brisbane',
    title: 'Real Estate Agent Fees in Brisbane: What You Actually Pay in 2026',
    summary: 'A transparent breakdown of Brisbane real estate commission in 2026: typical rates, how the fee is calculated, what is negotiable, and what you actually get for your money.',
    tag: 'Sellers',
  },
];

const tagColors: Record<string, string> = {
  'Sellers': '#f5d07a',
  'Buyers':  '#7ec8e3',
};
---
<Layout title="Property Costs, Taxes and Finance | Daniel Gierach Property" description="What it costs to sell, how stamp duty and capital gains tax apply, and how finance and mortgages interact with a Brisbane property sale." schema={clusterSchema}>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <!-- Hero -->
  <div style="background:#0a0806;padding:8rem 0 3.5rem;">
    <div class="max-w-[1100px] mx-auto px-8">
      <a href="/insights" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(240,236,228,0.6);text-decoration:none;margin-bottom:2rem;transition:color 0.2s;"
        onmouseover="this.style.color='#f5d07a'" onmouseout="this.style.color='rgba(240,236,228,0.6)'">
        &larr; All Articles
      </a>
      <span style="display:block;font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#f5d07a;margin-bottom:1rem;">Topic Guide &middot; 11 Articles</span>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,5vw,3.25rem);font-weight:400;color:#f0ece4;line-height:1.12;letter-spacing:-0.02em;margin-bottom:1.5rem;">
        Property Costs, Taxes and Finance
      </h1>
      <p style="font-size:1rem;color:rgba(240,236,228,0.6);line-height:1.8;max-width:58ch;">
        The financial side of a property transaction involves more line items than most buyers and sellers plan for. This guide covers selling costs, capital gains tax, stamp duty, how a mortgage interacts with your sale, and what every first home buyer grant option looks like in 2026.
      </p>
    </div>
  </div>

  <!-- Article Grid -->
  <div style="padding:3.5rem 0 5rem;background:var(--color-base);">
    <div class="max-w-[1100px] mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {articles.map(a => (
          <a href={`/insights/${a.slug}`}
            style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:2rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.25s,border-color 0.25s,transform 0.3s,box-shadow 0.3s;position:relative;overflow:hidden;box-shadow:0 1px 4px rgba(28,25,23,0.05);"
            onmouseover="this.style.background='#f2efe9';this.style.borderColor='rgba(196,145,42,0.3)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(28,25,23,0.09)'"
            onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.transform='translateY(0)';this.style.boxShadow='0 1px 4px rgba(28,25,23,0.05)'"
          >
            <div style={`position:absolute;top:0;left:0;right:0;height:3px;background:${tagColors[a.tag] || '#c4912a'};`}></div>
            <div style="display:flex;align-items:center;padding-top:0.25rem;">
              <span style={`font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:${tagColors[a.tag] || '#c4912a'};display:inline-flex;align-items:center;gap:0.35rem;`}>
                <span style={`width:5px;height:5px;border-radius:50%;background:${tagColors[a.tag] || '#c4912a'};flex-shrink:0;`}></span>
                {a.tag}
              </span>
            </div>
            <div style="flex:1;">
              <h2 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.75rem;">{a.title}</h2>
              <p style="font-size:0.82rem;color:#78716c;line-height:1.75;">{a.summary}</p>
            </div>
            <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;margin-top:auto;">Read Article &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div style="padding:4rem 0;background:#f7f5f0;border-top:1px solid rgba(28,25,23,0.08);">
    <div class="max-w-[1100px] mx-auto px-8" style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:1.25rem;">
      <p style="font-family:var(--font-serif);font-size:1.25rem;font-style:italic;color:#1c1917;">Want to understand your net proceeds before you list?</p>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;max-width:44ch;">Daniel can walk you through a clear cost and net equity estimate before you commit to listing. No surprises on settlement day.</p>
      <a href="/get-an-appraisal" style="display:inline-flex;align-items:center;gap:0.6rem;padding:0.85rem 1.75rem;background:#c4912a;color:#fff;font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;"
        onmouseover="this.style.background='#a87824'" onmouseout="this.style.background='#c4912a'">
        Get a Free Appraisal
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

</article>

</Layout>
