        }
      },
      {
        "@type": "Question",
        "name": "Can buyers get a loan to buy a unit with combustible cladding in Brisbane?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Some lenders restrict lending on buildings with unresolved combustible cladding issues. Restrictions vary by lender and can include outright refusal to lend, reduced loan-to-value ratios, or conditions requiring evidence of an approved remediation plan. Buildings where rectification is complete and certified are generally treated the same as any other building."
        }
      }
    ]
  })}</script>

