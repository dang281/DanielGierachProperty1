---
import Layout from '../../layouts/Layout.astro';

const clusterSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Preparing Your Home for Sale",
  "description": "Practical guides on presentation, compliance certificates, pest and building checks, and physical preparation before listing a Brisbane property.",
  "url": "https://danielgierach.com/insights/preparing-your-home-for-sale/",
  "author": { "@type": "Person", "name": "Daniel Gierach", "url": "https://danielgierach.com/about" }
};

const articles = [
  {
    slug: 'how-to-prepare-your-home-for-sale-brisbane',
    title: 'How to Prepare Your Home for Sale in Brisbane',
    summary: 'The gap between deciding to sell and going to market is where price outcomes are made or lost. A practical guide to preparing your Brisbane home for sale.',
  },
  {
    slug: 'prepare-home-for-sale',
    title: 'How to Prepare Your Home for Sale',
    summary: 'First impressions drive price. A focused pre-sale plan with the right repairs and the right styling can add tens of thousands to your result.',
  },
  {
    slug: 'property-styling-staging-brisbane',
    title: 'Property Styling and Staging When Selling in Brisbane',
    summary: 'What property styling actually costs in Brisbane, when it is worth the investment, and how to decide between professional staging and DIY presentation when selling your home.',
  },
  {
    slug: 'open-home-tips-for-sellers-brisbane',
    title: 'Open Home Tips for Sellers: How to Prepare',
    summary: 'What to do the day before, the morning of, and how to use buyer feedback to sharpen your campaign in Brisbane.',
  },
  {
    slug: 'building-pest-report',
    title: 'How to Read a Building and Pest Report',
    summary: "A building and pest report can be overwhelming. Here's what the findings actually mean and which issues are dealbreakers versus normal wear.",
  },
  {
    slug: 'building-pest-report-seller-guide-brisbane',
    title: 'How to Handle a Building and Pest Report as a Seller in Brisbane',
    summary: "A buyer's building and pest report is one of the most common sources of late-campaign conflict. Here is what Brisbane properties typically show, and how to respond to post-report negotiations.",
  },
  {
    slug: 'termite-chemical-barriers-annual-pest-contracts-selling-brisbane',
    title: 'Termite Chemical Barriers and Annual Pest Contracts When Selling a Brisbane Property',
    summary: 'In termite-prone Brisbane, an active chemical barrier and a clean inspection history are sale-critical. Here is what documentation to compile, what to disclose, and how a pre-sale inspection shifts the negotiating dynamic in your favour.',
  },
  {
    slug: 'pool-safety-certificate-selling-brisbane-qld',
    title: 'Pool Safety Certificate Requirements When Selling in Queensland',
    summary: 'Queensland sellers with a pool must provide a pool safety certificate or Form 36 before sale. Here is what the rules require, which path is better for sellers, and how to get compliant before listing.',
  },
  {
    slug: 'smoke-alarm-compliance-selling-queensland',
    title: 'Smoke Alarm Compliance When Selling Your Home in Queensland',
    summary: "Queensland's 2022 smoke alarm laws require interconnected photoelectric alarms in every bedroom before sale. Here is what the rules require, how to check compliance, and what upgrading costs.",
  },
  {
    slug: 'retaining-walls-brisbane-selling',
    title: 'Retaining Walls in Brisbane: Responsibility, Disclosure, and What Sellers Need to Know',
    summary: "Retaining walls are common on Brisbane's hilly inner east properties and frequently misunderstood. Here is who is responsible, what sellers must disclose, and how to handle a failing wall at sale.",
  },
  {
    slug: 'smart-home-features-selling-brisbane-buyers-value-vs-noise',
    title: 'Smart Home Features and Selling a Brisbane Property: Which Integrations Buyers Value and Which Are Noise',
    summary: 'Smart locks and video doorbells add value at sale; platform-locked lighting systems and personal automation routines do not. Here is how Brisbane sellers should present and manage smart home features when listing.',
  },
  {
    slug: 'storage-built-in-wardrobes-walk-in-robes-brisbane-property-value',
    title: 'Storage in Brisbane Homes: Built-in Wardrobes, Walk-in Robes, and How Storage Affects Value',
    summary: 'Storage is one of the cheapest ways to lift perceived value before listing: how built-in wardrobes, walk-in robes, pantries, and external storage shape buyer impressions and what the current buyer standard actually is.',
  },
  {
    slug: 'inspection-day-presentation-checklist-brisbane-sellers',
    title: 'Inspection Day Presentation Checklist for Brisbane Sellers',
    summary: 'A 30-minute pre-inspection checklist that lifts how your home presents. Practical, repeatable, and easy to follow before every open home or private inspection.',
  },
  {
    slug: 'pre-listing-styling-staging-brisbane-cost-return',
    title: 'Pre-Listing Styling and Staging in Brisbane: Cost and Return',
    summary: 'Professional styling can transform how a Brisbane property presents and what it sells for. Here is what real pre-listing styling costs and when the return justifies the investment.',
  },
  {
    slug: 'water-damage-mould-disclosure-inspection-findings-brisbane',
    title: 'Water Damage and Mould Disclosure for Brisbane Sellers',
    summary: "Brisbane's wet weather makes water damage and mould common findings on building inspections. What you must disclose, how to present the issue honestly, and what remediating before listing can do for your result.",
  },
  {
    slug: 'selling-house-with-pool-brisbane-buyer-perspective',
    title: "Selling a Brisbane Home with a Pool: The Buyer's Perspective",
    summary: 'Pools split buyer opinion in Brisbane. Understanding how buyers assess pool value, compliance, and ongoing cost helps sellers present and price a pool home more accurately.',
  },
];
---
<Layout title="Preparing Your Home for Sale | Daniel Gierach Property" description="Practical guides on presentation, compliance certificates, pest and building checks, and physical preparation before listing a Brisbane property." schema={clusterSchema}>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <!-- Hero -->
  <div style="background:#0a0806;padding:8rem 0 3.5rem;">
    <div class="max-w-[1100px] mx-auto px-8">
      <a href="/insights" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(240,236,228,0.6);text-decoration:none;margin-bottom:2rem;transition:color 0.2s;"
        onmouseover="this.style.color='#f5d07a'" onmouseout="this.style.color='rgba(240,236,228,0.6)'">
        &larr; All Articles
      </a>
      <span style="display:block;font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#f5d07a;margin-bottom:1rem;">Topic Guide &middot; 16 Articles</span>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,5vw,3.25rem);font-weight:400;color:#f0ece4;line-height:1.12;letter-spacing:-0.02em;margin-bottom:1.5rem;">
        Preparing Your Home for Sale
      </h1>
      <p style="font-size:1rem;color:rgba(240,236,228,0.6);line-height:1.8;max-width:58ch;">
        The gap between deciding to sell and going to market is where your price outcome is made or lost. This guide covers everything from compliance certificates and pest inspections to styling, open homes, and what not to spend money on.
      </p>
    </div>
  </div>

  <!-- Article Grid -->
  <div style="padding:3.5rem 0 5rem;background:var(--color-base);">
    <div class="max-w-[1100px] mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {articles.map(a => (
          <a href={`/insights/${a.slug}`}
            style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:2rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.25s,border-color 0.25s,transform 0.3s,box-shadow 0.3s;position:relative;overflow:hidden;box-shadow:0 1px 4px rgba(28,25,23,0.05);"
            onmouseover="this.style.background='#f2efe9';this.style.borderColor='rgba(196,145,42,0.3)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(28,25,23,0.09)'"
            onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.transform='translateY(0)';this.style.boxShadow='0 1px 4px rgba(28,25,23,0.05)'"
          >
            <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#f5d07a;"></div>
            <div style="display:flex;align-items:center;padding-top:0.25rem;">
              <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:#f5d07a;display:inline-flex;align-items:center;gap:0.35rem;">
                <span style="width:5px;height:5px;border-radius:50%;background:#f5d07a;flex-shrink:0;"></span>
                Sellers
              </span>
            </div>
            <div style="flex:1;">
              <h2 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.75rem;">{a.title}</h2>
              <p style="font-size:0.82rem;color:#78716c;line-height:1.75;">{a.summary}</p>
            </div>
            <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;margin-top:auto;">Read Article &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div style="padding:4rem 0;background:#f7f5f0;border-top:1px solid rgba(28,25,23,0.08);">
    <div class="max-w-[1100px] mx-auto px-8" style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:1.25rem;">
      <p style="font-family:var(--font-serif);font-size:1.25rem;font-style:italic;color:#1c1917;">Ready to find out what your home is worth?</p>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;max-width:44ch;">Daniel provides a tailored pre-sale preparation plan as part of every appraisal. Specific advice on what to fix, what to style, and what to leave alone.</p>
      <a href="/get-an-appraisal" style="display:inline-flex;align-items:center;gap:0.6rem;padding:0.85rem 1.75rem;background:#c4912a;color:#fff;font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;border-radius:8px;"
        onmouseover="this.style.background='#a87824'" onmouseout="this.style.background='#c4912a'">
        Get a Free Appraisal
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

</article>

</Layout>
