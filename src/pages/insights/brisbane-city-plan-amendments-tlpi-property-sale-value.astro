const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a Brisbane City Plan amendment and how does it affect my property's sale value?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A City Plan amendment is a change to the Brisbane City Plan 2014, the planning scheme that governs zoning, overlays, codes, and what can lawfully be built on every lot in the city. Amendments can be administrative (corrections and minor wording), minor (boundary clean-ups, code updates), or major (new zones, new overlays, neighbourhood plan rollouts). Major amendments often reshape what a buyer can do with a site, which directly changes what they will pay. A site rezoned from Low Density Residential to Low-Medium Density Residential typically sees a step change in land value because the buyer pool widens to include small developers. A site newly captured by a Traditional Building Character overlay or a height cap will usually see a step down in land value because demolition or full-scale redevelopment is no longer available."
      }
    },
    {
      "@type": "Question",
      "name": "What is a Temporary Local Planning Instrument (TLPI) in Brisbane?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Temporary Local Planning Instrument is a short-term planning rule that Brisbane City Council can adopt to address an urgent or significant planning issue while a permanent City Plan amendment is being prepared. TLPIs are valid for up to two years and can be extended once. They typically suspend or override specific City Plan provisions in defined geographic areas. Brisbane has used TLPIs to protect character housing precincts, manage flood-risk areas, and pause demolition or redevelopment in suburbs facing rapid change. A TLPI that lands over your property can shift its highest and best use overnight, which is why sale value can move before any permanent change is gazetted."
      }
    },
    {
      "@type": "Question",
      "name": "Do I have to disclose a pending City Plan amendment or TLPI when selling in Brisbane?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Queensland's seller disclosure regime under the Property Law Act 2023 requires sellers to disclose certain planning and statutory information via a Form 2 disclosure statement before the buyer signs. This includes the current zoning, applicable overlays, and any registered notices on title. Pending amendments and active TLPIs are public information, and a competent buyer's solicitor will run a planning search that picks them up. Hiding a known planning change is a poor idea: it does not stop the change from being discovered, it just damages trust and exposes the seller to termination or claims. The better approach is to handle the disclosure properly, price the property to current reality, and let the campaign work through buyers who understand what they are buying."
      }
    }
  ]
};
