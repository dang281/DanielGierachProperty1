const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "When should I brief my solicitor before selling my Brisbane property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Engage and brief your solicitor before you sign the agency agreement, not after you accept an offer. The Property Law Act 2023 requires a Mandatory Seller Disclosure Statement (Form 2) to be given to the buyer before a contract is signed, and your solicitor produces or reviews that document. Briefing them three to four weeks before listing gives time to order title searches, locate the Form 2 supporting documents, confirm pool, smoke alarm and asbestos certificates, and resolve any title issues such as caveats, easements or lapsed approvals before a buyer ever sees them."
      }
    },
    {
      "@type": "Question",
      "name": "What information does my solicitor need from me before listing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your solicitor needs the property address and lot/plan details, copies of council and water rates notices, body corporate disclosure documents if the property is a unit or townhouse, your current pool safety certificate, smoke alarm compliance evidence, any building approvals or final certificates for renovations, your loan account details and mortgage payout authority, your bank details for settlement proceeds, ATO clearance certificate application status, and any known disputes, easements, encumbrances or unapproved structures. The more you provide upfront, the cleaner the Form 2 disclosure and the fewer surprises after a buyer signs."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I communicate with my solicitor during a Brisbane property sale?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Expect three intensive contact points: the briefing and disclosure stage before listing, the contract review window after an offer is accepted, and the lead-up to settlement. Between those, the solicitor manages most things in the background and contacts you when a decision is needed. A useful baseline is one written update per week during the conditional period and same-day responses to anything time-sensitive such as a finance extension request, a building and pest report, or a buyer request for repairs."
      }
    }
  ]
};
