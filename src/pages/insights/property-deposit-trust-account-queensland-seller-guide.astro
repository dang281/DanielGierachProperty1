    {
      "@type": "Question",
      "name": "Where is the deposit held when I sell my Queensland property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The deposit is held in a statutory trust account by the real estate agent or the buyer's solicitor. It does not go directly to the seller until settlement, when the balance of the purchase price is also paid."
      }
    },
    {
      "@type": "Question",
      "name": "What happens to the deposit if the buyer pulls out of the contract?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on why they pull out. If the buyer exercises a cooling off right, they get the deposit back minus a 0.25% penalty. If they pull out under a valid condition (such as finance or building and pest), the full deposit is returned. If they default after the contract goes unconditional, the seller may be entitled to forfeit the deposit, though this requires legal advice and is not automatic."
      }
    },
    {
      "@type": "Question",
      "name": "How much deposit can I ask for in Queensland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ten percent of the purchase price is the most common deposit in Queensland. A 5% deposit is negotiable, particularly for buyers with strong finance or when a seller wants to move quickly. The deposit amount is specified in the contract of sale and should be agreed before signing."
      }
    }
  ]
}
</script>

<article style="background:var(--color-surface-0);min-height:100vh;">

