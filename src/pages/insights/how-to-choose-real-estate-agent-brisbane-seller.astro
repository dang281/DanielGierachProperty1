      }
    },
    {
      "@type": "Question",
      "name": "What questions should I ask a Brisbane real estate agent before signing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ask for their personal sales record (not the office's), the recommended method of sale and why it suits your property, how many active listings they are currently running and whether they have enough capacity, how they handle multiple offers or a slow first week, and how they will keep you informed throughout the campaign. Pay attention to how specifically they answer. Vague answers about 'market knowledge' and 'database' are red flags. Specific answers with data are green flags."
      }
    }
  ]
