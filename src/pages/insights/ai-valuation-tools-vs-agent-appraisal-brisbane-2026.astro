const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How accurate are online property valuation tools in Brisbane?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CoreLogic, which powers most major Australian valuation tools including realestate.com.au's PropertyValue and propertyvalue.com.au, reports that since early 2024 close to 90 percent of its automated valuation estimates fall within 15 percent of the eventual sale price. That is a useful starting point for typical, recently sold homes in homogeneous estates. For Brisbane inner east properties involving heritage overlays, character homes, post-renovation upgrades, or micro-pocket variation between streets, the variability is materially wider. The 15 percent band on a $1.5 million Bulimba home is a $450,000 spread, which is the difference between a strong result and a poor one."
      }
    },
    {
      "@type": "Question",
      "name": "Why do Domain and realestate.com.au give different estimates for the same Brisbane home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Domain and realestate.com.au use different underlying data and different model weightings. Realestate.com.au's estimates are powered by CoreLogic data. Domain runs its own model. They draw on different comparable sets, weight recency differently, and treat property attributes (renovation level, land size, view) differently. In Brisbane inner east, where the housing stock is mixed and renovations are common, gaps of 10 to 25 percent between the two estimates are not unusual. Neither figure is a substitute for a comparable sales analysis run on your specific property."
      }
    },
    {
      "@type": "Question",
      "name": "Should I rely on an online estimate to set my asking price?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. An online estimate is a useful sanity check and a reasonable starting point for general research. It is not a basis for setting an asking price or making a decision about whether to sell. Asking price should be built from a comparable sales analysis run on your specific property, by an agent who can walk through it and adjust for the things an algorithm cannot see: condition, aspect, position within the street, renovation quality, flood overlay, and the buyer pool currently active for your property type."
      }
    },
    {
      "@type": "Question",
      "name": "When are AVMs useful for a Brisbane homeowner?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AVMs are useful for early-stage research: getting a rough sense of value before deciding to sell, tracking how your suburb has moved over time, or comparing your home against recent sales nearby. They are useful for lenders running credit checks and for portfolio investors monitoring multiple properties at scale. They are not useful as the basis for an asking price, a tax valuation, a settlement decision, or any moment where the difference between a confident estimate and the real number actually matters."
      }
    }
  ]
};
