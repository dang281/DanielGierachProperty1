---
import Layout from '../../layouts/Layout.astro';
import AuthorBio from '../../components/AuthorBio.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the main residence CGT exemption?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The main residence exemption allows an Australian resident to sell their primary home without paying capital gains tax on the profit. The property must have been used as the seller's main residence for the period claimed, and only one property at a time can qualify (with limited overlap windows during a move). The exemption applies to the dwelling and up to two hectares of land."
      }
    },
    {
      "@type": "Question",
      "name": "What evidence proves a property was your main residence?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The ATO looks at where the seller lived in practice, not just the address on tax returns. Evidence includes electoral roll registration at the address, utility accounts in the seller's name with usage consistent with occupation, mail and bank statements addressed to the property, vehicle registration, and where personal possessions were kept. The longer the period and the more independent records, the stronger the evidence."
      }
    },
    {
      "@type": "Question",
      "name": "Can I claim the exemption if I lived in the home only briefly?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Brief occupation generally does not establish a main residence. The ATO considers genuine occupation, not token presence. There is no minimum legislated period, but a stay of weeks or a few months without ordinary indicators of residency is unlikely to qualify. Audit risk increases when the claim covers a short period and the property was rented or vacant for most of the ownership."
      }
    }
  ]
};
---
<Layout title="CGT Main Residence Exemption: What Sellers Must Prove | Daniel Gierach Property" description="Selling your main residence in Queensland and claiming the CGT exemption. What evidence proves the home was your main residence, what triggers ATO review, and the practical records to keep before settlement." schema={faqSchema}>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <div style="background:#e6d9bd;padding:8rem 0 3rem;">
    <div class="max-w-[780px] mx-auto px-8">
