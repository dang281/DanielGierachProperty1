---
import Layout from '../../layouts/Layout.astro';
import AuthorBio from '../../components/AuthorBio.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can a builder or tradesperson put a caveat on my Brisbane property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A builder, subcontractor or tradesperson cannot lodge a caveat on your Brisbane property unless your written contract grants them a caveatable interest, which is rare in standard residential building contracts. What they can do under Queensland's Building Industry Fairness (Security of Payment) Act 2017 is lodge a subcontractor's charge, register a payment claim, or pursue a money judgment that can later support a writ of execution against the property. A caveat lodged without a proper caveatable interest can be removed by application and the lodger may be liable for compensation under section 130 of the Land Title Act 1994."
      }
    },
    {
      "@type": "Question",
      "name": "What is a subcontractor's charge and how does it affect selling my property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A subcontractor's charge under chapter 4 of Queensland's BIF Act 2017 is a statutory charge over money payable to a head contractor, not directly over the land title. It does not register as a caveat or encumbrance on your certificate of title, so it generally does not block a sale of the property itself. However, if your property is the subject of an active building contract and a subcontractor has issued a notice of claim of charge, money that would otherwise flow to your builder can be redirected, which sometimes leaves a builder unable to complete works before settlement. The risk to a vendor is practical rather than registrable: incomplete works, builder insolvency mid-build, or disputes that delay practical completion."
      }
    },
    {
      "@type": "Question",
      "name": "How do I check if there is a caveat or charge on my Brisbane property before listing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Order a current title search through Titles Queensland or your solicitor before signing a listing authority. The title search shows registered interests including mortgages, easements and any caveats. Caveats appear as a separate line item with a caveat number, the caveator's name and the nature of the interest claimed. A current search costs around $24 and takes minutes. If a caveat appears, get advice from a property solicitor before listing. If you are mid-build or recently completed works, also ask your builder for a statutory declaration that all subcontractors and suppliers have been paid, and consider requesting evidence of progress payments to subcontractors before final invoices are settled."
      }
    }
  ]
};
---
