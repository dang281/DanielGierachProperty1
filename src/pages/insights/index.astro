<Layout title="Insights & Articles | Daniel Gierach Property" description="Property insights and guides for Brisbane sellers and investors. Practical advice on auctions, contracts, stamp duty, costs and more from Daniel Gierach.">

<!-- Hero -->
<section class="relative min-h-[40vh] flex items-center overflow-hidden" style="background:#0a0806;">
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1920&q=80&fm=webp&auto=format"
      alt="Brisbane property"
      class="w-full h-full object-cover"
      style="filter:grayscale(8%) brightness(0.4);"
    />
    <div class="absolute inset-0" style="background:linear-gradient(120deg,rgba(10,8,6,0.7) 0%,rgba(10,8,6,0.3) 100%);"></div>
  </div>
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-8 lg:px-12 pt-32 pb-16">
    <span class="eyebrow mb-4 reveal" style="display:block;color:#f5d07a;">Knowledge Base</span>
    <h1 class="reveal" data-delay="80"
      style="font-family:var(--font-serif);font-size:clamp(2.5rem,5vw,4rem);font-weight:400;color:#f0ece4;letter-spacing:-0.02em;line-height:1.1;margin-bottom:0.75rem;">
      Insights &amp; Articles.
    </h1>
    <p class="reveal" data-delay="160"
      style="font-size:0.95rem;color:rgba(240,236,228,0.6);max-width:46ch;line-height:1.8;">
      Practical property knowledge for Brisbane buyers, sellers, and owners. No fluff.
    </p>
    <a href="/resources" class="reveal" data-delay="220"
      style="display:inline-flex;align-items:center;gap:0.55rem;margin-top:1.5rem;padding:0.7rem 1.25rem;background:rgba(245,208,122,0.1);border:1px solid rgba(245,208,122,0.4);color:#f5d07a;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s,border-color 0.2s;"
      onmouseover="this.style.background='rgba(245,208,122,0.18)';this.style.borderColor='rgba(245,208,122,0.7)'"
      onmouseout="this.style.background='rgba(245,208,122,0.1)';this.style.borderColor='rgba(245,208,122,0.4)'">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
      Free Printable Guides &rarr;
    </a>
  </div>
</section>

<!-- Sticky Filter Bar -->
<div style="position:sticky;top:0;z-index:40;background:rgba(247,245,240,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(28,25,23,0.08);box-shadow:0 2px 16px rgba(28,25,23,0.05);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12" style="padding-top:0.9rem;padding-bottom:0.9rem;">
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;justify-content:space-between;">
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;">
{filters.map(f => (
        <button
          class="fpill"
          data-filter={f}
          style={`display:inline-flex;align-items:center;gap:0.45rem;padding:0.55rem 1.25rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;cursor:pointer;border:1.5px solid;line-height:1;transition:background 0.15s,color 0.15s,border-color 0.15s;background:${f==='All'?'#1c1917':'transparent'};color:${f==='All'?'#f0ece4':'#78716c'};border-color:${f==='All'?'#1c1917':'rgba(28,25,23,0.22)'};`}
        >
          {f === 'All' ? 'Show All' : f}
          <span style={`display:inline-flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 3px;font-size:0.6rem;font-weight:800;background:${f==='All'?'rgba(255,255,255,0.2)':'rgba(28,25,23,0.08)'};color:${f==='All'?'#f0ece4':'#78716c'};`}>
            {filterCount(f)}
          </span>
        </button>
      ))}
      </div>
      <!-- Search -->
      <div style="position:relative;flex-shrink:0;">
        <label for="insight-search" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0;">Search articles</label>
        <svg style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);pointer-events:none;z-index:1;" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#78716c" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input
          id="insight-search"
          type="search"
          placeholder="Search articles (e.g. auction, settlement, agent fees)"
          aria-label="Search articles"
          style="padding:0.55rem 2rem 0.55rem 2.25rem;font-family:var(--font-sans);font-size:0.7rem;color:#1c1917;background:#fff;border:1.5px solid rgba(28,25,23,0.22);outline:none;width:320px;transition:border-color 0.15s,box-shadow 0.15s;"
          onfocus="this.style.borderColor='#c4912a';this.style.boxShadow='0 0 0 3px rgba(196,145,42,0.12)'"
          onblur="this.style.borderColor='rgba(28,25,23,0.22)';this.style.boxShadow='none'"
        />
        <button
          id="search-clear"
          aria-label="Clear search"
          style="display:none;position:absolute;right:0.6rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0.2rem;color:#78716c;line-height:1;"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Articles Grid -->
<section style="background:var(--color-base);padding:3.5rem 0 7rem;">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {articles.map((a, i) => (
        <a href={`/insights/${a.slug}`}
          class="insight-card reveal"
          data-tag={a.tag}
          data-title={a.title.toLowerCase()}
          data-summary={a.summary.toLowerCase()}
          data-delay={i * 60}
          style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:2rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.25s cubic-bezier(0.4,0,0.2,1),border-color 0.25s cubic-bezier(0.4,0,0.2,1),transform 0.3s cubic-bezier(0.34,1,0.64,1),box-shadow 0.3s cubic-bezier(0.34,1,0.64,1);position:relative;overflow:hidden;box-shadow:0 1px 4px rgba(28,25,23,0.05);"
          onmouseover="this.style.background='#f2efe9';this.style.borderColor='rgba(196,145,42,0.3)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(28,25,23,0.09)'"
          onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.transform='translateY(0)';this.style.boxShadow='0 1px 4px rgba(28,25,23,0.05)'"
        >
          <div style={`position:absolute;top:0;left:0;right:0;height:3px;background:${tagColors[a.tag] || '#c4912a'};`}></div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding-top:0.25rem;">
            <span style={`font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:${tagColors[a.tag] || '#c4912a'};display:inline-flex;align-items:center;gap:0.35rem;`}>
              <span style={`width:5px;height:5px;border-radius:50%;background:${tagColors[a.tag] || '#c4912a'};flex-shrink:0;`}></span>
              {a.tag}
            </span>
            <span style="font-family:var(--font-sans);font-size:0.6rem;color:#78716c;letter-spacing:0.06em;">{a.readTime}</span>
          </div>
          <div style="flex:1;">
            <h2 style="font-family:var(--font-serif);font-size:1.15rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.75rem;">
              {a.title}
            </h2>
            <p style="font-size:0.82rem;color:#78716c;line-height:1.75;">
              {a.summary}
            </p>
          </div>
          <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;margin-top:auto;">
            Read Article →
          </span>
        </a>
      ))}
    </div>

    <p id="no-articles" style="display:none;text-align:center;padding:4rem 0;font-size:0.9rem;color:#78716c;">No articles found. Try a different search term.</p>

  </div>
</section>

<!-- Browse by Topic -->
<section style="background:#f2efe9;padding:4rem 0 4.5rem;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div class="reveal" style="margin-bottom:2rem;">
      <span style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;display:block;margin-bottom:0.75rem;">Browse by Topic</span>
      <h2 style="font-family:var(--font-serif);font-size:1.75rem;font-weight:400;color:#1c1917;letter-spacing:-0.02em;line-height:1.2;margin-bottom:0.5rem;">Browse all guides by topic.</h2>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;max-width:52ch;">Every article in this library belongs to one of these topic clusters. Pick the area that matches where you are in the selling process.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;" class="topic-cluster-grid">
      {[
        { href: '/insights/preparing-your-home-for-sale',   label: 'Preparing to Sell',           count: 12, desc: 'Presentation, pest reports, compliance certificates' },
        { href: '/insights/property-pricing-and-valuation', label: 'Pricing and Valuation',        count: 9,  desc: 'Appraisals, comparable sales, timing and market read' },
        { href: '/insights/marketing-and-selling-methods',  label: 'Marketing and Auctions',       count: 14, desc: 'Campaigns, auction, private treaty, EOI, choosing an agent' },
        { href: '/insights/contracts-and-settlement',       label: 'Contracts and Settlement',     count: 11, desc: 'Conditions, disclosure obligations, settlement process' },
        { href: '/insights/costs-taxes-and-finance',        label: 'Costs, Taxes and Finance',     count: 6,  desc: 'Selling costs, CGT, stamp duty, mortgage discharge' },
        { href: '/insights/investment-property-selling',    label: 'Investment Properties',        count: 7,  desc: 'Tenanted sales, landlord obligations, investor tax' },
        { href: '/insights/brisbane-property-types',        label: 'Property Types',               count: 15, desc: 'Queenslanders, post-war, units, architectural periods' },
        { href: '/insights/brisbane-inner-east-market',     label: 'Brisbane Inner East',          count: 8,  desc: 'Zoning, Cross River Rail, school catchments, overlays' },
        { href: '/insights/selling-in-brisbane-suburbs',    label: 'Suburb Selling Guides',        count: 47, desc: 'One detailed guide per suburb across greater Brisbane' },
