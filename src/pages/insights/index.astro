  { slug: 'queensland-conveyancing-process-contract-to-settlement-seller', tag: 'Sellers', title: 'The Queensland Conveyancing Process: What Happens from Contract to Settlement', summary: "A clear, step-by-step explanation of what happens between signing a contract and settlement day when selling in Queensland. What your solicitor does, what you need to do, and where things can go wrong.", readTime: '11 min read' },
  { slug: 'first-time-sellers-brisbane-end-to-end-guide', tag: 'Sellers', title: 'First-Time Sellers in Brisbane: A Complete End-to-End Guide', summary: "A step-by-step guide for first-time Brisbane sellers covering every stage from deciding to sell through to settlement. Realistic timelines, the most common mistakes to avoid, and what to expect at each step.", readTime: '16 min read' },
  { slug: 'building-pest-inspection-finds-defects-brisbane-seller-response', tag: 'Sellers', title: 'When a Building and Pest Inspection Finds Defects: How Brisbane Sellers Should Respond', summary: "A building and pest report rarely kills a deal. Handled well, it reshapes the negotiation. Here is how Brisbane sellers should respond when an inspection finds defects, including when to push back, when to concede, and how to keep the sale together.", readTime: '13 min read' },
  { slug: 'what-to-expect-property-walkthrough-brisbane', tag: 'Sellers', title: 'What to Expect at a Property Walkthrough in Brisbane', summary: "A walkthrough is a free, in-home conversation about your property and your options. Here is what actually happens, what gets discussed, and what you take away from it.", readTime: '7 min read' },
  { slug: 'walkthrough-vs-appraisal-brisbane', tag: 'Sellers', title: 'Walkthrough vs Appraisal: What is the Difference?', summary: "Most owners use these two terms interchangeably. They are not the same meeting. Here is what each one covers, when each one makes sense, and which to ask for.", readTime: '5 min read' },
  { slug: 'what-daniel-looks-for-property-walkthrough', tag: 'Sellers', title: 'What Daniel Looks for at a Property Walkthrough', summary: "The four big categories an experienced inner east agent assesses during a walkthrough, and what each one means for your final sale price.", readTime: '8 min read' },
