];

const filters = ['All', 'Buyers', 'Sellers', 'Suburbs', 'Buyers & Sellers', 'Owners'];

const tagColors: Record<string, string> = {
  'Buyers & Sellers': '#6b4610',
  'Buyers':           '#7ec8e3',
  'Sellers':          '#6b4610',
  'Suburbs':          '#7a9e7e',
  'Owners':           '#a8e6a3',
};

const isSuburbArticle = (slug: string) => slug.startsWith('selling-in-');

function filterCount(f: string): number {
  if (f === 'All') return articles.length;
  if (f === 'Suburbs') return articles.filter(a => isSuburbArticle(a.slug)).length;
  // Exclusive counts so they sum to the Show All total. selling-in-X articles are
  // tagged 'Sellers' in the data but live under Suburbs in the UI, so exclude them here.
  return articles.filter(a => a.tag === f && !isSuburbArticle(a.slug)).length;
}
