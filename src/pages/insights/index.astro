---
import Layout from '../../layouts/Layout.astro';

const articles = [
  { slug: 'unconditional-offer',       tag: 'Buyers & Sellers', title: 'What Is an Unconditional Offer?',                    summary: "An unconditional offer is one of the most powerful tools in property and one of the most misunderstood. Here's what it means and when to use it.",                                                          readTime: '4 min read' },
  { slug: 'mortgage-broker',           tag: 'Buyers',           title: 'Which Mortgage Broker Should I Use?',               summary: "Not all brokers are equal. Here's what to look for, what to ask, and the red flags that should send you elsewhere.",                                                                                   readTime: '5 min read' },
  { slug: 'buyers-agent',              tag: 'Buyers',           title: "What Is a Buyer's Agent and Do I Need One?",        summary: "A buyer's agent works exclusively for you, not the vendor. Understanding what they do and what they cost helps you decide if it's worth it.",                                                          readTime: '5 min read' },
  { slug: 'engage-right-builder',      tag: 'Owners',           title: 'How to Engage the Right Builder',                   summary: "Choosing the wrong builder is an expensive mistake. Here's how to verify licences, read contracts, and protect yourself before work starts.",                                                          readTime: '5 min read' },
  { slug: 'flood-mapping',             tag: 'Buyers & Sellers', title: 'Is Your Property in a Flood Zone?',                 summary: "Brisbane's flood mapping affects insurance, value, and what you can build. Here's how to check your property and what to do with the results.",                                                         readTime: '4 min read' },
  { slug: 'what-happens-at-settlement',tag: 'Buyers & Sellers', title: 'What Happens at Settlement?',                       summary: "Settlement day can feel like a black box. Here's exactly what happens, who does what, and how to make sure nothing goes wrong at the last minute.",                                                       readTime: '5 min read' },
  { slug: 'prepare-home-for-sale',     tag: 'Sellers',          title: 'How to Prepare Your Home for Sale',                 summary: 'First impressions drive price. A focused pre-sale plan with the right repairs and the right styling can add tens of thousands to your result.',                                                          readTime: '6 min read' },
  { slug: 'understanding-the-contract',tag: 'Buyers & Sellers', title: 'Understanding the REIQ Contract of Sale',           summary: "The standard Queensland contract is straightforward once you know what to look for. Here's what every buyer and seller should understand before signing.",                                              readTime: '5 min read' },
  { slug: 'stamp-duty-queensland',     tag: 'Buyers',           title: "Stamp Duty in Queensland: What You'll Actually Pay", summary: "Transfer duty is one of the biggest upfront costs in property. Here's how it's calculated, what concessions are available, and how to budget for it.",                                                readTime: '4 min read' },
  { slug: 'building-pest-report',      tag: 'Buyers',           title: 'How to Read a Building and Pest Report',            summary: "A building and pest report can be overwhelming. Here's what the findings actually mean and which issues are dealbreakers versus normal wear.",                                                         readTime: '5 min read' },
  { slug: 'auction-strategy',          tag: 'Buyers & Sellers', title: 'Auction Strategy: How to Buy and Sell at Auction',  summary: "Auctions in Brisbane's inner east are competitive. Whether you're bidding or selling under the hammer, strategy matters more than most people realise.",                                              readTime: '6 min read' },
  { slug: 'when-to-sell',              tag: 'Sellers',          title: 'When Is the Right Time to Sell?',                   summary: "Timing a property sale well can make a meaningful difference to your result. Here's how to think about market conditions, personal timing, and what actually drives price.", readTime: '5 min read' },
  { slug: 'best-time-to-sell-brisbane',           tag: 'Sellers', title: "Best Time to Sell Your Home in Brisbane",                    summary: "Brisbane's selling seasons do not follow Sydney or Melbourne. Here is an honest look at seasonal trends, auction clearance rates, and why autumn consistently outperforms expectations in the inner east.",  readTime: '6 min read' },
  { slug: 'cost-of-selling-house-brisbane',       tag: 'Sellers', title: "What Does It Cost to Sell a House in Brisbane?",             summary: "Selling a property in Brisbane costs more than most vendors expect. Here is a clear breakdown of agent commission, marketing, conveyancing, styling, and what capital gains means for your situation.",       readTime: '7 min read' },
  { slug: 'how-long-does-it-take-to-sell-a-home-in-brisbane', tag: 'Sellers', title: "How Long Does It Take to Sell a Home in Brisbane?", summary: "From preparation through to settlement, the full timeline for a Brisbane sale is typically 12 to 24 weeks. Here is what happens at each stage and what causes delays.",                                          readTime: '5 min read' },
  { slug: 'how-much-is-my-home-worth-brisbane',   tag: 'Sellers', title: "How Much Is My Home Worth in Brisbane?",                     summary: "Online valuations miss the things that matter most: land configuration, aspect, renovation quality, and how comparable sales are actually selected. Here is how Brisbane property value is really determined.", readTime: '6 min read' },
  { slug: 'how-to-choose-a-real-estate-agent-brisbane', tag: 'Sellers', title: "How to Choose a Real Estate Agent in Brisbane",        summary: "Most sellers interview two or three agents and choose the one with the highest quote. Here is what to ask instead, what red flags to watch for, and why local knowledge beats office brand.",                readTime: '6 min read' },
  { slug: 'brisbane-house-styles',     tag: 'Buyers & Sellers', title: 'Brisbane House Styles: A Field Guide to Every Era',  summary: "From Late Colonial cottages to postwar bungalows: how to identify the architectural era of any Brisbane home, and what that means when buying or selling.",             readTime: '8 min read' },
  { slug: 'prewar-homes-brisbane',          tag: 'Buyers & Sellers', title: 'Buying a Prewar Home in Brisbane',                                              summary: "Prewar homes dominate the inner east and command serious premiums. Here is what defines them, what to check before you buy, and how to think about value against newer builds.",                      readTime: '6 min read' },
  { slug: 'body-corporate',                tag: 'Buyers & Sellers', title: 'What Is Body Corporate and What Does It Actually Cost?',                       summary: "Body corporate levies in Brisbane can add thousands to your holding costs. Here is how they work, what the money pays for, and what to check before you buy a unit.",                              readTime: '7 min read' },
  { slug: 'buying-with-tenant',            tag: 'Buyers',           title: 'How to Buy a Property With a Tenant Already In It',                            summary: "Queensland tenancy law is strict. Here is what you need to know about lease types, notice periods, open home rights, and what transfers to you at settlement.",                                    readTime: '6 min read' },
  { slug: 'brisbane-inner-east-value',     tag: 'Buyers & Sellers', title: 'What Makes Brisbane Inner East Suburbs Hold Value',                            summary: "Hawthorne, Morningside, Coorparoo, and Cannon Hill have consistently outperformed the Brisbane average. Here are the structural reasons why.",                                                       readTime: '8 min read' },
  { slug: 'queenslander-vs-postwar',       tag: 'Buyers & Sellers', title: 'Queenslander vs Post-War vs Contemporary: Which Holds Value Best?',            summary: "The three dominant housing eras in Brisbane each have a different value proposition. Here is how they compare on price growth, maintenance cost, and long-term land content.",                       readTime: '7 min read' },
  { slug: 'heritage-overlays-brisbane',    tag: 'Buyers & Sellers', title: 'Understanding Heritage Overlays in Brisbane',                                  summary: "A heritage overlay restricts what you can build and demolish but also signals scarcity and value. Here is how they work under BCC CityPlan 2014 and what to check before you buy.",                 readTime: '6 min read' },
  { slug: 'airbnb-vs-longterm',            tag: 'Buyers & Sellers', title: 'Airbnb vs Long-Term Rental: The Real Numbers in Brisbane',                     summary: "Short-term rental can generate higher gross income but the true net return is often worse than long-term. Here are the real cost and income comparisons for Brisbane's inner east.",                readTime: '7 min read' },
  { slug: 'solicitor-vs-conveyancer-qld',  tag: 'Buyers & Sellers', title: 'Solicitor vs Conveyancer in Queensland: What Is the Difference?',              summary: "Both can handle your property settlement in Queensland. Here is what each does, what they cost, and when you genuinely need the full weight of a property solicitor.",                             readTime: '5 min read' },
  { slug: 'how-to-handle-offers-when-selling',              tag: 'Sellers',          title: 'How to Handle Offers When Selling Your Home',                                  summary: "Receiving an offer is one of the most important moments in a property sale. Here is how to read an offer, when to counter, how multiple-offer situations work, and what an unconditional offer really means in Queensland.",  readTime: '5 min read' },
  { slug: 'property-appraisal-brisbane',                    tag: 'Sellers',          title: 'What to Expect at a Property Appraisal in Brisbane',                          summary: "A property appraisal is your first step toward selling. Here is exactly what happens, what an agent looks at, and how to get the most out of the meeting.",                                                                  readTime: '4 min read' },
  { slug: 'capital-gains-tax-selling-home-brisbane',        tag: 'Sellers',          title: 'Capital Gains Tax When Selling Your Home in Brisbane 2026',                   summary: "What Brisbane home sellers need to know about capital gains tax, the main residence exemption, the 50% CGT discount, and partial exemptions when selling in 2026.",                                                          readTime: '6 min read' },
  { slug: 'selling-house-with-mortgage-brisbane',           tag: 'Sellers',          title: 'Selling a House With a Mortgage in Brisbane 2026',                            summary: "What Brisbane sellers need to know about mortgage discharge, net equity calculations, fixed-rate break costs, and how your lender fits into the settlement process.",                                                          readTime: '5 min read' },
  { slug: 'pre-settlement-inspection-seller-guide-qld',     tag: 'Buyers & Sellers', title: 'Pre-Settlement Inspection: A Seller\'s Guide for Queensland 2026',            summary: "What Queensland sellers need to know about the pre-settlement inspection, what buyers are checking, how to prepare, and how disputes are handled before settlement day.",                                                      readTime: '5 min read' },
  { slug: 'easements-property-brisbane-qld',                tag: 'Buyers & Sellers', title: 'Easements on Property in Brisbane: What Sellers Need to Know 2026',           summary: "A practical guide to easements on Brisbane properties in 2026, covering types of easements, disclosure obligations, how buyers react, and what sellers need to do before listing.",                                           readTime: '5 min read' },
  { slug: 'selling-by-auction-brisbane',                    tag: 'Sellers',          title: 'Selling by Auction in Brisbane: How It Works and What to Expect',             summary: "Auction suits a specific type of property and specific market conditions. Here is an honest account of the process from the vendor's side, including Queensland rules, reserve prices, vendor bids, and what happens if bidding falls short.",  readTime: '7 min read' },
  { slug: 'upgrading-property-brisbane-inner-east',         tag: 'Sellers',          title: 'Upgrading Property in Brisbane Inner East: Sell First or Buy First?',        summary: "Moving from one inner east home to a larger one involves a sequencing decision that most buyers underestimate. Here is how to navigate bridging finance, simultaneous settlement, and the current Brisbane market.",                           readTime: '8 min read' },
  { slug: 'fixtures-fittings-inclusions-property-sale-qld', tag: 'Sellers',          title: 'Fixtures, Fittings and Inclusions When Selling a House in Queensland',       summary: "What stays and what goes when you sell in Queensland? Understanding the fixture vs chattel distinction avoids disputes and contract complications at settlement.",          readTime: '6 min read' },
  { slug: 'development-potential-property-brisbane-inner-east', tag: 'Sellers',      title: "Development Potential When Selling Property in Brisbane's Inner East",        summary: "A lot with genuine development potential can attract a wider buyer pool and a higher price. Here is how to assess subdivision, duplex, and knockdown-rebuild potential accurately.",  readTime: '7 min read' },
  { slug: 'property-passed-in-at-auction-brisbane',            tag: 'Sellers',      title: 'What Happens If Your Property Passes In at Auction in Brisbane?',             summary: "A pass-in is one of the risks vendors weigh when choosing auction. Here is what happens after a property passes in, how to negotiate from that position, and what causes a pass-in in the first place.",  readTime: '7 min read' },
  { slug: 'school-catchments-property-brisbane-inner-east',    tag: 'Buyers & Sellers', title: "School Catchments and Property Values in Brisbane's Inner East",           summary: "School catchment access is one of the most consistent drivers of buyer competition in the inner east. Here is which catchments matter most and how sellers should market catchment access.",  readTime: '8 min read' },
  { slug: 'pool-safety-certificate-selling-brisbane-qld',      tag: 'Sellers',          title: 'Pool Safety Certificate Requirements When Selling in Queensland',          summary: "Queensland sellers with a pool must provide a pool safety certificate or Form 36 before sale. Here is what the rules require, which path is better for sellers, and how to get compliant before listing.",  readTime: '6 min read' },
  { slug: 'smoke-alarm-compliance-selling-queensland',          tag: 'Sellers',          title: 'Smoke Alarm Compliance When Selling Your Home in Queensland',              summary: "Queensland's 2022 smoke alarm laws require interconnected photoelectric alarms in every bedroom before sale. Here is what the rules require, how to check compliance, and what upgrading costs.",  readTime: '5 min read' },
];

const filters = ['All', 'Buyers', 'Sellers', 'Buyers & Sellers', 'Owners'];

const tagColors: Record<string, string> = {
  'Buyers & Sellers': '#f5d07a',
  'Buyers':           '#7ec8e3',
  'Sellers':          '#f5d07a',
  'Owners':           '#a8e6a3',
};

function filterCount(f: string): number {
  if (f === 'All')     return articles.length;
  if (f === 'Buyers')  return articles.filter(a => a.tag === 'Buyers'  || a.tag === 'Buyers & Sellers').length;
  if (f === 'Sellers') return articles.filter(a => a.tag === 'Sellers' || a.tag === 'Buyers & Sellers').length;
  return articles.filter(a => a.tag === f).length;
}
---


<Layout title="Insights & Articles | Daniel Gierach Property" description="Property insights and guides for Brisbane buyers, sellers and investors. Practical advice on auctions, contracts, flood mapping, stamp duty and more from Daniel Gierach.">

<!-- Hero -->
<section class="relative min-h-[40vh] flex items-center overflow-hidden" style="background:#0a0806;">
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1920&q=80&fm=webp&auto=format"
      alt="Brisbane property"
      class="w-full h-full object-cover"
      style="filter:grayscale(8%) brightness(0.4);"
    />
    <div class="absolute inset-0" style="background:linear-gradient(120deg,rgba(10,8,6,0.7) 0%,rgba(10,8,6,0.3) 100%);"></div>
  </div>
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-8 lg:px-12 pt-32 pb-16">
    <span class="eyebrow mb-4 reveal" style="display:block;color:#f5d07a;">Knowledge Base</span>
    <h1 class="reveal" data-delay="80"
      style="font-family:var(--font-serif);font-size:clamp(2.5rem,5vw,4rem);font-weight:400;color:#f0ece4;letter-spacing:-0.02em;line-height:1.1;margin-bottom:0.75rem;">
      Insights<br/><em style="font-style:italic;color:#f5d07a;">&amp; Articles.</em>
    </h1>
    <p class="reveal" data-delay="160"
      style="font-size:0.95rem;color:rgba(240,236,228,0.6);max-width:46ch;line-height:1.8;">
      Practical property knowledge for Brisbane buyers, sellers, and owners. No fluff.
    </p>
  </div>
</section>

<!-- Sticky Filter Bar -->
<div style="position:sticky;top:0;z-index:40;background:rgba(247,245,240,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(28,25,23,0.08);box-shadow:0 2px 16px rgba(28,25,23,0.05);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12" style="padding-top:0.9rem;padding-bottom:0.9rem;">
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;justify-content:space-between;">
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;">
{filters.map(f => (
        <button
          class="fpill"
          data-filter={f}
          style={`display:inline-flex;align-items:center;gap:0.45rem;padding:0.55rem 1.25rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;cursor:pointer;border:1.5px solid;line-height:1;transition:background 0.15s,color 0.15s,border-color 0.15s;background:${f==='All'?'#1c1917':'transparent'};color:${f==='All'?'#f0ece4':'#78716c'};border-color:${f==='All'?'#1c1917':'rgba(28,25,23,0.22)'};`}
        >
          {f === 'All' ? 'Show All' : f}
          <span style={`display:inline-flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 3px;font-size:0.6rem;font-weight:800;background:${f==='All'?'rgba(255,255,255,0.2)':'rgba(28,25,23,0.08)'};color:${f==='All'?'#f0ece4':'#78716c'};`}>
            {filterCount(f)}
          </span>
        </button>
      ))}
      </div>
      <!-- Search -->
      <div style="position:relative;flex-shrink:0;">
        <svg style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);pointer-events:none;" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#78716c" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input
          id="insight-search"
          type="search"
          placeholder="Search articles..."
          style="padding:0.55rem 1rem 0.55rem 2.25rem;font-family:var(--font-sans);font-size:0.7rem;color:#1c1917;background:#fff;border:1.5px solid rgba(28,25,23,0.22);outline:none;width:200px;transition:border-color 0.15s,box-shadow 0.15s;"
          onfocus="this.style.borderColor='#c4912a';this.style.boxShadow='0 0 0 3px rgba(196,145,42,0.12)'"
          onblur="this.style.borderColor='rgba(28,25,23,0.22)';this.style.boxShadow='none'"
        />
      </div>
    </div>
  </div>
</div>

<!-- Articles Grid -->
<section style="background:var(--color-base);padding:3.5rem 0 7rem;">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {articles.map((a, i) => (
        <a href={`/insights/${a.slug}`}
          class="insight-card reveal"
          data-tag={a.tag}
          data-title={a.title.toLowerCase()}
          data-summary={a.summary.toLowerCase()}
          data-delay={i * 60}
          style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:2rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.25s cubic-bezier(0.4,0,0.2,1),border-color 0.25s cubic-bezier(0.4,0,0.2,1),transform 0.3s cubic-bezier(0.34,1,0.64,1),box-shadow 0.3s cubic-bezier(0.34,1,0.64,1);position:relative;overflow:hidden;box-shadow:0 1px 4px rgba(28,25,23,0.05);"
          onmouseover="this.style.background='#f2efe9';this.style.borderColor='rgba(196,145,42,0.3)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(28,25,23,0.09)'"
          onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.transform='translateY(0)';this.style.boxShadow='0 1px 4px rgba(28,25,23,0.05)'"
        >
          <div style={`position:absolute;top:0;left:0;right:0;height:3px;background:${tagColors[a.tag] || '#c4912a'};`}></div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding-top:0.25rem;">
            <span style={`font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:${tagColors[a.tag] || '#c4912a'};display:inline-flex;align-items:center;gap:0.35rem;`}>
              <span style={`width:5px;height:5px;border-radius:50%;background:${tagColors[a.tag] || '#c4912a'};flex-shrink:0;`}></span>
              {a.tag}
            </span>
            <span style="font-family:var(--font-sans);font-size:0.6rem;color:#78716c;letter-spacing:0.06em;">{a.readTime}</span>
          </div>
          <div style="flex:1;">
            <h2 style="font-family:var(--font-serif);font-size:1.15rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.75rem;">
              {a.title}
            </h2>
            <p style="font-size:0.82rem;color:#78716c;line-height:1.75;">
              {a.summary}
            </p>
          </div>
          <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;margin-top:auto;">
            Read Article →
          </span>
        </a>
      ))}
    </div>

    <p id="no-articles" style="display:none;text-align:center;padding:4rem 0;font-size:0.9rem;color:#78716c;">No articles in this category.</p>

  </div>
</section>

<!-- Selling Guides by Suburb -->
<section style="background:#f7f5f0;padding:4rem 0 5rem;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div class="reveal" style="margin-bottom:2rem;">
      <span style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;display:block;margin-bottom:0.75rem;">Suburb Guides</span>
      <h2 style="font-family:var(--font-serif);font-size:1.75rem;font-weight:400;color:#1c1917;letter-spacing:-0.02em;line-height:1.2;margin-bottom:0.5rem;">Selling guides by suburb</h2>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;max-width:52ch;">Thinking about selling? Every suburb sells differently. Find your suburb below for timing, days-on-market data, and what drives value in your street.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.5rem;">
      {[
        { slug: 'selling-in-annerley',         name: 'Annerley' },
        { slug: 'selling-in-ascot',             name: 'Ascot' },
        { slug: 'selling-in-balmoral',          name: 'Balmoral' },
        { slug: 'selling-in-belmont',           name: 'Belmont' },
        { slug: 'selling-in-brisbane-cbd',      name: 'Brisbane CBD' },
        { slug: 'selling-in-bulimba',           name: 'Bulimba' },
        { slug: 'selling-in-camp-hill',         name: 'Camp Hill' },
        { slug: 'selling-in-cannon-hill',       name: 'Cannon Hill' },
        { slug: 'selling-in-carina',            name: 'Carina' },
        { slug: 'selling-in-carina-heights',    name: 'Carina Heights' },
        { slug: 'selling-in-carindale',         name: 'Carindale' },
        { slug: 'selling-in-coorparoo',         name: 'Coorparoo' },
        { slug: 'selling-in-dutton-park',       name: 'Dutton Park' },
        { slug: 'selling-in-east-brisbane',     name: 'East Brisbane' },
        { slug: 'selling-in-fortitude-valley',  name: 'Fortitude Valley' },
        { slug: 'selling-in-greenslopes',       name: 'Greenslopes' },
        { slug: 'selling-in-hamilton',          name: 'Hamilton' },
        { slug: 'selling-in-hawthorne',         name: 'Hawthorne' },
        { slug: 'selling-in-hemmant',           name: 'Hemmant' },
        { slug: 'selling-in-holland-park',      name: 'Holland Park' },
        { slug: 'selling-in-holland-park-west', name: 'Holland Park West' },
        { slug: 'selling-in-kangaroo-point',    name: 'Kangaroo Point' },
        { slug: 'selling-in-morningside',       name: 'Morningside' },
        { slug: 'selling-in-mount-gravatt',     name: 'Mount Gravatt' },
        { slug: 'selling-in-mount-gravatt-east',name: 'Mount Gravatt East' },
        { slug: 'selling-in-murarrie',          name: 'Murarrie' },
        { slug: 'selling-in-new-farm',          name: 'New Farm' },
        { slug: 'selling-in-norman-park',       name: 'Norman Park' },
        { slug: 'selling-in-paddington',        name: 'Paddington' },
        { slug: 'selling-in-red-hill',          name: 'Red Hill' },
        { slug: 'selling-in-seven-hills',       name: 'Seven Hills' },
        { slug: 'selling-in-stones-corner',     name: 'Stones Corner' },
        { slug: 'selling-in-tarragindi',        name: 'Tarragindi' },
        { slug: 'selling-in-teneriffe',         name: 'Teneriffe' },
        { slug: 'selling-in-tingalpa',          name: 'Tingalpa' },
        { slug: 'selling-in-upper-mount-gravatt',name: 'Upper Mount Gravatt' },
        { slug: 'selling-in-west-end',          name: 'West End' },
        { slug: 'selling-in-woolloongabba',     name: 'Woolloongabba' },
      ].map(s => (
        <a href={`/insights/${s.slug}`}
          style="display:flex;align-items:center;justify-content:space-between;padding:0.7rem 1rem;background:#ffffff;border:1px solid rgba(28,25,23,0.1);font-family:var(--font-sans);font-size:0.78rem;color:#1c1917;text-decoration:none;transition:background 0.15s,border-color 0.15s,color 0.15s;"
          onmouseover="this.style.background='#f2efe9';this.style.borderColor='rgba(196,145,42,0.3)';this.style.color='#c4912a'"
          onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.color='#1c1917'"
        >
          {s.name}
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Property Report CTA -->
<section style="background:#f2efe9;padding:4rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div class="reveal" style="padding:2.5rem;background:rgba(196,145,42,0.06);border:1px solid rgba(196,145,42,0.2);display:flex;flex-direction:column;align-items:center;text-align:center;gap:1rem;">
      <p style="font-family:var(--font-serif);font-size:1.1rem;font-style:italic;color:#1c1917;">What is your property worth?</p>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;">Get an instant digital property report, powered by Ray White, no obligation.</p>
      <a href="/walkthrough" class="btn-gold">
        Get My Free Property Report
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

</Layout>

<script>
  const activeBg: Record<string, string> = {
    'All':'#1c1917','Buyers':'#3a8fa8','Sellers':'#b89a2a','Buyers & Sellers':'#b89a2a','Owners':'#4a9e4a'
  };

  function insightMatches(tag: string, filter: string): boolean {
    if (filter === 'All') return true;
    if (filter === 'Buyers')  return tag === 'Buyers'  || tag === 'Buyers & Sellers';
    if (filter === 'Sellers') return tag === 'Sellers' || tag === 'Buyers & Sellers';
    return tag === filter;
  }

  const pills      = document.querySelectorAll<HTMLButtonElement>('.fpill');
  const cards      = document.querySelectorAll<HTMLElement>('.insight-card');
  const noEl       = document.getElementById('no-articles')!;
  const searchInput = document.getElementById('insight-search') as HTMLInputElement;

  let activeFilter = 'All';

  function applyFilter(active: string) {
    activeFilter = active;
    pills.forEach(p => {
      const f = p.dataset.filter!;
      const isActive = f === active;
      const bg = activeBg[f] || '#1c1917';
      p.style.background  = isActive ? bg    : 'transparent';
      p.style.color       = isActive ? '#fff' : '#78716c';
      p.style.borderColor = isActive ? bg    : 'rgba(28,25,23,0.22)';
      const badge = p.querySelector('span') as HTMLSpanElement;
      if (badge) {
        badge.style.background = isActive ? 'rgba(255,255,255,0.2)' : 'rgba(28,25,23,0.08)';
        badge.style.color      = isActive ? '#fff' : '#78716c';
      }
    });
    applyVisibility();
  }

  function applyVisibility() {
    const query = searchInput.value.trim().toLowerCase();
    let visible = 0;
    cards.forEach(c => {
      const tagMatch = insightMatches(c.dataset.tag!, activeFilter);
      const searchMatch = query === '' ||
        (c.dataset.title || '').includes(query) ||
        (c.dataset.summary || '').includes(query);
      const show = tagMatch && searchMatch;
      c.hidden = !show;
      if (show) visible++;
    });
    noEl.style.display = visible === 0 ? 'block' : 'none';
  }

  pills.forEach(p => p.addEventListener('click', () => applyFilter(p.dataset.filter!)));
  searchInput.addEventListener('input', applyVisibility);
  applyFilter('All');
</script>
