---
import Layout from '../../layouts/Layout.astro';

const articles = [
  { slug: 'unconditional-offer',       tag: 'Buyers & Sellers', title: 'What Is an Unconditional Offer?',                    summary: "An unconditional offer is one of the most powerful tools in property and one of the most misunderstood. Here's what it means and when to use it.",                                                          readTime: '4 min read' },
  { slug: 'mortgage-broker',           tag: 'Buyers',           title: 'Which Mortgage Broker Should I Use?',               summary: "Not all brokers are equal. Here's what to look for, what to ask, and the red flags that should send you elsewhere.",                                                                                   readTime: '5 min read' },
  { slug: 'buyers-agent',              tag: 'Buyers',           title: "What Is a Buyer's Agent and Do I Need One?",        summary: "A buyer's agent works exclusively for you, not the vendor. Understanding what they do and what they cost helps you decide if it's worth it.",                                                          readTime: '5 min read' },
  { slug: 'engage-right-builder',      tag: 'Owners',           title: 'How to Engage the Right Builder',                   summary: "Choosing the wrong builder is an expensive mistake. Here's how to verify licences, read contracts, and protect yourself before work starts.",                                                          readTime: '5 min read' },
  { slug: 'flood-mapping',             tag: 'Buyers & Sellers', title: 'Is Your Property in a Flood Zone?',                 summary: "Brisbane's flood mapping affects insurance, value, and what you can build. Here's how to check your property and what to do with the results.",                                                         readTime: '4 min read' },
  { slug: 'what-happens-at-settlement',tag: 'Buyers & Sellers', title: 'What Happens at Settlement?',                       summary: "Settlement day can feel like a black box. Here's exactly what happens, who does what, and how to make sure nothing goes wrong at the last minute.",                                                       readTime: '5 min read' },
  { slug: 'prepare-home-for-sale',     tag: 'Sellers',          title: 'How to Prepare Your Home for Sale',                 summary: 'First impressions drive price. A focused pre-sale plan with the right repairs and the right styling can add tens of thousands to your result.',                                                          readTime: '6 min read' },
  { slug: 'understanding-the-contract',tag: 'Buyers & Sellers', title: 'Understanding the REIQ Contract of Sale',           summary: "The standard Queensland contract is straightforward once you know what to look for. Here's what every buyer and seller should understand before signing.",                                              readTime: '5 min read' },
  { slug: 'stamp-duty-queensland',     tag: 'Buyers',           title: "Stamp Duty in Queensland: What You'll Actually Pay", summary: "Transfer duty is one of the biggest upfront costs in property. Here's how it's calculated, what concessions are available, and how to budget for it.",                                                readTime: '4 min read' },
  { slug: 'building-pest-report',      tag: 'Buyers',           title: 'How to Read a Building and Pest Report',            summary: "A building and pest report can be overwhelming. Here's what the findings actually mean and which issues are dealbreakers versus normal wear.",                                                         readTime: '5 min read' },
  { slug: 'auction-strategy',          tag: 'Buyers & Sellers', title: 'Auction Strategy: How to Buy and Sell at Auction',  summary: "Auctions in Brisbane's inner east are competitive. Whether you're bidding or selling under the hammer, strategy matters more than most people realise.",                                              readTime: '6 min read' },
  { slug: 'when-to-sell',              tag: 'Sellers',          title: 'When Is the Right Time to Sell?',                   summary: "Timing a property sale well can make a meaningful difference to your result. Here's how to think about market conditions, personal timing, and what actually drives price.", readTime: '5 min read' },
];

const filters = ['All', 'Buyers', 'Sellers', 'Buyers & Sellers', 'Owners'];

const tagColors: Record<string, string> = {
  'Buyers & Sellers': '#f5d07a',
  'Buyers':           '#7ec8e3',
  'Sellers':          '#f5d07a',
  'Owners':           '#a8e6a3',
};

function filterCount(f: string): number {
  if (f === 'All')     return articles.length;
  if (f === 'Buyers')  return articles.filter(a => a.tag === 'Buyers'  || a.tag === 'Buyers & Sellers').length;
  if (f === 'Sellers') return articles.filter(a => a.tag === 'Sellers' || a.tag === 'Buyers & Sellers').length;
  return articles.filter(a => a.tag === f).length;
}
---

<style>
  .filter-bar { display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:2.5rem; align-items:center; }
  .fpill {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.5rem 1.1rem; border-radius: 999px;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    cursor: pointer; border: 1.5px solid rgba(28,25,23,0.2);
    background: transparent; color: #78716c;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .fpill[data-active="true"] { color: #fff; }
  .fpill[data-active="true"][data-filter="All"]              { background:#1c1917; border-color:#1c1917; }
  .fpill[data-active="true"][data-filter="Buyers"]           { background:#3a8fa8; border-color:#3a8fa8; }
  .fpill[data-active="true"][data-filter="Sellers"]          { background:#b89a2a; border-color:#b89a2a; }
  .fpill[data-active="true"][data-filter="Buyers & Sellers"] { background:#b89a2a; border-color:#b89a2a; }
  .fpill[data-active="true"][data-filter="Owners"]           { background:#4a9e4a; border-color:#4a9e4a; }
  .fpill-count {
    display:inline-flex; align-items:center; justify-content:center;
    width:18px; height:18px; border-radius:999px;
    font-size:0.6rem; font-weight:800;
    background:rgba(28,25,23,0.08); color:#78716c;
    transition: background 0.15s, color 0.15s;
  }
  .fpill[data-active="true"] .fpill-count { background:rgba(255,255,255,0.22); color:#fff; }
</style>

<Layout title="Insights & Articles | Daniel Gierach Property" description="Property insights and guides for Brisbane buyers, sellers and investors. Practical advice on auctions, contracts, flood mapping, stamp duty and more from Daniel Gierach.">

<!-- Hero -->
<section class="relative min-h-[40vh] flex items-center overflow-hidden" style="background:#0a0806;">
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1920&q=80&fm=webp&auto=format"
      alt="Brisbane property"
      class="w-full h-full object-cover"
      style="filter:grayscale(8%) brightness(0.4);"
    />
    <div class="absolute inset-0" style="background:linear-gradient(120deg,rgba(10,8,6,0.7) 0%,rgba(10,8,6,0.3) 100%);"></div>
  </div>
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-8 lg:px-12 pt-32 pb-16">
    <span class="eyebrow mb-4 reveal" style="display:block;color:#f5d07a;">Knowledge Base</span>
    <h1 class="reveal" data-delay="80"
      style="font-family:var(--font-serif);font-size:clamp(2.5rem,5vw,4rem);font-weight:400;color:#f0ece4;letter-spacing:-0.02em;line-height:1.1;margin-bottom:0.75rem;">
      Insights<br/><em style="font-style:italic;color:#f5d07a;">&amp; Articles.</em>
    </h1>
    <p class="reveal" data-delay="160"
      style="font-size:0.95rem;color:rgba(240,236,228,0.6);max-width:46ch;line-height:1.8;">
      Practical property knowledge for Brisbane buyers, sellers, and owners. No fluff.
    </p>
  </div>
</section>

<!-- Articles Grid -->
<section style="background:var(--color-base);padding:6rem 0 7rem;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">

    <!-- Filter Pills -->
    <div class="filter-bar">
      {filters.map(f => (
        <button class="fpill" data-filter={f} data-active={f === 'All' ? 'true' : 'false'}>
          {f}
          <span class="fpill-count">{filterCount(f)}</span>
        </button>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {articles.map((a, i) => (
        <a href={`/insights/${a.slug}`}
          class="insight-card reveal"
          data-tag={a.tag}
          data-delay={i * 60}
          style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:2rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.2s,border-color 0.2s,transform 0.2s;position:relative;overflow:hidden;"
          onmouseover="this.style.background='#f2efe9';this.style.borderColor='rgba(196,145,42,0.35)';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.transform='translateY(0)'"
        >
          <div style={`position:absolute;top:0;left:0;right:0;height:3px;background:${tagColors[a.tag] || '#c4912a'};`}></div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding-top:0.25rem;">
            <span style={`font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:${tagColors[a.tag] || '#c4912a'};display:inline-flex;align-items:center;gap:0.35rem;`}>
              <span style={`width:5px;height:5px;border-radius:50%;background:${tagColors[a.tag] || '#c4912a'};flex-shrink:0;`}></span>
              {a.tag}
            </span>
            <span style="font-family:var(--font-sans);font-size:0.6rem;color:#78716c;letter-spacing:0.06em;">{a.readTime}</span>
          </div>
          <div style="flex:1;">
            <h2 style="font-family:var(--font-serif);font-size:1.15rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.75rem;">
              {a.title}
            </h2>
            <p style="font-size:0.82rem;color:#78716c;line-height:1.75;">
              {a.summary}
            </p>
          </div>
          <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#c4912a;margin-top:auto;">
            Read Article →
          </span>
        </a>
      ))}
    </div>

    <p id="no-articles" style="display:none;text-align:center;padding:4rem 0;font-size:0.9rem;color:#78716c;">No articles in this category.</p>

  </div>
</section>

<!-- Property Report CTA -->
<section style="background:#f2efe9;padding:4rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
    <div class="reveal" style="padding:2.5rem;background:rgba(196,145,42,0.06);border:1px solid rgba(196,145,42,0.2);display:flex;flex-direction:column;align-items:center;text-align:center;gap:1rem;">
      <p style="font-family:var(--font-serif);font-size:1.1rem;font-style:italic;color:#1c1917;">What is your property worth?</p>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;">Get an instant digital property report, powered by Ray White, no obligation.</p>
      <a href="/appraisal" class="btn-gold">
        Get My Free Property Report
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

</Layout>

<script>
  function insightMatches(tag: string, filter: string): boolean {
    if (filter === 'All') return true;
    if (filter === 'Buyers')  return tag === 'Buyers'  || tag === 'Buyers & Sellers';
    if (filter === 'Sellers') return tag === 'Sellers' || tag === 'Buyers & Sellers';
    return tag === filter;
  }

  const pills  = document.querySelectorAll<HTMLButtonElement>('.fpill');
  const cards  = document.querySelectorAll<HTMLElement>('.insight-card');
  const noEl   = document.getElementById('no-articles')!;

  function applyFilter(active: string) {
    pills.forEach(p => p.dataset.active = (p.dataset.filter === active) ? 'true' : 'false');
    let visible = 0;
    cards.forEach(c => {
      const show = insightMatches(c.dataset.tag!, active);
      c.hidden = !show;
      if (show) visible++;
    });
    noEl.style.display = visible === 0 ? 'block' : 'none';
  }

  pills.forEach(p => p.addEventListener('click', () => applyFilter(p.dataset.filter!)));
  applyFilter('All');
</script>
