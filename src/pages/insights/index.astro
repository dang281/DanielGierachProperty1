<script>
  const activeBg: Record<string, string> = {
    'All':'#b98229','Buyers':'#3a8fa8','Sellers':'#b89a2a','Suburbs':'#5e7d63','Buyers & Sellers':'#b89a2a','Owners':'#4a9e4a'
  };

  function insightMatches(tag: string, filter: string): boolean {
    if (filter === 'All') return true;
    return tag === filter;
  }

  const pills       = document.querySelectorAll<HTMLButtonElement>('.fpill');
  const cards       = document.querySelectorAll<HTMLElement>('.insight-card');
  const noEl        = document.getElementById('no-articles')!;
  const searchInput = document.getElementById('insight-search') as HTMLInputElement;
  const clearBtn    = document.getElementById('search-clear') as HTMLButtonElement;

  let activeFilter = 'All';

  function applyFilter(active: string) {
    activeFilter = active;
    pills.forEach(p => {
      const f = p.dataset.filter!;
      const isActive = f === active;
      const bg = activeBg[f] || '#f2ead4';
      p.style.background  = isActive ? bg    : 'transparent';
      p.style.color       = isActive ? '#fff' : 'rgba(25,24,23,0.75)';
      p.style.borderColor = isActive ? bg    : 'rgba(107,70,16,0.35)';
      const badge = p.querySelector('span') as HTMLSpanElement;
      if (badge) {
        badge.style.background = isActive ? 'rgba(255,255,255,0.25)' : 'rgba(107,70,16,0.1)';
        badge.style.color      = isActive ? '#fff' : 'rgba(25,24,23,0.75)';
      }
    });
    applyVisibility();
  }

  function applyVisibility() {
    const query = searchInput.value.trim().toLowerCase();
    clearBtn.style.display = query ? 'block' : 'none';
    let visible = 0;
    cards.forEach(c => {
      const tagMatch = insightMatches(c.dataset.tag!, activeFilter);
      const searchMatch = query === '' ||
        (c.dataset.title || '').includes(query) ||
        (c.dataset.summary || '').includes(query);
      const show = tagMatch && searchMatch;
      c.hidden = !show;
      if (show) visible++;
    });
    noEl.style.display = visible === 0 ? 'block' : 'none';
  }

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    searchInput.focus();
    applyVisibility();
  });

  pills.forEach(p => p.addEventListener('click', () => applyFilter(p.dataset.filter!)));
  searchInput.addEventListener('input', applyVisibility);

  // Pre-fill search from ?q= URL parameter (supports WebSite SearchAction)
  const urlQ = new URLSearchParams(window.location.search).get('q');
  if (urlQ) {
    searchInput.value = urlQ;
  }
  applyFilter('All');
</script>

