  { slug: 'when-to-book-property-walkthrough-before-selling', tag: 'Sellers', title: 'When to Book a Property Walkthrough Before Selling', summary: "The walkthrough that returns the most value is the one done with time on the clock. Here is how to think about timing based on where you are in the journey.", readTime: '6 min read' },
  { slug: 'cgt-main-residence-exemption-verification-queensland-sellers', tag: 'Sellers', title: 'CGT Main Residence Exemption: What Sellers Must Prove', summary: "Selling your main residence in Queensland and claiming the CGT exemption. What evidence proves the home was your main residence, what triggers ATO review, and the practical records to keep before settlement.", readTime: '7 min read' },
  { slug: 'body-corporate-financial-health-check-buying-selling-unit', tag: 'Sellers', title: 'Body Corporate Financial Health Check Before Selling Your Unit', summary: "Buyers and their solicitors look at the body corporate before they look at the unit. Here is how to assess your scheme's health and which red flags can hold up a sale.", readTime: '8 min read' },
  { slug: 'water-damage-mould-disclosure-inspection-findings-brisbane', tag: 'Sellers', title: 'Water Damage and Mould Disclosure for Brisbane Sellers', summary: "Brisbane's storm season makes water damage and mould common findings. Here is how to handle disclosure properly, fix the underlying cause, and protect your contract.", readTime: '7 min read' },
  { slug: 'easement-removal-covenant-discharge-brisbane-inner-east-selling', tag: 'Sellers', title: 'Easements and Covenants: Removing Them Before Selling', summary: "Old easements and restrictive covenants registered against your title can quietly cost you tens of thousands at sale. Here is how to identify them and whether removing them is worth the effort.", readTime: '7 min read' },
  { slug: 'settlement-statement-review-pre-settlement-seller-checklist', tag: 'Sellers', title: 'Settlement Statement Review: Pre-Settlement Seller Checklist', summary: "The settlement statement is the document that decides exactly what hits your bank account. Here is the line-by-line review checklist before you sign off.", readTime: '6 min read' },
  { slug: 'selling-investment-property-loss-carry-forward-cgt-brisbane', tag: 'Sellers', title: 'Investment Property Sale: Capital Losses and CGT Strategy', summary: "Carried forward capital losses can substantially reduce the tax on a Brisbane investment property sale. Here is how the calculation works and the questions to take to your accountant.", readTime: '7 min read' },
  { slug: '2032-olympics-impact-inner-east-brisbane-property-values', tag: 'Buyers & Sellers', title: '2032 Brisbane Olympics: Impact on Inner East Property Values', summary: "The 2032 Brisbane Olympics will reshape the inner east in real ways. Here is a calm view of which suburbs sit in the line of impact and how to think about timing as a seller.", readTime: '9 min read' },
  { slug: 'conveyancing-cooling-off-period-exceptions-queensland-2026', tag: 'Sellers', title: 'Cooling-Off Period Exceptions in Queensland Property Contracts', summary: "Standard residential contracts include a buyer's cooling-off period, but several exceptions remove or modify it. Here is how the rules work and how they affect your strategy as a seller.", readTime: '6 min read' },
  { slug: 'vendor-paid-digital-marketing-facebook-google-ads-brisbane', tag: 'Sellers', title: 'Vendor-Paid Digital Marketing for Brisbane Property', summary: "Paid Facebook, Instagram, and Google ads can supplement your portal listing and reach buyers the major sites miss. Here is when it works, what it costs, and how to know if you are getting value.", readTime: '7 min read' },
  { slug: 'bushfire-risk-disclosure-selling-brisbane-property', tag: 'Sellers', title: 'Bushfire Risk Disclosure for Brisbane Property Sellers', summary: "Bushfire mapping and overlays affect specific pockets of inner east Brisbane. Here is how the disclosure system works, which buyers will check it, and what it means for your sale.", readTime: '6 min read' },
  { slug: 'selling-vs-renting-out-decision-brisbane-inner-east', tag: 'Sellers', title: 'Sell or Rent Out Your Brisbane Home? A Decision Framework', summary: "The sell-or-hold decision is one of the most consequential financial choices you make. Here is a clean framework covering the financial, tax, and lifestyle factors that actually matter.", readTime: '8 min read' },
  { slug: 'real-estate-photography-quality-difference-price-brisbane', tag: 'Sellers', title: 'Real Estate Photography: Quality and Sale Price in Brisbane', summary: "Photography is the front door of your sale campaign. Here is what separates good photography from mediocre, what it costs, and how it affects the price you achieve.", readTime: '7 min read' },
  { slug: 'when-to-reduce-asking-price-brisbane-property', tag: 'Sellers', title: 'When to Reduce the Asking Price on Your Brisbane Property', summary: "A price reduction is one of the hardest decisions in a campaign. Here is how to read the signals honestly, when to act, and how much to reduce by to actually move the buyer pool.", readTime: '6 min read' },
  { slug: 'how-many-open-homes-before-property-sells-brisbane', tag: 'Sellers', title: 'How Many Open Homes Before a Brisbane Property Sells?', summary: "A practical benchmark for what to expect across an inner east sales campaign: typical open home counts, attendance numbers, and what variations from the norm signal.", readTime: '6 min read' },
  { slug: 'negotiating-price-after-offer-strategy-brisbane-sellers', tag: 'Sellers', title: 'Negotiating Price After an Offer: Strategy for Brisbane Sellers', summary: "Receiving an offer is one part of selling. Closing well is the other. Here is the negotiation framework for Brisbane sellers covering counter-offers, multiple offers, and reading buyer signals.", readTime: '8 min read' },
  { slug: 'open-home-vs-private-inspection-brisbane-strategy', tag: 'Sellers', title: 'Open Home vs Private Inspection: Strategy for Brisbane Sellers', summary: "The choice between open homes and private inspections affects buyer competition, price, and how the campaign actually feels. Here is when each format works best.", readTime: '7 min read' },
  { slug: 'agent-recommendations-trades-trusted-suppliers-brisbane-inner-east', tag: 'Sellers', title: 'Agent Recommendations: Trades, Brokers, and Suppliers in Brisbane Inner East', summary: "A local agent's network of trades, brokers, and suppliers can save you weeks and thousands. Here is how to use those recommendations well, what to verify, and what to push back on.", readTime: '7 min read' },
  { slug: 'buyers-agents-when-to-engage-brisbane-inner-east', tag: 'Buyers', title: "When to Engage a Buyers' Agent in Brisbane Inner East", summary: "A buyers' agent works exclusively for the buyer. Here is when engaging one makes sense in Brisbane's inner east, what they cost, and how to choose well.", readTime: '7 min read' },
  { slug: 'mortgage-broker-vs-bank-direct-brisbane-property-buyers', tag: 'Buyers', title: 'Mortgage Broker vs Bank Direct: A Brisbane Buyer\'s Guide', summary: "Should you go to your bank or use a broker for your Brisbane property loan? Here is the practical comparison covering rates, service, complexity, and which path suits which buyer.", readTime: '7 min read' },
  { slug: 'selling-during-divorce-separation-queensland-process', tag: 'Sellers', title: 'Selling the Family Home During Divorce or Separation', summary: "A practical guide to selling during a separation. The process, the consent issues, the choice of agent, and how to manage the campaign with discretion.", readTime: '8 min read' },
  { slug: 'inheriting-property-with-siblings-queensland-options', tag: 'Sellers', title: 'Inheriting Property with Siblings in Queensland: Your Options', summary: "When you inherit a Brisbane property with siblings, you face a financial decision and a family decision. Here are the practical options and the structures that work.", readTime: '8 min read' },
  { slug: 'downsizing-brisbane-inner-east-strategy-process', tag: 'Sellers', title: 'Downsizing in Brisbane Inner East: Strategy and Process', summary: "Downsizing well requires more thought than upsizing. Here is the strategic framework, the sequencing decisions, and the financial considerations.", readTime: '9 min read' },
  { slug: 'selling-house-with-pool-brisbane-buyer-perspective', tag: 'Sellers', title: "Selling a Brisbane Home with a Pool: The Buyer's Perspective", summary: "Pools split buyer opinion. Some want them, others see them as a maintenance burden. Here is how pool condition and configuration affect your inner east sale price.", readTime: '7 min read' },
  { slug: 'pre-listing-styling-staging-brisbane-cost-return', tag: 'Sellers', title: 'Pre-Listing Styling and Staging in Brisbane: Cost and Return', summary: "Professional styling can transform how a property presents and what it sells for. Here is what styling actually costs, what it delivers, and when it is worth the spend.", readTime: '7 min read' },
  { slug: 'inspection-day-presentation-checklist-brisbane-sellers', tag: 'Sellers', title: 'Inspection Day Presentation Checklist for Brisbane Sellers', summary: "A 30-minute pre-inspection checklist that lifts how your home presents. Practical, repeatable, and effective for every open home through your campaign.", readTime: '6 min read' },
  { slug: 'brisbane-property-buying-process-overseas-australian-citizen', tag: 'Buyers', title: 'Buying Brisbane Property as an Australian Citizen Living Overseas', summary: "Australian citizens overseas can buy Brisbane property. Here is the practical guide to tax, finance, contracts, and remote logistics.", readTime: '8 min read' },
];

const filters = ['All', 'Buyers', 'Sellers', 'Buyers & Sellers', 'Owners'];

const tagColors: Record<string, string> = {
  'Buyers & Sellers': '#f5d07a',
  'Buyers':           '#7ec8e3',
  'Sellers':          '#f5d07a',
  'Owners':           '#a8e6a3',
};

function filterCount(f: string): number {
  if (f === 'All') return articles.length;
  // Exclusive counts so they sum to the Show All total. Articles tagged "Buyers & Sellers"
  // are counted only under that bucket, not double-counted under Buyers and Sellers.
  return articles.filter(a => a.tag === f).length;
}
