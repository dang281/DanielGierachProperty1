const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do Brisbane sellers have to disclose a previous cash sale that fell through?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no specific statutory requirement under Queensland law to tell buyers that a prior cash buyer walked away. However, the seller disclosure statement under the new Property Law Act 2023 regime requires you to disclose certain prescribed information, and if the reason the cash sale collapsed reveals a defect, encumbrance, or material issue with the property, that underlying issue almost certainly does need to be disclosed. Sellers should be careful not to confuse 'we don't have to mention that it happened' with 'we don't have to mention what it revealed.'"
      }
    },
    {
      "@type": "Question",
      "name": "Should sellers tell buyers about a previous off-market campaign that did not sell?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not as a legal obligation, but increasingly as a practical one. Sophisticated buyers and most buyer's agents now run search history on the property through RP Data, CoreLogic, and prior listing portals. A prior off-market or quiet campaign that resurfaces in a buyer's agent's search creates a credibility problem if the seller has been silent about it. The better approach is to let your agent handle the framing honestly: the property was marketed quietly to a narrow buyer pool, those buyers did not move, and the seller has now committed to a full public campaign."
      }
    },
    {
      "@type": "Question",
      "name": "Do you have to disclose previous price reductions on a Brisbane property listing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no obligation under Queensland law to volunteer prior asking prices or to publish a history of reductions. However, that information is freely visible to buyers through Domain, realestate.com.au, and CoreLogic, all of which preserve listing history. Pretending the history does not exist damages trust when a buyer raises it at inspection. A seller is better served by acknowledging the prior campaign, explaining what was different (price expectation, presentation, agent, timing), and demonstrating what has changed for this campaign."
      }
    }
  ]
};
