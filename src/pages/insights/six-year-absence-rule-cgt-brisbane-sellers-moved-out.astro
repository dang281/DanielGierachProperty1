const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the 6-year absence rule for CGT in Australia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Under Section 118-145 of the Income Tax Assessment Act 1997, if you move out of your main residence and rent it out, you can continue to treat that property as your main residence for capital gains tax purposes for up to 6 years. The election is only available if you have not nominated another property as your main residence during the absence. The 6 year clock resets each time you move back in and the property becomes your main residence again before being rented again."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use the 6-year absence rule if I bought another home while away?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Generally no. You can only treat one property as your main residence at any given time for CGT purposes. If you bought another home and treated it as your main residence during the absence period, the original Brisbane home cannot continue to be treated as your main residence for the same period. There is a limited 6 month overlap concession when moving between homes, but it does not extend to long-term concurrent ownership. The election is not automatic and is made by the way you report the sale in your tax return."
      }
    },
    {
      "@type": "Question",
      "name": "Does the 6-year clock reset if I move back into my Brisbane home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Each time you re-establish the property as your main residence and then move out again to rent it, a new 6 year absence period begins. There is no lifetime cap on the number of times the rule can be used, provided each absence period stays within 6 years and you do not elect another property as your main residence during that period. The dates and the nature of each move back in matter, and the ATO can ask for evidence that the property genuinely returned to being your main residence rather than a brief stay engineered to reset the clock."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I am away for more than 6 years and rent out my Brisbane home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If your absence is longer than 6 years and the property has been income-producing throughout that time, the absence rule covers the first 6 years and the period beyond that becomes a partial exemption calculation. The capital gain is apportioned across the days the property was treated as your main residence (including the 6 year absence period) and the days it was not. The 50% CGT discount still applies on the taxable portion if you have held the property for more than 12 months."
      }
    }
  ]
};
