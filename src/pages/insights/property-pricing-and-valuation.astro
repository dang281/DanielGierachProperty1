---
import Layout from '../../layouts/Layout.astro';

const clusterSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Pricing, Timing and Valuation",
  "description": "How to set an asking price, when to sell, what a home is worth, and how long a Brisbane sale typically takes.",
  "url": "https://danielgierach.com/insights/property-pricing-and-valuation/",
  "author": { "@type": "Person", "name": "Daniel Gierach", "url": "https://danielgierach.com/about" }
};

const articles = [
  {
    slug: 'how-much-is-my-home-worth-brisbane',
    title: 'How Much Is My Home Worth in Brisbane?',
    summary: 'Online valuations miss the things that matter most: land configuration, aspect, renovation quality, and how comparable sales are actually selected. Here is how Brisbane property value is really determined.',
  },
  {
    slug: 'property-appraisal-brisbane',
    title: 'What to Expect at a Property Appraisal in Brisbane',
    summary: 'A property appraisal is your first step toward selling. Here is exactly what happens, what an agent looks at, and how to get the most out of the meeting.',
  },
  {
    slug: 'property-appraisal-vs-valuation-brisbane',
    title: 'Property Appraisal vs Valuation in Brisbane',
    summary: 'The difference between an agent appraisal and a formal bank or statutory valuation, and when you need each in a sale.',
  },
  {
    slug: 'how-to-price-your-property',
    title: 'How to Price Your Property for Sale in Brisbane',
    summary: 'Pricing is the most consequential decision you make when selling. Here is how to set a price that attracts the right buyers and maximises your result.',
  },
  {
    slug: 'how-to-price-your-property-for-sale-brisbane',
    title: 'How to Price Your Property for Sale in Brisbane 2026',
    summary: "Should you set a fixed price, go offers over, or take it to auction? Here is how pricing works in Brisbane's inner east market and how to avoid the most common mistakes.",
  },
  {
    slug: 'best-time-to-sell-brisbane',
    title: 'Best Time to Sell Your Home in Brisbane',
    summary: "Brisbane's selling seasons do not follow Sydney or Melbourne. Here is an honest look at seasonal trends, auction clearance rates, and why autumn consistently outperforms expectations in the inner east.",
  },
  {
    slug: 'when-to-sell',
    title: 'When Is the Right Time to Sell?',
    summary: "Timing a property sale well can make a meaningful difference to your result. Here's how to think about market conditions, personal timing, and what actually drives price.",
  },
  {
    slug: 'how-long-does-it-take-to-sell-a-home-in-brisbane',
    title: 'How Long Does It Take to Sell a Home in Brisbane?',
    summary: 'From preparation through to settlement, the full timeline for a Brisbane sale is typically 12 to 24 weeks. Here is what happens at each stage and what causes delays.',
  },
  {
    slug: 'downsizing-property-brisbane',
    title: 'Downsizing Property in Brisbane Inner East: A Practical Guide',
    summary: 'A guide for Brisbane homeowners considering downsizing, the financial and emotional considerations, the best inner east suburbs to move to, and how to plan the transition.',
  },
  {
    slug: 'ai-valuation-tools-vs-agent-appraisal-brisbane-2026',
    title: 'AI Valuation Tools vs a Real Agent Appraisal in Brisbane 2026',
    summary: 'Online property estimates from CoreLogic, Domain, and realestate.com.au are useful starting points but routinely miss the factors that move Brisbane prices. Here is what each tool can and cannot tell you.',
  },
  {
    slug: 'walkthrough-vs-appraisal-brisbane',
    title: 'Walkthrough vs Appraisal: What is the Difference?',
    summary: 'A walkthrough and an appraisal are not the same thing. Here is what each meeting covers, when to book each, and what to prepare so you get maximum value from both.',
  },
  {
    slug: 'what-daniel-looks-for-property-walkthrough',
    title: 'What Daniel Looks for at a Property Walkthrough',
    summary: 'The four big categories an experienced inner east agent assesses during a walkthrough, and what each finding tells you about how to prepare, price, and time your sale.',
  },
  {
    slug: 'what-to-expect-property-walkthrough-brisbane',
    title: 'What to Expect at a Property Walkthrough in Brisbane',
    summary: 'Daniel runs a free in-home property walkthrough across Brisbane\'s inner east. Here is exactly what happens, what he assesses, and what you will leave the meeting knowing.',
  },
  {
    slug: 'when-to-book-property-walkthrough-before-selling',
    title: 'When to Book a Property Walkthrough Before Selling',
    summary: 'The most useful walkthrough is the one done well before listing. Here is when to book based on your property\'s condition, your timeline, and what preparation you are planning.',
  },
  {
    slug: 'free-property-walkthrough-brisbane-faq',
    title: 'Free Property Walkthrough Brisbane: FAQ',
    summary: "Common questions about Daniel's free in-home property walkthrough in Brisbane's inner east. Suburbs covered, what happens at the meeting, and what you walk away with.",
  },
  {
    slug: 'when-to-reduce-asking-price-brisbane-property',
    title: 'When to Reduce the Asking Price on Your Brisbane Property',
    summary: 'A price reduction is one of the hardest decisions in a sale campaign. Here is how to read the signals early, what the data says about campaign duration, and how to act before you lose momentum.',
  },
  {
    slug: 'selling-house-after-renovation-brisbane-pricing-strategy',
    title: 'Selling After a Renovation: Pricing Strategy for Brisbane Homes',
    summary: 'A renovated home is positioned differently to one that needs work. Here is how to price it accurately, what buyers expect from renovation quality, and how to present the work without overclaiming.',
  },
  {
    slug: 'downsizing-brisbane-inner-east-strategy-process',
    title: 'Downsizing in Brisbane Inner East: Strategy and Process',
    summary: 'Downsizing well requires more thought than upsizing. Here is the strategic framework, the sequencing decision between selling and buying, and how to make the transition in the inner east.',
  },
  {
    slug: 'how-property-valuations-work-brisbane',
    title: 'How Brisbane Property Valuations Work: What Moves the Number Up or Down',
    summary: 'Bank valuation and agent appraisal are not the same thing. Here is how each is produced, why they differ, and the five factors that consistently move a Brisbane property valuation.',
  },
  {
    slug: 'compare-multiple-agent-appraisals-brisbane-before-listing',
    title: 'How to Compare Multiple Brisbane Agent Appraisals Before Listing',
    summary: 'Three agents will give you three different numbers. Here is how to read each appraisal honestly, spot the inflated one, and choose the agent who will actually deliver the price.',
  },
  {
    slug: 'unimproved-capital-value-ucv-brisbane-selling',
    title: 'How Brisbane Unimproved Capital Value (UCV) Affects Your Sale',
    summary: 'The unimproved capital value sits on every Brisbane rates notice and confuses both buyers and sellers. Here is what UCV actually is, what it changes when you sell, and how to handle it.',
  },
  {
    slug: 'selling-brisbane-corner-block-developer-premium-explained',
    title: 'Selling a Brisbane Corner Block: The Developer Premium Explained',
    summary: "Corner blocks in Brisbane's inner east often attract a developer premium that single-frontage blocks do not. Here is how dual frontage, splitter potential and access flexibility translate into price.",
  },
  {
    slug: 'how-long-to-sell-house-brisbane',
    title: 'How Long Does It Take to Sell a House in Brisbane in 2026?',
    summary: 'The honest answer on Brisbane property sale timelines in 2026: inner east vs outer suburbs, auction vs private treaty, what drives a faster result, and when to reprice.',
  },
  {
    slug: 'highset-vs-lowset-brisbane-homes',
    title: 'Highset vs Lowset Homes in Brisbane: What Buyers Actually Pay Extra For',
    summary: "Brisbane's two dominant structural forms carry distinct trade-offs. Here is what drives the price gap between highset and lowset homes and when the premium is actually worth it.",
  },
  {
    slug: 'school-catchment-boundaries-brisbane-property-sale-price',
    title: 'How Brisbane School Catchment Boundaries Affect Property Sale Price',
    summary: "In Brisbane's inner east the state school catchment line can be the single largest pricing variable on a family home. Here is how the boundary itself affects sale price, when the premium is real, and what to verify before listing.",
  },
  {
    slug: 'brisbane-lot-shape-frontage-depth-battle-axe-sale-value',
    title: 'How Brisbane Property Lot Shape Affects Sale Value: Frontage, Depth and Battle-Axe Blocks',
    summary: "Two Brisbane blocks of identical area can sell at very different prices because of shape. How frontage, depth, and battle-axe configuration move sale value in the inner east, who pays the premium, and what sellers should benchmark against.",
  },
  {
    slug: 'brisbane-city-plan-amendments-tlpi-property-sale-value',
    title: 'How Brisbane City Plan Amendments and TLPIs Affect Property Sale Value',
    summary: "Brisbane City Plan amendments and Temporary Local Planning Instruments can move sale value before they are gazetted. How planning changes flow through to price, what to verify before listing, and how to time a campaign when a change is pending.",
  },
  {
    slug: 'how-bank-valuation-works-brisbane-property-sale',
    title: "How the Buyer's Bank Valuation Actually Works in a Brisbane Property Sale",
    summary: "After your Brisbane buyer signs the contract, their bank orders a valuation that most sellers never see. Who does it (CoreLogic, Herron Todd White, Opteon), what they compare to, why it sometimes comes in low, and what you can do.",
  },
  {
    slug: 'nearby-construction-development-brisbane-property-sale-value',
    title: 'How Nearby Construction or Development Affects Your Brisbane Property Sale Value',
    summary: "A house going up next door, a council water main on your street, or a tower under construction two blocks away changes how buyers value your home. How the impact actually flows through to price in Brisbane's inner east, and what sellers should do before and during the campaign.",
  },
];
---
<Layout title="Pricing, Timing and Valuation | Daniel Gierach Property" description="How to set an asking price, when to sell, what a home is worth, and how long a Brisbane sale typically takes. Nine guides for Brisbane sellers." schema={clusterSchema}>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <!-- Hero -->
  <div style="background:#e6d9bd;padding:8rem 0 3.5rem;">
    <div class="max-w-[1100px] mx-auto px-8">
      <a href="/insights" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(25,24,23,0.6);text-decoration:none;margin-bottom:2rem;transition:color 0.2s;"
        onmouseover="this.style.color='#6b4610'" onmouseout="this.style.color='rgba(25,24,23,0.6)'">
        &larr; All Articles
      </a>
      <span style="display:block;font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#6b4610;margin-bottom:1rem;">Topic Guide &middot; 25 Articles</span>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,5vw,3.25rem);font-weight:400;color:#191817;line-height:1.12;letter-spacing:-0.02em;margin-bottom:1.5rem;">
        Pricing, Timing and Valuation
      </h1>
      <p style="font-size:1rem;color:rgba(25,24,23,0.6);line-height:1.8;max-width:58ch;">
        Pricing is the most consequential decision you make when selling. This cluster covers how to set an accurate asking price, when the Brisbane market favours sellers, what your home is actually worth, and how long the full process takes from preparation to settlement.
      </p>
    </div>
  </div>

  <!-- Article Grid -->
  <div style="padding:3.5rem 0 5rem;background:var(--color-base);">
    <div class="max-w-[1100px] mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {articles.map(a => (
          <a href={`/insights/${a.slug}`}
            style="background:#ffffff;border:1px solid rgba(28,25,23,0.1);padding:2rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.25s,border-color 0.25s,transform 0.3s,box-shadow 0.3s;position:relative;overflow:hidden;box-shadow:0 1px 4px rgba(28,25,23,0.05);"
            onmouseover="this.style.background='#f2ead4';this.style.borderColor='rgba(185,130,41,0.3)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 28px rgba(28,25,23,0.09)'"
            onmouseout="this.style.background='#ffffff';this.style.borderColor='rgba(28,25,23,0.1)';this.style.transform='translateY(0)';this.style.boxShadow='0 1px 4px rgba(28,25,23,0.05)'"
          >
            <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#6b4610;"></div>
            <div style="display:flex;align-items:center;padding-top:0.25rem;">
              <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:#6b4610;display:inline-flex;align-items:center;gap:0.35rem;">
                <span style="width:5px;height:5px;border-radius:50%;background:#6b4610;flex-shrink:0;"></span>
                Sellers
              </span>
            </div>
            <div style="flex:1;">
              <h2 style="font-family:var(--font-serif);font-size:1.1rem;font-weight:400;color:#191817;line-height:1.3;margin-bottom:0.75rem;">{a.title}</h2>
              <p style="font-size:0.82rem;color:#78716c;line-height:1.75;">{a.summary}</p>
            </div>
            <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#b98229;margin-top:auto;">Read Article &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div style="padding:4rem 0;background:#f7f5f0;border-top:1px solid rgba(28,25,23,0.08);">
    <div class="max-w-[1100px] mx-auto px-8" style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:1.25rem;">
      <p style="font-family:var(--font-serif);font-size:1.25rem;font-style:italic;color:#191817;">What is your property worth in 2026?</p>
      <p style="font-size:0.85rem;color:#78716c;line-height:1.75;max-width:44ch;">Get an honest, data-led appraisal from Daniel. No inflated figures, no obligation, and a clear explanation of how your price range was determined.</p>
      <a href="/get-an-appraisal" style="display:inline-flex;align-items:center;gap:0.6rem;padding:0.85rem 1.75rem;background:#b98229;color:#fff;font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;border-radius:8px;"
        onmouseover="this.style.background='#a87824'" onmouseout="this.style.background='#b98229'">
        Get a Free Appraisal
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

</article>

</Layout>
