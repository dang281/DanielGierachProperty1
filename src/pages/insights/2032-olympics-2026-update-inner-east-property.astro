---
import Layout from '../../layouts/Layout.astro';
import ResourceCTA from '../../components/ResourceCTA.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What has actually been confirmed for the 2032 Brisbane Olympics in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Queensland Government confirmed the new $3.8 billion, 63,000-seat Olympic stadium at Victoria Park on 5 January 2026, with construction commencing 1 June 2026 and completion targeted for 2031. The architectural consortium of Cox, Hassell and Azusa Sekkei was appointed at the same time. Northshore Hamilton remains the location for the Athletes Village, with an $87 million street renewal program already underway. Cross River Rail stations at Woolloongabba and Boggo Road are progressing through fit-out, with the line scheduled to open in 2029. The full Games Venue Infrastructure Program is budgeted at $7.1 billion."
      }
    },
    {
      "@type": "Question",
      "name": "Which Brisbane inner east suburbs are most affected by the 2026 Olympic infrastructure decisions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Woolloongabba is the most directly affected through the Cross River Rail underground station and the surrounding precinct investment. Hamilton and the Northshore precinct sit closest to the confirmed Athletes Village. Cannon Hill, Murarrie and Hemmant benefit from improved Gateway access and rail catchment. Seven Hills, Coorparoo and Norman Park sit further from the venue infrastructure but within the broader inner east buyer pool that has attracted sustained interstate interest."
      }
    },
    {
      "@type": "Question",
      "name": "Should I sell my Brisbane inner east home before or after the 2032 Olympics?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Property markets price in expected infrastructure gains progressively as certainty increases. Much of the 2032-linked investment story is already reflected in current buyer behaviour. For most owners, current local conditions and personal circumstances matter more than the Games calendar. SQM Research and ANZ both forecast Brisbane dwelling growth in the high single digits to low double digits across 2026, supported by tight supply and ongoing infrastructure investment. The right time to sell is the point where the property is well presented, the market is active for that segment, and the owner's plans are settled."
      }
    },
    {
      "@type": "Question",
      "name": "What did past Olympic host cities show about long term property prices?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sydney 2000 research found that property prices rose strongly in the bidding and pre-Games period, with the strongest sustained effects in suburbs near the Olympic Village at Homebush. London 2012 host boroughs saw an 84 percent rise in average prices between 2005 and 2015, against 41 percent for the rest of England and Wales, although researchers note the gains were uneven and concentrated in areas that received permanent transport and urban renewal investment. The consistent finding across both case studies is that durable price effects come from the infrastructure built around the Games, not the event itself."
      }
    }
  ]
};
