const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much have home insurance premiums risen in Brisbane in recent years?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Average Queensland home insurance premiums have roughly doubled across the five years to 2026 for many southeast Queensland postcodes, with the steepest increases on properties in flood overlay areas, on or near waterways, and in older timber housing stock. ASIC and Treasury reports have repeatedly flagged that South East Queensland is one of the highest-cost insurance regions in Australia, driven by 2011 flood claims, the 2022 Brisbane River and South East Queensland flood event, and a series of severe hail and storm seasons. A standard inner-east weatherboard Queenslander that paid $1,400 a year for combined home and contents in 2020 commonly pays well over $2,500 by 2026, and waterfront or low-lying properties can pay multiples of that figure."
      }
    },
    {
      "@type": "Question",
      "name": "Are Brisbane buyers actually factoring insurance premiums into their offers in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, and the conversation has shifted noticeably over the past two years. Where buyers once treated insurance as a settlement-week admin task, finance brokers and conveyancers now routinely ask vendors and listing agents for an indicative annual premium during due diligence. Buyers with mortgages must demonstrate insurance is in place before settlement, and a quote that comes back at $5,000 or $8,000 a year materially changes their borrowing power. On marginal flood-affected properties, insurance pricing is now a deal-breaking line item rather than a footnote, and sellers who do not anticipate it lose buyers between contract and settlement."
      }
    },
    {
      "@type": "Question",
      "name": "What should a Brisbane seller do if their home has a high insurance premium?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Get ahead of it. Obtain a current annual premium quote for the property before listing, including any flood, storm and hail components separately broken out. Ask your insurer or broker for the underwriting reason if the premium is unusually high, since the property's flood line, elevation and construction often drive the number more than the postcode. Where the property genuinely qualifies for the federal Cyclone Reinsurance Pool or any state mitigation rebate, document it. In marketing, address insurance directly with buyers who ask rather than deflecting, and price the campaign to reflect the buyer pool that can actually afford the ongoing cost, which is often a smaller pool than the suburb median suggests."
      }
    }
  ]
};
