<Layout title="Selling a Tenanted Property in Queensland: Rights, Rules and Process | Daniel Gierach Property" description="What Queensland sellers need to know about notice periods, inspection rights, lease assignment, and whether to sell vacant or tenanted." draft={draft}>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <!-- Hero -->
  <div style="background:#0a0806;padding:8rem 0 3rem;">
    <div class="max-w-[780px] mx-auto px-8">
