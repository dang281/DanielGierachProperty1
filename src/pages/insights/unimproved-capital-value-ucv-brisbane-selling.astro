const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Does the unimproved capital value affect what I can sell my Brisbane home for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not directly. The unimproved capital value (UCV) is the Queensland Valuer-General's assessment of the land alone, excluding the house, pool, landscaping, and any other improvements. Sale price is set by comparable sales and what buyers are willing to pay for the whole property. A high UCV does not push your sale price up, and a low UCV does not cap it. UCV matters more for holding costs (council rates and land tax) than for what your property fetches at sale."
      }
    },
    {
      "@type": "Question",
      "name": "How does UCV affect Brisbane council rates and land tax for a property I am selling?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Brisbane City Council calculates general rates by multiplying your property's three-year average UCV by a rate-in-the-dollar set each budget. Queensland state land tax (paid by investors and second-property owners, not owner-occupiers on a principal residence) uses the same UCV. A sharp annual UCV increase can lift quarterly council rates by hundreds of dollars and, for investors, materially increase the annual land tax bill. At sale, council rates and any land tax are adjusted between buyer and seller at settlement based on the day of possession."
      }
    },
    {
      "@type": "Question",
      "name": "Can I object to a UCV that I think is too high before selling my Brisbane property?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The Queensland Valuer-General publishes new statutory land valuations annually, usually issued in March and effective 30 June. You have 60 days from the date on your valuation notice to lodge a properly grounded objection. Acceptable grounds include comparable land sales that contradict the assessed value, errors in land area or site characteristics, or a clear inconsistency with similar lots in your street. The objection is free, but the case must be evidence-based, not an opinion. A successful objection reduces your council rates and land tax going forward, which can be a useful talking point for an investor buyer."
      }
    }
  ]
};
