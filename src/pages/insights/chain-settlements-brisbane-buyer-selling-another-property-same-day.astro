---
import Layout from '../../layouts/Layout.astro';
import AuthorBio from '../../components/AuthorBio.astro';
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a chain settlement in a Brisbane property sale?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A chain settlement is where your buyer is also selling another property and the two contracts are scheduled to settle on the same day. Your buyer typically needs the proceeds of their own sale to fund the purchase of yours. The chain can be two contracts or, in the worst cases, three or four, with each transaction depending on the one before it landing in cleared funds."
      }
    },
    {
      "@type": "Question",
      "name": "Should a Brisbane seller accept a buyer in a chain settlement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most of the time, yes, because a meaningful share of Brisbane inner-east buyers are funding their purchase from another sale. The question is not whether to accept a buyer with a settlement chain, but whether their chain is short, well advanced, and properly contracted. A buyer whose own sale is unconditional with a matched settlement date is a low-risk chain. A buyer whose own sale is still under building and pest with a settlement date that does not align is a high-risk chain that needs different protection in your contract."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if my buyer's own sale falls over before settlement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your buyer is still legally bound to settle on your contract on the agreed date. If they cannot fund the settlement because their own sale collapsed, they are in default. You can issue a notice to complete, claim the deposit, and pursue damages. In practice, sellers usually negotiate a short extension to give the buyer time to put bridging finance in place or replace the failed sale, because litigation is slower and more expensive than a one or two week delay. The outcome depends entirely on what your contract says about the buyer's other sale and whether a finance clause is still active."
      }
    }
  ]
};
