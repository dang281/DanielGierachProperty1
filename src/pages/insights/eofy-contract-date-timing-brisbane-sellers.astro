const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Should Brisbane sellers time their contract date around the end of financial year?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on what is in the contract. For Brisbane homeowners selling a fully exempt main residence, the financial year of the contract is largely irrelevant to tax. For investors, retirees, deceased estates and sellers using the 6-year absence rule, the contract date determines which financial year the gain falls into, and that single decision can move the final tax bill by tens or hundreds of thousands of dollars. EOFY timing is a real lever for the second group, not the first. Run the numbers with a registered tax agent before deciding on a campaign date."
      }
    },
    {
      "@type": "Question",
      "name": "Does a 30 June contract or a 1 July contract affect CGT in Queensland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, materially, for property sales subject to CGT. The CGT event happens on the contract date under ATO rules. A contract signed on 30 June 2026 puts the gain in the 2025-26 financial year. A contract signed on 1 July 2026 puts the same gain in the 2026-27 financial year, even where settlement happens on the same August day in both scenarios. The choice of contract date is the choice of which year's income, brackets, deductions, super cap and tax position the gain stacks onto."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best time of year to sign a Brisbane property contract for tax purposes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no universal best time. The right contract date depends on your taxable income shape, super eligibility, retirement timing, carry-forward losses, ownership structure and the size of the gain. For Brisbane investors retiring in the next 24 months, the first full year of retirement is often the lowest-tax year to crystallise. For sellers with large unused concessional super cap and a high-income year ending, a late June contract can be the right call. For sellers with no CGT exposure (a fully exempt main residence), the financial year of the contract does not change the tax outcome and the market campaign should drive the timing."
      }
    },
    {
      "@type": "Question",
      "name": "Can a Brisbane seller change the contract date after signing to shift the CGT year?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, not without rescinding and re-signing the contract, which the buyer would have to agree to and which is very rarely available. The contract date is the date the buyer and seller signed the binding contract, not the date you intended to sign it. Once both parties have signed, the CGT event has occurred. This is why the contract date decision must be made before the offer is accepted, not after. Sellers wanting a 1 July contract have to delay the offer process, not back-date or amend after the fact."
      }
    }
  ]
};
