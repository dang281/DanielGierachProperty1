  <!-- FAQ Schema -->
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can you buy and sell property at the same time in Brisbane?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, buying and selling at the same time is common in Brisbane. Many owner-occupiers need the proceeds from their sale to fund their purchase. The key is to either make one contract conditional on the other, negotiate matching settlement dates, or arrange bridging finance as a fallback if the timings do not align perfectly."
        }
      },
      {
        "@type": "Question",
        "name": "What is a simultaneous settlement in Queensland?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A simultaneous settlement is when the settlement of your property sale and the settlement of your property purchase are coordinated to occur on the same day, usually within hours of each other. The proceeds from your sale are used to fund your purchase, removing the need for short-term bridging finance."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if one settlement falls through in a simultaneous settlement?",
