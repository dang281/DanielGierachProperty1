const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does subject to finance mean in a Queensland property contract?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A subject to finance condition means the buyer's obligation to proceed with the purchase is conditional on them obtaining formal finance approval from their lender by a specified date. If the buyer cannot obtain finance approval by the finance date, they can notify the seller in writing and the contract terminates. Both parties are released from the contract and the buyer's deposit is returned in full. If the buyer does obtain finance approval, the finance condition is satisfied and the contract proceeds."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a finance condition last in a Queensland property contract?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Finance periods in Queensland property contracts are typically 14 to 21 days from the contract date. This is a negotiated term: the buyer may request a longer period (sometimes 21-28 days) if their loan application is complex or if their lender has longer processing times. The seller may push for a shorter period if they want certainty sooner. The finance date is written into the contract before signing."
      }
    },
    {
      "@type": "Question",
      "name": "Can a seller accept other offers while the property is under a finance condition?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Generally no. Once a contract is signed, the property is under contract and the seller cannot enter into another contract for the same property unless the existing contract is terminated. The seller can keep other interested parties warm by staying in contact during the finance period, and some sellers choose to be transparent with other buyers that the property is under a conditional contract and that they will make contact if the condition is not satisfied."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if the buyer's finance is declined during the finance period in Queensland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If the buyer's finance is declined, the buyer must provide written notification to the seller before the finance date, stating that the finance condition has not been satisfied. The contract then terminates and the buyer's deposit is refunded in full. The seller's property returns to market. If the buyer fails to notify within the finance period and the contract allows for automatic termination on non-notification, different rules apply and the exact outcome depends on how the finance condition is drafted in the contract."
      }
    },
    {
      "@type": "Question",
      "name": "Should I insist on an unconditional offer rather than accept a subject to finance offer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An unconditional offer gives the seller certainty immediately. A subject to finance offer creates a conditional period where the sale is not guaranteed. The decision depends on the strength of the competing offers, the buyer's financial profile, and market conditions. A strong conditional offer from a well-qualified buyer with a short finance period is often better than a lower unconditional offer. Your agent should advise you on the buyer's profile and the realistic risk of the finance condition failing based on the specific circumstances."
      }
    }
  ]
};
