---
import Layout from '../layouts/Layout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Free Property Appraisal and Walkthrough",
  "provider": {
    "@type": "Person",
    "name": "Daniel Gierach",
    "worksFor": {
      "@type": "Organization",
      "name": "Ray White The Collective"
    }
  },
  "serviceType": "Property Appraisal",
  "areaServed": "Brisbane Inner East",
  "url": "https://danielgierach.com/walkthrough"
};
---

<Layout preloadImage="https://cdn6.ep.dynamics.net/s3/rw-propertyimages/65cb-H3485122-195546888__1775524459-58394-AMY1219.jpg" title="Book a Walk Through | Daniel Gierach Property" description="Book a free in-person property walkthrough with Daniel Gierach. A frank, well-researched appraisal of your home's value. No obligation, no call centres." schema={serviceSchema}>

<!-- ════════════════════════════════════════════
     FULL-VIEWPORT SPLIT LAYOUT
     Left: dark hero  |  Right: form
════════════════════════════════════════════ -->
<section style="display:grid;grid-template-columns:1fr 1fr;min-height:100dvh;" class="appraisal-split">

  <!-- ── LEFT: dark hero panel ── -->
  <div class="relative flex flex-col justify-center overflow-hidden" style="padding:8rem 4rem 4rem;">

    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://cdn6.ep.dynamics.net/s3/rw-propertyimages/65cb-H3485122-195546888__1775524459-58394-AMY1219.jpg"
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Brisbane inner-east property"
        class="w-full h-full object-cover"
        style="filter:grayscale(8%) brightness(0.45);"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background:linear-gradient(105deg,rgba(10,8,6,0.82) 0%,rgba(10,8,6,0.6) 55%,rgba(10,8,6,0.25) 100%);"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10">
      <span class="appraisal-hero-eyebrow eyebrow mb-5 reveal" style="display:block;color:#f5d07a;">Free Property Walk Through</span>

      <h1 class="reveal" data-delay="60"
        style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3.5rem);font-weight:400;line-height:1.08;letter-spacing:-0.02em;color:#f0ece4;margin-bottom:1.25rem;">
        Let's get you booked in.
      </h1>

      <p class="appraisal-hero-desc reveal" data-delay="120"
        style="font-size:1rem;color:rgba(240,236,228,0.82);line-height:1.9;max-width:44ch;margin-bottom:2.75rem;">
        Fill in your details and Daniel will confirm a time that suits you. Takes less than a minute.
      </p>

      <!-- Testimonial -->
      <div class="reveal" data-delay="160" style="padding:1.25rem 1.5rem;background:rgba(10,8,6,0.5);backdrop-filter:blur(8px);border:1px solid rgba(197,160,60,0.2);margin-bottom:2.75rem;">
        <div style="display:flex;gap:0.2rem;margin-bottom:0.75rem;">
          {[1,2,3,4,5].map(() => (
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#c5a03c" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
        </div>
        <p style="font-family:var(--font-serif);font-size:0.9rem;font-style:italic;color:rgba(240,236,228,0.9);line-height:1.75;margin-bottom:0.75rem;">
          "Daniel was honestly fantastic to work with. He was incredibly knowledgeable, professional and responsive throughout the entire process."
        </p>
        <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#c5a03c;">5 Stars · Recent Review</p>
      </div>

      <!-- Contact details -->
      <div class="appraisal-hero-contacts reveal" data-delay="180" style="display:flex;flex-direction:column;gap:1.5rem;">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Phone</p>
          <a href="tel:+61412523821"
            style="font-family:var(--font-serif);font-size:1.25rem;font-weight:400;color:#ffffff;text-decoration:none;transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='#ffffff'">0412 523 821</a>
        </div>

        <div style="width:100%;height:1px;background:rgba(255,255,255,0.1);"></div>

        <div>
          <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Email</p>
          <a href="mailto:daniel.gierach@raywhite.com"
            style="font-family:var(--font-serif);font-size:1.25rem;font-weight:400;color:#ffffff;text-decoration:none;transition:color 0.2s;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='#ffffff'">daniel.gierach@raywhite.com</a>
        </div>

        <div style="width:100%;height:1px;background:rgba(255,255,255,0.1);"></div>

        <div style="display:flex;gap:0.85rem;align-items:center;">
          <a href="https://www.instagram.com/dgierach/" target="_blank" rel="noopener" aria-label="Instagram"
            style="color:rgba(240,236,228,0.65);transition:color 0.2s;padding:0.75rem;min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='rgba(240,236,228,0.45)'">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/danielgierach" target="_blank" rel="noopener" aria-label="LinkedIn"
            style="color:rgba(240,236,228,0.65);transition:color 0.2s;padding:0.75rem;min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='rgba(240,236,228,0.45)'">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href="https://www.realestate.com.au/agent/daniel-gierach-3819232" target="_blank" rel="noopener" aria-label="realestate.com.au"
            style="opacity:0.65;transition:opacity 0.2s;padding:0.75rem;min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.45'">
            <img src="https://www.realestate.com.au/favicon.ico" width="24" height="24" alt="realestate.com.au" style="display:block;" />
          </a>
          <a href="https://share.google/WipmgyJnjC5nkhGwx" target="_blank" rel="noopener" aria-label="Google Business Profile"
            style="color:rgba(240,236,228,0.65);transition:color 0.2s;padding:0.75rem;min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;"
            onmouseover="this.style.color='#f5d07a'"
            onmouseout="this.style.color='rgba(240,236,228,0.45)'">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ── RIGHT: form panel ── -->
  <div class="flex flex-col justify-center overflow-y-auto" style="background:var(--color-surface-1);padding:8rem 4rem 4rem;">

    <div class="reveal" data-delay="80" style="max-width:480px;width:100%;">

      <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Book a Walk Through</p>
      <h2 style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:#1c1917;line-height:1.2;margin-bottom:1.75rem;">
        Daniel will be in touch promptly.
      </h2>

      <form id="walkthrough-form" style="display:flex;flex-direction:column;gap:1rem;">
  <input type="hidden" name="_next" value="https://danielgierach.com/thank-you?from=walkthrough" />
  <input type="hidden" name="_subject" value="New appraisal request - danielgierach.com" />

        <!-- First Name + Last Name -->
        <div class="name-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          <div>
            <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
              First Name <span style="color:#c4912a;">*</span>
            </label>
            <input type="text" name="first_name" required placeholder="First Name"
              class="obs-input form-field" autocomplete="given-name"
            />
          </div>
          <div>
            <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
              Last Name <span style="color:#c4912a;">*</span>
            </label>
            <input type="text" name="last_name" required placeholder="Last Name"
              class="obs-input form-field" autocomplete="family-name"
            />
          </div>
        </div>

        <!-- Phone -->
        <div>
          <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
            Phone <span style="color:#c4912a;">*</span>
          </label>
          <input type="tel" name="phone" required placeholder="04xx xxx xxx"
            class="obs-input form-field" autocomplete="tel"
          />
        </div>

        <!-- Property Address -->
        <div>
          <label style="display:block;font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#44403c;margin-bottom:0.35rem;">
            Property Address <span style="color:#c4912a;">*</span>
          </label>
          <input type="text" id="appraisal-address" name="property_address" required placeholder="e.g. 12 River Street, Bulimba 4171"
            class="obs-input form-field" autocomplete="off"
          />
        </div>

        <!-- Calendar picker -->
        <div class="cal-wrap">
          <label class="cal-label">Suggest a Date &amp; Time <span style="font-weight:400;opacity:0.6;">(optional)</span></label>

          <!-- Calendar -->
          <div class="cal-card">
            <!-- Month nav -->
            <div class="cal-header">
              <button type="button" id="cal-prev" class="cal-nav" aria-label="Previous month">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <span id="cal-month-label" class="cal-month-name"></span>
              <button type="button" id="cal-next" class="cal-nav" aria-label="Next month">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            </div>
            <!-- Day-of-week headers -->
            <div class="cal-dow-row">
              {['Mo','Tu','We','Th','Fr','Sa','Su'].map(d => <span class="cal-dow">{d}</span>)}
            </div>
            <!-- Day grid -->
            <div id="cal-grid" class="cal-grid"></div>
          </div>

          <!-- Time slots, shown after day is picked -->
          <div id="cal-time-section" class="cal-time-section" style="display:none;">
            <p class="cal-time-label">Choose a time</p>
            <div class="cal-time-grid">
              <button type="button" class="cal-time-btn" data-time="Morning  ·  8-12pm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <span>Morning</span>
                <small>8, 12pm</small>
              </button>
              <button type="button" class="cal-time-btn" data-time="Afternoon  ·  12-5pm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <span>Afternoon</span>
                <small>12, 5pm</small>
              </button>
              <button type="button" class="cal-time-btn" data-time="Evening  ·  5-7pm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                <span>Evening</span>
                <small>5, 7pm</small>
              </button>
            </div>
          </div>

          <!-- Selected summary pill -->
          <div id="cal-summary" class="cal-summary" style="display:none;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c4912a" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span id="cal-summary-text"></span>
          </div>

          <input type="hidden" name="preferred_date" id="preferred-date-input" />
          <input type="hidden" name="preferred_time" id="preferred-time-input" />
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-gold"
          style="width:100%;justify-content:center;padding:1rem;margin-top:0.5rem;"
          onclick="gtag('event', 'appraisal_cta_click', { event_category: 'lead', event_label: 'Request My Appraisal' })"
        >
          Confirm My Booking
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
        <p style="font-family:var(--font-sans);font-size:0.65rem;color:#78716c;text-align:center;margin-top:0.5rem;line-height:1.5;">Daniel will call to confirm the time. No pressure.</p>

      </form>
    </div>
  </div>

</section>

<style>
  @media (max-width: 768px) {
    .name-grid { grid-template-columns: 1fr !important; }
    .appraisal-split {
      grid-template-columns: 1fr !important;
    }
    .appraisal-split > div:first-child {
      min-height: 0;
      padding: 6.5rem 1.75rem 4.5rem !important;
      justify-content: center;
    }
    .appraisal-split > div:last-child {
      padding: 3rem 2rem 4rem !important;
    }
    /* Hide eyebrow, description + contact details on mobile, headline only */
    .appraisal-hero-eyebrow,
    .appraisal-hero-desc,
    .appraisal-hero-contacts { display: none !important; }
  }
  input::placeholder { color: var(--color-text-muted); }


  input:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 1000px var(--color-surface-4) inset;
    -webkit-text-fill-color: #1c1917;
  }
</style>

<style is:global>
  /* ══ Calendar, global so JS-created elements inherit styles ══ */
  .cal-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
  .cal-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #44403c;
    margin-bottom: 0.15rem;
  }
  .cal-card {
    border: 1.5px solid rgba(28,25,23,0.12);
    background: #fff;
    padding: 1rem;
    user-select: none;
  }
  .cal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }
  .cal-nav {
    width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    background: none;
    border: 1px solid rgba(28,25,23,0.15);
    cursor: pointer;
    color: #44403c;
    transition: border-color 0.15s, color 0.15s;
    border-radius: 2px;
  }
  .cal-nav:hover { border-color: #c4912a; color: #c4912a; }
  .cal-nav:disabled { opacity: 0.25; cursor: default; pointer-events: none; }
  .cal-month-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    color: #1c1917;
  }
  .cal-dow-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    margin-bottom: 0.4rem;
    border-bottom: 1px solid rgba(28,25,23,0.08);
    padding-bottom: 0.4rem;
  }
  .cal-dow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #78716c;
    padding: 0.2rem 0;
  }
  /* Weekend column header tints */
  .cal-dow:nth-child(6) { background: rgba(28,25,23,0.04); color: #78716c; }
  .cal-dow:last-child   { background: rgba(28,25,23,0.04); color: #78716c; opacity: 0.6; }
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 3px;
  }

  /* ── Base day button ── */
  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    border-radius: 3px;
    border: 1.5px solid transparent;
    background: none;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    color: #1c1917;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.1s;
  }

  /* Available, subtle hover */
  .cal-day:hover:not(.cal-day--disabled):not(.cal-day--selected):not(.cal-day--sunday) {
    background: rgba(196,145,42,0.1);
    border-color: rgba(196,145,42,0.4);
    color: #c4912a;
    transform: scale(1.08);
  }

  /* ── SELECTED, bold gold fill, unmissable ── */
  .cal-day--selected {
    background: #c4912a !important;
    color: #fff !important;
    font-weight: 700 !important;
    border-color: #c4912a !important;
    box-shadow: 0 2px 8px rgba(196,145,42,0.45);
    transform: scale(1.1);
  }

  /* ── PAST / DISABLED, very obviously unavailable ── */
  .cal-day--disabled {
    color: #d4cfc9 !important;
    background: transparent !important;
    border-color: transparent !important;
    cursor: default;
    pointer-events: none;
    font-weight: 400;
  }

  /* ── SATURDAY, shaded column, bookable ── */
  .cal-day--saturday {
    background: rgba(28,25,23,0.04);
    color: #1c1917;
  }

  /* ── SUNDAY, deeper shade, not bookable ── */
  .cal-day--sunday {
    background: rgba(28,25,23,0.04) !important;
    color: #c9b8b8 !important;
    cursor: default;
    pointer-events: none;
    font-style: italic;
  }

  /* Today/tomorrow dot marker */
  .cal-day--today::after {
    content: '';
    position: absolute;
    bottom: 3px; left: 50%; transform: translateX(-50%);
    width: 3px; height: 3px;
    border-radius: 50%;
    background: #c9b8b8;
  }

  .cal-day--empty { pointer-events: none; }

  /* Ripple on click */
  @keyframes calRipple {
    0%   { transform: translate(-50%,-50%) scale(0); opacity: 0.5; }
    100% { transform: translate(-50%,-50%) scale(3); opacity: 0; }
  }
  .cal-day .ripple {
    position: absolute;
    top: 50%; left: 50%;
    width: 80%; height: 80%;
    border-radius: 50%;
    background: rgba(255,255,255,0.6);
    pointer-events: none;
    animation: calRipple 0.35s ease-out forwards;
  }

  /* ── Time slots ── */
  @keyframes calFadeUp {
    from { opacity:0; transform:translateY(8px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .cal-time-section {
    margin-top: 0.5rem;
    animation: calFadeUp 0.25s ease both;
  }
  .cal-time-label {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #78716c;
    margin-bottom: 0.5rem;
  }
  .cal-time-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 0.5rem;
  }
  .cal-time-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.9rem 0.5rem;
    border: 1.5px solid rgba(28,25,23,0.12);
    background: #faf9f7;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, transform 0.1s;
    border-radius: 2px;
  }
  .cal-time-btn svg { color: #78716c; transition: color 0.15s; }
  .cal-time-btn span {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    color: #1c1917;
  }
  .cal-time-btn small {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    color: #78716c;
    font-weight: 400;
  }
  .cal-time-btn:hover {
    border-color: #c4912a;
    background: rgba(196,145,42,0.05);
    transform: translateY(-2px);
  }
  .cal-time-btn.selected {
    border-color: #c4912a;
    background: rgba(196,145,42,0.1);
    box-shadow: 0 2px 8px rgba(196,145,42,0.2);
  }
  .cal-time-btn.selected span { color: #c4912a; }
  .cal-time-btn.selected svg  { color: #c4912a; }
  .cal-time-btn.selected small { color: #c4912a; opacity: 0.75; }

  /* Summary pill */
  .cal-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: rgba(196,145,42,0.08);
    border: 1px solid rgba(196,145,42,0.3);
    border-radius: 2px;
    animation: calFadeUp 0.2s ease both;
    margin-top: 0.25rem;
  }
  .cal-summary span {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: #44403c;
  }

  body.appraisal-page #site-header {
    background: rgba(247,245,240,0.96) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid rgba(28,25,23,0.08) !important;
    box-shadow: 0 4px 24px rgba(28,25,23,0.08) !important;
  }
  body.appraisal-page #logo-name {
    color: var(--color-text-primary) !important;
  }
  body.appraisal-page #nav-links .nav-link-mono,
  body.appraisal-page #nav-cta .nav-link-mono {
    color: var(--color-text-secondary) !important;
  }
</style>

<script>
  document.body.classList.add('appraisal-page');
  document.body.dataset.lightNav = 'true';

  // ── Calendar picker ──────────────────────────────────────────────
  (function() {
    const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const today = new Date();
    today.setHours(0,0,0,0);
    const minDate = new Date(today); minDate.setDate(today.getDate() + 2); // earliest = day after tomorrow
    const maxDate = new Date(today); maxDate.setDate(today.getDate() + 60);

    let viewYear  = minDate.getFullYear();
    let viewMonth = minDate.getMonth();
    let selectedDate: Date | null = null;

    const grid        = document.getElementById('cal-grid')!;
    const monthLabel  = document.getElementById('cal-month-label')!;
    const prevBtn     = document.getElementById('cal-prev') as HTMLButtonElement;
    const nextBtn     = document.getElementById('cal-next') as HTMLButtonElement;
    const timeSection = document.getElementById('cal-time-section')!;
    const summary     = document.getElementById('cal-summary')!;
    const summaryTxt  = document.getElementById('cal-summary-text')!;
    const hiddenDate  = document.getElementById('preferred-date-input') as HTMLInputElement;
    const hiddenTime  = document.getElementById('preferred-time-input') as HTMLInputElement;

    function renderCalendar() {
      monthLabel.textContent = `${MONTH_NAMES[viewMonth]} ${viewYear}`;

      // Disable prev if first selectable month
      const minMonth = new Date(minDate.getFullYear(), minDate.getMonth(), 1);
      const currView = new Date(viewYear, viewMonth, 1);
      prevBtn.disabled = currView <= minMonth;

      const maxMonth = new Date(maxDate.getFullYear(), maxDate.getMonth(), 1);
      nextBtn.disabled = currView >= maxMonth;

      grid.innerHTML = '';

      // Leading empty cells (Mon=0 … Sun=6)
      const firstDay = new Date(viewYear, viewMonth, 1).getDay();
      const offset   = firstDay === 0 ? 6 : firstDay - 1; // Mon-start
      for (let i = 0; i < offset; i++) {
        const empty = document.createElement('div');
        empty.className = 'cal-day cal-day--empty';
        grid.appendChild(empty);
      }

      const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();
      for (let d = 1; d <= daysInMonth; d++) {
        const date = new Date(viewYear, viewMonth, d);
        const btn  = document.createElement('button');
        btn.type   = 'button';
        btn.textContent = String(d);
        btn.className = 'cal-day';

        const isToday    = date.getTime() === today.getTime();
        const isTomorrow = date.getTime() === new Date(today.getTime() + 86400000).getTime();
        const isPast     = date < minDate;
        const isFuture   = date > maxDate;
        const isSunday   = date.getDay() === 0;
        const isSaturday = date.getDay() === 6;
        const isSelected = selectedDate && date.getTime() === selectedDate.getTime();

        if (isPast || isFuture) btn.classList.add('cal-day--disabled');
        if (isToday || isTomorrow) btn.classList.add('cal-day--today');
        if (isSunday)   btn.classList.add('cal-day--sunday');
        if (isSaturday) btn.classList.add('cal-day--saturday');
        if (isSelected) btn.classList.add('cal-day--selected');

        if (!isPast && !isFuture && !isSunday) {
          btn.addEventListener('click', () => {
            // Ripple effect
            const ripple = document.createElement('span');
            ripple.className = 'ripple';
            btn.appendChild(ripple);
            ripple.addEventListener('animationend', () => ripple.remove());
            selectDate(date);
          });
        }
        grid.appendChild(btn);
      }
    }

    function selectDate(date: Date) {
      selectedDate = date;
      const label = date.toLocaleDateString('en-AU', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
      hiddenDate.value = label;
      renderCalendar();

      // Show time section
      timeSection.style.display = 'block';
      // Reset time selection
      document.querySelectorAll('.cal-time-btn').forEach(b => b.classList.remove('selected'));
      hiddenTime.value = '';
      updateSummary();
    }

    function updateSummary() {
      if (!selectedDate) return;
      const dateLabel = selectedDate.toLocaleDateString('en-AU', { weekday:'short', day:'numeric', month:'short' });
      const timeLabel = hiddenTime.value ? '  ·  ' + hiddenTime.value : '';
      summaryTxt.textContent = dateLabel + timeLabel;
      summary.style.display = 'flex';
    }

    prevBtn.addEventListener('click', () => {
      viewMonth--;
      if (viewMonth < 0) { viewMonth = 11; viewYear--; }
      renderCalendar();
    });
    nextBtn.addEventListener('click', () => {
      viewMonth++;
      if (viewMonth > 11) { viewMonth = 0; viewYear++; }
      renderCalendar();
    });

    document.querySelectorAll('.cal-time-btn').forEach(btn => {
      btn.addEventListener('click', function(this: HTMLElement) {
        document.querySelectorAll('.cal-time-btn').forEach(b => b.classList.remove('selected'));
        this.classList.add('selected');
        hiddenTime.value = this.dataset.time || '';
        updateSummary();
      });
    });

    renderCalendar();
  })();

  // Field validation animation
  document.querySelectorAll<HTMLInputElement>('.form-field').forEach(input => {
    // Wrap in relative container and inject tick icon
    const wrap = document.createElement('div');
    wrap.className = 'field-wrap';
    input.parentNode!.insertBefore(wrap, input);
    wrap.appendChild(input);

    const tick = document.createElement('span');
    tick.className = 'field-tick';
    tick.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
    wrap.appendChild(tick);

    input.addEventListener('blur', () => {
      if (input.value.trim() && input.checkValidity()) {
        input.classList.add('valid');
        tick.classList.add('show');
      } else {
        input.classList.remove('valid');
        tick.classList.remove('show');
      }
    });

    input.addEventListener('focus', () => {
      input.classList.remove('valid');
      tick.classList.remove('show');
    });
  });

  const header = document.getElementById('site-header')!;
  const logoName = document.getElementById('logo-name')!;
  const navLinkEls = document.querySelectorAll<HTMLElement>('#nav-links .nav-link-mono, #nav-cta .nav-link-mono');

  header.classList.add('glass-nav');
  logoName.style.color = 'var(--color-text-primary)';
  navLinkEls.forEach(el => el.style.color = '');

  window.addEventListener('scroll', () => {
    setTimeout(() => {
      header.classList.add('glass-nav');
      header.style.boxShadow = '0 4px 24px rgba(28,25,23,0.1)';
      logoName.style.color = 'var(--color-text-primary)';
      navLinkEls.forEach(el => el.style.color = '');
    }, 0);
  });

  // ── Google Places autocomplete on property address ─────────────────
  function initGooglePlacesAppraisal() {
    const input = document.getElementById('appraisal-address') as HTMLInputElement;
    if (!input) return;
    const ac = new (window as any).google.maps.places.Autocomplete(input, {
      componentRestrictions: { country: 'au' },
      fields: ['formatted_address'],
      types: ['address'],
    });
    ac.addListener('place_changed', () => {
      const place = ac.getPlace();
      if (place.formatted_address) input.value = place.formatted_address;
    });
  }
  (window as any).initGooglePlacesAppraisal = function() { initGooglePlacesAppraisal(); };
  if ((window as any).google?.maps?.places) {
    initGooglePlacesAppraisal();
  } else {
    const s = document.createElement('script');
    s.src = 'https://maps.googleapis.com/maps/api/js?key=AIzaSyD2sghjRZa7NJeUDKUm6_EHt_aAL0ntvzw&libraries=places&callback=initGooglePlacesAppraisal';
    s.async = true; s.defer = true;
    document.head.appendChild(s);
  }

  // ── Form submit via fetch → /thank-you?from=walkthrough ─────────────
  function attachWalkthroughSubmit() {
    const form = document.getElementById('walkthrough-form') as HTMLFormElement;
    if (!form) return;
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
      try { (window as any).gtag('event', 'appraisal_form_submit', { event_category: 'lead', event_label: 'Walkthrough Request' }); } catch(_) {}
      fetch('https://formspree.io/f/xnjgedwp', {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      }).finally(() => { window.location.href = '/thank-you?from=walkthrough'; });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachWalkthroughSubmit);
  } else {
    attachWalkthroughSubmit();
  }
</script>

</Layout>
