---
// Palette trial: this page is a local-only clone of meet-the-team.astro
// with the dashboard's warm-cream + mustard-gold palette applied. The
// original /meet-the-team page is untouched. Preview at /meet-the-team-dash.
import LandingLayout from '../layouts/LandingLayout.astro';

const services = [
  {
    href: '/tools/presale-checklist',
    title: 'Prepare your home for sale',
    desc: 'A room-by-room checklist.',
    icon: 'home',
  },
  {
    href: '/listings',
    title: 'Current listings',
    desc: 'Homes Daniel and Conrad have on the market right now.',
    icon: 'tag',
  },
];

const articles = [
  {
    href: '/insights/professionals-you-need-when-selling-your-home-brisbane',
    title: 'Who you\'ll need on your team when selling',
    desc: 'The professionals a typical Brisbane sale involves, and which ones you actually need.',
    icon: 'users',
  },
  {
    href: '/insights/aml-changes-real-estate-brisbane-1-july-2026',
    title: 'New AML rules from 1 July 2026',
    desc: 'What changes for buyers and sellers.',
    icon: 'shield',
  },
  {
    href: '/insights/seller-disclosure-obligations-queensland',
    title: 'Seller disclosure obligations in Queensland',
    desc: 'What a vendor must (and should) tell a buyer.',
    icon: 'doc',
  },
];

const agents = [
  {
    name: 'Daniel Gierach',
    slug: 'daniel-gierach',
    photo: '/img/daniel-headshot-tight.jpg',
    phone: '0412 523 821',
    tel: '+61412523821',
    email: 'daniel.gierach@raywhite.com',
    handle: 'dgierach',
    instagramUrl: 'https://www.instagram.com/dgierach/',
    ctaKey: 'daniel',
    role: 'Lead Agent',
  },
  {
    name: 'Conrad Leisemann',
    slug: 'conrad-leisemann',
    photo: '/img/conrad-headshot.jpg',
    phone: '0403 978 813',
    tel: '+61403978813',
    email: 'conrad.leisemann@raywhite.com',
    handle: 'connie_leisemann',
    instagramUrl: 'https://www.instagram.com/connie_leisemann/',
    ctaKey: 'conrad',
    role: 'Lead Agent',
  },
];

// Samantha sits in Dan + Conrad's direct team: she's Operations for
// the lead agents, not part of the extended Ray White group. Rendered
// solo between the two agent cards and the wider-team block.
const directTeam = {
  slug: 'samantha-squires',
  name: 'Samantha Squires',
  role: 'Operations Manager',
  photo: '/img/samantha-squires-headshot.jpg',
};

// Wider team: extended Ray White specialists Dan + Conrad partner with.
const supportTeam = [
  { slug: 'haesley-cush',     name: 'Haesley Cush',     role: 'In-Room Auctioneer', photo: '/img/haesley-cush-headshot.jpg' },
  { slug: 'peter-burgin',     name: 'Peter Burgin',     role: 'On-site Auctioneer', photo: '/img/peter-burgin-headshot.jpg' },
];
---

<!--
  Palette trial: dashboard tokens applied via CSS variable overrides.
  Every existing rule in global.css reads these via var(--color-*) so we
  can retint the entire page without editing components.
-->
<style is:global>
  :root {
    /* Surfaces: dashboard hierarchy */
    --color-base:        #fdfcf7;   /* was #f7f5f0 */
    --color-surface-0:   #fdfcf7;
    --color-surface-1:   #f7f5ec;   /* was #f2efe9 (zebra step) */
    --color-surface-2:   #efece0;   /* was #edeae3 (row hover) */
    --color-surface-3:   #ffffff;   /* pure white card */
    --color-surface-4:   #efece0;   /* was #f5f2eb */
    --color-surface-5:   #e0dccb;   /* was #ece9e1 (badges / group heads) */

    /* Gold: dashboard mustard */
    --color-gold:        #b98229;   /* was #c4912a */
    --color-gold-dim:    #a5721c;   /* was #b07e22 */
    --color-gold-muted:  rgba(185,130,41,0.12);

    /* Accent + eyebrow */
    --color-accent:      #191817;   /* was #1c1917 */
    --color-accent-soft: #2a2724;
    --color-eyebrow:     rgba(25,24,23,0.38);   /* was #78716c */

    /* Text */
    --color-text-primary:   #191817;
    --color-text-secondary: rgba(25,24,23,0.58);
    --color-text-muted:     rgba(25,24,23,0.38);
    --color-ghost:          rgba(25,24,23,0.10);
  }
</style>

<LandingLayout
  title="Meet The Team | Daniel Gierach & Conrad Leisemann (palette trial)"
  description="Palette trial: dashboard warm-cream and mustard-gold applied to the Meet The Team layout."
>

<style>
  /* PALETTE TRIAL: dashboard warm-cream + mustard-gold applied to the
     page-scoped tokens. The original dark charcoal values above are
     retained as reference comments so we can flip back easily. */
  :root {
    /* Surfaces: flip from dark charcoal to cream/white hierarchy */
    --bg:            #fdfcf7;                     /* was #0a0806  */
    --bg-soft:       #f7f5ec;                     /* was #100c08  */
    --card:          #ffffff;                     /* was #15110d  */
    --card-hover:    #efece0;                     /* was #1c1612  */

    /* Lines: soft ink instead of cream-on-dark */
    --line:          rgba(25,24,23,0.08);         /* was rgba(240,236,228,0.07)  */
    --line-strong:   rgba(185,130,41,0.32);       /* was rgba(196,145,42,0.32)   */
    --line-glow:     rgba(185,130,41,0.5);        /* was rgba(196,145,42,0.5)    */

    /* Text: near-black warm on cream */
    --text:          #191817;                     /* was #f2efe9              */
    --text-mute:     rgba(25,24,23,0.38);         /* was rgba(242,239,233,0.5) */
    --text-soft:     rgba(25,24,23,0.58);         /* was rgba(242,239,233,0.78)*/

    /* Gold: dashboard mustard, slightly deeper than the site's brighter gold */
    --gold:          #b98229;                     /* was #c4912a  */
    --gold-bright:   #cc933a;                     /* was #d4a23a  */
    --gold-soft:     rgba(185,130,41,0.85);       /* was rgba(196,145,42,0.85) */
  }

  body { background: var(--bg); color: var(--text); position: relative; }

  /* Header background photo: full-bleed, dark, fades to solid charcoal
     before the first card so it never competes with content. */
  .hero-bg {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 380px;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 92%;
    filter: grayscale(12%) brightness(0.62) contrast(1.05);
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(196,145,42,0.1) 0%, rgba(196,145,42,0) 70%),
      linear-gradient(
        180deg,
        rgba(10,8,6,0.55) 0%,
        rgba(10,8,6,0.5) 28%,
        rgba(10,8,6,0.7) 55%,
        rgba(10,8,6,0.88) 80%,
        var(--bg) 100%
      );
  }
  @media (min-width: 640px) { .hero-bg { height: 420px; } }

  .shell {
    max-width: 480px;
    margin: 0 auto;
    padding: 1.5rem 1.15rem 2.5rem;
    min-height: 100svh;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 640px) {
    .shell { padding: 2rem 1.5rem 3rem; }
  }

  /* ── Header (two-agent: Daniel + Conrad) ─────────────────────── */
  .header { text-align: center; margin-bottom: 1.5rem; }

  .agency-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.56rem; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold-soft);
    margin-bottom: 0.5rem;
  }

  .team-title {
    font-family: var(--font-serif);
    font-size: 1.25rem; font-weight: 400;
    font-style: italic;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 1.4rem;
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
  }

  .agents {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 0;
  }
  @media (min-width: 480px) { .agents { gap: 1.5rem; } }

  .agent {
    display: flex; flex-direction: column; align-items: center;
    min-width: 0;
  }

  .avatar {
    width: 76px; height: 76px;
    border-radius: 14px;
    object-fit: cover; object-position: center 35%;
    display: block;
    margin: 0 0 0.5rem;
    border: 1.5px solid rgba(197, 160, 60, 0.55);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.55), 0 0 0 4px rgba(196, 145, 42, 0.05);
  }
  @media (min-width: 480px) { .avatar { width: 88px; height: 88px; } }

  .name {
    font-family: var(--font-serif);
    font-size: 1rem; font-weight: 700;
    line-height: 1.15; letter-spacing: 0.005em;
    margin-bottom: 0.3rem;
    min-height: 2.4em;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    text-shadow: 0 1px 12px rgba(0,0,0,0.65), 0 1px 2px rgba(0,0,0,0.5);
  }
  @media (min-width: 480px) { .name { font-size: 1.15rem; min-height: 1.3em; } }

  /* Stack phone / handle / email vertically so both columns always have
     the same number of lines, keeping the two cards aligned no matter
     how long the handles or addresses are. */
  .contact-line {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.1rem;
    font-family: var(--font-sans);
    font-size: 0.7rem; font-weight: 700;
    line-height: 1.25;
    margin-bottom: 0.15rem;
    text-shadow: 0 1px 8px rgba(0,0,0,0.6), 0 1px 2px rgba(0,0,0,0.45);
  }
  @media (min-width: 480px) { .contact-line { font-size: 0.78rem; } }
  .contact-line a { color: var(--gold); text-decoration: none; transition: color 0.2s; white-space: nowrap; }
  .contact-line a:hover { color: var(--gold-bright); }
  .contact-line .sep { display: none; }
  .handle-text { color: rgba(242,239,233,0.78); font-weight: 600; }
  .handle-text a { color: rgba(242,239,233,0.78); }
  .handle-text a:hover { color: var(--gold); }

  .email {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 500;
    line-height: 1.25;
    word-break: break-all;
    text-shadow: 0 1px 6px rgba(0,0,0,0.55);
    padding: 0 0.25rem;
    margin: 0;
  }
  @media (min-width: 480px) { .email { font-size: 0.66rem; word-break: normal; } }
  .email a {
    color: rgba(242,239,233,0.85); text-decoration: none;
    transition: color 0.2s;
  }
  .email a:hover { color: var(--gold); }

  /* "More info" button under each primary agent card (links to /team/{slug}) */
  .agent-info-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.3rem;
    margin-top: 0.65rem;
    padding: 0.4rem 0.75rem;
    background: rgba(196, 145, 42, 0.08);
    border: 1px solid rgba(196, 145, 42, 0.35);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.52rem; font-weight: 800;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    white-space: nowrap;
  }
  @media (min-width: 480px) { .agent-info-btn { font-size: 0.55rem; padding: 0.45rem 0.9rem; } }
  .agent-info-btn:hover {
    background: rgba(196, 145, 42, 0.18);
    border-color: var(--gold);
    color: var(--gold-bright);
  }

  /* ── Wider team (Samantha, Haesley, Peter) ────────────────────
     Centered row of equal-width cards. align-items:stretch via flex
     gives every card the same height so the "More info" button at
     the bottom of each card lines up across the row. */
  .wider-team-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.56rem; font-weight: 800;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--text-mute);
    text-align: center;
    margin-top: 2rem; margin-bottom: 1rem;
  }
  .wider-team {
    display: flex;
    justify-content: center;
    gap: 0.7rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 480px) { .wider-team { gap: 1rem; } }
  .wt-card {
    display: flex; flex-direction: column; align-items: center;
    padding: 0.9rem 0.5rem 0.85rem;
    background: rgba(15, 11, 7, 0.55);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(196, 145, 42, 0.18);
    border-radius: 8px;
    transition: background 0.18s, border-color 0.18s;
    /* Equal width siblings; cap at 200px so the row stays compact */
    flex: 1 1 0;
    min-width: 0;
    max-width: 200px;
  }
  .wt-card:hover { background: rgba(20, 14, 9, 0.75); border-color: rgba(196, 145, 42, 0.4); }
  .wt-avatar {
    width: 60px; height: 60px;
    border-radius: 10px;
    object-fit: cover; object-position: center 22%;
    border: 1px solid rgba(197, 160, 60, 0.45);
    margin-bottom: 0.6rem;
  }
  @media (min-width: 480px) { .wt-avatar { width: 70px; height: 70px; border-radius: 12px; } }
  .wt-name {
    font-family: var(--font-serif);
    font-size: 0.78rem; font-weight: 700;
    line-height: 1.2;
    text-align: center;
    margin-bottom: 0.2rem;
    color: var(--text);
    text-shadow: 0 1px 8px rgba(0,0,0,0.55);
    /* Reserve 2 lines so cards stay the same height even if a name fits
       on one line (e.g. Peter Burgin) vs wraps (Samantha Squires) */
    min-height: 2.4em;
    display: flex; align-items: center;
  }
  @media (min-width: 480px) { .wt-name { font-size: 0.88rem; min-height: 1.2em; } }
  .wt-role {
    font-family: var(--font-sans);
    font-size: 0.5rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gold-soft);
    text-align: center;
    margin-bottom: 0.7rem;
    line-height: 1.3;
    min-height: 2.6em;
    display: flex; align-items: center; justify-content: center;
  }
  @media (min-width: 480px) { .wt-role { font-size: 0.55rem; } }
  .wt-info-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.3rem;
    padding: 0.5rem 0.8rem;
    background: rgba(196, 145, 42, 0.08);
    border: 1px solid rgba(196, 145, 42, 0.35);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.52rem; font-weight: 800;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    margin-top: auto;
    white-space: nowrap;
  }
  @media (min-width: 480px) { .wt-info-btn { font-size: 0.55rem; padding: 0.55rem 1rem; } }
  .wt-info-btn:hover {
    background: rgba(196, 145, 42, 0.18);
    border-color: var(--gold);
    color: var(--gold-bright);
  }

  /* ── The Collective call-out band ─────────────────────────────── */
  .collective-band {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    margin: 0.75rem 0 1.75rem;
    background:
      linear-gradient(135deg, rgba(196,145,42,0.08) 0%, rgba(196,145,42,0) 55%),
      var(--bg-soft);
    border: 1px solid rgba(196,145,42,0.3);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, transform 0.2s;
  }
  .collective-band:hover, .collective-band:focus-visible {
    border-color: var(--gold);
    transform: translateY(-1px);
  }
  .cb-body { flex: 1; min-width: 0; }
  .cb-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 800;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.3rem;
  }
  .cb-title {
    font-family: var(--font-serif);
    font-size: 1.02rem; font-weight: 400;
    line-height: 1.25;
    margin: 0 0 0.25rem;
  }
  .cb-desc {
    font-size: 0.72rem; line-height: 1.4;
    color: var(--text-mute);
    margin: 0;
  }
  .cb-arrow {
    color: var(--gold-soft);
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }
  .collective-band:hover .cb-arrow {
    color: var(--gold);
    transform: translateX(2px);
  }

  /* ── Section labels ───────────────────────────────────────────── */
  .section { margin-bottom: 1.5rem; }
  .section-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 800;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-mute);
    margin-bottom: 0.7rem; padding-left: 0.2rem;
  }

  /* ── Service cards (with icon) ────────────────────────────────── */
  .card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.95rem;
    background:
      linear-gradient(135deg, rgba(196,145,42,0.04) 0%, rgba(196,145,42,0) 60%),
      var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.95rem 1.05rem;
    text-decoration: none;
    color: var(--text);
    margin-bottom: 0.55rem;
    transition: background 0.2s, border-color 0.2s, transform 0.18s;
    position: relative;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px; background: var(--gold);
    opacity: 0.6;
    transition: opacity 0.2s, width 0.2s;
  }
  .card:hover, .card:focus-visible {
    background:
      linear-gradient(135deg, rgba(196,145,42,0.08) 0%, rgba(196,145,42,0.01) 60%),
      var(--card-hover);
    border-color: var(--line-strong);
    transform: translateY(-1px);
  }
  .card:hover::before { opacity: 1; width: 3px; }
  .card:active { transform: translateY(0); }

  .card-icon {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(196, 145, 42, 0.1);
    border: 1px solid rgba(196, 145, 42, 0.18);
    border-radius: 50%;
    color: var(--gold-bright);
    flex-shrink: 0;
  }

  .card-body { min-width: 0; }
  .card-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.52rem; font-weight: 800;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold);
    display: block; margin-bottom: 0.18rem;
  }
  .card-title {
    font-family: var(--font-serif);
    font-size: 1rem; font-weight: 400;
    line-height: 1.2;
    margin-bottom: 0.2rem;
  }
  .card-desc {
    font-size: 0.7rem; line-height: 1.4;
    color: var(--text-soft);
  }
  .card-arrow {
    color: var(--text-mute);
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .card:hover .card-arrow {
    color: var(--gold);
    transform: translateX(2px);
  }

  /* ── Article cards (smaller, icon-led) ────────────────────────── */
  .acard {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 0.95rem;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 10px;
    text-decoration: none;
    color: var(--text);
    margin-bottom: 0.45rem;
    transition: background 0.2s, border-color 0.2s;
  }
  .acard:hover, .acard:focus-visible {
    background: var(--bg-soft);
    border-color: var(--line-strong);
  }
  .acard-icon {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    color: var(--gold-soft);
    flex-shrink: 0;
  }
  .acard-body { min-width: 0; }
  .acard-title {
    font-family: var(--font-serif);
    font-size: 0.88rem; font-weight: 400;
    line-height: 1.25;
    margin-bottom: 0.15rem;
  }
  .acard-desc {
    font-size: 0.66rem; line-height: 1.35;
    color: var(--text-mute);
  }

  .browse-all {
    display: inline-flex; align-items: center; gap: 0.35rem;
    margin-top: 0.4rem; padding: 0.3rem 0.2rem;
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 800;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold); text-decoration: none;
    transition: color 0.18s;
  }
  .browse-all:hover { color: var(--gold-bright); }

  /* ── Final CTA panel ──────────────────────────────────────────── */
  .final {
    background:
      linear-gradient(135deg, rgba(196,145,42,0.15) 0%, rgba(196,145,42,0.04) 100%);
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    padding: 1.75rem 1.25rem;
    margin-top: 1.5rem;
    text-align: center;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
  .final > * { margin: 0; }
  .final-title {
    font-family: var(--font-serif);
    font-size: 0.98rem; font-weight: 400; line-height: 1.3;
  }
  .final-sub {
    font-size: 0.7rem; line-height: 1.5;
    color: var(--text-soft);
  }
  .btn-gold {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.75rem 1.25rem;
    background: var(--gold); color: var(--bg);
    font-family: var(--font-sans);
    font-size: 0.66rem; font-weight: 800;
    letter-spacing: 0.14em; text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s, transform 0.18s;
  }
  .btn-gold:hover { background: var(--gold-bright); transform: translateY(-1px); }

  /* ── Bottom row ──────────────────────────────────────────────── */
  .contact-row {
    display: flex; justify-content: center; gap: 1.25rem;
    margin-top: 1.25rem; padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
  .contact-row a {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--text-mute); text-decoration: none;
    transition: color 0.18s;
  }
  .contact-row a:hover { color: var(--gold); }

  .legal {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.56rem; color: var(--text-mute);
    line-height: 1.5;
    opacity: 0.85;
  }

  /* ═══════════════════════════════════════════════════════════════════
     CREAM-MODE OVERRIDES: retint the dark-first design for the
     dashboard palette (cream + mustard gold). Everything above stays
     as-is; this block overrides what breaks on cream.
     ═════════════════════════════════════════════════════════════════ */

  /* Hero backdrop: fully removed. The body gradient now runs from
     top-of-viewport to bottom without any competing overlay. */
  .hero-bg { display: none !important; }

  /* Hero-area typography: remove the heavy shadows meant for dark bg.
     Names, titles, contact lines are dark ink on cream now: shadows
     make them look dirty. */
  .team-title,
  .name,
  .contact-line,
  .email,
  .wt-name { text-shadow: none; }

  .team-title { color: #191817; }
  .name       { color: #191817; }

  /* Handles + email: hardcoded cream tones flipped to warm ink. */
  .handle-text,
  .handle-text a { color: rgba(25,24,23,0.62); }
  .handle-text a:hover { color: #b98229; }
  .email a { color: rgba(25,24,23,0.55); }
  .email a:hover { color: #b98229; }

  /* Avatar frames + shadows: were tuned for cream-on-dark. Ease the
     shadow so it reads as a soft float on cream, not a dark hole. */
  .avatar {
    border: 1px solid rgba(185,130,41,0.35);
    box-shadow:
      0 6px 18px rgba(25,24,23,0.08),
      0 0 0 3px rgba(185,130,41,0.06);
  }

  /* MORE INFO button: was subtle gold-tint on dark, now a clean pill
     matching the dashboard's gold-pill active state pattern. */
  .agent-info-btn,
  .wt-info-btn {
    background: rgba(185,130,41,0.10);
    border: 1px solid rgba(185,130,41,0.35);
    color: #b98229;
  }
  .agent-info-btn:hover,
  .wt-info-btn:hover {
    background: rgba(185,130,41,0.18);
    border-color: #b98229;
    color: #a5721c;
  }

  /* Wider team cards: flip from dark translucent to white cards with
     a soft warm border. Matches how the dashboard renders info tiles. */
  .wt-card {
    background: #ffffff;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    border: 1px solid rgba(25,24,23,0.10);
    box-shadow: 0 1px 2px rgba(25,24,23,0.03), inset 0 1px 0 rgba(255,255,255,0.4);
  }
  .wt-card:hover {
    background: #fbf9f0;
    border-color: rgba(185,130,41,0.4);
  }
  .wt-name { color: #191817; }
  .wt-role { color: rgba(185,130,41,0.9); }

  /* Wider team section label + section labels: quieter warm grey. */
  .wider-team-label,
  .section-label { color: rgba(25,24,23,0.44); }

  /* Collective band: was subtle-gold on dark; now light warm surface. */
  .collective-band {
    background:
      linear-gradient(135deg, rgba(185,130,41,0.08) 0%, rgba(185,130,41,0) 55%),
      #fbf9f0;
    border-color: rgba(185,130,41,0.32);
    color: #191817;
  }
  .cb-eyebrow { color: #b98229; }
  .cb-desc    { color: rgba(25,24,23,0.55); }
  .cb-arrow   { color: rgba(185,130,41,0.85); }

  /* Service cards + article cards: cleaner white surface + subtle gold
     hover. Old rgba(196,145,42, X) values swap to new gold rgba. */
  .card {
    background:
      linear-gradient(135deg, rgba(185,130,41,0.05) 0%, rgba(185,130,41,0) 60%),
      #ffffff;
    border-color: rgba(25,24,23,0.10);
  }
  .card:hover, .card:focus-visible {
    background:
      linear-gradient(135deg, rgba(185,130,41,0.09) 0%, rgba(185,130,41,0.01) 60%),
      #fbf9f0;
    border-color: rgba(185,130,41,0.35);
  }
  .card-desc { color: rgba(25,24,23,0.58); }

  .card-icon {
    background: rgba(185,130,41,0.10);
    border: 1px solid rgba(185,130,41,0.22);
    color: #b98229;
  }

  .acard { border-color: rgba(25,24,23,0.10); }
  .acard:hover, .acard:focus-visible {
    background: #fbf9f0;
    border-color: rgba(185,130,41,0.35);
  }
  .acard-icon { color: rgba(185,130,41,0.9); }
  .acard-desc { color: rgba(25,24,23,0.48); }

  /* Final CTA panel: soft warm gold wash on cream. */
  .final {
    background: linear-gradient(135deg, rgba(185,130,41,0.14) 0%, rgba(185,130,41,0.04) 100%);
    border-color: rgba(185,130,41,0.35);
  }
  .final-sub { color: rgba(25,24,23,0.55); }

  /* Big gold CTA button: dark ink on gold reads cleaner than cream. */
  .btn-gold { background: #b98229; color: #ffffff; }
  .btn-gold:hover { background: #a5721c; }

  /* ═══════════════════════════════════════════════════════════════════
     PREMIUM PASS: air, editorial serif (Fraunces), no button noise.
     Applied on top of the cream-mode overrides. Feels like a magazine
     spread rather than a resource-list page.
     ═════════════════════════════════════════════════════════════════ */

  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..500;1,9..144,300..500&display=swap');

  :root {
    --font-serif: 'Fraunces', 'Noto Serif', Georgia, serif;
  }

  /* ── Air: wider shell, roomier vertical rhythm ───────────────────── */
  .shell {
    max-width: 640px;
    padding: 3rem 1.5rem 4rem;
  }
  @media (min-width: 640px) {
    .shell { max-width: 720px; padding: 4.5rem 2rem 5rem; }
  }

  .header { margin-bottom: 3rem; }
  .agents { gap: 2rem; }
  @media (min-width: 480px) { .agents { gap: 3rem; } }

  .wider-team-label,
  .section-label { margin-top: 4rem; margin-bottom: 1.5rem; }
  .wider-team { gap: 1rem; margin-bottom: 3rem; }
  @media (min-width: 640px) { .wider-team { gap: 1.5rem; margin-bottom: 4rem; } }

  .section { margin-bottom: 3rem; }
  .collective-band { padding: 1.75rem 2rem; margin: 2rem 0 3rem; border-radius: 16px; }
  .card { padding: 1.5rem 1.75rem; border-radius: 16px; margin-bottom: 0.85rem; }
  .acard { padding: 1.15rem 1.4rem; border-radius: 14px; margin-bottom: 0.65rem; }
  .wt-card { padding: 1.5rem 1rem 1.25rem; border-radius: 16px; }
  .final { padding: 2.5rem 1.75rem; border-radius: 16px; }

  /* ── Editorial serif: Fraunces, lighter weight, more scale ──────── */
  .team-title {
    font-size: 2.25rem; font-weight: 300;
    font-style: normal;
    letter-spacing: -0.02em;
    margin-bottom: 2.75rem;
  }
  @media (min-width: 640px) { .team-title { font-size: 2.75rem; } }

  .name-link {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: 1.35rem; font-weight: 400;
    line-height: 1.15; letter-spacing: -0.01em;
    color: #191817;
    text-decoration: none;
    margin: 0.75rem 0 0.5rem;
    min-height: 2.4em;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s, color 0.2s;
  }
  @media (min-width: 480px) {
    .name-link { font-size: 1.5rem; min-height: 1.3em; }
  }
  .name-link:hover,
  .name-link:focus-visible {
    color: #b98229;
    border-bottom-color: rgba(185,130,41,0.4);
  }

  /* Phone + handle: quieter, unbolded */
  .contact-line {
    font-weight: 400;
    font-size: 0.85rem;
    margin-top: 0.35rem;
  }
  .contact-line a { color: rgba(25,24,23,0.7); font-weight: 400; }
  .contact-line a:hover { color: #b98229; }
  .handle-text a { color: rgba(25,24,23,0.5); font-weight: 400; }
  .email a { font-size: 0.75rem; }

  /* Wider team name: Fraunces, quieter, no bold */
  .wt-name {
    font-size: 1.05rem; font-weight: 400;
    letter-spacing: -0.005em;
    color: #191817;
    margin-bottom: 0.35rem;
  }
  @media (min-width: 480px) { .wt-name { font-size: 1.15rem; } }

  .wt-role { font-size: 0.55rem; margin-bottom: 0; }

  /* Wider-team card is now a link: inherit dark ink, no underline. */
  .wt-card-link { text-decoration: none; color: inherit; cursor: pointer; }

  /* Section labels: unify to a single scale + colour */
  .wider-team-label,
  .section-label,
  .cb-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    color: rgba(25,24,23,0.42);
  }

  /* Cards: quieter titles in Fraunces */
  .cb-title,
  .card-title,
  .acard-title,
  .final-title {
    font-family: var(--font-serif);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .cb-title    { font-size: 1.4rem; margin: 0 0 0.4rem; }
  .card-title  { font-size: 1.2rem; margin-bottom: 0.35rem; }
  .acard-title { font-size: 1.05rem; margin-bottom: 0.2rem; }
  .final-title { font-size: 1.35rem; }

  .card-desc, .acard-desc, .cb-desc, .final-sub {
    font-size: 0.85rem;
    line-height: 1.55;
  }

  /* Icons: kill the chip backgrounds, use flat monoline instead */
  .card-icon {
    background: transparent;
    border: none;
    color: rgba(185,130,41,0.9);
    width: 26px; height: 26px;
  }
  .card-icon svg { width: 22px; height: 22px; }

  /* Kill the leftmost gold accent bar on service cards: reads utility */
  .card::before { display: none; }

  /* ═══════════════════════════════════════════════════════════════════
     FLOW PASS 2: quieter wider-team tiles, better hierarchy, agent
     name asymmetry fix.
     ═════════════════════════════════════════════════════════════════ */

  /* Wider-team cards: were pure-white rectangles that competed with the
     cream page for attention. Now transparent by default, sitting on
     cream with just a hairline. Card lifts on hover only. */
  .wt-card {
    background: transparent;
    border: 1px solid transparent;
    box-shadow: none;
    padding: 1.25rem 0.75rem 1rem;
  }
  .wt-card-link:hover,
  .wt-card-link:focus-visible {
    background: rgba(255,255,255,0.65);
    border-color: rgba(25,24,23,0.10);
    box-shadow: 0 4px 20px rgba(25,24,23,0.04);
  }

  /* Bigger avatars, tighter frames: the photo IS the card. */
  .wt-avatar {
    width: 84px; height: 84px;
    border-radius: 14px;
    border: 1px solid rgba(185,130,41,0.28);
    margin-bottom: 0.85rem;
  }
  @media (min-width: 480px) {
    .wt-avatar { width: 96px; height: 96px; border-radius: 16px; }
  }

  /* Fix the Daniel / Conrad asymmetry: Conrad Leisemann was wrapping
     to two lines while Daniel stayed on one. Tuning size + min-height. */
  .name-link {
    font-size: 1.2rem;
    min-height: 1.6em;
  }
  @media (min-width: 480px) {
    .name-link { font-size: 1.35rem; min-height: 1.4em; }
  }
  @media (min-width: 640px) {
    .name-link { font-size: 1.45rem; min-height: 1.3em; }
  }

  /* Email wrap policy: allow break-word but not mid-domain. */
  .email {
    word-break: normal;
    overflow-wrap: anywhere;
    max-width: 15rem;
    margin: 0 auto;
  }

  /* Flow: give the primary "Your Team" section stronger space AFTER
     it, so eye clearly transitions to "The Wider Team" next. */
  .header { margin-bottom: 4rem; }
  @media (min-width: 640px) { .header { margin-bottom: 5rem; } }

  /* And separate About the Group from the wider team + services below
     with clean whitespace instead of matching rhythms everywhere. */
  .collective-band { margin-top: 3rem; margin-bottom: 4rem; }
  @media (min-width: 640px) { .collective-band { margin-top: 4rem; margin-bottom: 5rem; } }

  /* Agent role tag: quiet uppercase micro-label under the name.
     Same tracking as section labels so the eye recognises the pattern. */
  .agent-role {
    font-family: var(--font-sans);
    font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(185,130,41,0.9);
    text-align: center;
    margin: 0 0 0.85rem;
    line-height: 1.4;
  }
  @media (min-width: 480px) {
    .agent-role { font-size: 0.68rem; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     MOBILE PASS: this page will be viewed on phones a lot. Tighten
     everything for narrow screens without losing the editorial feel.
     Applied below 640px only; desktop rhythm above is unchanged.
     ═════════════════════════════════════════════════════════════════ */
  @media (max-width: 639.98px) {

    /* Shell: less side padding on phone so cards get real estate. */
    .shell {
      padding: 2rem 1rem 3rem;
      max-width: 100%;
    }

    /* Eyebrow: sit closer to the top so hero starts higher */
    .agency-eyebrow {
      font-size: 0.6rem;
      letter-spacing: 0.24em;
      margin-bottom: 0.75rem;
    }

    /* Big serif title: tune for phone: smaller, tighter margin */
    .team-title {
      font-size: 1.75rem;
      letter-spacing: -0.02em;
      margin-bottom: 2rem;
    }

    /* Agents grid: keep 2-col even on phone so photos sit side-by-side.
       Photos + names shrink a notch to fit comfortably. */
    .agents { gap: 1.25rem; }
    .avatar { width: 84px; height: 84px; border-radius: 14px; margin-bottom: 0.75rem; }
    .name-link {
      font-size: 1.15rem;
      min-height: 2.4em; /* two-line reserve so DG + CL align */
      margin: 0.6rem 0 0.35rem;
    }
    .agent-role {
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      margin-bottom: 0.7rem;
    }
    .contact-line { font-size: 0.78rem; margin-top: 0.25rem; }
    .email a { font-size: 0.72rem; }
    .email {
      max-width: 100%;
      padding: 0 0.5rem;
      line-height: 1.35;
    }
    /* Handle line stays on same row as phone on mobile */
    .contact-line .sep { display: none; }

    .header { margin-bottom: 2.5rem; }

    /* Wider team: keep 3-col but tighten to work on 375px screens */
    .wider-team-label { margin-top: 2.5rem; margin-bottom: 1rem; font-size: 0.6rem; }
    .wider-team { gap: 0.5rem; margin-bottom: 2.5rem; }
    .wt-card { padding: 0.9rem 0.35rem 0.85rem; }
    .wt-avatar {
      width: 62px; height: 62px;
      border-radius: 12px;
      margin-bottom: 0.6rem;
    }
    .wt-name {
      font-size: 0.9rem;
      min-height: 2.4em;
      line-height: 1.15;
      margin-bottom: 0.3rem;
    }
    .wt-role {
      font-size: 0.5rem;
      letter-spacing: 0.14em;
      line-height: 1.3;
      min-height: 2.6em;
    }

    /* Collective band: full-width padding on phone */
    .collective-band {
      padding: 1.25rem 1.15rem;
      margin: 2rem 0 2.5rem;
      border-radius: 14px;
      gap: 0.85rem;
    }
    .cb-title { font-size: 1.15rem; margin-bottom: 0.3rem; }
    .cb-desc { font-size: 0.78rem; }

    /* Service cards + article cards: tighter phone padding */
    .card {
      padding: 1.1rem 1.2rem;
      border-radius: 14px;
      gap: 0.8rem;
      margin-bottom: 0.5rem;
    }
    .card-title { font-size: 1.05rem; }
    .card-desc { font-size: 0.78rem; line-height: 1.5; }
    .card-icon { width: 22px; height: 22px; }
    .card-icon svg { width: 20px; height: 20px; }

    .acard {
      padding: 0.95rem 1.15rem;
      border-radius: 12px;
      margin-bottom: 0.4rem;
      gap: 0.75rem;
    }
    .acard-title { font-size: 0.95rem; }
    .acard-desc { font-size: 0.75rem; }

    /* Section spacing: pull sections closer on mobile so scroll doesn't feel endless */
    .section { margin-bottom: 2rem; }
    .section-label { margin-top: 2.5rem; margin-bottom: 1rem; font-size: 0.6rem; }

    /* Final CTA panel */
    .final { padding: 1.75rem 1.25rem; border-radius: 14px; }
    .final-title { font-size: 1.15rem; }
    .final-sub { font-size: 0.78rem; }
  }

  /* Extra-narrow phones (iPhone SE, older Androids): one more notch tighter */
  @media (max-width: 380px) {
    .agents { gap: 1rem; }
    .avatar { width: 72px; height: 72px; }
    .name-link { font-size: 1.05rem; }
    .wider-team { gap: 0.35rem; }
    .wt-avatar { width: 54px; height: 54px; border-radius: 10px; }
    .wt-name { font-size: 0.82rem; }
    .wt-role { font-size: 0.46rem; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     TYPOGRAPHY DISCIPLINE PASS: 6-stop modular scale (1.25 ratio),
     3 weights only, opsz axis leveraged per size, italic used as
     editorial signal, tabular-nums on data, small-caps for labels.
     ═════════════════════════════════════════════════════════════════ */

  /* ── 1. OPTICAL SIZE AXIS: Fraunces per-size drawing ─────────────
     Bigger opsz = higher-contrast display letterforms.
     Smaller opsz = thicker strokes + open counters for legibility.
     Also enable the ss01 stylistic set (softer g + a) + contextual
     alternates for a warmer, less mechanical text texture. */
  body,
  .team-title,
  .name-link,
  .cb-title,
  .card-title,
  .acard-title,
  .final-title,
  .wt-name,
  .agent-role,
  .wt-role {
    font-feature-settings: "ss01" 1, "calt" 1;
  }

  .team-title    { font-variation-settings: "opsz" 96; }
  .cb-title,
  .final-title   { font-variation-settings: "opsz" 32; }
  .name-link     { font-variation-settings: "opsz" 36; }
  .card-title    { font-variation-settings: "opsz" 24; }
  .acard-title,
  .wt-name       { font-variation-settings: "opsz" 20; }

  /* ── 2. MODULAR SCALE: six stops, 1.25 ratio (major third) ─────
     Anchor at 15px body. Every size derives from it.
        Display   44px  2.75rem
        H1        32px  2.00rem     Ray White Collective / Final title
        H2        24px  1.50rem     Agent names / card titles
        H3        19px  1.20rem     Wider-team names / article titles
        Body      15px  0.94rem     Descriptions
        Meta      12px  0.75rem     Contact line, email, phone
        Caption   11px  0.68rem     Eyebrows, section labels, role tags */
  .team-title    { font-size: 2.75rem; line-height: 1.05; letter-spacing: -0.028em; }
  .cb-title      { font-size: 2rem;    line-height: 1.15; letter-spacing: -0.02em;  margin-bottom: 0.5rem; }
  .final-title   { font-size: 2rem;    line-height: 1.15; letter-spacing: -0.02em; }
  .name-link     { font-size: 1.5rem;  line-height: 1.2;  letter-spacing: -0.012em; }
  .card-title    { font-size: 1.5rem;  line-height: 1.2;  letter-spacing: -0.012em; }
  .acard-title   { font-size: 1.2rem;  line-height: 1.25; letter-spacing: -0.008em; }
  .wt-name       { font-size: 1.2rem;  line-height: 1.2;  letter-spacing: -0.008em; }

  /* Body copy (descriptions): 15px anchor with generous leading. */
  .card-desc,
  .acard-desc,
  .cb-desc,
  .final-sub {
    font-size: 0.94rem;
    line-height: 1.6;
    letter-spacing: 0.002em;
  }

  /* Meta / data (contact + email): 12px, tabular for phone numbers. */
  .contact-line { font-size: 0.75rem; line-height: 1.5; margin-top: 0.5rem; }
  .contact-line a {
    font-family: var(--font-sans);
    font-variant-numeric: tabular-nums lining-nums;
    letter-spacing: 0;
    font-weight: 400;
  }
  .email a { font-size: 0.75rem; }

  /* Caption / eyebrow scale: 11px small-cap-adjacent labels. */
  .agency-eyebrow,
  .section-label,
  .wider-team-label,
  .cb-eyebrow,
  .wt-role,
  .browse-all {
    font-size: 0.68rem;
    letter-spacing: 0.24em;
    line-height: 1.4;
  }

  /* ── 3. WEIGHT DISCIPLINE: three weights only ────────────────────
     Fraunces 400 for all serif, Manrope 500 for eyebrows/labels,
     Manrope 400 for body copy. No 700 anywhere on this page. */
  .team-title,
  .name-link,
  .cb-title,
  .final-title,
  .card-title,
  .acard-title,
  .wt-name { font-weight: 400; }

  .agency-eyebrow,
  .section-label,
  .wider-team-label,
  .cb-eyebrow,
  .browse-all { font-weight: 500; }

  .card-desc,
  .acard-desc,
  .cb-desc,
  .final-sub,
  .contact-line,
  .email { font-weight: 400; }

  /* ── 4. ITALIC: used as an editorial signal, purposefully ───────
     Display H1 goes italic to establish tone; role tags become italic
     lowercase Fraunces to differentiate from brand eyebrows above. */
  .team-title { font-style: italic; }

  .agent-role,
  .wt-role {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 0.94rem;
    letter-spacing: 0;
    text-transform: none;      /* strip the uppercase */
    color: rgba(25,24,23,0.55);
    line-height: 1.3;
    margin: 0 0 0.85rem;
    font-variation-settings: "opsz" 14;
  }

  /* ── 5. TABULAR + LINING FIGURES on numeric data ──────────────────
     Applied to phone number links (already scoped above) and any
     currency-adjacent elsewhere. */
  .contact-line,
  .email { font-variant-numeric: tabular-nums lining-nums; }

  /* ── DETAILS: small-caps eyebrows, hover polish ─────────────────
     Section labels + agency eyebrow use Fraunces small-caps for a
     properly editorial feel. Falls back to sans-serif uppercase where
     small-caps aren't rendered (extremely rare). */
  .agency-eyebrow,
  .section-label,
  .wider-team-label {
    font-family: var(--font-serif);
    font-variant-caps: all-small-caps;
    text-transform: none;
    letter-spacing: 0.16em;
    font-size: 0.85rem;
    font-weight: 400;
    color: rgba(185,130,41,0.72);
    font-variation-settings: "opsz" 14;
  }

  /* Body-level defaults so descriptions get lining + tabular numerals too */
  body { font-variant-numeric: lining-nums; }

  /* Mobile overrides for the new scale: proportionally smaller,
     same ratio between stops, tabular preserved. */
  @media (max-width: 639.98px) {
    .team-title    { font-size: 2rem; }
    .cb-title,
    .final-title   { font-size: 1.5rem; }
    .name-link     { font-size: 1.2rem;  min-height: 2.4em; }
    .card-title    { font-size: 1.2rem; }
    .acard-title,
    .wt-name       { font-size: 1rem; }
    .card-desc,
    .acard-desc,
    .cb-desc,
    .final-sub     { font-size: 0.88rem; line-height: 1.55; }
    .agency-eyebrow,
    .section-label,
    .wider-team-label { font-size: 0.75rem; letter-spacing: 0.14em; }
    .agent-role,
    .wt-role       { font-size: 0.82rem; }
  }
  @media (max-width: 380px) {
    .team-title    { font-size: 1.65rem; }
    .name-link     { font-size: 1.05rem; }
    .wt-name       { font-size: 0.88rem; }
    .agent-role,
    .wt-role       { font-size: 0.75rem; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     CONSISTENCY PASS: one tap target per person. Photo + name + role
     become a single link block for BOTH the primary agents (Dan +
     Conrad) and the wider team (Sam, Haesley, Peter). Contact info
     (phone / handle / email) stays as its own independent links.
     ═════════════════════════════════════════════════════════════════ */

  /* Primary agent tap-target: matches the wt-card-link pattern. */
  .agent-primary-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    padding: 0.85rem 0.5rem 1rem;
    border-radius: 16px;
    border: 1px solid transparent;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .agent-primary-link:hover,
  .agent-primary-link:focus-visible {
    background: rgba(255,255,255,0.65);
    border-color: rgba(25,24,23,0.10);
    box-shadow: 0 4px 20px rgba(25,24,23,0.04);
  }
  .agent-primary-link:hover .name-link,
  .agent-primary-link:focus-visible .name-link {
    color: #b98229;
  }

  /* The name inside the tap-target no longer needs its own click
     affordance: the whole block is the affordance. Drop the border
     hover; keep the color shift so name reads as "clickable within". */
  .name-link {
    display: block;
    border-bottom: none;
    margin-top: 0.85rem;
    margin-bottom: 0.4rem;
    text-align: center;
    color: #191817;
  }

  /* Match the wt-card-link's identical treatment so both patterns
     read as siblings visually. Already tuned for the wider team above;
     re-affirm here for parity. */
  .wt-card-link {
    -webkit-tap-highlight-color: transparent;
    cursor: pointer;
  }
  .wt-card-link:hover .wt-name,
  .wt-card-link:focus-visible .wt-name {
    color: #b98229;
    transition: color 0.2s;
  }

  /* Mobile: the tap targets should feel generous: Apple recommends
     44px min. Increase padding on the tap-target block on phones. */
  @media (max-width: 639.98px) {
    .agent-primary-link { padding: 0.75rem 0.5rem 0.9rem; }
    .wt-card            { padding: 0.9rem 0.4rem 0.85rem; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     FINAL POLISH: visible profile borders, tighter mobile rhythm,
     darker gold for legibility, Samantha as direct-team.
     ═════════════════════════════════════════════════════════════════ */

  /* Profile borders: every person tile now shows a subtle hairline
     border by default so the click-target is obvious without hover. */
  .agent-primary-link {
    border: 1px solid rgba(25,24,23,0.08);
    background: rgba(255,255,255,0.35);
  }
  .agent-primary-link:hover,
  .agent-primary-link:focus-visible {
    background: rgba(255,255,255,0.85);
    border-color: rgba(185,130,41,0.35);
  }
  .wt-card {
    border: 1px solid rgba(25,24,23,0.08);
    background: rgba(255,255,255,0.35);
  }
  .wt-card-link:hover,
  .wt-card-link:focus-visible {
    background: rgba(255,255,255,0.85);
    border-color: rgba(185,130,41,0.35);
    box-shadow: 0 4px 20px rgba(25,24,23,0.04);
  }

  /* Gold labels darker for legibility, especially at small sizes on
     mobile. #b98229 on cream is ~3.4:1 (marginal); shifting to
     #8f6317 pushes it to ~4.6:1 which reads cleanly at 11-14px. */
  .agency-eyebrow,
  .section-label,
  .wider-team-label,
  .cb-eyebrow {
    color: #8f6317;
  }

  /* Direct-team block: Samantha alone, centered, capped in width so
     she reads as a single primary teammate rather than a wider-team
     card that lost its friends. */
  .direct-team {
    display: flex;
    justify-content: center;
    margin: 0.5rem 0 3rem;
  }
  .direct-team-card {
    max-width: 240px;
    width: 100%;
  }
  @media (min-width: 640px) {
    .direct-team { margin: 1rem 0 4rem; }
    .direct-team-card { max-width: 280px; }
  }

  /* Mobile: tighten vertical rhythm INSIDE each agent card so name →
     role → contact don't feel disconnected. Also reduce the gap
     between the two agent columns so they don't drift apart. */
  @media (max-width: 639.98px) {
    /* Wider columns AND small horizontal gap so photos + names feel
       like a pair rather than two lonely towers. */
    .agents { gap: 0.75rem; }

    .agent-primary-link {
      padding: 0.7rem 0.35rem 0.85rem;
      border-radius: 14px;
    }
    .avatar { margin-bottom: 0.55rem; }

    .name-link {
      margin-top: 0.55rem;
      margin-bottom: 0.25rem;
    }
    .agent-role {
      margin-top: 0.15rem;
      margin-bottom: 0.35rem;
      font-size: 0.82rem;
    }
    .contact-line {
      margin-top: 0.85rem;
      font-size: 0.72rem;
    }
    .email {
      margin-top: 0.15rem;
      padding: 0 0.35rem;
    }
    .email a { font-size: 0.68rem; }

    /* Direct-team Samantha keeps her width but breathes on phones. */
    .direct-team { margin: 0.25rem 0 2.25rem; }
    .direct-team-card { max-width: 220px; }
  }

  /* Extra-narrow (iPhone SE): reduce photo + gaps one more notch. */
  @media (max-width: 380px) {
    .agents { gap: 0.5rem; }
    .agent-primary-link { padding: 0.55rem 0.25rem 0.75rem; }
    .name-link { margin-top: 0.4rem; }
    .contact-line { margin-top: 0.65rem; font-size: 0.68rem; }
    .email a { font-size: 0.64rem; }
    .direct-team-card { max-width: 200px; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     UNIFIED CARDS: all profile photos same size, all cards use the
     dashboard commission-calculator's warm-stone bg + inset highlight.
     ═════════════════════════════════════════════════════════════════ */

  /* One avatar size to rule them all. Reads as parallel siblings. */
  .avatar,
  .wt-avatar {
    width: 88px;
    height: 88px;
    border-radius: 14px;
    border: 1px solid rgba(185,130,41,0.28);
    margin-bottom: 0.85rem;
    box-shadow: 0 6px 18px rgba(25,24,23,0.08), 0 0 0 3px rgba(185,130,41,0.06);
  }
  @media (min-width: 640px) {
    .avatar,
    .wt-avatar {
      width: 100px;
      height: 100px;
      border-radius: 16px;
    }
  }
  @media (max-width: 639.98px) {
    .avatar,
    .wt-avatar {
      width: 78px;
      height: 78px;
      border-radius: 12px;
      margin-bottom: 0.7rem;
    }
  }
  @media (max-width: 380px) {
    .avatar,
    .wt-avatar {
      width: 66px;
      height: 66px;
      border-radius: 11px;
    }
  }

  /* Card backgrounds match the commission calculator's AgentTile -
     warm stone (#e0dccb) with the same subtle inset highlight so the
     card floats above the cream page. Same treatment on all three tiers
     (Dan + Conrad / Samantha / Haesley + Peter). */
  .agent-primary-link,
  .wt-card {
    background: #e0dccb;
    border: 1px solid rgba(25,24,23,0.06);
    box-shadow:
      0 1px 2px rgba(0,0,0,0.03),
      inset 0 1px 0 rgba(255,255,255,0.4);
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.18s;
  }

  .agent-primary-link:hover,
  .agent-primary-link:focus-visible,
  .wt-card-link:hover,
  .wt-card-link:focus-visible {
    background: #d4cfb9;
    border-color: rgba(185,130,41,0.32);
    box-shadow:
      0 4px 20px rgba(25,24,23,0.06),
      inset 0 1px 0 rgba(255,255,255,0.4);
    transform: translateY(-1px);
  }

  /* ═══════════════════════════════════════════════════════════════════
     UNIFORM CARD HEIGHTS: every card in a section becomes the same
     height. Enough vertical space for a two-line title + two-line desc
     so no content ever pushes a card taller than its neighbours.
     Content stays vertically centered via the existing align-items.
     ═════════════════════════════════════════════════════════════════ */

  /* Tools & Services cards */
  .card {
    min-height: 132px;
    align-items: center;
  }
  @media (max-width: 639.98px) {
    .card { min-height: 108px; }
  }

  /* Article cards */
  .acard {
    min-height: 118px;
    align-items: center;
  }
  @media (max-width: 639.98px) {
    .acard { min-height: 100px; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     FINAL LOCK-IN: every profile card + every profile photo is now
     mathematically identical, regardless of which section they're in.
     This block has the LAST word; !important is used against the
     stack of earlier responsive tweaks.
     ═════════════════════════════════════════════════════════════════ */

  /* Every profile photo: identical dimensions across Dan, Conrad,
     Samantha, Haesley, Peter, at every breakpoint. */
  .avatar,
  .wt-avatar {
    width: 88px !important;
    height: 88px !important;
    border-radius: 14px !important;
    object-fit: cover;
    object-position: center 20%;
    border: 1px solid rgba(185,130,41,0.28) !important;
    margin: 0 auto 0.85rem !important;
    box-shadow: none !important;
  }
  @media (max-width: 639.98px) {
    .avatar,
    .wt-avatar {
      width: 74px !important;
      height: 74px !important;
      border-radius: 12px !important;
      margin-bottom: 0.65rem !important;
    }
  }
  @media (max-width: 380px) {
    .avatar,
    .wt-avatar {
      width: 62px !important;
      height: 62px !important;
    }
  }

  /* Every profile card: identical padding + border + background,
     regardless of which section it lives in. */
  .agent-primary-link,
  .wt-card {
    padding: 1.25rem 1rem 1.35rem !important;
    border-radius: 14px !important;
    min-height: unset !important;
    max-width: none;
  }
  @media (min-width: 640px) {
    .agent-primary-link,
    .wt-card {
      padding: 1.5rem 1rem 1.65rem !important;
    }
  }
  @media (max-width: 639.98px) {
    .agent-primary-link,
    .wt-card {
      padding: 0.9rem 0.6rem 1rem !important;
    }
  }

  /* Samantha's card: same width as Dan/Conrad/Haesley/Peter (half a
     row) so she reads as a single column rather than an oversized
     island. */
  .direct-team {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0.5rem 0 3rem !important;
  }
  .direct-team-card {
    grid-column: 1 / -1;
    justify-self: center;
    width: calc(50% - 0.5rem);
    max-width: none !important;
  }
  @media (min-width: 640px) {
    .direct-team { gap: 1.5rem; margin: 1rem 0 4rem !important; }
    .direct-team-card { width: calc(50% - 0.75rem); }
  }
  @media (max-width: 639.98px) {
    .direct-team { gap: 0.75rem; margin: 0.25rem 0 2rem !important; }
    .direct-team-card { width: calc(50% - 0.375rem); }
  }

  /* Wider team: force flex children to equal width so Haesley + Peter
     match Dan/Conrad exactly. Uses grid instead of flex to guarantee
     equal-width, equal-height siblings. */
  .wider-team {
    display: grid !important;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .wider-team { gap: 1.5rem; }
  }
  @media (max-width: 639.98px) {
    .wider-team { gap: 0.75rem; }
  }
  .wt-card {
    flex: unset;
    max-width: none;
    min-width: 0;
  }

  /* Same for the agents grid: guarantee it stays 2-col with equal
     width children. */
  .agents {
    display: grid !important;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .agents { gap: 1.5rem; }
  }
  @media (max-width: 639.98px) {
    .agents { gap: 0.75rem; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     DESIGN FUNDAMENTAL: colour off, borders on. Structure comes from
     the hairline, whitespace, and typographic hierarchy. Colour is
     reserved for accent (gold on links + eyebrows), never for surface
     fill on chrome elements.
     ═════════════════════════════════════════════════════════════════ */

  /* ABOUT THE GROUP panel: the warm gold-gradient fill made it feel
     "boxed". Strip to a hairline + generous whitespace. The eyebrow,
     serif title, and body copy do the hierarchy work. */
  .collective-band {
    background: transparent !important;
    border: 1px solid rgba(25,24,23,0.10);
  }
  .collective-band:hover,
  .collective-band:focus-visible {
    background: transparent !important;
    border-color: rgba(185,130,41,0.4);
    transform: translateY(-1px);
  }

  /* Same treatment on the final CTA: border-defined, not filled. */
  .final {
    background: transparent !important;
    border: 1px solid rgba(185,130,41,0.35);
  }

  /* ═══════════════════════════════════════════════════════════════════
     ROUND-4 FIXES: strip fill from profile cards, unify their sizes,
     bump section labels for readability, tighten Tools + Articles.
     ═════════════════════════════════════════════════════════════════ */

  /* PROFILE CARDS: same design fundamental as ABOUT THE GROUP: no
     fill, hairline border, structure comes from whitespace + type. */
  .agent-primary-link,
  .wt-card {
    background: transparent !important;
    border: 1px solid rgba(25,24,23,0.10) !important;
    box-shadow: none !important;
  }
  .agent-primary-link:hover,
  .agent-primary-link:focus-visible,
  .wt-card-link:hover,
  .wt-card-link:focus-visible {
    background: rgba(255,255,255,0.4) !important;
    border-color: rgba(185,130,41,0.4) !important;
    box-shadow: none !important;
    transform: translateY(-1px);
  }

  /* Profile NAMES: same size across all five people. Using H3 scale
     (19px) so the compact cards feel uniform. Dan/Conrad were H2
     (24px) which made their cards taller than the wider team. */
  .name-link,
  .wt-name {
    font-size: 1.2rem !important;
    line-height: 1.2 !important;
    letter-spacing: -0.008em !important;
    font-weight: 400 !important;
    min-height: unset !important;
    margin: 0.75rem 0 0.35rem !important;
    text-align: center;
    display: block;
  }
  @media (max-width: 639.98px) {
    .name-link,
    .wt-name {
      font-size: 1.05rem !important;
      margin: 0.55rem 0 0.3rem !important;
    }
  }
  @media (max-width: 380px) {
    .name-link,
    .wt-name {
      font-size: 0.95rem !important;
    }
  }

  /* Profile ROLES: same italic serif treatment across all five. */
  .agent-role,
  .wt-role {
    font-family: var(--font-serif) !important;
    font-style: italic !important;
    font-weight: 400 !important;
    font-size: 0.9rem !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    color: rgba(25,24,23,0.55) !important;
    margin: 0 !important;
    padding: 0;
    line-height: 1.3 !important;
    min-height: unset !important;
    text-align: center;
  }
  @media (max-width: 639.98px) {
    .agent-role,
    .wt-role { font-size: 0.82rem !important; }
  }

  /* PROFILE CARDS: explicitly full-width so the grid can't render
     them at different widths. Min-height sized to content, not
     inflated. Content vertically centered. */
  .agent-primary-link,
  .wt-card {
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100% !important;
    box-sizing: border-box !important;
    margin: 0 !important;
    min-height: 195px !important;
    padding: 1.15rem 0.75rem !important;
  }
  @media (max-width: 639.98px) {
    .agent-primary-link,
    .wt-card {
      min-height: 165px !important;
      padding: 0.95rem 0.5rem !important;
    }
  }
  @media (max-width: 380px) {
    .agent-primary-link,
    .wt-card {
      min-height: 145px !important;
      padding: 0.8rem 0.4rem !important;
    }
  }

  /* Belt-and-braces: agents grid strictly 2-col, gap-tight, children
     stretch to fill columns. */
  .agents,
  .wider-team {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 1rem !important;
    align-items: stretch;
    justify-items: stretch;
  }
  @media (min-width: 640px) {
    .agents,
    .wider-team { gap: 1.5rem !important; }
  }
  @media (max-width: 639.98px) {
    .agents,
    .wider-team { gap: 0.75rem !important; }
  }
  .agent { min-width: 0; width: 100%; }
  .wt-card, .agent-primary-link { align-self: stretch; }

  /* Samantha lines up too: same column width as one of the pairs. */
  .direct-team {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 1rem !important;
  }
  .direct-team-card {
    grid-column: 1 / -1;
    justify-self: center;
    width: calc(50% - 0.5rem);
    max-width: none !important;
    align-self: stretch;
  }
  @media (min-width: 640px) {
    .direct-team { gap: 1.5rem !important; }
    .direct-team-card { width: calc(50% - 0.75rem); }
  }
  @media (max-width: 639.98px) {
    .direct-team { gap: 0.75rem !important; }
    .direct-team-card { width: calc(50% - 0.375rem); }
  }

  /* SECTION LABELS: bumped size so small-caps read cleanly. Was 0.85rem
     (~11px effective small-cap height), now 1.05rem (~14px effective). */
  .agency-eyebrow,
  .section-label,
  .wider-team-label,
  .cb-eyebrow {
    font-size: 1.05rem !important;
    letter-spacing: 0.18em !important;
  }
  @media (max-width: 639.98px) {
    .agency-eyebrow,
    .section-label,
    .wider-team-label,
    .cb-eyebrow {
      font-size: 0.95rem !important;
      letter-spacing: 0.15em !important;
    }
  }

  /* TOOLS & SERVICES + ARTICLES cards: compact + uniform height.
     Fixed height so 1-line + 2-line descriptions render at the same
     card height. Both card types use the same height so the two
     sections read as a matched family. */
  .card,
  .acard {
    min-height: 84px !important;
    height: 84px !important;
    padding: 0 1.15rem !important;
    margin-bottom: 0.5rem !important;
    align-items: center !important;
  }
  @media (max-width: 639.98px) {
    .card,
    .acard {
      min-height: 72px !important;
      height: 72px !important;
      padding: 0 1rem !important;
      margin-bottom: 0.4rem !important;
    }
  }
  @media (max-width: 380px) {
    .card,
    .acard {
      min-height: 66px !important;
      height: 66px !important;
      padding: 0 0.85rem !important;
    }
  }

  /* Description: clamp to 1 line so 2-line descriptions don't blow the
     fixed height. Ellipsises past 1 line for consistency. */
  .card-desc,
  .acard-desc {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: 0 !important;
  }
  .card-title,
  .acard-title {
    margin-bottom: 0.15rem !important;
    line-height: 1.2 !important;
  }

  /* Tools & Services + Article titles a touch smaller for compactness */
  .card-title { font-size: 1.15rem !important; line-height: 1.25 !important; }
  .acard-title { font-size: 1.02rem !important; line-height: 1.25 !important; }
  @media (max-width: 639.98px) {
    .card-title { font-size: 1.05rem !important; }
    .acard-title { font-size: 0.95rem !important; }
  }
  .card-desc, .acard-desc { font-size: 0.85rem !important; line-height: 1.45 !important; }

  /* ═══════════════════════════════════════════════════════════════════
     TERRACOTTA + MOTION: second warm accent introduces section
     identity, motion turns the flat scan into a scroll experience.
     Fundamentals: colour used sparingly for semantic differentiation,
     motion for signalling affordance + reward for interaction.
     ═════════════════════════════════════════════════════════════════ */
  :root {
    /* Two shades of gold from the same warm family: Ray White DNA.
       Deep mustard for text + eyebrows, bright honey for icon fills
       and hover accents. No unrelated accent colours. */
    --color-gold-deep:   #8f6317;
    --color-gold-bright: #c69428;
    --color-gold-fill:   rgba(198,148,40,0.10);
  }

  /* Tools & Services icons: bright honey gold. Same warm family as
     the rest of the page, just one step brighter for subtle territorial
     distinction (Tools = action-oriented, Articles = reading). */
  .card .card-icon {
    color: var(--color-gold-bright) !important;
    background: var(--color-gold-fill) !important;
    border: 1px solid rgba(198,148,40,0.24) !important;
    width: 34px; height: 34px;
    border-radius: 50%;
    transition: background 0.24s ease, border-color 0.24s ease, transform 0.24s ease;
  }
