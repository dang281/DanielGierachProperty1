---
import Layout from '../layouts/Layout.astro';

const buyerSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Off-Market Property Buyer Registration, Brisbane Inner East",
  "description": "Register your buying criteria with Daniel Gierach to be notified of off-market and pre-market properties across Brisbane's inner east before they reach realestate.com.au.",
  "provider": {
    "@type": "RealEstateAgent",
    "name": "Daniel Gierach",
    "url": "https://danielgierach.com"
  },
  "areaServed": {
    "@type": "Place",
    "name": "Brisbane Inner East, Queensland"
  },
  "url": "https://danielgierach.com/buyers",
  "serviceType": "Buyer Matching"
};
---

<Layout
  title="Off-Market &amp; Pre-Market Property Alerts | Daniel Gierach, Brisbane Inner East"
  description="Register your buying criteria and get notified first when off-market and pre-market properties come up across Brisbane's inner east. Murarrie, Bulimba, Hawthorne, Morningside and more."
  hideMobileCta={true}
  schema={buyerSchema}
>

<!-- ══════════════════════════════════════════════
     SPLIT LAYOUT  Left: dark hero  |  Right: wizard
══════════════════════════════════════════════ -->
<section style="display:grid;grid-template-columns:1fr 1fr;align-items:start;" class="buyers-split">

  <!-- ── LEFT: dark hero panel ── -->
  <div class="relative flex flex-col justify-center overflow-hidden buyers-hero-panel" style="padding:8rem 4rem 4rem;">

    <div class="absolute inset-0 z-0">
      <img
        src="/_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Fa665-H3373155-164932053__1758673927-230712-AMY19482.jpg&w=1200&q=70"
        srcset="/_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Fa665-H3373155-164932053__1758673927-230712-AMY19482.jpg&w=640&q=70 640w, /_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Fa665-H3373155-164932053__1758673927-230712-AMY19482.jpg&w=1080&q=70 1080w, /_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Fa665-H3373155-164932053__1758673927-230712-AMY19482.jpg&w=1200&q=70 1200w"
        sizes="(max-width: 860px) 100vw, 50vw"
        alt="22 Marshall Avenue Seven Hills, sold by Daniel Gierach"
        class="w-full h-full object-cover"
        style="filter:grayscale(12%) brightness(0.38);"
        fetchpriority="high"
        width="1200" height="800"
      />
      <div class="absolute inset-0" style="background:linear-gradient(105deg,rgba(10,8,6,0.88) 0%,rgba(10,8,6,0.65) 55%,rgba(10,8,6,0.3) 100%);"></div>
    </div>

    <div class="relative z-10">
      <span class="reveal" style="display:block;font-family:var(--font-sans);font-size:0.68rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#f5d07a;margin-bottom:1.25rem;">Off-Market &amp; Pre-Market · Inner East</span>

      <h1 id="hero-heading" class="reveal" data-delay="60"
        style="font-family:var(--font-serif);font-size:clamp(2.4rem,4vw,3.8rem);font-weight:400;line-height:1.08;letter-spacing:-0.02em;color:#f0ece4;margin-bottom:1.5rem;transition:opacity 0.3s;">
        Find your next home before it hits the market.
      </h1>

      <p id="hero-desc" class="buyers-hero-desc reveal" data-delay="120"
        style="font-size:1rem;color:rgba(240,236,228,0.8);line-height:1.9;max-width:44ch;margin-bottom:2.5rem;transition:opacity 0.3s;">
        Most of the best properties in Brisbane's inner east are spoken for before a sign goes up. Register your brief and get early access to both off-market and pre-market properties when they come up.
      </p>

      <div class="buyers-hero-contact reveal" data-delay="240" style="padding-top:2rem;border-top:1px solid rgba(255,255,255,0.1);">
        <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#c4912a;margin-bottom:0.6rem;">Prefer to talk first?</p>
        <a href="tel:+61412523821"
          style="font-family:var(--font-serif);font-size:1.2rem;font-weight:400;color:#ffffff;text-decoration:none;transition:color 0.2s;"
          onmouseover="this.style.color='#f5d07a'"
          onmouseout="this.style.color='#ffffff'">0412 523 821</a>
      </div>
    </div>
  </div>

  <!-- ── RIGHT: wizard panel ── -->
  <div class="flex flex-col justify-center overflow-y-auto buyers-form-panel" style="background:var(--color-surface-1);padding:8rem 4rem 4rem;">

    <div class="reveal" data-delay="80" style="max-width:500px;width:100%;">

      <!-- Mobile-only brand anchor — shown when hero is scrolled away -->
      <div class="wz-mobile-brand">
        <span>Daniel Gierach</span>
        <span class="wz-mobile-brand-sep">·</span>
        <span>Ray White Bulimba</span>
      </div>

      <!-- Step progress indicator -->
      <div class="wz-indicator" id="wz-indicator" style="margin-bottom:2.25rem;">
        <div class="wz-dot-wrap active" data-step="1">
          <div class="wz-dot"></div>
          <span class="wz-dot-lbl">Property</span>
        </div>
        <div class="wz-connector" data-after="1"></div>
        <div class="wz-dot-wrap" data-step="2">
          <div class="wz-dot"></div>
          <span class="wz-dot-lbl">Where</span>
        </div>
        <div class="wz-connector" data-after="2"></div>
        <div class="wz-dot-wrap" data-step="3">
          <div class="wz-dot"></div>
          <span class="wz-dot-lbl">Contact</span>
        </div>
      </div>

      <!-- Step counter + heading (both change per step) -->
      <p id="wz-counter" style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#c4912a;margin-bottom:0.5rem;">Step 1 of 3</p>
      <h2 id="wz-heading" style="font-family:var(--font-serif);font-size:1.5rem;font-weight:400;color:#1c1917;line-height:1.2;margin-bottom:0.4rem;transition:opacity 0.25s;">
        What are you after?
      </h2>
      <p id="wz-subhead" style="font-size:0.85rem;color:#78716c;line-height:1.7;margin-bottom:1.75rem;transition:opacity 0.25s;">
        Start with what kind of place you want. All fields are optional.
      </p>
      <!-- Note: wz-subhead text is overwritten by setStep() for steps 2 and 3 -->

      <form id="buyer-form" method="POST" action="https://formspree.io/f/meedzvyv">

        <!-- Honeypot + hidden fields -->
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" />
        <input type="hidden" name="_next" value="https://danielgierach.com/thank-you?from=buyer-registration" />
        <input type="hidden" name="_subject" value="New buyer registration - danielgierach.com" />
        <input type="hidden" name="_source" value="buyers" />

        <!-- ─── STEP 1: Property details ────────────────────── -->
        <div id="step-1" class="wz-step" style="display:flex;flex-direction:column;gap:1.25rem;">

          <!-- Property type -->
          <div>
            <label class="field-label">Property type <span class="field-opt">(optional)</span></label>
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:0.4rem;margin-top:0.4rem;" id="type-group">
              {['House','Townhouse','Unit / Apartment','Development Site'].map((t) => (
                <button type="button" class="selector-btn" data-group="type" data-value={t}
                  style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:0;height:2.75rem;background:var(--color-surface-2);border:1px solid rgba(28,25,23,0.15);color:#44403c;cursor:pointer;transition:all 0.18s;display:flex;align-items:center;justify-content:center;text-align:center;line-height:1.2;">
                  {t}
                </button>
              ))}
            </div>
            <input type="hidden" name="property_type" id="type-value" />
          </div>

          <!-- Bedrooms -->
          <div>
            <label class="field-label">Bedrooms <span class="field-opt">(optional)</span></label>
            <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:0.4rem;margin-top:0.4rem;" id="beds-group">
              {['1','2','3','4','5+'].map((b) => (
                <button type="button" class="selector-btn" data-group="beds" data-value={b}
                  style="font-family:var(--font-sans);font-size:0.7rem;font-weight:700;padding:0;height:2.75rem;background:var(--color-surface-2);border:1px solid rgba(28,25,23,0.15);color:#44403c;cursor:pointer;transition:all 0.18s;display:flex;align-items:center;justify-content:center;">
                  {b}
                </button>
              ))}
            </div>
            <input type="hidden" name="bedrooms" id="beds-value" />
          </div>

          <!-- Budget -->
          <div>
            <label class="field-label">Budget range <span class="field-opt">(optional)</span></label>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.4rem;margin-top:0.4rem;" id="budget-group">
              {['Under $800k','$800k-$1.2m','$1.2m-$1.5m','$1.5m-$2m','$2m-$3m','$3m-$5m','$5m+'].map((b) => (
                <button type="button" class="selector-btn" data-group="budget" data-value={b}
                  style="font-family:var(--font-sans);font-size:0.6rem;font-weight:700;letter-spacing:0.04em;padding:0;height:2.75rem;background:var(--color-surface-2);border:1px solid rgba(28,25,23,0.15);color:#44403c;cursor:pointer;transition:all 0.18s;display:flex;align-items:center;justify-content:center;text-align:center;line-height:1.3;">
                  {b}
                </button>
              ))}
            </div>
            <input type="hidden" name="budget" id="budget-value" />
          </div>

          <div class="wz-footer" style="margin-top:0.5rem;">
            <button type="button" class="btn-gold wz-next-btn" data-to="2" style="width:100%;justify-content:center;">
              Where are you looking?
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- ─── STEP 2: Suburbs ─────────────────────────────── -->
        <div id="step-2" class="wz-step" style="display:none;flex-direction:column;gap:1.1rem;">

          <div>
            <!-- Inline tag input: tags + search live in one box -->
            <div class="suburb-input-box" style="margin-bottom:1rem;">
              <div id="selected-suburbs-display" class="suburb-tags-inline"></div>
              <div class="suburb-search-wrap">
                <div class="suburb-search-row">
                  <svg class="suburb-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                  <input type="text" id="suburb-search"
                    placeholder="Search any suburb…"
                    autocomplete="off" />
                  <button type="button" id="suburb-add-btn" aria-label="Add suburb">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
                    <span>Add</span>
                  </button>
                </div>
                <div id="suburb-dropdown"></div>
              </div>
            </div>

            <!-- Quick-select chips -->
            <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#a8a29e;margin-bottom:0.6rem;">Or select from Daniel's areas</p>
            <div id="quick-chips" class="suburb-chip-grid">
              {['Balmoral','Bulimba','Camp Hill','Cannon Hill',
                'Carina','Carina Heights','Carindale','Coorparoo',
                'East Brisbane','Greenslopes','Hamilton','Hawthorne',
                'Hemmant','Holland Park','Manly','Morningside',
                'Mount Gravatt','Mount Gravatt East','Murarrie','New Farm',
                'Norman Park','Seven Hills','Tarragindi','Teneriffe',
                'Tingalpa','Woolloongabba','Wynnum'
              ].map(s => (
                <button type="button" class="quick-chip" data-suburb={s}>{s}</button>
              ))}
            </div>

            <input type="hidden" name="areas" id="areas-value" />
            <div id="areas-error" style="display:none;margin-top:0.6rem;padding:0.7rem 1rem;background:rgba(196,145,42,0.1);border-left:3px solid #c4912a;">
              <p style="font-family:var(--font-sans);font-size:0.75rem;font-weight:700;color:#7a5618;margin:0;">Select at least one suburb to continue.</p>
            </div>
          </div>

          <div class="wz-footer wz-footer-split" style="margin-top:0.5rem;">
            <button type="button" class="wz-back-btn" data-to="1">← Back</button>
            <button type="button" class="btn-gold wz-next-btn" data-to="3" style="flex:1;justify-content:center;">
              Your details
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- ─── STEP 3: Contact ──────────────────────────────── -->
        <div id="step-3" class="wz-step" style="display:none;flex-direction:column;gap:1.1rem;">

          <div>
            <label for="buyer-name" class="field-label">Name <span style="color:#c4912a;">*</span></label>
            <input type="text" id="buyer-name" name="name" required placeholder="Your full name"
              class="obs-input form-field" autocomplete="name" />
          </div>

          <div>
            <label for="buyer-phone" class="field-label">Phone <span style="color:#c4912a;">*</span></label>
            <input type="tel" id="buyer-phone" name="phone" required placeholder="04xx xxx xxx"
              class="obs-input form-field" autocomplete="tel" />
          </div>

          <div>
            <label for="buyer-email" class="field-label">Email <span style="color:#c4912a;">*</span></label>
            <input type="email" id="buyer-email" name="email" required placeholder="your@email.com"
              class="obs-input form-field" autocomplete="email" />
          </div>

          <div>
            <label for="buyer-inspo" class="field-label">
              A property you love <span class="field-opt">(optional)</span>
            </label>
            <input type="url" id="buyer-inspo" name="inspiration_property_link"
              placeholder="Paste a realestate.com.au link that matches your style"
              class="obs-input" />
          </div>

          <p style="font-size:0.72rem;color:#78716c;line-height:1.7;margin-top:0.25rem;">
            Daniel works with buyers across 30+ Brisbane suburbs. Most hear back the same day.
          </p>

          <div class="wz-footer wz-footer-split" style="margin-top:0.25rem;">
            <button type="button" class="wz-back-btn" data-to="2">← Back</button>
            <button type="submit" id="buyer-submit" class="btn-gold" style="flex:1;justify-content:center;">
              <span id="buyer-submit-label">Send my brief to Daniel</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

      </form>
    </div>
  </div>

</section>

<!-- ══════════════════════════════════════════════
     BUYER RESOURCES STRIP
══════════════════════════════════════════════ -->
<section style="background:var(--color-base);border-top:1px solid rgba(28,25,23,0.08);padding:4rem 0;">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <p style="font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#c4912a;margin-bottom:0.6rem;">Buyer Resources</p>
    <h2 style="font-family:var(--font-serif);font-size:clamp(1.3rem,2.5vw,1.75rem);font-weight:400;color:#1c1917;line-height:1.2;margin-bottom:0.65rem;">
      Free guides for Brisbane buyers.
    </h2>
    <p style="font-size:0.88rem;color:#57534e;line-height:1.8;max-width:52ch;margin-bottom:2.5rem;">
      Buying your first home, heading to auction, or navigating a building and pest report. Daniel has put together practical guides for each stage.
    </p>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;" class="resources-grid">

      <a href="/resources/first-home-buyer-brisbane-inner-east-guide" class="resource-card"
        style="display:flex;flex-direction:column;padding:1.75rem;border:1px solid rgba(28,25,23,0.1);text-decoration:none;background:var(--color-surface-1);transition:border-color 0.2s,box-shadow 0.2s;"
        onmouseover="this.style.borderColor='#c4912a';this.style.boxShadow='0 4px 16px rgba(196,145,42,0.1)'"
        onmouseout="this.style.borderColor='rgba(28,25,23,0.1)';this.style.boxShadow='none'">
        <span style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin-bottom:0.75rem;">8 pages · Free</span>
        <span style="font-family:var(--font-serif);font-size:1.05rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.6rem;">First Home Buyer's Guide to Brisbane Inner East</span>
        <span style="font-size:0.78rem;color:#78716c;line-height:1.7;flex:1;">Borrowing capacity, Queensland stamp duty concessions, suburb comparisons, and what to do from offer to settlement.</span>
        <span style="display:inline-flex;align-items:center;gap:0.4rem;margin-top:1.25rem;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#c4912a;">
          Read guide
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>

      <a href="/resources/auction-bidding-playbook-buyers" class="resource-card"
        style="display:flex;flex-direction:column;padding:1.75rem;border:1px solid rgba(28,25,23,0.1);text-decoration:none;background:var(--color-surface-1);transition:border-color 0.2s,box-shadow 0.2s;"
        onmouseover="this.style.borderColor='#c4912a';this.style.boxShadow='0 4px 16px rgba(196,145,42,0.1)'"
        onmouseout="this.style.borderColor='rgba(28,25,23,0.1)';this.style.boxShadow='none'">
        <span style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin-bottom:0.75rem;">7 pages · Free</span>
        <span style="font-family:var(--font-serif);font-size:1.05rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.6rem;">Auction Bidding Playbook for Brisbane Buyers</span>
        <span style="font-size:0.78rem;color:#78716c;line-height:1.7;flex:1;">How to register, bid, and win at a Brisbane auction. Contract, finance, bidding strategy, and what happens after the hammer falls.</span>
        <span style="display:inline-flex;align-items:center;gap:0.4rem;margin-top:1.25rem;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#c4912a;">
          Read guide
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>

      <a href="/resources/building-pest-report-explainer" class="resource-card"
        style="display:flex;flex-direction:column;padding:1.75rem;border:1px solid rgba(28,25,23,0.1);text-decoration:none;background:var(--color-surface-1);transition:border-color 0.2s,box-shadow 0.2s;"
        onmouseover="this.style.borderColor='#c4912a';this.style.boxShadow='0 4px 16px rgba(196,145,42,0.1)'"
        onmouseout="this.style.borderColor='rgba(28,25,23,0.1)';this.style.boxShadow='none'">
        <span style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#c4912a;margin-bottom:0.75rem;">Free</span>
        <span style="font-family:var(--font-serif);font-size:1.05rem;font-weight:400;color:#1c1917;line-height:1.3;margin-bottom:0.6rem;">Building & Pest Report Explainer</span>
        <span style="font-size:0.78rem;color:#78716c;line-height:1.7;flex:1;">What the report actually means, which defects matter, which don't, and how to use it to negotiate or walk away with confidence.</span>
        <span style="display:inline-flex;align-items:center;gap:0.4rem;margin-top:1.25rem;font-family:var(--font-sans);font-size:0.62rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#c4912a;">
          Read guide
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>

    </div>
  </div>
</section>

<!-- SEO: indexable suburb list + buyer FAQ -->
<section style="background:var(--color-surface-0);padding:4rem 1.5rem 5rem;">
  <div style="max-width:780px;margin:0 auto;">

    <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#c4912a;margin:0 0 0.5rem;">Suburbs covered</p>
    <h2 style="font-family:var(--font-serif);font-size:clamp(1.4rem,3vw,2rem);font-weight:400;color:#1c1917;margin:0 0 1rem;line-height:1.2;">Off-market and pre-market access across Brisbane's inner east</h2>
    <p style="font-size:0.9rem;color:#57534e;line-height:1.8;max-width:58ch;margin:0 0 1.75rem;">Daniel works with buyers across the following suburbs. Properties are matched to registered buyers before any public listing is created.</p>

    <div style="display:flex;flex-wrap:wrap;gap:0.4rem 0.6rem;margin-bottom:3rem;">
      {['Balmoral','Bulimba','Camp Hill','Cannon Hill','Carina','Carina Heights','Carindale','Coorparoo','East Brisbane','Eight Mile Plains','Greenslopes','Hamilton','Hawthorne','Holland Park','Holland Park West','Hemmant','Morningside','Mount Gravatt East','Murarrie','New Farm','Newstead','Norman Park','Tingalpa','Teneriffe','Woolloongabba'].map(s => (
        <span style="font-family:var(--font-sans);font-size:0.72rem;font-weight:600;color:#57534e;background:var(--color-surface-1);border:1px solid rgba(28,25,23,0.1);padding:0.3rem 0.7rem;">{s}</span>
      ))}
    </div>

    <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#c4912a;margin:0 0 1.25rem;">Common questions</p>

    <div style="display:flex;flex-direction:column;gap:0;">
      <details style="border-top:1px solid rgba(28,25,23,0.1);padding:1.1rem 0;">
        <summary style="font-family:var(--font-serif);font-size:1rem;cursor:pointer;color:#1c1917;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem;">
          What is an off-market property?
          <span style="color:#c4912a;font-size:1.3rem;flex-shrink:0;line-height:1;">+</span>
        </summary>
        <p style="font-family:var(--font-sans);font-size:0.88rem;line-height:1.8;color:#57534e;margin:0.75rem 2rem 0 0;">An off-market property is sold without ever being listed on realestate.com.au or Domain. The agent approaches a small group of registered buyers directly and the transaction completes quietly, often without a sign or open homes.</p>
      </details>

      <details style="border-top:1px solid rgba(28,25,23,0.1);padding:1.1rem 0;">
        <summary style="font-family:var(--font-serif);font-size:1rem;cursor:pointer;color:#1c1917;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem;">
          What is a pre-market property?
          <span style="color:#c4912a;font-size:1.3rem;flex-shrink:0;line-height:1;">+</span>
        </summary>
        <p style="font-family:var(--font-sans);font-size:0.88rem;line-height:1.8;color:#57534e;margin:0.75rem 2rem 0 0;">A pre-market property is one being prepared for sale that has not yet been publicly listed. Registered buyers get access in the days or weeks before the campaign launches. If someone makes an acceptable offer in that window, the sale is done before the portals are ever involved.</p>
      </details>

      <details style="border-top:1px solid rgba(28,25,23,0.1);padding:1.1rem 0;">
        <summary style="font-family:var(--font-serif);font-size:1rem;cursor:pointer;color:#1c1917;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem;">
          How does Daniel's buyer matching service work?
          <span style="color:#c4912a;font-size:1.3rem;flex-shrink:0;line-height:1;">+</span>
        </summary>
        <p style="font-family:var(--font-sans);font-size:0.88rem;line-height:1.8;color:#57534e;margin:0.75rem 2rem 0 0;">You register your brief: the suburbs you want, the property type, your bedroom requirement and your budget. When a property that fits comes up, Daniel contacts you directly before it is publicly listed. There is no cost and no obligation to proceed.</p>
      </details>

      <details style="border-top:1px solid rgba(28,25,23,0.1);padding:1.1rem 0;">
        <summary style="font-family:var(--font-serif);font-size:1rem;cursor:pointer;color:#1c1917;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem;">
          Is there any cost to registering?
          <span style="color:#c4912a;font-size:1.3rem;flex-shrink:0;line-height:1;">+</span>
        </summary>
        <p style="font-family:var(--font-sans);font-size:0.88rem;line-height:1.8;color:#57534e;margin:0.75rem 2rem 0 0;">No. Registering your search is free. Daniel is paid by the vendor when a sale completes, not by buyers. There is no commitment required and you can update or cancel your brief at any time by contacting Daniel directly.</p>
      </details>

      <details style="border-top:1px solid rgba(28,25,23,0.1);border-bottom:1px solid rgba(28,25,23,0.1);padding:1.1rem 0;">
        <summary style="font-family:var(--font-serif);font-size:1rem;cursor:pointer;color:#1c1917;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem;">
          Which suburbs have the most off-market activity?
          <span style="color:#c4912a;font-size:1.3rem;flex-shrink:0;line-height:1;">+</span>
        </summary>
        <p style="font-family:var(--font-sans);font-size:0.88rem;line-height:1.8;color:#57534e;margin:0.75rem 2rem 0 0;">Bulimba, Hawthorne, Balmoral and Morningside see the most consistent off-market and pre-market activity. Supply in these suburbs is limited and buyer demand is strong, which means vendors can often transact quietly without needing a full public campaign.</p>
      </details>
    </div>

    <p style="font-size:0.8rem;color:#78716c;line-height:1.7;margin:2rem 0 0;">
      For more context on how off-market and pre-market selling works in Brisbane, read:
      <a href="/insights/off-market-pre-market-properties-brisbane-inner-east" style="color:#c4912a;font-weight:600;">How to Access Off-Market and Pre-Market Properties in Brisbane's Inner East &rarr;</a>
    </p>

  </div>
</section>

