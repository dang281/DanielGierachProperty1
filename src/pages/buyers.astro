  .suburb-tag-remove {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    min-height: 34px;
    background: none;
    border: none;
    border-left: 1px solid rgba(196,145,42,0.3);
    cursor: pointer;
    color: rgba(196,145,42,0.6);
    font-size: 1rem;
    line-height: 1;
    transition: background 0.15s, color 0.15s;
    padding: 0;
  }
  .suburb-tag-remove:hover {
    background: rgba(196,145,42,0.15);
    color: #c4912a;
  }
</style>

<style>
  .field-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #44403c;
    margin-bottom: 0.4rem;
  }
  .field-opt {
    font-weight: 400;
    text-transform: none;
    color: #78716c;
    font-size: 0.58rem;
    letter-spacing: 0.04em;
  }

  /* ── Wizard step animation ─────────────────────────────────────────────── */
  @keyframes wz-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .wz-step[style*="flex"] {
    animation: wz-in 0.25s ease both;
  }

  /* ── Wizard footer nav ─────────────────────────────────────────────────── */
  .wz-footer-split {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .wz-back-btn {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #78716c;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem 0;
    white-space: nowrap;
    transition: color 0.18s;
    flex-shrink: 0;
  }
  .wz-back-btn:hover { color: #1c1917; }

  /* ── Progress dots ─────────────────────────────────────────────────────── */
  .wz-indicator {
    display: flex;
    align-items: flex-start;
    margin-bottom: 2.25rem;
  }
  .wz-dot-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .wz-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: rgba(196,145,42,0.12);
    border: 2px solid rgba(196,145,42,0.22);
    transition: all 0.25s;
  }
  .wz-dot-wrap.active .wz-dot {
    background: #c4912a;
    border-color: #c4912a;
    box-shadow: 0 0 0 4px rgba(196,145,42,0.18);
  }
  .wz-dot-wrap.done .wz-dot {
    background: rgba(196,145,42,0.5);
    border-color: rgba(196,145,42,0.5);
  }
  .wz-dot-lbl {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(28,25,23,0.28);
    transition: color 0.25s;
    white-space: nowrap;
  }
  .wz-dot-wrap.active .wz-dot-lbl { color: #c4912a; }
  .wz-dot-wrap.done .wz-dot-lbl   { color: rgba(196,145,42,0.65); }
  .wz-connector {
    flex: 1;
    height: 1.5px;
    background: rgba(196,145,42,0.16);
    margin: 6px 0.75rem 0;
  }

  /* ── Desktop: left panel sticky ─────────────────────────────────────────── */
  @media (min-width: 861px) {
    .buyers-hero-panel {
      position: sticky;
      top: 0;
      height: 100dvh;
      overflow: hidden;
    }
    .buyers-form-panel {
      min-height: 100dvh;
    }
  }

  @media (max-width: 860px) {
    .buyers-split { grid-template-columns: 1fr !important; }
    .buyers-hero-panel {
      min-height: 0;
      max-height: 28vh;
      padding: 4.5rem 1.5rem 1.5rem !important;
      overflow: hidden;
    }
    .buyers-hero-panel h1 {
      font-size: clamp(1.4rem, 5vw, 2rem) !important;
      margin-bottom: 0 !important;
    }
    .buyers-form-panel { padding: 2rem 1.25rem 4rem !important; }
    .buyers-hero-desc,
    .buyers-hero-points,
    .buyers-hero-contact { display: none !important; }
  }

  @media (max-width: 540px) {
    #budget-group { grid-template-columns: repeat(2, 1fr) !important; }
    #beds-group button { font-size: 0.65rem !important; }
    #type-group button { font-size: 0.58rem !important; line-height: 1.3 !important; padding: 0 0.3rem !important; }
  }

  /* ── Suburb chip grid ──────────────────────────────────────────────────── */
  .suburb-chip-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.45rem;
    margin-bottom: 1rem;
  }
  @media (max-width: 480px) {
    .suburb-chip-grid { grid-template-columns: repeat(2, 1fr); gap: 0.4rem; }
  }

  .quick-chip {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-weight: 400;
    font-style: italic;
    padding: 0 0.5rem;
    height: 44px;
    background: transparent;
    border: 1px solid rgba(196,145,42,0.28);
    color: #57534e;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
  }
  .quick-chip:hover {
    border-color: #c4912a;
    background: rgba(196,145,42,0.05);
    color: #1c1917;
  }
  .quick-chip.active {
    border-color: #c4912a;
    background: rgba(196,145,42,0.09);
    color: #7a5618;
  }
  .quick-chip.active::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #c4912a;
    flex-shrink: 0;
  }

  /* ── Search row ────────────────────────────────────────────────────────── */
  .suburb-search-wrap { position: relative; }
  .suburb-search-row {
    display: flex;
    align-items: center;
    border: 1px solid rgba(196,145,42,0.35);
    background: var(--color-surface-0, #fff);
    transition: border-color 0.2s;
  }
  .suburb-search-row:focus-within { border-color: #c4912a; }
  .suburb-search-icon {
    flex-shrink: 0;
    margin: 0 0.6rem 0 0.85rem;
    color: #a8a29e;
    pointer-events: none;
  }
  #suburb-search {
    flex: 1;
    min-width: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9rem;
    padding: 0.75rem 0.5rem;
    border: none;
    background: transparent;
    color: #1c1917;
    outline: none;
  }
  #suburb-search::placeholder { color: #a8a29e; font-style: italic; }
  #suburb-add-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0 1.1rem;
    min-height: 46px;
    min-width: 44px;
    background: transparent;
    border: none;
    border-left: 1px solid rgba(196,145,42,0.28);
    color: #c4912a;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.18s, color 0.18s;
    white-space: nowrap;
  }
  #suburb-add-btn:hover { background: rgba(196,145,42,0.08); color: #7a5618; }

  #suburb-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 1px);
    left: 0; right: 0;
    z-index: 2000;
    background: #faf8f4;
    border: 1px solid rgba(196,145,42,0.4);
    max-height: 220px;
    overflow-y: auto;
    box-shadow: 0 16px 40px rgba(28,25,23,0.13);
  }
  #suburb-dropdown::-webkit-scrollbar { width: 4px; }
  #suburb-dropdown::-webkit-scrollbar-track { background: transparent; }
  #suburb-dropdown::-webkit-scrollbar-thumb { background: rgba(196,145,42,0.3); border-radius: 2px; }

  .suburb-tags-row { display: flex; flex-wrap: wrap; gap: 0.5rem; min-height: 1rem; margin-top: 0.1rem; }

  .selector-btn.active {
    background: rgba(196,145,42,0.1) !important;
    border-color: #c4912a !important;
    color: #c4912a !important;
  }

  input::placeholder, textarea::placeholder { color: var(--color-text-muted); }
  input:-webkit-autofill, textarea:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 1000px var(--color-surface-4) inset;
    -webkit-text-fill-color: #1c1917;
  }
</style>

<script is:inline>
  (function() {
    var h = document.getElementById('site-header');
    if (!h) return;
    function sync() {
      if (window.scrollY <= 50) {
        h.style.background = 'rgba(10,8,6,0.9)';
        h.style.backdropFilter = 'blur(16px)';
        h.style.webkitBackdropFilter = 'blur(16px)';
      } else {
        h.style.background = '';
        h.style.backdropFilter = '';
        h.style.webkitBackdropFilter = '';
      }
    }
    sync();
    window.addEventListener('scroll', sync, { passive: true });
  })();
</script>

<script>
  // ── Suburb data ────────────────────────────────────────────────────────────
  const ALL_SUBURBS = [
    'Acacia Ridge','Albany Creek','Alderley','Algester','Annerley','Anstead','Archerfield','Ascot','Ashgrove','Aspley','Auchenflower',
    'Balmoral','Banyo','Bardon','Belmont','Belvedere','Birkdale','Boondall','Bowen Hills','Bracken Ridge','Bray Park','Bridgeman Downs','Brisbane City','Brookfield','Bulimba',
    'Calamvale','Camp Hill','Cannon Hill','Capalaba','Carina','Carina Heights','Carindale','Carseldine','Chandler','Chapel Hill','Chelmer','Chermside','Chermside West','Clayfield','Coopers Plains','Corinda','Coorparoo',
    'Darra','Deagon','Doolandella','Drewvale','Durack','Dutton Park',
    'Eagle Farm','East Brisbane','Eight Mile Plains','Ellen Grove','Enoggera','Everton Hills','Everton Park',
    'Fairfield','Ferny Grove','Fig Tree Pocket','Fitzgibbon','Forest Lake','Fortitude Valley',
    'Gaythorne','Gordon Park','Graceville','Grange','Greenslopes','Gumdale',
    'Hamilton','Hawthorne','Hemmant','Hendra','Herston','Highgate Hill','Holland Park','Holland Park West',
    'Indooroopilly','Inala',
    'Jindalee',
    'Kangaroo Point','Karana Downs','Kedron','Kelvin Grove','Kenmore','Kenmore Hills','Keperra',
    'Lota','Lutwyche',
    'MacGregor','Manly','Manly West','Mansfield','McDowall','Middle Park','Milton','Mitchelton','Moggill','Moorooka','Morningside','Mount Gravatt','Mount Gravatt East','Mount Ommaney','Murarrie',
    'Nathan','Nundah','Newmarket','New Farm','Newstead','Norman Park','Nudgee',
    'Oxley',
    'Paddington','Parkinson','Petrie Terrace','Pinjarra Hills','Pinkenba','Pullenvale',
    'Red Hill','Robertson','Rochedale South','Rocklea','Runcorn',
    'Salisbury','Seven Hills','Sherwood','South Brisbane','Spring Hill','St Lucia','Stafford','Stafford Heights','Stones Corner','Stretton','Sunnybank','Sunnybank Hills',
    'Taigum','Taringa','Tarragindi','Teneriffe','The Gap','Tingalpa','Toombul','Toowong',
    'Upper Brookfield','Upper Mount Gravatt',
    'Virginia',
    'Wakerley','Wavell Heights','West End','Windsor','Wishart','Woolloongabba','Wynnum','Wynnum West',
    'Yeronga',
    'Zillmere',
  ].sort();

  // ── Suburb state ───────────────────────────────────────────────────────────
  const areasInput  = document.getElementById('areas-value') as HTMLInputElement;
  const areasError  = document.getElementById('areas-error') as HTMLElement;
  const tagsDisplay = document.getElementById('selected-suburbs-display')!;
  const selected    = new Set<string>();

  function syncInput() {
    areasInput.value = [...selected].join(', ');
    if (selected.size > 0) areasError.style.display = 'none';
  }

  function renderTags() {
    tagsDisplay.innerHTML = '';
    [...selected].sort().forEach(name => {
      const tag = document.createElement('span');
      tag.className = 'suburb-tag';
      tag.innerHTML = `<span class="suburb-tag-name">${name}</span><button type="button" class="suburb-tag-remove" aria-label="Remove ${name}">×</button>`;
      tag.querySelector('button')!.addEventListener('click', () => removeSuburb(name));
      tagsDisplay.appendChild(tag);
    });
  }

  function addSuburb(name: string) {
    if (!name || selected.has(name)) return;
    selected.add(name);
    document.querySelectorAll<HTMLButtonElement>('.quick-chip').forEach(c => {
      if (c.dataset.suburb === name) c.classList.add('active');
    });
    renderTags();
    syncInput();
  }

  function removeSuburb(name: string) {
    selected.delete(name);
    document.querySelectorAll<HTMLButtonElement>('.quick-chip').forEach(c => {
      if (c.dataset.suburb === name) c.classList.remove('active');
    });
    renderTags();
    syncInput();
  }

  // Quick chips
  document.querySelectorAll<HTMLButtonElement>('.quick-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const s = chip.dataset.suburb!;
      if (selected.has(s)) removeSuburb(s); else addSuburb(s);
    });
  });

  // Search + dropdown
  const searchInput = document.getElementById('suburb-search') as HTMLInputElement;
  const dropdown    = document.getElementById('suburb-dropdown')!;
  const addBtn      = document.getElementById('suburb-add-btn')!;
  let focusedIdx    = -1;

  function renderDropdown(matches: string[]) {
    if (!matches.length) { dropdown.style.display = 'none'; return; }
    dropdown.innerHTML = matches
      .map((s, i) => `<div class="suburb-dd-item" data-suburb="${s}" data-idx="${i}">${s}</div>`)
      .join('');
    dropdown.style.display = 'block';
    focusedIdx = -1;
    dropdown.querySelectorAll<HTMLElement>('.suburb-dd-item').forEach(item => {
      item.addEventListener('mousedown', e => {
        e.preventDefault();
        addSuburb(item.dataset.suburb!);
        searchInput.value = '';
        dropdown.style.display = 'none';
      });
    });
  }

  searchInput.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    if (!q) { dropdown.style.display = 'none'; return; }
    renderDropdown(ALL_SUBURBS.filter(s => s.toLowerCase().includes(q)));
  });

  searchInput.addEventListener('keydown', (e: KeyboardEvent) => {
    const items = dropdown.querySelectorAll<HTMLElement>('.suburb-dd-item');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      focusedIdx = Math.min(focusedIdx + 1, items.length - 1);
      items.forEach((el, i) => el.classList.toggle('focused', i === focusedIdx));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      focusedIdx = Math.max(focusedIdx - 1, 0);
      items.forEach((el, i) => el.classList.toggle('focused', i === focusedIdx));
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const active = focusedIdx >= 0 ? items[focusedIdx] : items[0];
      if (active) { addSuburb(active.dataset.suburb!); searchInput.value = ''; dropdown.style.display = 'none'; }
    } else if (e.key === 'Escape') {
      dropdown.style.display = 'none';
    }
  });

  addBtn.addEventListener('click', () => {
    const q = searchInput.value.trim();
    if (!q) return;
    const match = ALL_SUBURBS.find(s => s.toLowerCase() === q.toLowerCase())
      ?? ALL_SUBURBS.find(s => s.toLowerCase().startsWith(q.toLowerCase()))
      ?? q;
    addSuburb(match);
    searchInput.value = '';
    dropdown.style.display = 'none';
  });

  document.addEventListener('click', e => {
    if (!(e.target as Element).closest('#suburb-search, #suburb-add-btn, #suburb-dropdown'))
      dropdown.style.display = 'none';
  });

  // Type + beds: multi-select (toggle). Budget: single-select (range).
  document.querySelectorAll<HTMLButtonElement>('.selector-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.dataset.group!;
      const input = document.getElementById(`${group}-value`) as HTMLInputElement;
      if (group === 'budget') {
        document.querySelectorAll<HTMLButtonElement>(`.selector-btn[data-group="budget"]`)
          .forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        input.value = btn.dataset.value!;
      } else {
        btn.classList.toggle('active');
        const vals = [...document.querySelectorAll<HTMLButtonElement>(`.selector-btn[data-group="${group}"].active`)]
          .map(b => b.dataset.value!);
        input.value = vals.join(', ');
      }
    });
  });

  // ── Wizard ─────────────────────────────────────────────────────────────────
  type StepNum = 1 | 2 | 3;

  const heroHeading = document.getElementById('hero-heading')!;
  const heroDesc    = document.getElementById('hero-desc')!;
  const wzHeading   = document.getElementById('wz-heading')!;
  const wzSubhead   = document.getElementById('wz-subhead')!;
  const wzCounter   = document.getElementById('wz-counter')!;

  const heroContent: Record<StepNum, { h: string; d: string }> = {
    1: {
      h: 'Find your next home before it hits the market.',
      d: 'Most of the best properties in Bulimba, Hawthorne, Morningside and the wider inner east are spoken for before a sign goes up. Register your criteria and Daniel will contact you directly when something matches.'
    },
    2: {
      h: 'Tell Daniel what you\'re after.',
      d: 'The more specific your criteria, the more precisely Daniel can match you. All fields on this step are optional.'
    },
    3: {
      h: 'Almost done.',
      d: 'Daniel reviews every registration personally and will follow up the same day.'
    }
  };

  const stepContent: Record<StepNum, { h: string; s: string }> = {
    1: { h: 'Where are you looking?',         s: 'Select the suburbs you\'re searching in. Add as many as you like.' },
    2: { h: 'What are you after?',             s: 'All optional. The more detail, the better the match.' },
    3: { h: 'How should Daniel reach you?',    s: 'Daniel reviews every registration personally.' }
  };

  let currentStep: StepNum = 1;

  function setStep(to: StepNum) {
    const from = currentStep;
    currentStep = to;

    // Show/hide step panels
    ([1, 2, 3] as StepNum[]).forEach(n => {
      const el = document.getElementById(`step-${n}`)!;
      el.style.display = n === to ? 'flex' : 'none';
    });

    // Update dots
    document.querySelectorAll<HTMLElement>('.wz-dot-wrap').forEach(dot => {
      const n = Number(dot.dataset.step) as StepNum;
      dot.classList.remove('active', 'done');
      if (n === to)   dot.classList.add('active');
      if (n < to)     dot.classList.add('done');
    });

    // Fade heading/subhead/counter
    wzHeading.style.opacity = '0';
    wzSubhead.style.opacity = '0';
    setTimeout(() => {
      wzCounter.textContent = `Step ${to} of 3`;
      wzHeading.textContent = stepContent[to].h;
      wzSubhead.textContent = stepContent[to].s;
      wzHeading.style.opacity = '1';
      wzSubhead.style.opacity = '1';
    }, 180);

    // Fade hero text (desktop only)
    heroHeading.style.opacity = '0';
    heroDesc.style.opacity    = '0';
    setTimeout(() => {
      heroHeading.textContent = heroContent[to].h;
      heroDesc.textContent    = heroContent[to].d;
      heroHeading.style.opacity = '1';
      heroDesc.style.opacity    = '1';
    }, 200);

    // Scroll form panel to top on mobile
    if (window.innerWidth <= 860) {
      document.querySelector('.buyers-form-panel')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  // Wire Next buttons
  document.querySelectorAll<HTMLButtonElement>('.wz-next-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const to = Number(btn.dataset.to) as StepNum;
      if (to === 2 && !areasInput.value) {
        areasError.style.display = 'block';
        document.getElementById('quick-chips')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      setStep(to);
    });
  });

  // Wire Back buttons
  document.querySelectorAll<HTMLButtonElement>('.wz-back-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      setStep(Number(btn.dataset.to) as StepNum);
    });
  });

  // Submit
  document.getElementById('buyer-form')?.addEventListener('submit', function() {
    (document.getElementById('buyer-submit-label') as HTMLElement).textContent = 'Sending…';
  });
</script>

<!-- Meta Pixel Lead + GA4 generate_lead on submit -->
<script is:inline>
  (function() {
    function attachLead() {
      var form = document.getElementById('buyer-form');
      if (!form) return;
      form.addEventListener('submit', function() {
        try { if (typeof fbq === 'function') fbq('track', 'Lead', { content_name: 'buyer-registration' }); } catch(e) {}
        try { if (typeof gtag === 'function') gtag('event', 'generate_lead', { content_name: 'buyer-registration', event_category: 'buyer' }); } catch(e) {}
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', attachLead);
    } else {
      attachLead();
    }
  })();
</script>

</Layout>
