---
import Layout from '../layouts/Layout.astro';
import { suburbs } from '../data/suburbs';
const suburbsJson = JSON.stringify(suburbs);
---

<Layout
  preloadImage="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format"
  title="What's Your Property Worth? | Daniel Gierach Property"
  description="Find out what your home is worth. Instant report, free in-person walkthrough, or call Daniel directly. No obligation."
  hideMobileCta={true}
>

<style>
  @keyframes bgDrift {
    0%   { transform: scale(1)    translateY(0); }
    100% { transform: scale(1.06) translateY(-20px); }
  }
  .pw-bg { animation: bgDrift 14s ease-in-out infinite alternate; }

  /* ── Shared ─────────────────────────────────────── */
  .pw-wrap {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding: 6rem 0 5rem;
  }
  .pw-inner {
    position: relative;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .pw-eyebrow {
    display: block;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #c5a03c;
    margin-bottom: 1rem;
  }
  .pw-title {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 4.5vw, 3.5rem);
    font-weight: 400;
    color: #f0ece4;
    letter-spacing: -0.02em;
    line-height: 1.12;
    text-align: center;
    margin: 0 auto 1rem;
    max-width: 22ch;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .pw-title em { font-style: italic; color: #c5a03c; }
  .pw-subtitle {
    font-size: 0.9rem;
    color: rgba(240,236,228,0.6);
    text-align: center;
    max-width: 46ch;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }

  /* ── Testimonial ────────────────────────────────── */
  .pw-testimonial {
    padding: 1.5rem 2rem;
    background: rgba(10,8,6,0.55);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(197,160,60,0.18);
    display: flex;
    align-items: center;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .pw-testimonial blockquote {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-style: italic;
    color: rgba(240,236,228,0.8);
    line-height: 1.65;
    max-width: 58ch;
    margin: 0;
    text-align: center;
  }
  .pw-stars {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
  }
  .pw-stars-label {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(197,160,60,0.7);
    white-space: nowrap;
  }

  /* ── Desktop 3-col cards ────────────────────────── */
  .pw-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    padding-top: 32px; /* space for floating badge */
  }
  .pw-card {
    background: rgba(10,8,6,0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(240,236,228,0.08);
    padding: 2.25rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease, border-color 0.25s ease;
    cursor: pointer;
  }
  .pw-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.45);
    background: rgba(20,16,12,0.85);
    border-color: rgba(197,160,60,0.35);
  }
  .pw-card-featured {
    border-color: rgba(197,160,60,0.55);
    box-shadow: inset 0 0 40px rgba(197,160,60,0.04);
    position: relative;
  }
  .pw-card-featured:hover {
    transform: translateY(-5px);
    border-color: rgba(197,160,60,0.75);
  }
  .pw-card-top-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: #c5a03c;
  }
  .pw-badge-float {
    position: absolute;
    top: -1px; left: 50%;
    transform: translate(-50%, -100%);
    background: #c5a03c;
    padding: 0.5rem 1.5rem;
    white-space: nowrap;
    z-index: 2;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #0a0806;
  }
  .pw-card-tag {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(197,160,60,0.7);
    margin-bottom: 0.5rem;
    display: block;
  }
  .pw-card h2 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: #f0ece4;
    line-height: 1.2;
    margin: 0 0 0.65rem;
  }
  .pw-card p {
    font-size: 0.82rem;
    color: rgba(240,236,228,0.58);
    line-height: 1.75;
    margin: 0;
  }
  .pw-bullets {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .pw-bullets li {
    font-size: 0.77rem;
    color: rgba(240,236,228,0.55);
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
  }
  .pw-bullets li span { color: #c5a03c; font-size: 0.68rem; margin-top: 0.1rem; }
  .pw-card-body { display: flex; flex-direction: column; gap: 1rem; flex: 1; }
  .pw-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.9rem 1.5rem;
    background: rgba(197,160,60,0.8);
    color: #0a0806;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background 0.18s, gap 0.18s;
    border: none;
    cursor: pointer;
  }
  .pw-btn-featured { background: #c5a03c; }
  .pw-btn-outline {
    background: transparent;
    color: #f0ece4;
    border: 1px solid rgba(240,236,228,0.22);
    transition: border-color 0.18s, color 0.18s;
  }
  .pw-card:hover .pw-btn { background: #d4af4a; gap: 0.75rem; }
  .pw-card:hover .pw-btn-outline { border-color: rgba(197,160,60,0.6); color: #c5a03c; }

  /* ── Mobile ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .pw-wrap { padding: 5rem 0 6rem; }
    .pw-inner { padding: 0 1.1rem; }
    .pw-subtitle { display: none; }
    .pw-testimonial { display: none; }

    /* Cards become compact rows */
    .pw-cards {
      grid-template-columns: 1fr;
      padding-top: 0;
      gap: 0.65rem;
    }
    .pw-card {
      padding: 1.25rem 1.25rem;
      gap: 0.9rem;
      flex-direction: row;
      align-items: center;
    }
    .pw-card-body { gap: 0.35rem; }
    .pw-card h2 { font-size: 1.05rem; margin-bottom: 0.2rem; }
    .pw-card p { font-size: 0.78rem; line-height: 1.5; }
    .pw-bullets { display: none; }
    .pw-btn {
      display: none; /* CTA is the whole card tap on mobile */
    }
    /* Arrow indicator instead */
    .pw-card-arrow {
      flex-shrink: 0;
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(197,160,60,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: auto;
    }
    .pw-card-featured .pw-card-arrow {
      background: rgba(197,160,60,0.3);
    }
    .pw-card-top-bar { display: none; }

    /* Featured: gold left border instead of floating badge */
    .pw-card-featured {
      border-left: 3px solid #c5a03c !important;
      border-color: rgba(197,160,60,0.4);
    }
    .pw-badge-float { display: none; }

    /* "Most Accurate" shown as inline tag on mobile */
    .pw-featured-mobile-badge {
      display: inline-flex !important;
    }

    /* Bottom padding for sticky bar */
    .pw-wrap { padding-bottom: 5.5rem; }

    /* Make card touch feedback clearer */
    .pw-card:active { background: rgba(25,20,15,0.85); }
  }

  @media (min-width: 769px) {
    .pw-card-arrow { display: none; }
    .pw-featured-mobile-badge { display: none !important; }
  }
</style>

<div class="pw-wrap">
  <!-- Background -->
  <div style="position:absolute;inset:0;overflow:hidden;">
    <img
      src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format"
      alt="Premium Brisbane property"
      class="pw-bg"
      style="width:100%;height:100%;object-fit:cover;filter:grayscale(35%) brightness(0.22);"
      loading="eager" decoding="async" width="1920" height="1080"
    />
    <div style="position:absolute;inset:0;background:rgba(10,8,6,0.5);"></div>
  </div>

  <div class="pw-inner">

    <!-- Heading -->
    <div style="text-align:center;margin-bottom:2rem;">
      <span class="pw-eyebrow" id="pw-eyebrow">What's Your Property Worth?</span>
      <h1 class="pw-title" id="pw-title">
        Find out in<br/><em>three ways.</em>
      </h1>
      <p class="pw-subtitle">
        Pick whichever option suits. A number now, an in-person walkthrough, or a phone call. Each one gets you closer to a decision.
      </p>
    </div>

    <!-- Testimonial (desktop only) -->
    <div class="pw-testimonial">
      <blockquote>
        "Daniel was honestly fantastic to work with. He was always one step ahead and made the whole process feel easy. He took care of it all with zero stress for me."
      </blockquote>
      <div class="pw-stars">
        <div style="display:flex;gap:0.2rem;">
          {[1,2,3,4,5].map(() => (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="#f5d07a"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
        </div>
        <span class="pw-stars-label">5 Stars · Recent Review</span>
      </div>
    </div>

    <!-- Three options -->
    <div class="pw-cards">

      <!-- Card 1: Instant Report -->
      <a id="pw-card-report" href="/property-report" class="pw-card">
        <div class="pw-card-body">
          <div>
            <span class="pw-card-tag">Instant · Online</span>
            <h2>Get an Instant Property Report</h2>
            <p>An automated estimate based on recent sales. Good for a ballpark figure fast.</p>
          </div>
          <ul class="pw-bullets">
            <li><span>✓</span> Estimate from real sales data</li>
            <li><span>✓</span> No phone call required</li>
            <li><span>✓</span> Ready in under 60 seconds</li>
          </ul>
        </div>
        <div class="pw-card-arrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c5a03c" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
        <span class="pw-btn">
          Get My Instant Report
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Card 2: Walkthrough (featured) -->
      <a href="/walkthrough" class="pw-card pw-card-featured" style="position:relative;">
        <div class="pw-badge-float">Most Accurate</div>
        <div class="pw-card-top-bar"></div>
        <div class="pw-card-body">
          <div>
            <span class="pw-card-tag">
              Free · In-Person · 10-15 mins
              <span class="pw-featured-mobile-badge" style="display:none;margin-left:0.5rem;background:#c5a03c;color:#0a0806;padding:0.15rem 0.5rem;font-size:0.5rem;letter-spacing:0.15em;">MOST ACCURATE</span>
            </span>
            <h2>Book a Free Property Walkthrough</h2>
            <p>Daniel visits, assesses your home against comparable sales, and gives you a frank, precise opinion of value.</p>
          </div>
          <ul class="pw-bullets">
            <li><span>✓</span> Comparable-based assessment</li>
            <li><span>✓</span> Tailored to your home's condition</li>
            <li><span>✓</span> No scripts, just honest advice</li>
          </ul>
        </div>
        <div class="pw-card-arrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c5a03c" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
        <span class="pw-btn pw-btn-featured">
          Book a Free Walkthrough
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Card 3: Call -->
      <a href="tel:+61412523821" class="pw-card">
        <div class="pw-card-body">
          <div>
            <span class="pw-card-tag">0412 523 821 · 7 days</span>
            <h2>Talk to Daniel Now</h2>
            <p>A quick call is the fastest way to get a straight answer. No assistants, no scripts.</p>
          </div>
          <ul class="pw-bullets">
            <li><span>✓</span> Speak directly to Daniel</li>
            <li><span>✓</span> Available 7am, 8pm, 7 days</li>
            <li><span>✓</span> No obligation, no sales pitch</li>
          </ul>
        </div>
        <div class="pw-card-arrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c5a03c" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 5.92 5.92l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.21 16z"/></svg>
        </div>
        <span class="pw-btn pw-btn-outline">
          Call Now, 0412 523 821
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 5.92 5.92l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.21 16z"/></svg>
        </span>
      </a>

    </div>
  </div>
</div>

<script define:vars={{ suburbsJson }}>
(function() {
  const suburbs = JSON.parse(suburbsJson);
  const params  = new URLSearchParams(window.location.search);
  const addr    = params.get('address') || '';

  if (addr) {
    const link = document.getElementById('pw-card-report');
    if (link) link.href = '/property-report?address=' + encodeURIComponent(addr);
  }

  function extractSuburb(address) {
    const parts = address.split(',').map(p => p.trim());
    for (const part of parts) {
      const cleaned = part.replace(/\s+(QLD|NSW|VIC|WA|SA|TAS|ACT|NT)\s+\d{4}$/i, '').trim();
      const match = suburbs.find(s => s.name.toLowerCase() === cleaned.toLowerCase());
      if (match) return match;
    }
    return null;
  }

  const suburb = addr ? extractSuburb(addr) : null;

  if (suburb) {
    const title = document.getElementById('pw-title');
    if (title) title.innerHTML = 'What is your property worth<br/><em>in ' + suburb.name + '?</em>';
    const sub = document.querySelector('.pw-subtitle');
    if (sub) sub.textContent = suburb.overview;
  } else if (addr) {
    const parts = addr.split(',');
    if (parts.length >= 2) {
      const raw = parts[parts.length - 2].replace(/\s+(QLD|NSW|VIC|WA|SA|TAS|ACT|NT)\s+\d{4}$/i, '').trim();
      if (raw) {
        const title = document.getElementById('pw-title');
        if (title) title.innerHTML = 'What is your property worth<br/><em>in ' + raw + '?</em>';
      }
    }
  }
})();
</script>

<!-- Mobile sticky CTA bar -->
<div id="mobile-sticky-cta" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:999;background:#c5a03c;padding:1rem 1.25rem;box-shadow:0 -4px 24px rgba(0,0,0,0.25);">
  <a href="/walkthrough" style="display:flex;align-items:center;justify-content:center;gap:0.5rem;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;">
    Book a Free Walkthrough
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </a>
</div>
<style>
  @media (max-width: 768px) {
    #mobile-sticky-cta { display: block !important; }
  }
</style>

</Layout>
