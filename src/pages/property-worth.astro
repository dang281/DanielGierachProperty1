---
import Layout from '../layouts/Layout.astro';
import { suburbs } from '../data/suburbs';
const suburbsJson = JSON.stringify(suburbs);
---

<Layout
  preloadImage="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format"
  title="What's Your Property Worth? | Daniel Gierach Property"
  description="Find out what your home is worth in three ways — instant report, free in-person appraisal, or call Daniel directly. No obligation."
>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes bgDrift {
    0%   { transform: scale(1)    translateY(0); }
    100% { transform: scale(1.06) translateY(-20px); }
  }

  .pw-bg-img {
    animation: bgDrift 12s ease-in-out infinite alternate;
  }

  .pw-heading  { animation: fadeUp 0.7s ease both; }
  .pw-subtitle { animation: fadeUp 0.7s 0.15s ease both; }
  .pw-cards    { animation: fadeUp 0.7s 0.3s ease both; }

  .pw-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    cursor: pointer;
  }
  .pw-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.45);
    background: rgba(20,16,12,0.85) !important;
    border-color: rgba(197,160,60,0.4) !important;
  }
  .pw-card:hover .pw-card-tag { color: #c5a03c !important; }
  .pw-card:hover .pw-card-btn {
    background: #d4af4a !important;
    gap: 0.75rem !important;
  }
  .pw-card-featured:hover {
    background: rgba(197,160,60,0.14) !important;
    border-color: rgba(197,160,60,0.6) !important;
  }
  .pw-card-btn { transition: background 0.2s, gap 0.2s; }
  .pw-card-outline-btn {
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }
  .pw-card:hover .pw-card-outline-btn {
    border-color: rgba(197,160,60,0.7) !important;
    color: #c5a03c !important;
  }
</style>

<section class="relative overflow-hidden" style="min-height:100dvh;display:flex;align-items:center;padding:7rem 0 5rem;">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format"
      srcset="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=640&q=50&fm=webp&auto=format 640w, https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format 1200w"
      sizes="100vw"
      alt="Premium property"
      class="w-full h-full object-cover"
      class="pw-bg-img"
      style="filter:grayscale(40%) brightness(0.25);"
      loading="eager" decoding="async" width="1920" height="1080"
    />
    <div class="absolute inset-0" style="background:rgba(10,8,6,0.55);"></div>
  </div>

  <div class="relative max-w-[1400px] mx-auto px-8 lg:px-12 w-full">

    <!-- Heading (dynamic or default) -->
    <div class="text-center mb-10 pw-heading" id="pw-heading">
      <span id="pw-eyebrow" style="display:block;text-align:center;color:#f5d07a;font-family:var(--font-sans);font-size:0.85rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;margin-bottom:1.25rem;">What's Your Home Worth?</span>
      <h1 id="pw-title"
        style="font-family:var(--font-serif);font-size:clamp(2.25rem,5vw,3.75rem);font-weight:400;color:#f0ece4;letter-spacing:-0.02em;line-height:1.1;margin-bottom:1.25rem;">
        Find out in three ways.<br/><em style="font-style:italic;color:#c5a03c;">Choose yours.</em>
      </h1>
      <p id="pw-subtitle" class="pw-subtitle" style="font-size:0.9375rem;color:rgba(240,236,228,0.65);max-width:52ch;margin:0 auto;line-height:1.8;">
        Whether you want a number now, a detailed assessment, or a conversation, there's a starting point for every stage of thinking.
      </p>
    </div>

    <!-- Three option cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px pw-cards" style="background:rgba(255,255,255,0.08);">

      <!-- Option 1: Instant report -->
      <a id="pw-card-report" href="/property-report" class="pw-card" style="background:rgba(10,8,6,0.6);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.25rem;border:1px solid transparent;text-decoration:none;cursor:pointer;">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:rgba(197,160,60,0.7);margin-bottom:0.6rem;">Instant · Online</p>
          <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.2;margin-bottom:0.75rem;">
            Get an Instant<br/>Property Report
          </h2>
          <p style="font-size:0.82rem;color:rgba(240,236,228,0.6);line-height:1.75;">
            Enter your address and receive a data-driven property value estimate instantly, powered by Ray White's national sales database. No waiting, no commitment.
          </p>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Instant estimate from real sales data
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> No phone call required
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Ready in under 60 seconds
          </li>
        </ul>
        <span class="pw-card-btn" style="margin-top:auto;display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.85rem 1.5rem;background:#c5a03c;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;">
          Get My Instant Report
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Option 2: Appraisal (featured) -->
      <a href="/appraisal" class="pw-card pw-card-featured" style="background:rgba(197,160,60,0.08);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.25rem;position:relative;border:1px solid rgba(197,160,60,0.25);text-decoration:none;cursor:pointer;">
        <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#c5a03c;padding:0.25rem 0.9rem;">
          <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#0a0806;">Most Popular & Accurate</span>
        </div>
        <div>
          <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:#c5a03c;margin-bottom:0.6rem;">Free · In-Person · 10–15 mins</p>
          <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.2;margin-bottom:0.75rem;">
            Book a Free<br/>Property Appraisal
          </h2>
          <p style="font-size:0.82rem;color:rgba(240,236,228,0.6);line-height:1.75;">
            Daniel walks through your home, assesses it against recent comparable sales, and gives you a frank, well-researched opinion of value. No charge, no obligation.
          </p>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Accurate, comparable-based assessment
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Tailored to your home's condition and position
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Completely free, no strings attached
          </li>
        </ul>
        <span class="pw-card-btn" style="margin-top:auto;display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.85rem 1.5rem;background:#c5a03c;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;">
          Request an Appraisal
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Option 3: Call -->
      <a href="tel:+61412523821" class="pw-card" style="background:rgba(10,8,6,0.6);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.25rem;border:1px solid transparent;text-decoration:none;cursor:pointer;">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:rgba(197,160,60,0.7);margin-bottom:0.6rem;">Immediate · Personal</p>
          <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.2;margin-bottom:0.75rem;">
            Call Daniel<br/>Directly
          </h2>
          <p style="font-size:0.82rem;color:rgba(240,236,228,0.6);line-height:1.75;">
            Got a specific question about your property, a recent sale nearby, or the current market? Call Daniel directly and get a straight answer in minutes.
          </p>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Speak directly with Daniel, no assistants
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Available 7 days, 7am to 8pm
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> No scripts, no sales pitch
          </li>
        </ul>
        <span class="pw-card-outline-btn" style="margin-top:auto;display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.85rem 1.5rem;background:transparent;color:#f0ece4;border:1px solid rgba(240,236,228,0.25);font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;">
          Call 0412 523 821
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 5.92 5.92l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.21 16z"/></svg>
        </span>
      </a>

    </div>
  </div>
</section>

<script define:vars={{ suburbsJson }}>
(function() {
  const suburbs = JSON.parse(suburbsJson);
  const params  = new URLSearchParams(window.location.search);
  const addr    = params.get('address') || '';

  // Pre-fill report link with address
  if (addr) {
    const link = document.getElementById('pw-report-link');
    if (link) link.href = '/property-report?address=' + encodeURIComponent(addr);
  }

  // Extract suburb from Google Places address
  // e.g. "39 Moolabar Street, Morningside QLD 4122, Australia" → finds "Morningside"
  function extractSuburb(address) {
    const parts = address.split(',').map(p => p.trim());
    for (const part of parts) {
      // Strip trailing state/postcode e.g. "Morningside QLD 4122" → "Morningside"
      const cleaned = part.replace(/\s+(QLD|NSW|VIC|WA|SA|TAS|ACT|NT)\s+\d{4}$/i, '').trim();
      const match = suburbs.find(s =>
        s.name.toLowerCase() === cleaned.toLowerCase()
      );
      if (match) return match;
    }
    return null;
  }

  const suburb = addr ? extractSuburb(addr) : null;

  if (suburb) {
    // Update eyebrow
    document.getElementById('pw-eyebrow').textContent = suburb.name + ' · ' + suburb.region;

    // Update heading
    document.getElementById('pw-title').innerHTML =
      'What is your property worth<br/><em style="font-style:italic;color:#c5a03c;">in ' + suburb.name + '?</em>';

    // Update subtitle
    document.getElementById('pw-subtitle').textContent = suburb.overview;

  }
})();
</script>

</Layout>
