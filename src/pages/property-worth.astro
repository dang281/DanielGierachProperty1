---
import Layout from '../layouts/Layout.astro';
import { suburbs } from '../data/suburbs';
const suburbsJson = JSON.stringify(suburbs);
---

<Layout
  preloadImage="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format"
  title="What's Your Property Worth? | Daniel Gierach Property"
  description="Find out what your home is worth in three ways. Instant report, free in-person walkthrough, or call Daniel directly. No obligation."
>

<style>
  @keyframes bgDrift {
    0%   { transform: scale(1)    translateY(0); }
    100% { transform: scale(1.06) translateY(-20px); }
  }
  .pw-bg-img { animation: bgDrift 12s ease-in-out infinite alternate; }

  .pw-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    cursor: pointer;
    text-decoration: none;
  }
  .pw-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.45);
    background: rgba(20,16,12,0.85) !important;
    border-color: rgba(197,160,60,0.4) !important;
  }
  .pw-card:hover .pw-card-tag { color: #c5a03c !important; }
  .pw-card:hover .pw-card-btn {
    background: #d4af4a !important;
    gap: 0.75rem !important;
  }
  .pw-card-featured:hover {
    transform: none !important;
    background: rgba(20,16,12,0.85) !important;
    border-color: rgba(197,160,60,0.7) !important;
  }
  .pw-featured-wrapper {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .pw-featured-wrapper:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.45);
  }
  .pw-card:hover .pw-card-outline-btn {
    border-color: rgba(197,160,60,0.7) !important;
    color: #c5a03c !important;
  }
  .pw-card-btn { transition: background 0.2s, gap 0.2s; }
  .pw-card-outline-btn { transition: border-color 0.2s, color 0.2s; }
</style>

<section class="relative overflow-hidden" style="min-height:100dvh;display:flex;align-items:center;padding:7rem 0 5rem;">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format"
      alt="Premium property"
      class="pw-bg-img w-full h-full object-cover"
      style="filter:grayscale(40%) brightness(0.25);"
      loading="eager" decoding="async" width="1920" height="1080"
    />
    <div class="absolute inset-0" style="background:rgba(10,8,6,0.55);"></div>
  </div>

  <div class="relative max-w-[1400px] mx-auto px-8 lg:px-12 w-full">

    <!-- Heading -->
    <div class="text-center mb-10">
      <span id="pw-eyebrow" style="display:block;text-align:center;color:#f5d07a;font-family:var(--font-sans);font-size:0.72rem;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:1.25rem;">What's Your Home Worth?</span>
      <h1 id="pw-title"
        style="font-family:var(--font-serif);font-size:clamp(2.25rem,5vw,3.75rem);font-weight:400;color:#f0ece4;letter-spacing:-0.02em;line-height:1.1;margin-bottom:1.25rem;">
        Find out in three ways.<br/><em style="font-style:italic;color:#c5a03c;">Choose yours.</em>
      </h1>
      <p id="pw-subtitle" style="font-size:0.9375rem;color:rgba(240,236,228,0.65);max-width:52ch;margin:0 auto;line-height:1.8;">
        Whether you want a number now, a detailed assessment, or a conversation, there's a starting point for every stage of thinking.
      </p>
    </div>

    <!-- Testimonial strip -->
    <div style="margin-bottom:2.5rem;padding:1.75rem 2rem;background:rgba(10,8,6,0.6);backdrop-filter:blur(8px);border:1px solid rgba(197,160,60,0.2);display:flex;flex-wrap:wrap;align-items:center;gap:1.75rem;justify-content:center;">
      <p style="font-family:var(--font-serif);font-size:0.95rem;font-style:italic;color:rgba(240,236,228,0.85);line-height:1.65;max-width:60ch;text-align:center;">
        "Daniel was honestly fantastic to work with. He was always one step ahead and made the whole process feel easy. He took care of it all with zero stress for me. If you're after an agent who genuinely cares and goes above and beyond, Daniel's your guy."
      </p>
      <div style="display:flex;flex-direction:column;align-items:center;gap:0.3rem;flex-shrink:0;">
        <div style="display:flex;gap:0.2rem;">
          {[1,2,3,4,5].map(() => (
            <svg width="11" height="11" viewBox="0 0 24 24" fill="#f5d07a"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
        </div>
        <span style="font-family:var(--font-sans);font-size:0.58rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(197,160,60,0.7);white-space:nowrap;">5 Stars · Recent Review</span>
      </div>
    </div>

    <!-- Three cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" style="padding-top:28px;">

      <!-- Card 1: Instant Report -->
      <a id="pw-card-report" href="/property-report" class="pw-card"
        style="background:rgba(10,8,6,0.6);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;justify-content:space-between;gap:1.5rem;border:1px solid transparent;">
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div>
            <p class="pw-card-tag" style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:rgba(197,160,60,0.7);margin-bottom:0.6rem;">Instant · Online</p>
            <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.2;margin-bottom:0.75rem;">
              Get an Instant<br/>Property Report
            </h2>
            <p style="font-size:0.82rem;color:rgba(240,236,228,0.6);line-height:1.75;">
              An automated estimate based on recent sales data in your area. Good for a ballpark. For a precise number, book a walkthrough.
            </p>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
              <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Instant estimate from real sales data
            </li>
            <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
              <span style="color:#c5a03c;font-size:0.7rem;">✓</span> No phone call required
            </li>
            <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
              <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Ready in under 60 seconds
            </li>
          </ul>
        </div>
        <span class="pw-card-btn" style="display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.85rem 1.5rem;background:rgba(197,160,60,0.75);color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;">
          Get My Instant Report
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Card 2: Walkthrough (featured) -->
      <div class="pw-featured-wrapper" style="position:relative;display:flex;flex-direction:column;align-self:stretch;">
        <div style="position:absolute;top:-1px;left:50%;transform:translate(-50%,-100%);background:#c5a03c;padding:0.55rem 1.75rem;white-space:nowrap;z-index:2;">
          <span style="font-family:var(--font-sans);font-size:0.62rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#0a0806;">Most Accurate</span>
        </div>
        <a href="/walkthrough" class="pw-card pw-card-featured"
          style="background:rgba(10,8,6,0.6);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;justify-content:space-between;gap:1.5rem;position:relative;border:1px solid rgba(197,160,60,0.6);box-shadow:0 0 0 1px rgba(197,160,60,0.15),inset 0 0 40px rgba(197,160,60,0.04);flex:1;">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#c5a03c;"></div>
          <div style="display:flex;flex-direction:column;gap:1.25rem;">
            <div>
              <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:rgba(197,160,60,0.7);margin-bottom:0.6rem;">Free · In-Person · 10-15 mins</p>
              <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.25;margin-bottom:0.75rem;">
                Book a Free<br/>Property Walkthrough
              </h2>
              <p style="font-size:0.82rem;color:rgba(240,236,228,0.65);line-height:1.75;">
                Daniel walks through your home, assesses it against recent comparable sales, and gives you a frank, well-researched opinion of value. No charge, no obligation.
              </p>
            </div>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
              <li style="font-size:0.78rem;color:rgba(240,236,228,0.6);display:flex;align-items:flex-start;gap:0.5rem;">
                <span style="color:#c5a03c;font-size:0.7rem;margin-top:0.1rem;">✓</span> Accurate, comparable-based assessment
              </li>
              <li style="font-size:0.78rem;color:rgba(240,236,228,0.6);display:flex;align-items:flex-start;gap:0.5rem;">
                <span style="color:#c5a03c;font-size:0.7rem;margin-top:0.1rem;">✓</span> Tailored to your home's condition and position
              </li>
              <li style="font-size:0.78rem;color:rgba(240,236,228,0.6);display:flex;align-items:flex-start;gap:0.5rem;">
                <span style="color:#c5a03c;font-size:0.7rem;margin-top:0.1rem;">✓</span> No scripts, just honest advice
              </li>
            </ul>
          </div>
          <span class="pw-card-btn" style="display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.9rem 1.5rem;background:#c5a03c;color:#0a0806;font-family:var(--font-sans);font-size:0.68rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;">
            Book a Free Walkthrough
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>

      <!-- Card 3: Call -->
      <a href="tel:+61412523821" class="pw-card"
        style="background:rgba(10,8,6,0.6);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;justify-content:space-between;gap:1.5rem;border:1px solid transparent;">
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div>
            <p class="pw-card-tag" style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:rgba(197,160,60,0.7);margin-bottom:0.6rem;">Immediate · Personal</p>
            <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.2;margin-bottom:0.75rem;">
              Call Daniel<br/>Directly
            </h2>
            <p style="font-size:0.82rem;color:rgba(240,236,228,0.6);line-height:1.75;">
              Got a specific question about your property, a recent sale nearby, or the current market? Call Daniel directly and get a straight answer in minutes.
            </p>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
              <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Speak directly with Daniel, no assistants
            </li>
            <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
              <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Available 7 days, 7am to 8pm
            </li>
            <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
              <span style="color:#c5a03c;font-size:0.7rem;">✓</span> No scripts, no sales pitch
            </li>
          </ul>
        </div>
        <span class="pw-card-outline-btn" style="display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.85rem 1.5rem;background:transparent;color:#f0ece4;border:1px solid rgba(240,236,228,0.25);font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;">
          Call 0412 523 821
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 5.92 5.92l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.21 16z"/></svg>
        </span>
      </a>

    </div>
  </div>
</section>

<script define:vars={{ suburbsJson }}>
(function() {
  const suburbs = JSON.parse(suburbsJson);
  const params  = new URLSearchParams(window.location.search);
  const addr    = params.get('address') || '';

  // Pre-fill report link with address
  if (addr) {
    const link = document.getElementById('pw-card-report');
    if (link) link.href = '/property-report?address=' + encodeURIComponent(addr);
  }

  function extractSuburb(address) {
    const parts = address.split(',').map(p => p.trim());
    for (const part of parts) {
      const cleaned = part.replace(/\s+(QLD|NSW|VIC|WA|SA|TAS|ACT|NT)\s+\d{4}$/i, '').trim();
      const match = suburbs.find(s => s.name.toLowerCase() === cleaned.toLowerCase());
      if (match) return match;
    }
    return null;
  }

  const suburb = addr ? extractSuburb(addr) : null;

  if (suburb) {
    document.getElementById('pw-eyebrow').textContent = "What's Your Home Worth?";
    document.getElementById('pw-title').innerHTML =
      'What is your property worth<br/><em style="font-style:italic;color:#c5a03c;">in ' + suburb.name + '?</em>';
    document.getElementById('pw-subtitle').textContent = suburb.overview;
  } else if (addr) {
    // Extract suburb name fallback from address string
    const parts = addr.split(',');
    if (parts.length >= 2) {
      const raw = parts[parts.length - 2].replace(/\s+(QLD|NSW|VIC|WA|SA|TAS|ACT|NT)\s+\d{4}$/i, '').trim();
      if (raw) {
        document.getElementById('pw-title').innerHTML =
          'What is your property worth<br/><em style="font-style:italic;color:#c5a03c;">in ' + raw + '?</em>';
      }
    }
  }
})();
</script>

<!-- Mobile sticky CTA bar -->
<div id="mobile-sticky-cta" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:999;background:#c5a03c;padding:1rem 1.25rem;box-shadow:0 -4px 24px rgba(0,0,0,0.25);">
  <a href="/walkthrough" style="display:flex;align-items:center;justify-content:center;gap:0.5rem;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;">
    Book a Free Walkthrough
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </a>
</div>
<style>
  @media (max-width: 768px) {
    #mobile-sticky-cta { display: block !important; }
  }
</style>

</Layout>
