---
import Layout from '../layouts/Layout.astro';
import { suburbs } from '../data/suburbs';
const suburbsJson = JSON.stringify(suburbs);
---

<Layout
  preloadImage="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format"
  title="What's Your Property Worth? | Daniel Gierach Property"
  description="Find out what your home is worth in three ways — instant report, free in-person appraisal, or call Daniel directly. No obligation."
>

<section class="relative overflow-hidden" style="min-height:100dvh;display:flex;align-items:center;padding:7rem 0 5rem;">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format"
      srcset="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=640&q=50&fm=webp&auto=format 640w, https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1200&q=55&fm=webp&auto=format 1200w"
      sizes="100vw"
      alt="Premium property"
      class="w-full h-full object-cover"
      style="filter:grayscale(40%) brightness(0.25);"
      loading="eager" decoding="async" width="1920" height="1080"
    />
    <div class="absolute inset-0" style="background:rgba(10,8,6,0.55);"></div>
  </div>

  <div class="relative max-w-[1400px] mx-auto px-8 lg:px-12 w-full">

    <!-- Heading (dynamic or default) -->
    <div class="text-center mb-10" id="pw-heading">
      <span id="pw-eyebrow" style="display:block;text-align:center;color:#f5d07a;font-family:var(--font-sans);font-size:0.85rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;margin-bottom:1.25rem;">What's Your Home Worth?</span>
      <h1 id="pw-title"
        style="font-family:var(--font-serif);font-size:clamp(2.25rem,5vw,3.75rem);font-weight:400;color:#f0ece4;letter-spacing:-0.02em;line-height:1.1;margin-bottom:1.25rem;">
        Find out in three ways.<br/><em style="font-style:italic;color:#c5a03c;">Choose yours.</em>
      </h1>
      <p id="pw-subtitle" style="font-size:0.9375rem;color:rgba(240,236,228,0.65);max-width:52ch;margin:0 auto;line-height:1.8;">
        Whether you want a number now, a detailed assessment, or a conversation, there's a starting point for every stage of thinking.
      </p>
    </div>

    <!-- Suburb stats strip (hidden by default, shown when suburb matched) -->
    <div id="pw-stats" style="display:none;margin-bottom:2.5rem;">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(255,255,255,0.1);" class="sm:grid-cols-4">
        <div style="background:rgba(10,8,6,0.55);backdrop-filter:blur(8px);padding:1.25rem 1.5rem;text-align:center;">
          <p id="pw-stat-median" style="font-family:var(--font-serif);font-size:1.4rem;font-weight:400;color:#f0ece4;line-height:1;margin-bottom:0.3rem;">—</p>
          <p style="font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:rgba(240,236,228,0.5);">Median House Price</p>
        </div>
        <div style="background:rgba(10,8,6,0.55);backdrop-filter:blur(8px);padding:1.25rem 1.5rem;text-align:center;">
          <p id="pw-stat-growth" style="font-family:var(--font-serif);font-size:1.4rem;font-weight:400;color:#c5a03c;line-height:1;margin-bottom:0.3rem;">—</p>
          <p style="font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:rgba(240,236,228,0.5);">Price Growth (1yr)</p>
        </div>
        <div style="background:rgba(10,8,6,0.55);backdrop-filter:blur(8px);padding:1.25rem 1.5rem;text-align:center;">
          <p id="pw-stat-dom" style="font-family:var(--font-serif);font-size:1.4rem;font-weight:400;color:#f0ece4;line-height:1;margin-bottom:0.3rem;">—</p>
          <p style="font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:rgba(240,236,228,0.5);">Avg Days on Market</p>
        </div>
        <div style="background:rgba(10,8,6,0.55);backdrop-filter:blur(8px);padding:1.25rem 1.5rem;text-align:center;">
          <p id="pw-stat-yield" style="font-family:var(--font-serif);font-size:1.4rem;font-weight:400;color:#f0ece4;line-height:1;margin-bottom:0.3rem;">—</p>
          <p style="font-size:0.58rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:rgba(240,236,228,0.5);">Rental Yield</p>
        </div>
      </div>
      <!-- Agent commentary -->
      <div id="pw-commentary" style="display:none;background:rgba(197,160,60,0.06);border-left:3px solid rgba(197,160,60,0.4);padding:1rem 1.5rem;margin-top:1px;">
        <p id="pw-commentary-text" style="font-size:0.82rem;color:rgba(240,236,228,0.7);line-height:1.8;font-style:italic;"></p>
        <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#c5a03c;margin-top:0.5rem;">— Daniel Gierach, local market specialist</p>
      </div>
    </div>

    <!-- Three option cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px" style="background:rgba(255,255,255,0.08);">

      <!-- Option 1: Instant report -->
      <div style="background:rgba(10,8,6,0.6);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.25rem;">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:rgba(197,160,60,0.7);margin-bottom:0.6rem;">Instant · Online</p>
          <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.2;margin-bottom:0.75rem;">
            Get an Instant<br/>Property Report
          </h2>
          <p style="font-size:0.82rem;color:rgba(240,236,228,0.6);line-height:1.75;">
            Enter your address and receive a data-driven property value estimate instantly, powered by Ray White's national sales database. No waiting, no commitment.
          </p>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Instant estimate from real sales data
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> No phone call required
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Ready in under 60 seconds
          </li>
        </ul>
        <a id="pw-report-link" href="/property-report"
          onclick="try{gtag('event','property_report_click',{event_category:'lead',event_label:'Property Worth Page'})}catch(_){}"
          style="margin-top:auto;display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.85rem 1.5rem;background:#c5a03c;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;"
          onmouseover="this.style.background='#d4af4a'" onmouseout="this.style.background='#c5a03c'">
          Get My Instant Report
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Option 2: Appraisal (featured) -->
      <div style="background:rgba(197,160,60,0.08);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.25rem;position:relative;border:1px solid rgba(197,160,60,0.25);">
        <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:#c5a03c;padding:0.25rem 0.9rem;">
          <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#0a0806;">Most Popular</span>
        </div>
        <div>
          <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:#c5a03c;margin-bottom:0.6rem;">Free · In-Person · 10–15 mins</p>
          <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.2;margin-bottom:0.75rem;">
            Book a Free<br/>Property Appraisal
          </h2>
          <p style="font-size:0.82rem;color:rgba(240,236,228,0.6);line-height:1.75;">
            Daniel walks through your home, assesses it against recent comparable sales, and gives you a frank, well-researched opinion of value. No charge, no obligation.
          </p>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Accurate, comparable-based assessment
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Tailored to your home's condition and position
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Completely free, no strings attached
          </li>
        </ul>
        <a href="/appraisal"
          onclick="try{gtag('event','appraisal_click',{event_category:'lead',event_label:'Property Worth Page'})}catch(_){}"
          style="margin-top:auto;display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.85rem 1.5rem;background:#c5a03c;color:#0a0806;font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;"
          onmouseover="this.style.background='#d4af4a'" onmouseout="this.style.background='#c5a03c'">
          Request an Appraisal
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Option 3: Call -->
      <div style="background:rgba(10,8,6,0.6);backdrop-filter:blur(8px);padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.25rem;">
        <div>
          <p style="font-family:var(--font-sans);font-size:0.58rem;font-weight:800;letter-spacing:0.22em;text-transform:uppercase;color:rgba(197,160,60,0.7);margin-bottom:0.6rem;">Immediate · Personal</p>
          <h2 style="font-family:var(--font-serif);font-size:1.35rem;font-weight:400;color:#f0ece4;line-height:1.2;margin-bottom:0.75rem;">
            Call Daniel<br/>Directly
          </h2>
          <p style="font-size:0.82rem;color:rgba(240,236,228,0.6);line-height:1.75;">
            Got a specific question about your property, a recent sale nearby, or the current market? Call Daniel directly and get a straight answer in minutes.
          </p>
        </div>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Speak directly with Daniel, no assistants
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> Available 7 days, 7am to 8pm
          </li>
          <li style="font-size:0.78rem;color:rgba(240,236,228,0.55);display:flex;align-items:center;gap:0.5rem;">
            <span style="color:#c5a03c;font-size:0.7rem;">✓</span> No scripts, no sales pitch
          </li>
        </ul>
        <a href="tel:+61412523821"
          onclick="try{gtag('event','phone_click',{event_category:'contact',event_label:'Property Worth Page'})}catch(_){}"
          style="margin-top:auto;display:inline-flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.85rem 1.5rem;background:transparent;color:#f0ece4;border:1px solid rgba(240,236,228,0.25);font-family:var(--font-sans);font-size:0.72rem;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;transition:all 0.2s;"
          onmouseover="this.style.borderColor='rgba(197,160,60,0.6)';this.style.color='#c5a03c'" onmouseout="this.style.borderColor='rgba(240,236,228,0.25)';this.style.color='#f0ece4'">
          Call 0412 523 821
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 5.92 5.92l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.21 16z"/></svg>
        </a>
      </div>

    </div>
  </div>
</section>

<script define:vars={{ suburbsJson }}>
(function() {
  const suburbs = JSON.parse(suburbsJson);
  const params  = new URLSearchParams(window.location.search);
  const addr    = params.get('address') || '';

  // Pre-fill report link with address
  if (addr) {
    const link = document.getElementById('pw-report-link');
    if (link) link.href = '/property-report?address=' + encodeURIComponent(addr);
  }

  // Extract suburb name from address string
  // e.g. "39, Moolabar Street, Morningside, Brisbane, Queensland" → "Morningside"
  function extractSuburb(address) {
    const parts = address.split(',').map(p => p.trim());
    // Try each part against known suburb names
    for (const part of parts) {
      const match = suburbs.find(s =>
        s.name.toLowerCase() === part.toLowerCase() ||
        s.name.toLowerCase().replace(' ', '-') === part.toLowerCase().replace(' ', '-')
      );
      if (match) return match;
    }
    return null;
  }

  function fmtPrice(n) {
    if (n >= 1_000_000) return '$' + (n / 1_000_000).toFixed(2).replace(/\.?0+$/, '') + 'm';
    return '$' + (n / 1000).toFixed(0) + 'k';
  }

  const suburb = addr ? extractSuburb(addr) : null;

  if (suburb) {
    // Update eyebrow
    document.getElementById('pw-eyebrow').textContent = suburb.name + ' · ' + suburb.region;

    // Update heading
    document.getElementById('pw-title').innerHTML =
      'What is your property worth<br/><em style="font-style:italic;color:#c5a03c;">in ' + suburb.name + '?</em>';

    // Update subtitle
    document.getElementById('pw-subtitle').textContent = suburb.overview;

    // Show and populate stats
    document.getElementById('pw-stats').style.display = 'block';
    document.getElementById('pw-stat-median').textContent = fmtPrice(suburb.medianHousePrice);

    const growth = suburb.priceGrowth1yr;
    const growthEl = document.getElementById('pw-stat-growth');
    growthEl.textContent = (growth >= 0 ? '+' : '') + growth.toFixed(1) + '%';
    growthEl.style.color = growth >= 0 ? '#c5a03c' : '#e07070';

    document.getElementById('pw-stat-dom').textContent = suburb.medianDaysOnMarket + ' days';
    document.getElementById('pw-stat-yield').textContent = suburb.rentalYield.toFixed(2) + '%';

    // Show agent commentary
    if (suburb.agentCommentary) {
      document.getElementById('pw-commentary-text').textContent = suburb.agentCommentary;
      document.getElementById('pw-commentary').style.display = 'block';
    }
  }
})();
</script>

</Layout>
