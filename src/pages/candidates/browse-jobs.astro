---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PageHero from '../../components/PageHero.astro';
import Footer from '../../components/Footer.astro';

const jobs = [
  {
    title: 'Agentic Workflow Consultant',
    location: 'Brisbane, QLD',
    type: 'Contract',
    category: 'Consultant',
    date: '30 Jun 2025',
    description: 'Design and implement AI agent workflows across enterprise systems. Strong experience with LLM orchestration frameworks required.',
  },
  {
    title: 'L2 Tech Support Officer',
    location: 'Brisbane, QLD',
    type: 'Permanent',
    category: 'Support',
    date: '9 Jul 2025',
    description: 'Provide Level 2 technical support across desktop, network, and application environments for a Queensland government client.',
  },
  {
    title: 'AI Agent Developer',
    location: 'Brisbane, QLD',
    type: 'Contract',
    category: 'Developer',
    date: '4 Apr 2025',
    description: 'Build and deploy AI agents using modern frameworks. Experience with Python, vector databases, and prompt engineering required.',
  },
];

const categories = ['All', 'Architect', 'Business Analyst', 'Consultant', 'Developer', 'DBA', 'Security', 'Network', 'Project Management', 'QA', 'Support'];
const locations = ['All Locations', 'Brisbane', 'Sydney', 'Melbourne', 'Gold Coast', 'Perth', 'Adelaide'];
---

<Layout title="Browse Jobs | Cirqle Group" description="Browse current IT and technology job opportunities with Cirqle Group across Queensland and Australia.">
  <Navbar />
  <PageHero
    badge="For Job Seekers"
    title="Find Your Next"
    titleHighlight="Technology Role"
    subtitle="Current opportunities across IT, data, cloud, cyber, and project delivery — placed with enterprise and government clients in Queensland."
    cta={{ label: 'Register as Candidate', href: '/candidates/register/' }}
    ctaSecondary={{ label: 'Upload Your Resume', href: '/candidates/register/' }}
  />

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filters -->
      <div class="bg-[#E5F3FA] rounded-2xl p-6 mb-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#383E4F] mb-1.5">Category</label>
            <select class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] bg-white focus:outline-none focus:border-[#26A8FF] transition">
              {categories.map(c => <option>{c}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#383E4F] mb-1.5">Location</label>
            <select class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] bg-white focus:outline-none focus:border-[#26A8FF] transition">
              {locations.map(l => <option>{l}</option>)}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-[#383E4F] mb-1.5">Keywords</label>
            <input type="text" placeholder="e.g. Business Analyst, Cloud..." class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm text-[#383E4F] placeholder-gray-400 bg-white focus:outline-none focus:border-[#26A8FF] transition" />
          </div>
        </div>
      </div>

      <!-- Job listings -->
      <div class="space-y-4 mb-12">
        {jobs.map(job => (
          <div class="group bg-white border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-lg hover:border-[#26A8FF]/20 transition-all duration-200 flex flex-col sm:flex-row sm:items-center gap-5">
            <div class="w-12 h-12 rounded-xl bg-[#E5F3FA] flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-briefcase text-[#26A8FF]"></i>
            </div>
            <div class="flex-grow">
              <div class="flex flex-wrap items-center gap-2 mb-1.5">
                <h3 class="font-bold text-[#1F2848] group-hover:text-[#26A8FF] transition-colors">{job.title}</h3>
                <span class="bg-[#E5F3FA] text-[#26A8FF] text-xs font-medium px-2.5 py-0.5 rounded-full">{job.type}</span>
              </div>
              <div class="flex flex-wrap gap-3 text-sm text-[#383E4F] mb-2">
                <span class="flex items-center gap-1"><i class="fa-solid fa-location-dot text-[#26A8FF] text-xs"></i> {job.location}</span>
                <span class="flex items-center gap-1"><i class="fa-solid fa-tag text-[#26A8FF] text-xs"></i> {job.category}</span>
                <span class="flex items-center gap-1"><i class="fa-solid fa-calendar text-[#26A8FF] text-xs"></i> Posted {job.date}</span>
              </div>
              <p class="text-[#383E4F] text-sm">{job.description}</p>
            </div>
            <a href="/candidates/register/" class="btn-primary text-sm whitespace-nowrap flex-shrink-0">
              Apply Now
            </a>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="bg-[#1F2848] rounded-2xl p-8 text-center">
        <h3 class="text-xl font-bold text-white mb-3">Don't See the Right Role?</h3>
        <p class="text-white/70 mb-6 max-w-xl mx-auto">Register your profile and we'll match you with opportunities as they come up — many of our best roles are filled before they're advertised.</p>
        <a href="/candidates/register/" class="inline-flex items-center gap-2 bg-[#26A8FF] text-white font-semibold px-7 py-3.5 rounded-md hover:bg-[#0090e8] transition-colors">
          Upload Your Resume <i class="fa-solid fa-arrow-up-from-bracket"></i>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
