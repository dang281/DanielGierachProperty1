---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PageHero from '../../components/PageHero.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Register as a Candidate | Cirqle Group" description="Register with Cirqle Group and access IT and technology opportunities with enterprise and government clients across Queensland.">
  <Navbar />
  <PageHero
    badge="For Job Seekers"
    title="Register &"
    titleHighlight="Get Discovered"
    subtitle="Upload your resume and join our network of technology professionals. We'll match you with roles that fit your skills, experience, and career goals."
  />

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        <!-- Left: why register -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-[#1F2848] mb-6">Why Register with Cirqle?</h2>
          <div class="space-y-5 mb-8">
            {[
              { icon: 'fa-solid fa-bolt', title: 'Early Access to Roles', body: 'Many of our best opportunities are filled before they reach job boards.' },
              { icon: 'fa-solid fa-comments', title: 'Honest Feedback', body: 'We keep you updated throughout every step of the process — no ghosting.' },
              { icon: 'fa-solid fa-building-columns', title: 'Enterprise & Government', body: 'Access to top-tier clients including Queensland government agencies.' },
              { icon: 'fa-solid fa-people-carry-box', title: 'People-First Approach', body: 'We care about fit — for you and for the client. Long-term placements matter to us.' },
            ].map(item => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-[#E5F3FA] flex items-center justify-center flex-shrink-0">
                  <i class={`${item.icon} text-[#26A8FF] text-sm`}></i>
                </div>
                <div>
                  <h4 class="font-semibold text-[#1F2848] text-sm mb-1">{item.title}</h4>
                  <p class="text-[#383E4F] text-sm">{item.body}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="bg-[#E5F3FA] rounded-2xl p-5">
            <div class="flex gap-1 mb-3">
              {[1,2,3,4,5].map(() => <i class="fa-solid fa-star text-[#26A8FF] text-sm"></i>)}
            </div>
            <blockquote class="text-[#383E4F] text-sm italic mb-3">"They kept me updated throughout the entire interview process. Professional, responsive, and genuinely invested in my outcome."</blockquote>
            <div class="text-[#1F2848] text-xs font-semibold">Madeleine B. <span class="text-[#26A8FF] font-normal">· Placed Candidate</span></div>
          </div>
        </div>

        <!-- Right: registration form -->
        <div class="lg:col-span-3">
          <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-lg">
            <h2 class="text-2xl font-bold text-[#1F2848] mb-6">Register Your Profile</h2>
            <form name="candidate-register" method="POST" action="/thank-you" class="space-y-5" enctype="multipart/form-data">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-[#383E4F] mb-1.5">First Name *</label>
                  <input type="text" id="first-name" name="first-name" required placeholder="Jane"
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-medium text-[#383E4F] mb-1.5">Last Name *</label>
                  <input type="text" id="last-name" name="last-name" required placeholder="Smith"
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-[#383E4F] mb-1.5">Email *</label>
                <input type="email" id="email" name="email" required placeholder="jane@email.com"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-[#383E4F] mb-1.5">Phone *</label>
                <input type="tel" id="phone" name="phone" required placeholder="04XX XXX XXX"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
              </div>
              <div>
                <label for="role-type" class="block text-sm font-medium text-[#383E4F] mb-1.5">What type of roles are you looking for? *</label>
                <select id="role-type" name="role-type" required
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm bg-white focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition">
                  <option value="" disabled selected>Select a discipline</option>
                  <option>Project / Programme Management</option>
                  <option>Business Analysis</option>
                  <option>Software Development</option>
                  <option>Data & Analytics</option>
                  <option>Cloud & Infrastructure</option>
                  <option>Cyber Security</option>
                  <option>Solutions Architecture</option>
                  <option>Testing & QA</option>
                  <option>Network Administration</option>
                  <option>Other</option>
                </select>
              </div>
              <div>
                <label for="work-type" class="block text-sm font-medium text-[#383E4F] mb-1.5">Employment preference</label>
                <select id="work-type" name="work-type"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm bg-white focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition">
                  <option>Permanent</option>
                  <option>Contract</option>
                  <option>Both</option>
                </select>
              </div>
              <div>
                <label for="linkedin" class="block text-sm font-medium text-[#383E4F] mb-1.5">LinkedIn Profile</label>
                <input type="url" id="linkedin" name="linkedin" placeholder="linkedin.com/in/yourprofile"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
              </div>
              <div>
                <label for="resume" class="block text-sm font-medium text-[#383E4F] mb-1.5">Upload Resume (PDF or DOCX)</label>
                <div class="border-2 border-dashed border-gray-200 rounded-lg p-6 text-center hover:border-[#26A8FF] transition-colors">
                  <i class="fa-solid fa-cloud-arrow-up text-[#26A8FF] text-2xl mb-2"></i>
                  <p class="text-sm text-[#383E4F] mb-1">Drag and drop or</p>
                  <label for="resume" class="text-[#26A8FF] text-sm font-medium cursor-pointer hover:underline">browse files</label>
                  <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx" class="sr-only" />
                  <p class="text-xs text-gray-400 mt-1">PDF or DOCX, max 5MB</p>
                </div>
              </div>
              <button type="submit" class="w-full bg-[#26A8FF] text-white font-semibold py-4 rounded-lg hover:bg-[#0090e8] transition-colors flex items-center justify-center gap-2">
                Submit Registration <i class="fa-solid fa-arrow-right"></i>
              </button>
              <p class="text-xs text-gray-400 text-center">We'll be in touch within 2 business days.</p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
