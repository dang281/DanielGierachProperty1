---
import Layout from '../../layouts/Layout.astro';
import { resources } from '../../data/resources/index.js';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Free Resources for Brisbane Sellers",
  "description": "Free, downloadable PDF guides and checklists for Brisbane homeowners considering a sale.",
  "url": "https://danielgierach.com/resources",
  "author": { "@type": "Person", "name": "Daniel Gierach", "url": "https://danielgierach.com/about" }
};
---
<Layout
  title="Free Resources for Brisbane Sellers | Daniel Gierach"
  description="Free, downloadable PDF guides and checklists for Brisbane homeowners. Preparation, auction, settlement, building and pest, and more."
  schema={schema}
>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <!-- Hero -->
  <div style="background:linear-gradient(180deg,#dcc898 0%,#e6d9bd 100%);padding:8rem 0 3.5rem;">
    <div class="max-w-[1100px] mx-auto px-8">
      <span style="display:block;font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#6b4610;margin-bottom:1rem;">Free Resources</span>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,5vw,3.5rem);font-weight:400;font-style:italic;color:#191817;line-height:1.12;letter-spacing:-0.02em;margin-bottom:1.5rem;">
        Field Resources for Brisbane Sellers
      </h1>
      <p style="font-size:1rem;color:rgba(25,24,23,0.6);line-height:1.8;max-width:62ch;">
        Downloadable PDF guides and checklists, written for Queensland homeowners. Each one is a single-source reference you can print and work through. Free, no email required.
      </p>
    </div>
  </div>

  <!-- Resource Grid -->
  <div style="padding:3.5rem 0 5rem;background:#f2ead4;">
    <div class="max-w-[1100px] mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {resources.map(r => (
          <a href={`/resources/${r.slug}`}
            style="background:#f2ead4;border:1px solid rgba(185,130,41,0.15);border-radius:16px;padding:2rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:background 0.25s,border-color 0.25s,transform 0.3s,box-shadow 0.3s;position:relative;overflow:hidden;box-shadow:0 2px 8px rgba(107,70,16,0.07);"
            onmouseover="this.style.background='#faf3dc';this.style.borderColor='rgba(185,130,41,0.35)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(107,70,16,0.14)'"
            onmouseout="this.style.background='#f2ead4';this.style.borderColor='rgba(185,130,41,0.15)';this.style.transform='translateY(0)';this.style.boxShadow='0 2px 8px rgba(107,70,16,0.07)'"
          >
            <div style="position:absolute;top:0;left:0;right:0;height:3px;background:#b98229;border-top-left-radius:16px;border-top-right-radius:16px;"></div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding-top:0.25rem;">
              <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.16em;text-transform:uppercase;color:#b98229;display:inline-flex;align-items:center;gap:0.35rem;">
                <span style="width:5px;height:5px;border-radius:50%;background:#b98229;flex-shrink:0;"></span>
                {r.category}
              </span>
              <span style="font-size:0.6rem;color:rgba(25,24,23,0.55);letter-spacing:0.1em;text-transform:uppercase;font-weight:600;">PDF · {r.pages} pages</span>
            </div>
            <div style="flex:1;">
              <h2 style="font-family:var(--font-serif);font-size:1.2rem;font-weight:400;color:#191817;line-height:1.25;margin-bottom:0.75rem;">{r.title}</h2>
              <p style="font-size:0.82rem;color:rgba(25,24,23,0.55);line-height:1.7;">{r.description}</p>
            </div>
            <span style="font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#b98229;margin-top:auto;">Read &amp; Download &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div style="padding:4rem 0;background:#f2ead4;border-top:1px solid rgba(107,70,16,0.1);">
    <div class="max-w-[1100px] mx-auto px-8" style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:1.25rem;">
      <p style="font-family:var(--font-serif);font-size:1.4rem;font-style:italic;color:#191817;">Want a personal, property-specific plan?</p>
      <p style="font-size:0.9rem;color:rgba(25,24,23,0.55);line-height:1.75;max-width:48ch;">These resources cover the general principles. Daniel can walk through your home and give you a specific plan based on your property, your suburb, and the current buyer pool.</p>
      <a href="/get-an-appraisal" data-cta="resource_to_walkthrough" style="display:inline-flex;align-items:center;gap:0.6rem;padding:1rem 2rem;background:#b98229;color:#fff;font-family:var(--font-sans);font-size:0.72rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;border-radius:10px;"
        onmouseover="this.style.background='#a5721c'" onmouseout="this.style.background='#b98229'">
        Book a Free Appraisal
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

</article>

</Layout>
