---
import Layout from '../../layouts/Layout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import { resources, resourceBySlug } from '../../data/resources/index.js';

export function getStaticPaths() {
  return resources.map(r => ({ params: { slug: r.slug } }));
}

const { slug } = Astro.params;
const r = resourceBySlug[slug];
if (!r) return Astro.redirect('/resources');

const pdfUrl = `/downloads/${r.slug}.pdf`;

// Map resource category to insight-topics topic key for cross-linking.
const categoryTopicMap = {
  'Auction': 'auction',
  'Brisbane reference': 'overlays',
  'Buyers': 'buyer',
  'Inspections': 'inspections',
  'Investors': 'investor',
  'Life events': 'life-events',
  'Marketing': 'marketing',
  'Master checklist': 'general',
  'Pre-listing': 'presentation',
  'Pricing': 'pricing',
  'Renovations': 'renovation',
  'Settlement': 'settlement',
  'Vendor handout': 'general',
};
const relatedTopic = categoryTopicMap[r.category] || 'general';

// Up to 3 cross-link resources from the same category, excluding current.
const relatedResources = resources
  .filter((x) => x.category === r.category && x.slug !== r.slug)
  .slice(0, 3);

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": r.title,
  "description": r.description,
  "url": `https://danielgierach.com/resources/${r.slug}`,
  "author": { "@type": "Person", "name": "Daniel Gierach", "url": "https://danielgierach.com/about" },
  "publisher": { "@type": "Organization", "name": "Daniel Gierach Property", "url": "https://danielgierach.com" }
};
---
<Layout
  title={`${r.title} | Free PDF for Brisbane Sellers | Daniel Gierach`}
  description={r.description}
  schema={schema}
>

<article style="background:var(--color-surface-0);min-height:100vh;">

  <!-- Hero -->
  <div style="background:#e6d9bd;padding:8rem 0 3.5rem;">
    <div class="max-w-[860px] mx-auto px-8">
      <a href="/resources" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(25,24,23,0.6);text-decoration:none;margin-bottom:2rem;transition:color 0.2s;"
        onmouseover="this.style.color='#6b4610'" onmouseout="this.style.color='rgba(25,24,23,0.6)'">
        &larr; All Resources
      </a>
      <span style="display:block;font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#6b4610;margin-bottom:1rem;">Field Resource &middot; {r.category}</span>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,5vw,3.5rem);font-weight:400;color:#191817;line-height:1.1;letter-spacing:-0.02em;margin-bottom:1.25rem;">
        {r.title}
      </h1>
      <p style="font-family:var(--font-serif);font-style:italic;font-size:1.15rem;color:rgba(25,24,23,0.7);line-height:1.5;margin-bottom:2.5rem;">
        {r.subtitle}
      </p>

      <!-- Download CTA -->
      <a
        href={pdfUrl}
        download
        data-pdf-download={r.slug}
        style="display:inline-flex;align-items:center;gap:0.75rem;padding:1.1rem 2rem;background:#b98229;color:#fff;font-family:var(--font-sans);font-size:0.72rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;transition:background 0.2s;border-radius:8px;"
        onmouseover="this.style.background='#a87824'" onmouseout="this.style.background='#b98229'"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/>
        </svg>
        Download PDF · {r.pages} pages
      </a>
    </div>
  </div>

  <!-- Body -->
  <div style="padding:3rem 0 5rem;">
    <div class="max-w-[780px] mx-auto px-8" style="font-size:0.97rem;color:var(--color-text-secondary);line-height:1.85;display:flex;flex-direction:column;gap:2rem;">

      <!-- Intro -->
      <div style="padding:1.5rem 1.75rem;background:rgba(185,130,41,0.06);border-left:3px solid #b98229; border-radius:12px;">
        <p style="margin:0;font-size:1rem;color:var(--color-text-primary);line-height:1.75;">{r.intro}</p>
      </div>

      <!-- Sections -->
      {r.sections.map(s => (
        <section>
          <h2 style="font-family:var(--font-serif);font-size:1.6rem;font-weight:400;color:var(--color-text-primary);line-height:1.2;margin-bottom:0.75rem;">{s.heading}</h2>
          {s.body && <p style="margin-bottom:1.25rem;color:var(--color-text-secondary);line-height:1.8;">{s.body}</p>}
          {s.items && (
            <ul style="list-style:none;padding:0;margin:0;">
              {s.items.map(li => (
                <li style="position:relative;padding:0.6rem 0 0.6rem 1.75rem;border-bottom:1px dashed rgba(28,25,23,0.1);line-height:1.65;">
                  <span style="position:absolute;left:0;top:0.85rem;width:0.6rem;height:0.6rem;border:1.5px solid #b98229;border-radius:1px;"></span>
                  {li}
                </li>
              ))}
            </ul>
          )}
          {s.table && (
            <div style="overflow-x:auto;margin-top:1.25rem;">
              <table style="width:100%;border-collapse:collapse;font-size:0.78rem;">
                <thead>
                  <tr>
                    {s.table.headers.map(h => (
                      <th style="background:#e6d9bd;color:#191817;padding:0.6rem 0.5rem;text-align:left;font-weight:600;font-size:0.65rem;letter-spacing:0.06em;text-transform:uppercase;">{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {Array.from({ length: s.table.rows }).map(() => (
                    <tr>
                      {s.table.headers.map(() => (
                        <td style="border:1px solid rgba(28,25,23,0.18);padding:1.25rem 0.5rem;">&nbsp;</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>
      ))}

      {r.footerNote && (
        <div style="margin-top:1rem;padding:1.75rem 2rem;background:#e6d9bd;color:#191817;">
          <p style="margin:0;font-family:var(--font-serif);font-style:italic;font-size:1.1rem;line-height:1.55;">{r.footerNote}</p>
        </div>
      )}

      <!-- Repeat download CTA -->
      <div style="margin-top:1rem;padding:2rem;background:#f7f5f0;border:1px solid rgba(28,25,23,0.08);text-align:center;">
        <p style="font-family:var(--font-serif);font-size:1.15rem;font-style:italic;color:#191817;margin-bottom:1rem;">Take this with you.</p>
        <a
          href={pdfUrl}
          download
          data-pdf-download={r.slug}
          style="display:inline-flex;align-items:center;gap:0.75rem;padding:1rem 1.75rem;background:#b98229;color:#fff;font-family:var(--font-sans);font-size:0.7rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;text-decoration:none;border-radius:8px;"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/>
          </svg>
          Download as PDF
        </a>
      </div>

      <!-- Appraisal CTA -->
      <div style="padding:2rem;border-left:3px solid #b98229;background:rgba(185,130,41,0.04); border-radius:12px;">
        <p style="font-family:var(--font-serif);font-size:1.05rem;color:#191817;margin-bottom:0.5rem;"><strong style="color:#b98229;">Want a personal walkthrough?</strong></p>
        <p style="font-size:0.92rem;line-height:1.7;color:#78716c;margin-bottom:1rem;">Daniel can visit your property and give you a tailored plan based on your suburb, your buyer pool, and the current market.</p>
        <a href="/get-an-appraisal" data-cta="resource_to_walkthrough" style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.7rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#b98229;text-decoration:none;border-bottom:2px solid #b98229;padding-bottom:2px;">
          Book a Free Appraisal &rarr;
        </a>
      </div>

      {relatedResources.length > 0 && (
        <div style="margin-top:1.5rem;padding-top:2rem;border-top:1px solid rgba(28,25,23,0.08);">
          <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:#b98229;margin-bottom:0.85rem;">Related resources</p>
          <p style="font-size:0.92rem;color:#78716c;line-height:1.65;margin-bottom:1.25rem;">Other Brisbane field guides in the {r.category.toLowerCase()} category.</p>
          <ul style="list-style:none;padding:0;margin:0;display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem;">
            {relatedResources.map((rr) => (
              <li>
                <a href={`/resources/${rr.slug}`} style="display:flex;flex-direction:column;gap:0.4rem;padding:1rem 1.1rem;background:#f7f5f0;border:1px solid rgba(28,25,23,0.08);text-decoration:none;color:#191817;transition:border-color 0.2s;"
                  onmouseover="this.style.borderColor='#b98229'" onmouseout="this.style.borderColor='rgba(28,25,23,0.08)'">
                  <span style="font-family:var(--font-sans);font-size:0.55rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#b98229;">{rr.category}</span>
                  <span style="font-family:var(--font-serif);font-size:0.95rem;line-height:1.35;">{rr.title}</span>
                  <span style="font-family:var(--font-sans);font-size:0.7rem;color:#b98229;margin-top:auto;">Open guide &rarr;</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

    </div>
  </div>

</article>

<RelatedContent currentSlug={r.slug} category={r.category} topic={relatedTopic} />

<!-- Fire Meta Pixel Lead event on PDF download -->
<script is:inline>
  document.addEventListener('click', function(e) {
    const link = e.target.closest('[data-pdf-download]');
    if (!link) return;
    const slug = link.getAttribute('data-pdf-download');
    if (typeof fbq === 'function') {
      fbq('track', 'Lead', { content_name: slug, content_category: 'pdf_download' });
    }
    if (typeof gtag === 'function') {
      gtag('event', 'pdf_download', { content_name: slug });
    }
  });
</script>

</Layout>
