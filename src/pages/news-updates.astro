---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';

const articles = [
  { title: 'The Soft Skills That Actually Get You Promoted at Work', date: 'April 13, 2025', category: 'Career' },
  { title: 'Survive (and Thrive) in Your First 90 Days at Your New Job', date: 'April 6, 2025', category: 'Career' },
  { title: 'Can Virtual Reality Transform Technical Interviews?', date: 'March 30, 2025', category: 'Technology' },
  { title: 'The Key to Retaining IT Talent in 2025: Why Upskilling Matters', date: 'March 23, 2025', category: 'Hiring' },
  { title: 'Is Freelance IT Talent the Future?', date: 'March 16, 2025', category: 'Industry' },
  { title: 'The Cost of a Bad Hire in Tech: Why Rushing Recruitment Can Cost Millions', date: 'March 9, 2025', category: 'Hiring' },
  { title: 'Tech Nostalgia: The Software We Loved (and Loved to Hate)', date: 'March 2, 2025', category: 'Culture' },
  { title: 'Is Remote Work Still Relevant? A Look at Hybrid Hiring in IT', date: 'February 16, 2025', category: 'Industry' },
  { title: 'What Does Your Desk Snack Say About Your IT Job Role?', date: 'February 9, 2025', category: 'Culture' },
  { title: "IT Recruitment Bingo: Signs You've Found the Perfect Candidate", date: 'February 2, 2025', category: 'Hiring' },
  { title: 'What Your Zodiac Sign Says About Your Tech Career Path', date: 'February 2, 2025', category: 'Culture' },
  { title: "Contractors vs. Full-Time: What's the Best Fit for Your IT Team?", date: 'January 26, 2025', category: 'Hiring' },
];

const categoryColors: Record<string, string> = {
  Career: 'bg-blue-50 text-blue-600',
  Technology: 'bg-purple-50 text-purple-600',
  Hiring: 'bg-[#E5F3FA] text-[#26A8FF]',
  Industry: 'bg-teal-50 text-teal-600',
  Culture: 'bg-orange-50 text-orange-600',
};
---

<Layout title="Articles & Updates | Cirqle Group" description="IT recruitment insights, tech industry trends, and career advice from Cirqle Group.">
  <Navbar />
  <PageHero
    badge="Insights"
    title="Articles &"
    titleHighlight="Updates"
    subtitle="IT recruitment insights, technology trends, and career advice from the Cirqle Group team."
  />

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map(article => (
          <article class="group bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 flex flex-col">
            <!-- Placeholder image area -->
            <div class="h-44 bg-gradient-to-br from-[#E5F3FA] to-[#1F2848]/10 flex items-center justify-center">
              <i class="fa-solid fa-newspaper text-[#26A8FF]/30 text-5xl"></i>
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center gap-3 mb-3">
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${categoryColors[article.category] ?? 'bg-gray-100 text-gray-600'}`}>
                  {article.category}
                </span>
                <span class="text-gray-400 text-xs">{article.date}</span>
              </div>
              <h3 class="font-bold text-[#1F2848] leading-snug mb-4 flex-grow group-hover:text-[#26A8FF] transition-colors">
                {article.title}
              </h3>
              <div class="inline-flex items-center gap-1.5 text-[#26A8FF] text-sm font-medium group-hover:gap-2.5 transition-all">
                Read Article <i class="fa-solid fa-arrow-right text-xs"></i>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Podcast CTA -->
  <section class="py-16 bg-[#E5F3FA]">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <i class="fa-solid fa-podcast text-[#26A8FF] text-3xl mb-4"></i>
      <h2 class="text-2xl font-bold text-[#1F2848] mb-3">Also Check Out Chasing Good</h2>
      <p class="text-[#383E4F] mb-6">Our podcast featuring inspiring conversations with social entrepreneurs and purpose-driven leaders.</p>
      <a href="/chasing-good/" class="btn-primary">Listen to the Podcast <i class="fa-solid fa-arrow-right"></i></a>
    </div>
  </section>

  <Footer />
</Layout>
