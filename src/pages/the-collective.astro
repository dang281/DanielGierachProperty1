---
import Layout from '../layouts/Layout.astro';

const offices = [
  { name: 'Ray White Bulimba',        phone: '(07) 3254 1022', tel: '+61732541022' },
  { name: 'Ray White New Farm',       phone: '(07) 3254 1022', tel: '+61732541022' },
  { name: 'Ray White Toowong',        phone: '(07) 3741 4922', tel: '+61737414922' },
  { name: 'Ray White Living Here',    phone: '(07) 3606 8300', tel: '+61736068300' },
  { name: 'Ray White Clayfield',      phone: '(07) 3124 9891', tel: '+61731249891', principal: 'Kim Olsen Property' },
  { name: 'Ray White Woody Point',    phone: '(07) 3283 2277', tel: '+61732832277' },
];

const stats = [
  { value: '6',        label: 'Offices across Brisbane' },
  { value: '100+',     label: 'Agents in the network' },
  { value: '550,000+', label: 'Registered buyers in the database' },
  { value: '20%',      label: 'More buyer enquiries per campaign' },
];

const results = [
  { value: '$1.5B+', label: 'Total sales' },
  { value: '1,025',  label: 'Properties sold' },
  { value: '30,000+', label: 'Open home attendees' },
  { value: '#1',     label: 'Ray White group internationally' },
];

const reasons = [
  {
    title: '1 in 3 sales come from collaboration.',
    body: 'One in every three Collective sales is generated by agents working together across offices. Not from a single agent\'s contact list, but from a listing being actively shopped across the group before and during the campaign.',
  },
  {
    title: '20% more buyer enquiries.',
    body: 'A listing loaded into the Collective network attracts, on average, 20% more qualified enquiries than a comparable single-office campaign. More qualified enquiries means more genuine competition when the offers come in.',
  },
  {
    title: 'A 550,000+ buyer database.',
    body: 'Every registered buyer at every office sees your listing. Your first inspection surfaces buyers you would never have reached from a single suburb, including buyers already looking in adjacent Ray White pockets across Brisbane.',
  },
  {
    title: 'Group scale. Personal service.',
    body: 'Ray White is Australia\'s largest network, and the Collective is its #1 group internationally. You still have one agent, one strategy, one point of contact. The network sits behind them.',
  },
];
---

<Layout
  title="Ray White Collective | Six Offices, 550,000+ Buyers | Daniel Gierach"
  description="Ray White Collective is a network of six Ray White offices and over 100 agents across Brisbane, sharing a 550,000+ buyer database. What the group means for a vendor selling with Daniel Gierach."
>

<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Ray White Collective | Six Offices, 550,000+ Buyers",
  "description": "Ray White Collective is a network of six Ray White offices and over 100 agents across Brisbane. Daniel Gierach explains what the group means for a vendor.",
  "url": "https://danielgierach.com/the-collective",
  "author": { "@id": "https://danielgierach.com/#person" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://danielgierach.com" },
      { "@type": "ListItem", "position": 2, "name": "The Collective", "item": "https://danielgierach.com/the-collective" }
    ]
  }
})}</script>

<!-- ════════════════════════════════════════════
     HERO
════════════════════════════════════════════ -->
<section class="hero-section" style="background:#0a0806; color:#f0ece4; padding:120px 24px 90px;">
  <div style="max-width:920px; margin:0 auto; text-align:center;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1.25rem;">Ray White · The Collective</p>
    <h1 style="font-family:var(--font-serif); font-size:clamp(2.4rem, 5.2vw, 4.4rem); font-weight:300; line-height:1.1; letter-spacing:-0.015em; color:#f0ece4; margin-bottom:1.5rem;">
      The advantages of a big group. With personalised service.
    </h1>
    <div class="rank-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l2.9 6.9 7.1.6-5.4 4.7 1.7 7L12 17.8 5.7 21.2l1.7-7L2 9.5l7.1-.6L12 2z"/>
      </svg>
      #1 Ray White Group Internationally
    </div>
    <p style="font-family:var(--font-sans); font-size:1.05rem; font-weight:300; line-height:1.75; color:rgba(240,236,228,0.7); max-width:640px; margin:0 auto;">
      Ray White Collective is a network of over 100 agents across six Brisbane offices, sharing a database of 550,000+ registered buyers. Every listing benefits from the reach of the entire group, while you keep a single dedicated agent from start to finish.
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════════
     STATS BAND
════════════════════════════════════════════ -->
<section style="background:#1c1917; padding:60px 24px; border-top:1px solid rgba(240,236,228,0.06);">
  <div style="max-width:1200px; margin:0 auto;">
    <div class="stats-grid">
      {stats.map(s => (
        <div class="stat">
          <div class="stat-value">{s.value}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     WHAT IT IS
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-0); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:820px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem;">What Is The Collective</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.9rem, 3.6vw, 2.8rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:1.75rem;">One listing. Six offices worth of buyers.</h2>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.85; color:#4a4540; margin-bottom:1.25rem;">
      Each Collective office runs its own team, its own campaigns, and its own suburbs. What sits underneath them is shared infrastructure: one buyer database, one CRM, one auction team, and one marketing platform.
    </p>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.85; color:#4a4540;">
      For a vendor, the practical effect is straightforward. The moment your property is loaded into the system, it is visible to every registered buyer at Bulimba, New Farm, Toowong, Clayfield, Living Here and Woody Point. Not just the pool at whichever office you signed with. And you still have a single dedicated agent, running your strategy, communicating with you, and accountable for the result.
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════════
     THE SIX OFFICES
════════════════════════════════════════════ -->
<section style="background:var(--color-base); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:1200px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem; text-align:center;">The Offices</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.7rem, 3vw, 2.4rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:2rem; text-align:center;">Six offices. Brisbane to Redcliffe.</h2>

    <div class="map-wrap">
      <svg viewBox="0 0 540 480" class="offices-map" role="img" aria-labelledby="collective-map-title collective-map-desc">
        <title id="collective-map-title">Ray White Collective office locations</title>
        <desc id="collective-map-desc">Editorial map showing six Ray White Collective offices from Woody Point in the north down to Toowong in the south west, with Clayfield, Living Here, Bulimba and New Farm in between.</desc>

        <!-- Cardinal / context labels -->
        <text x="270" y="24" text-anchor="middle" class="map-cardinal">Redcliffe Peninsula</text>
        <text x="270" y="465" text-anchor="middle" class="map-cardinal">Brisbane CBD &amp; Inner East</text>

        <!-- Compass N -->
        <g transform="translate(30, 40)">
          <line x1="0" y1="14" x2="0" y2="-8" stroke="#c4912a" stroke-width="1.2" opacity="0.55" />
          <polygon points="0,-12 -4,-4 4,-4" fill="#c4912a" opacity="0.55" />
          <text x="0" y="26" text-anchor="middle" class="map-compass">N</text>
        </g>

        <!-- Moreton Bay arc (top-right hint) -->
        <path d="M 490 45 Q 530 120 510 210" fill="none" stroke="#c4912a" stroke-width="1" opacity="0.16" />
        <text x="512" y="140" text-anchor="end" class="map-river">Moreton Bay</text>

        <!-- Brisbane River sweep (west to east through inner suburbs) -->
        <path d="M 20 415 Q 130 405 210 388 Q 285 373 340 356 Q 405 335 470 300 Q 510 280 530 260"
              fill="none" stroke="#c4912a" stroke-width="1.5" stroke-linecap="round" opacity="0.2" />
        <text x="150" y="420" class="map-river">Brisbane River</text>

        <!-- Subtle "25km" hint on the long north-south stretch -->
        <text x="430" y="150" text-anchor="middle" class="map-distance">~25km</text>
        <line x1="430" y1="90" x2="430" y2="130" stroke="#c4912a" stroke-width="0.8" opacity="0.35" stroke-dasharray="2,3" />
        <line x1="430" y1="160" x2="430" y2="200" stroke="#c4912a" stroke-width="0.8" opacity="0.35" stroke-dasharray="2,3" />

        <!-- CBD marker -->
        <g transform="translate(160, 350)">
          <rect x="-4" y="-4" width="8" height="8" fill="none" stroke="#c4912a" stroke-width="1" opacity="0.5" />
          <text x="12" y="4" class="map-landmark">Brisbane CBD</text>
        </g>

        <!-- Office pins -->

        <!-- Woody Point (top right) -->
        <g class="office-pin">
          <circle cx="450" cy="70" r="7" />
          <text x="450" y="94" text-anchor="middle">Woody Point</text>
        </g>

        <!-- Clayfield (upper mid) -->
        <g class="office-pin">
          <circle cx="320" cy="230" r="7" />
          <text x="334" y="234" text-anchor="start">Clayfield</text>
        </g>

        <!-- Living Here (mid-left) -->
        <g class="office-pin">
          <circle cx="220" cy="315" r="7" />
          <text x="206" y="319" text-anchor="end">Living Here</text>
        </g>

        <!-- Bulimba (mid-right) -->
        <g class="office-pin">
          <circle cx="365" cy="335" r="7" />
          <text x="379" y="339" text-anchor="start">Bulimba</text>
        </g>

        <!-- New Farm (lower mid) -->
        <g class="office-pin">
          <circle cx="255" cy="380" r="7" />
          <text x="241" y="384" text-anchor="end">New Farm</text>
        </g>

        <!-- Toowong (bottom left) -->
        <g class="office-pin">
          <circle cx="80" cy="425" r="7" />
          <text x="94" y="429" text-anchor="start">Toowong</text>
        </g>
      </svg>
      <p class="map-note">Approximate positions, not to scale.</p>
    </div>

    <div class="offices-grid">
      {offices.map(o => (
        <div class={`office-card ${o.note ? 'is-featured' : ''}`}>
          <p class="office-name">{o.name}</p>
          {o.principal && <p class="office-principal">{o.principal}</p>}
          <a href={`tel:${o.tel}`} class="office-phone">{o.phone}</a>
          {o.note && <p class="office-note">{o.note}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     WHY IT MATTERS
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-0); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:1200px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem;">Why It Matters</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.9rem, 3.6vw, 2.8rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:3rem; max-width:640px;">What the group actually does for your sale.</h2>

    <div class="reasons-grid">
      {reasons.map((r, i) => (
        <div class="reason-card">
          <div class="reason-num">{String(i + 1).padStart(2, '0')}</div>
          <p class="reason-title">{r.title}</p>
          <p class="reason-body">{r.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     2024 / 2025 RESULTS
════════════════════════════════════════════ -->
<section style="background:var(--color-base); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:1200px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem;">2024 / 2025 Results</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.7rem, 3vw, 2.4rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:2.5rem; max-width:640px;">What the Collective delivered last financial year.</h2>

    <div class="results-grid">
      {results.map(r => (
        <div class="result-card">
          <div class="result-value">{r.value}</div>
          <div class="result-label">{r.label}</div>
        </div>
      ))}
    </div>

    <p style="font-family:var(--font-sans); font-size:0.7rem; color:#78716c; margin-top:1.75rem; letter-spacing:0.02em;">
      Source: Ray White Collective, 2024/2025 group figures.
    </p>
  </div>
</section>

<style>
  /* Rank badge (under hero H1) */
  .rank-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    margin: 0 auto 1.75rem;
    background: rgba(196, 145, 42, 0.14);
    border: 1px solid rgba(196, 145, 42, 0.4);
    border-radius: 999px;
    color: #d4a23a;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .rank-badge svg { flex-shrink: 0; }

  /* Stats band */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .stat {
    text-align: center;
    padding: 0.5rem 0;
    border-left: 1px solid rgba(240,236,228,0.08);
  }
  .stat:first-child { border-left: none; }
  .stat-value {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: #c4912a;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .stat-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    color: rgba(240,236,228,0.6);
    line-height: 1.5;
    letter-spacing: 0.03em;
  }

  /* Map */
  .map-wrap {
    max-width: 560px;
    margin: 0 auto 3rem;
    padding: 1.5rem 1rem 0.5rem;
    background: var(--color-surface-0);
    border: 1px solid rgba(28,25,23,0.1);
    border-radius: 12px;
  }
  .offices-map {
    display: block;
    width: 100%;
    height: auto;
  }
  .offices-map .map-cardinal {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    fill: #c4912a;
  }
  .offices-map .map-river {
    font-family: var(--font-serif);
    font-size: 11px;
    font-style: italic;
    fill: #a8a29e;
    opacity: 0.7;
  }
  .offices-map .map-compass {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    fill: #c4912a;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }
  .offices-map .map-distance {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    fill: #a8a29e;
    letter-spacing: 0.08em;
  }
  .offices-map .map-landmark {
    font-family: var(--font-sans);
    font-size: 10px;
    font-style: italic;
    fill: #a8a29e;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }
  .offices-map .office-pin circle {
    fill: #c4912a;
    stroke: #0a0806;
    stroke-width: 2;
    transition: r 0.2s, fill 0.2s;
  }
  .offices-map .office-pin text {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    fill: #1c1917;
    letter-spacing: 0.01em;
  }
  .offices-map .office-pin:hover circle { r: 9; fill: #d4a23a; }
  .map-note {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    color: #a8a29e;
    letter-spacing: 0.06em;
    margin-top: 0.75rem;
  }

  /* Office cards */
  .offices-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(28,25,23,0.1);
    border: 1px solid rgba(28,25,23,0.1);
  }
  .office-card {
    background: var(--color-surface-0);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-height: 180px;
  }
  .office-card.is-featured {
    background: #fbf7ee;
    border-left: 3px solid #c4912a;
    padding-left: calc(1.75rem - 3px);
  }
  .office-name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: #1c1917;
    line-height: 1.3;
    margin: 0;
  }
  .office-principal {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: #78716c;
    margin: 0;
  }
  .office-phone {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    color: #c4912a;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: color 0.2s;
  }
  .office-phone:hover { color: #d4a23a; }
  .office-note {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    color: #c4912a;
    margin-top: auto;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* Reason cards */
  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(28,25,23,0.1);
    border: 1px solid rgba(28,25,23,0.1);
  }
  .reason-card {
    background: var(--color-surface-0);
    padding: 2.5rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .reason-num {
    font-family: var(--font-serif);
    font-size: 0.75rem;
    font-weight: 400;
    color: #c4912a;
    letter-spacing: 0.15em;
  }
  .reason-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    color: #1c1917;
    line-height: 1.35;
    margin: 0;
  }
  .reason-body {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 300;
    color: #4a4540;
    line-height: 1.8;
    margin: 0;
  }

  /* Results grid */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(28,25,23,0.1);
    border: 1px solid rgba(28,25,23,0.1);
  }
  .result-card {
    background: var(--color-surface-0);
    padding: 2rem 1.75rem;
    text-align: left;
  }
  .result-value {
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    font-weight: 300;
    color: #1c1917;
    line-height: 1;
    margin-bottom: 0.65rem;
    letter-spacing: -0.01em;
  }
  .result-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    color: #78716c;
    line-height: 1.45;
  }

  @media (max-width: 768px) {
    .hero-section { padding: 72px 20px 56px !important; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem 1rem; }
    .stat { border-left: none; }
    .stat-value { font-size: 1.9rem; }
    .offices-grid { grid-template-columns: 1fr; }
    .office-card { min-height: auto; padding: 1.5rem 1.4rem; }
    .reasons-grid { grid-template-columns: 1fr; }
    .reason-card { padding: 2rem 1.5rem; }
    .results-grid { grid-template-columns: repeat(2, 1fr); }
    .result-card { padding: 1.5rem 1.25rem; }
    .result-value { font-size: 1.55rem; }
    .rank-badge {
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      padding: 0.45rem 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .rank-badge {
      font-size: 0.56rem;
      letter-spacing: 0.12em;
      padding: 0.4rem 0.75rem;
    }
  }
</style>

</Layout>
