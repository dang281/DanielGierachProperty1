---
import Layout from '../layouts/Layout.astro';
import PageTOC from '../components/PageTOC.astro';

const offices = [
  { name: 'Ray White Bulimba',        phone: '(07) 3254 1022', tel: '+61732541022' },
  { name: 'Ray White New Farm',       phone: '(07) 3254 1022', tel: '+61732541022' },
  { name: 'Ray White Toowong',        phone: '(07) 3741 4922', tel: '+61737414922' },
  { name: 'Ray White Living Here',    phone: '(07) 3606 8300', tel: '+61736068300' },
  { name: 'Ray White Clayfield',      phone: '(07) 3124 9891', tel: '+61731249891' },
  { name: 'Ray White Woody Point',    phone: '(07) 3283 2277', tel: '+61732832277' },
];

const stats = [
  { value: '6',        label: 'Offices across Brisbane' },
  { value: '100+',     label: 'Agents in the network' },
  { value: '608,000+', label: 'Registered buyers in the database' },
  { value: '20%',      label: 'More buyer enquiries per campaign' },
];

const results = [
  { value: '$1.5B+', label: 'Total sales' },
  { value: '1,025',  label: 'Properties sold' },
  { value: '30,000+', label: 'Open home attendees' },
  { value: '#1',     label: 'Ray White group internationally' },
];

// ⚠️ VERIFY: Matt Lancashire external link is his Ray White New Farm
// agent page. Confirm title wording ("Principal & co-partner") with Daniel.
const leaders = [
  {
    name: 'Haesley Cush',
    role: 'CEO · Ray White Collective',
    photo: '/img/haesley-cush-headshot.jpg',
    href: '/team/haesley-cush',
    external: false,
  },
  {
    name: 'Matt Lancashire',
    role: 'Principal · Co-partner',
    photo: 'https://cdn6.ep.dynamics.net/s3/rw-media/memberphotos/e6c7f75c-1f0e-4c7f-9085-cf2c52dcfdd0.jpg?maxwidth=1280',
    href: 'https://rwnf.com.au/agents/matt-lancashire/16194',
    external: true,
  },
  {
    name: 'Peter Burgin',
    role: 'Head of Performance · Chief Auctioneer',
    photo: '/img/peter-burgin-headshot.jpg',
    href: '/team/peter-burgin',
    external: false,
  },
];

const reasons = [
  {
    title: '1 in 3 sales come from collaboration.',
    body: 'One in every three Collective sales is generated by agents working together across offices. Not from a single agent\'s contact list, but from a listing being actively shopped across the group before and during the campaign.',
  },
  {
    title: '20% more buyer enquiries.',
    body: 'A listing loaded into the Collective network attracts, on average, 20% more qualified enquiries than a comparable single-office campaign. More qualified enquiries means more genuine competition when the offers come in.',
  },
  {
    title: 'A 608,000+ buyer database.',
    body: 'Every registered buyer at every office sees your listing. Your first inspection surfaces buyers you would never have reached from a single suburb, including buyers already looking in adjacent Ray White pockets across Brisbane.',
  },
  {
    title: 'Group scale. Personal service.',
    body: 'Ray White is Australia\'s largest network, and the Collective is its #1 group internationally. You still have one agent, one strategy, one point of contact. The network sits behind them.',
  },
];
---

<!-- GieMann palette retint (surfaces, gold, ink, header, sticky bar) -->

<Layout
  title="Ray White Collective | Six Offices, 608,000+ Buyers | Daniel Gierach"
  description="Ray White Collective is a network of six Ray White offices and 100+ agents across Brisbane, sharing a 608,000+ buyer database. What the group means for a vendor selling with Daniel Gierach."
  hideFooterCta={true}
>

<PageTOC />

<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Ray White Collective | Six Offices, 608,000+ Buyers",
  "description": "Ray White Collective is a network of six Ray White offices and 100+ agents across Brisbane. Daniel Gierach explains what the group means for a vendor.",
  "url": "https://danielgierach.com/the-collective",
  "author": { "@id": "https://danielgierach.com/#person" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://danielgierach.com" },
      { "@type": "ListItem", "position": 2, "name": "The Collective", "item": "https://danielgierach.com/the-collective" }
    ]
  }
})}</script>

<!-- ════════════════════════════════════════════
     HERO · editorial cream with restrained gold glow anchor
════════════════════════════════════════════ -->
<section class="hero-section">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-inner">
    <p class="brand-eyebrow">Ray White · The Collective</p>
    <h1 class="hero-title">
      The advantages of a big group.<br />
      <em>With personalised service.</em>
    </h1>
    <div class="hero-divider" aria-hidden="true">
      <span class="hero-divider-line"></span>
      <span class="hero-divider-mark">✦</span>
      <span class="hero-divider-line"></span>
    </div>
    <p class="hero-lede">
      A network of 100+ agents across six Brisbane offices, sharing a database of 608,000+ registered buyers. Every listing benefits from the reach of the entire group, while you keep a single dedicated agent from start to finish.
    </p>
    <div class="rank-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l2.9 6.9 7.1.6-5.4 4.7 1.7 7L12 17.8 5.7 21.2l1.7-7L2 9.5l7.1-.6L12 2z"/>
      </svg>
      #1 Ray White Group Internationally
    </div>
  </div>
</section>

<!-- Ornamental section divider between Hero and What Is -->
<div class="ornament" aria-hidden="true">
  <span class="ornament-line"></span>
  <span class="ornament-mark">✦</span>
  <span class="ornament-line"></span>
</div>

<!-- ════════════════════════════════════════════
     WHAT IT IS · editorial definition, tighter column
════════════════════════════════════════════ -->
<section class="section-block">
  <div class="wrap-md">
    <p class="eyebrow">What Is The Collective</p>
    <h2 class="section-title">One listing.<br />Six offices worth of buyers.</h2>
    <p class="section-lede">
      Each Collective office runs its own team, its own campaigns, and its own suburbs. What sits underneath them is shared infrastructure: <em>one buyer database, one CRM, one auction team, and one marketing platform.</em>
    </p>
    <p class="section-body">
      For a vendor, the practical effect is straightforward. The moment your property is loaded into the system, it is visible to every registered buyer at Bulimba, New Farm, Toowong, Clayfield, Living Here and Woody Point. Not just the pool at whichever office you signed with. And you still have a single dedicated agent, running your strategy, communicating with you, and accountable for the result.
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════════
     COMPARISON · Single office vs The Collective
════════════════════════════════════════════ -->
<section class="section-block section-band">
  <div class="wrap-lg">
    <p class="eyebrow eyebrow-center">The Difference</p>
    <h2 class="section-title section-title-center">Single office vs six offices.</h2>
    <p class="section-sub section-sub-center">
      Same listing. Two very different reach profiles.
    </p>

    <div class="compare-grid">
      <div class="compare-col compare-col-single">
        <p class="compare-header">Traditional single office</p>
        <ul class="compare-list">
          <li>
            <span class="compare-cross" aria-hidden="true">×</span>
            <span><strong>~50,000</strong> buyers in one local database</span>
          </li>
          <li>
            <span class="compare-cross" aria-hidden="true">×</span>
            <span><strong>15 to 25 agents</strong> on the ground promoting your listing</span>
          </li>
          <li>
            <span class="compare-cross" aria-hidden="true">×</span>
            <span>No cross-office collaboration on offers</span>
          </li>
          <li>
            <span class="compare-cross" aria-hidden="true">×</span>
            <span>Single-office marketing budget and platform</span>
          </li>
          <li>
            <span class="compare-cross" aria-hidden="true">×</span>
            <span>Local auctioneer only</span>
          </li>
        </ul>
      </div>

      <div class="compare-divider" aria-hidden="true"></div>

      <div class="compare-col compare-col-collective">
        <p class="compare-header compare-header-gold">Ray White Collective</p>
        <ul class="compare-list">
          <li>
            <span class="compare-tick" aria-hidden="true">✓</span>
            <span><strong>608,000+</strong> registered buyers across six offices</span>
          </li>
          <li>
            <span class="compare-tick" aria-hidden="true">✓</span>
            <span><strong>100+ agents</strong> shopping your listing pre- and mid-campaign</span>
          </li>
          <li>
            <span class="compare-tick" aria-hidden="true">✓</span>
            <span><strong>1 in 3</strong> Collective sales come from cross-office collaboration</span>
          </li>
          <li>
            <span class="compare-tick" aria-hidden="true">✓</span>
            <span>Shared group marketing platform and campaign infrastructure</span>
          </li>
          <li>
            <span class="compare-tick" aria-hidden="true">✓</span>
            <span>Chief auctioneer + specialist auction team</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     STATS · massive display numbers on cream tile
════════════════════════════════════════════ -->
<section class="stats-section">
  <div class="wrap-lg">
    <p class="eyebrow eyebrow-center">The Network In Numbers</p>
    <div class="stats-grid">
      {stats.map((s, i) => (
        <div class="stat">
          <div class="stat-value">{s.value}</div>
          <div class="stat-rule" aria-hidden="true"></div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     WHY IT MATTERS · the four reasons, editorial cards
════════════════════════════════════════════ -->
<section class="section-block">
  <div class="wrap-lg">
    <p class="eyebrow">Why It Matters</p>
    <h2 class="section-title" style="max-width:640px;">What the group actually does for your sale.</h2>

    <div class="reasons-grid">
      {reasons.map((r, i) => (
        <article class="reason-card">
          <div class="reason-num">{String(i + 1).padStart(2, '0')}</div>
          <h3 class="reason-title">{r.title}</h3>
          <p class="reason-body">{r.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     RESULTS · recent proof closes the case
════════════════════════════════════════════ -->
<section class="section-block section-band">
  <div class="wrap-lg">
    <p class="eyebrow">2024 / 2025 Results</p>
    <h2 class="section-title" style="max-width:640px;">What the Collective delivered last financial year.</h2>

    <div class="results-grid">
      {results.map(r => (
        <div class="result-card">
          <div class="result-value">{r.value}</div>
          <div class="result-label">{r.label}</div>
        </div>
      ))}
    </div>

    <p class="source-note">
      Source: Ray White Collective, 2024/2025 group figures.
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════════
     LEADERSHIP · magazine-style portrait cards
════════════════════════════════════════════ -->
<section class="section-block">
  <div class="wrap-lg">
    <p class="eyebrow eyebrow-center">Leadership</p>
    <h2 class="section-title section-title-center">Who sits behind the network.</h2>
    <p class="section-sub section-sub-center">
      The people responsible for how the Collective operates as one group.
    </p>

    <div class="leaders-grid">
      {leaders.map(l => (
        <a href={l.href} class="leader-card"
          {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}
          data-cta={`the_collective_leader_${l.name.toLowerCase().replace(/ /g,'_')}`}>
          <div class="leader-photo-wrap">
            <img src={l.photo} alt={l.name} class="leader-photo" width="240" height="240" loading="lazy" />
          </div>
          <div class="leader-body">
            <p class="leader-name">{l.name}</p>
            <p class="leader-role">{l.role}</p>
            <span class="leader-cta">
              {l.external ? 'Ray White profile' : 'Read more'}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     OFFICES · network diagram + layout
════════════════════════════════════════════ -->
<section class="section-block section-band">
  <div class="wrap-lg">
    <p class="eyebrow eyebrow-center">The Offices</p>
    <h2 class="section-title section-title-center">Six offices across Brisbane.</h2>
    <p class="section-sub section-sub-center">
      Each office is independently led. The network sits underneath them.
    </p>

    <!-- Network diagram: 6 offices as connected mesh, approximating
         their real geographic spread across Brisbane -->
    <div class="network-diagram" role="img" aria-label="Six Ray White Collective offices connected as a Brisbane-wide network">
      <svg viewBox="0 0 800 380" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <radialGradient id="nodeGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#b98229" stop-opacity="0.28"/>
            <stop offset="100%" stop-color="#b98229" stop-opacity="0"/>
          </radialGradient>
          <linearGradient id="riverGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#b98229" stop-opacity="0"/>
            <stop offset="50%" stop-color="#b98229" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="#b98229" stop-opacity="0"/>
          </linearGradient>
        </defs>

        <!-- Stylised Brisbane River curve running through the diagram -->
        <path d="M 30 260 Q 220 300, 380 210 T 720 140"
              fill="none" stroke="url(#riverGrad)" stroke-width="18" stroke-linecap="round"/>
        <path d="M 30 260 Q 220 300, 380 210 T 720 140"
              fill="none" stroke="rgba(107,70,16,0.14)" stroke-width="1" stroke-dasharray="3 5"/>

        <!-- Mesh: every office connected to every other office -->
        <g stroke="rgba(185,130,41,0.28)" stroke-width="1" fill="none">
          <line x1="180" y1="130" x2="420" y2="70"/>
          <line x1="180" y1="130" x2="620" y2="60"/>
          <line x1="180" y1="130" x2="580" y2="260"/>
          <line x1="180" y1="130" x2="360" y2="290"/>
          <line x1="180" y1="130" x2="700" y2="180"/>
          <line x1="420" y1="70" x2="620" y2="60"/>
          <line x1="420" y1="70" x2="580" y2="260"/>
          <line x1="420" y1="70" x2="360" y2="290"/>
          <line x1="420" y1="70" x2="700" y2="180"/>
          <line x1="620" y1="60" x2="580" y2="260"/>
          <line x1="620" y1="60" x2="360" y2="290"/>
          <line x1="620" y1="60" x2="700" y2="180"/>
          <line x1="580" y1="260" x2="360" y2="290"/>
          <line x1="580" y1="260" x2="700" y2="180"/>
          <line x1="360" y1="290" x2="700" y2="180"/>
        </g>

        <!-- Node: Toowong (west) -->
        <g class="net-node">
          <circle cx="180" cy="130" r="30" fill="url(#nodeGlow)"/>
          <circle cx="180" cy="130" r="9" fill="#b98229" stroke="#f2ead4" stroke-width="2.5"/>
          <text x="180" y="105" text-anchor="middle" class="net-label">Toowong</text>
        </g>

        <!-- Node: Clayfield (north) -->
        <g class="net-node">
          <circle cx="420" cy="70" r="30" fill="url(#nodeGlow)"/>
          <circle cx="420" cy="70" r="9" fill="#b98229" stroke="#f2ead4" stroke-width="2.5"/>
          <text x="420" y="45" text-anchor="middle" class="net-label">Clayfield</text>
        </g>

        <!-- Node: Woody Point (far north, peninsula) -->
        <g class="net-node">
          <circle cx="620" cy="60" r="30" fill="url(#nodeGlow)"/>
          <circle cx="620" cy="60" r="9" fill="#b98229" stroke="#f2ead4" stroke-width="2.5"/>
          <text x="620" y="35" text-anchor="middle" class="net-label">Woody Point</text>
        </g>

        <!-- Node: New Farm (north-east / inner) -->
        <g class="net-node">
          <circle cx="700" cy="180" r="30" fill="url(#nodeGlow)"/>
          <circle cx="700" cy="180" r="9" fill="#b98229" stroke="#f2ead4" stroke-width="2.5"/>
          <text x="700" y="210" text-anchor="middle" class="net-label">New Farm</text>
        </g>

        <!-- Node: Bulimba (east / inner-east) -->
        <g class="net-node">
          <circle cx="580" cy="260" r="34" fill="url(#nodeGlow)"/>
          <circle cx="580" cy="260" r="10" fill="#6b4610" stroke="#f2ead4" stroke-width="2.5"/>
          <text x="580" y="292" text-anchor="middle" class="net-label net-label-bold">Bulimba</text>
        </g>

        <!-- Node: Living Here (south / south-side) -->
        <g class="net-node">
          <circle cx="360" cy="290" r="30" fill="url(#nodeGlow)"/>
          <circle cx="360" cy="290" r="9" fill="#b98229" stroke="#f2ead4" stroke-width="2.5"/>
          <text x="360" y="320" text-anchor="middle" class="net-label">Living Here</text>
        </g>

      </svg>
      <p class="network-caption">
        <span class="network-caption-badge">Bulimba</span>
        Daniel and Conrad operate from Ray White Bulimba. Your listing is broadcast across all six.
      </p>
    </div>

    <div class="offices-grid">
      {offices.map(o => (
        <div class="office-card">
          <div class="office-mark" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="office-body">
            <p class="office-name">{o.name}</p>
            <a href={`tel:${o.tel}`} class="office-phone">{o.phone}</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     RAY WHITE STORY · heritage closes
════════════════════════════════════════════ -->
<section class="section-block section-heritage">
  <div class="wrap-lg" style="max-width:1100px;">
    <p class="eyebrow">The Ray White Story</p>
    <h2 class="section-title" style="max-width:640px;">
      Four generations. <em>1902 to today.</em>
    </h2>

    <div class="white-story-grid">
      <div>
        <p class="section-body">
          Ray White is a fourth-generation family-owned and family-led business. It was established in 1902 in the small Queensland country town of Crows Nest, and has grown into Australasia's most successful real estate business, with over 1,000 offices worldwide across Australia, New Zealand, Indonesia and Hong Kong.
        </p>
        <p class="section-body">
          Ray White today spans residential, commercial and rural property, as well as marine and other specialist businesses. A group that has thrived through many periods of volatility, and one that will provide the strongest level of support to enable its customers to make the best real estate decisions.
        </p>
      </div>

      <aside class="white-story-side">
        <p class="side-eyebrow">Unparalleled Corporate Support</p>
        <p class="side-body">
          The Ray White Group is backed by the largest corporate team of any real estate group in Australasia. The group's biggest investment is always in its people, providing industry and speciality leaders across every aspect of the business.
        </p>
        <p class="side-body" style="margin-top:0.9rem;">
          At any given time, Ray White corporate employs in excess of 300 support staff. Each region is backed by local market specialists supporting each business at every level.
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  /* ══════════════════════════════════════════════════════════════════
     LAYOUT PRIMITIVES
     ══════════════════════════════════════════════════════════════════ */
  .wrap-md { max-width: 780px; margin: 0 auto; }
  .wrap-lg { max-width: 1200px; margin: 0 auto; }

  /* ── Eyebrows ───────────────────────────────────────────────────── */
  .brand-eyebrow,
  .eyebrow,
  .side-eyebrow {
    font-family: var(--font-serif);
    font-variant-caps: all-small-caps;
    font-weight: 400;
    font-size: 1.05rem;
    letter-spacing: 0.22em;
    color: #6b4610;
    margin: 0 0 1.25rem;
    font-variation-settings: "opsz" 14;
  }
  .brand-eyebrow { font-size: 1.15rem; margin-bottom: 1.5rem; }
  .side-eyebrow { font-size: 0.9rem; margin-bottom: 0.9rem; }
  .eyebrow-center { text-align: center; }

  /* ── Section titles ─────────────────────────────────────────────── */
  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.8vw, 3rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.022em;
    color: #191817;
    margin: 0 0 1.75rem;
    font-variation-settings: "opsz" 72;
  }
  .section-title em { font-style: italic; font-weight: 400; }
  .section-title-center { text-align: center; margin-bottom: 1.25rem; }

  /* ── Body / lede ────────────────────────────────────────────────── */
  .section-lede {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.55;
    color: #191817;
    margin: 0 0 1.75rem;
    letter-spacing: -0.005em;
    font-variation-settings: "opsz" 24;
  }
  .section-lede em {
    font-style: italic;
    color: #6b4610;
  }
  .section-body {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.75;
    color: rgba(25,24,23,0.7);
    margin: 0 0 1.25rem;
  }
  .section-body:last-child { margin-bottom: 0; }
  .section-sub {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.55;
    color: rgba(25,24,23,0.62);
    margin: 0 0 3rem;
    max-width: 640px;
    font-variation-settings: "opsz" 24;
  }
  .section-sub-center { text-align: center; margin-left: auto; margin-right: auto; }

  /* ══════════════════════════════════════════════════════════════════
     HERO · editorial anchor with soft gold glow behind the title
     ══════════════════════════════════════════════════════════════════ */
  .hero-section {
    position: relative;
    padding: 130px 24px 100px;
    background: #e6d9bd;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: 8%;
    left: 50%;
    transform: translateX(-50%);
    width: 780px; height: 620px;
    background: radial-gradient(ellipse at center, rgba(185,130,41,0.18) 0%, rgba(185,130,41,0.04) 45%, rgba(185,130,41,0) 70%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 940px;
    margin: 0 auto;
    text-align: center;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 5.4vw, 4.6rem);
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #191817;
    margin: 0 0 2rem;
    font-variation-settings: "opsz" 144;
  }
  .hero-title em {
    font-style: italic;
    font-weight: 300;
    color: #6b4610;
  }

  .hero-divider {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    margin: 0 auto 2rem;
