  }
  .rank-badge svg { flex-shrink: 0; color: #b98229; }

  /* ══════════════════════════════════════════════════════════════════
     SECTION BLOCKS + ORNAMENTAL DIVIDER
     ══════════════════════════════════════════════════════════════════ */
  .section-block {
    background: #e6d9bd;
    padding: 100px 24px;
    position: relative;
  }
  .section-band {
    background: #f2ead4;
    border-top: 1px solid rgba(107,70,16,0.14);
    border-bottom: 1px solid rgba(107,70,16,0.14);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.5),
      inset 0 -1px 0 rgba(255,255,255,0.35);
  }
  .section-heritage {
    background: #ddccaa;
    border-top: 1px solid rgba(107,70,16,0.16);
  }

  /* Ornamental section divider · clearly visible between same-toned bands */
  .ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    max-width: 420px;
    margin: 0 auto;
    padding: 40px 24px;
    background: #e6d9bd;
    position: relative;
    z-index: 2;
  }
  .ornament-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(107,70,16,0.55), transparent);
  }
  .ornament-mark {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: #b98229;
    line-height: 1;
  }
  /* Ornament that follows a section-block: reset its own top padding so
     it sits inside the visual whitespace rather than doubling it. */
  .section-block + .ornament,
  .hero-section + .ornament { padding-top: 0; padding-bottom: 20px; }

  /* ══════════════════════════════════════════════════════════════════
     COMPARISON · Single office vs The Collective
     ══════════════════════════════════════════════════════════════════ */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3rem;
    align-items: start;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2.5rem 2rem 2rem;
    background: #ffffff;
    border: 1px solid rgba(25,24,23,0.06);
    border-radius: 16px;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 10px 30px rgba(107,70,16,0.08);
  }
  .compare-divider {
    width: 1px;
    align-self: stretch;
    background: linear-gradient(180deg, transparent, rgba(107,70,16,0.25), transparent);
  }
  .compare-header {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 400;
    font-style: italic;
    color: rgba(25,24,23,0.55);
    margin: 0 0 1.5rem;
    line-height: 1.3;
    letter-spacing: -0.005em;
    font-variation-settings: "opsz" 20;
  }
  .compare-header-gold {
    color: #6b4610;
    font-style: normal;
    font-weight: 500;
  }
  .compare-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .compare-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.55;
    color: rgba(25,24,23,0.68);
  }
  .compare-list li strong {
    font-weight: 700;
    color: #191817;
  }
  .compare-col-collective .compare-list li strong { color: #6b4610; }
  .compare-cross,
  .compare-tick {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px; height: 22px;
    border-radius: 50%;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 700;
    line-height: 1;
    margin-top: 0.1rem;
  }
  .compare-cross {
    background: rgba(25,24,23,0.06);
    color: rgba(25,24,23,0.4);
  }
  .compare-tick {
    background: rgba(185,130,41,0.18);
    color: #6b4610;
  }

  /* ══════════════════════════════════════════════════════════════════
     NETWORK DIAGRAM · 6 offices as a Brisbane-shaped mesh
     ══════════════════════════════════════════════════════════════════ */
  .network-diagram {
    max-width: 800px;
    margin: 0 auto 3rem;
    padding: 1.5rem 1rem 1rem;
    background: rgba(255,255,255,0.4);
    border: 1px solid rgba(107,70,16,0.12);
    border-radius: 16px;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 8px 24px rgba(107,70,16,0.06);
  }
  .network-diagram svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .network-diagram .net-label {
    font-family: 'Fraunces', 'Noto Serif', Georgia, serif;
    /* SVG font-size lives in viewBox units. Bumped from 15 to 22 so
       labels still read once the 800-unit viewBox is scaled down to
       a 335px column on iPhone SE. */
    font-size: 22px;
    font-weight: 400;
    fill: #191817;
    letter-spacing: -0.005em;
  }
  .network-diagram .net-label-bold {
    font-weight: 500;
    fill: #6b4610;
  }
  .network-diagram .net-caption {
    font-family: 'Fraunces', 'Noto Serif', Georgia, serif;
    font-style: italic;
    font-size: 16px;
    fill: rgba(25,24,23,0.42);
    letter-spacing: 0.02em;
  }
  .network-caption {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 1rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 400;
    color: rgba(25,24,23,0.65);
    text-align: center;
    line-height: 1.5;
  }
  .network-caption-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.7rem;
    background: rgba(185,130,41,0.15);
    color: #6b4610;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* ══════════════════════════════════════════════════════════════════
     STATS · hero of the numbers, magazine display type
     ══════════════════════════════════════════════════════════════════ */
  .stats-section {
    background: #f2ead4;
    padding: 90px 24px;
    border-top: 1px solid rgba(107,70,16,0.12);
    border-bottom: 1px solid rgba(107,70,16,0.12);
  }
  .stats-section .eyebrow-center { margin-bottom: 3rem; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .stat {
    text-align: center;
    padding: 0 0.5rem;
  }
  .stat-value {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 5.5vw, 4.5rem);
    font-weight: 300;
    color: #6b4610;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    font-variation-settings: "opsz" 144;
  }
  .stat-rule {
    width: 32px;
    height: 1px;
    background: #b98229;
    margin: 0 auto 1rem;
  }
  .stat-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(25,24,23,0.65);
    line-height: 1.5;
    letter-spacing: 0.04em;
    max-width: 180px;
    margin: 0 auto;
  }

  /* ══════════════════════════════════════════════════════════════════
     REASONS · cards with real drop shadow, editorial layout
     ══════════════════════════════════════════════════════════════════ */
  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .reason-card {
    background: #ffffff;
    border: 1px solid rgba(25,24,23,0.06);
    border-radius: 16px;
    padding: 3rem 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 8px 24px rgba(107,70,16,0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .reason-card:hover {
    transform: translateY(-3px);
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 14px 32px rgba(107,70,16,0.14);
  }
  .reason-num {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-weight: 400;
    font-style: italic;
    color: #b98229;
    letter-spacing: 0.15em;
  }
  .reason-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: #191817;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 0;
    font-variation-settings: "opsz" 36;
  }
  .reason-body {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 400;
    color: rgba(25,24,23,0.68);
    line-height: 1.72;
    margin: 0;
  }

  /* ══════════════════════════════════════════════════════════════════
     RESULTS · display values, cleaner grid
     ══════════════════════════════════════════════════════════════════ */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  .result-card {
    background: #ffffff;
    border: 1px solid rgba(25,24,23,0.06);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: left;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 6px 18px rgba(107,70,16,0.06);
  }
  .result-value {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 300;
    color: #191817;
    line-height: 1;
    margin-bottom: 0.75rem;
    letter-spacing: -0.028em;
    font-variation-settings: "opsz" 72;
  }
  .result-label {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(25,24,23,0.62);
    line-height: 1.5;
    letter-spacing: 0.02em;
  }
  .source-note {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: rgba(25,24,23,0.5);
    margin-top: 2rem;
    letter-spacing: 0.02em;
  }

  /* ══════════════════════════════════════════════════════════════════
     LEADERSHIP · magazine-style portrait cards, larger imagery
     ══════════════════════════════════════════════════════════════════ */
  .leaders-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .leader-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid rgba(25,24,23,0.06);
    border-radius: 16px;
    text-decoration: none;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 8px 24px rgba(107,70,16,0.08);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .leader-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 16px 36px rgba(107,70,16,0.14);
  }
  .leader-photo-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.05;
    background: #ede2c5;
    overflow: hidden;
  }
  .leader-photo {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 22%;
    display: block;
    transition: transform 0.4s ease;
  }
  .leader-card:hover .leader-photo { transform: scale(1.04); }
  .leader-body {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
  }
  .leader-name {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: #191817;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0;
    font-variation-settings: "opsz" 32;
  }
  .leader-role {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.92rem;
    font-weight: 400;
    color: rgba(25,24,23,0.6);
    line-height: 1.4;
    margin: 0 0 1rem;
    font-variation-settings: "opsz" 14;
  }
  .leader-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6b4610;
    transition: gap 0.2s ease, color 0.2s ease;
    margin-top: auto;
  }
  .leader-card:hover .leader-cta {
    color: #b98229;
    gap: 0.55rem;
  }

  /* ══════════════════════════════════════════════════════════════════
     OFFICES · icon-led card layout
     ══════════════════════════════════════════════════════════════════ */
  .offices-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .office-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: #ffffff;
    border: 1px solid rgba(25,24,23,0.06);
    border-radius: 14px;
    padding: 1.75rem 1.75rem;
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 4px 14px rgba(107,70,16,0.05);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .office-card:hover {
    transform: translateY(-2px);
    border-color: rgba(185,130,41,0.4);
    box-shadow:
      0 1px 2px rgba(107,70,16,0.05),
      0 10px 22px rgba(107,70,16,0.10);
  }
  .office-mark {
    flex-shrink: 0;
    width: 38px; height: 38px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(185,130,41,0.12);
    color: #b98229;
    margin-top: 2px;
  }
  .office-body { display: flex; flex-direction: column; gap: 0.4rem; }
  .office-name {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    color: #191817;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .office-phone {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    color: #6b4610;
    text-decoration: none;
    font-variant-numeric: tabular-nums lining-nums;
    transition: color 0.2s;
  }
  .office-phone:hover { color: #b98229; }

  /* ══════════════════════════════════════════════════════════════════
     RAY WHITE STORY · heritage close, side callout
     ══════════════════════════════════════════════════════════════════ */
  .white-story-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 3.5rem;
    align-items: start;
  }
  .white-story-side {
    padding: 2rem 2rem;
    background: rgba(255,255,255,0.5);
    border: 1px solid rgba(107,70,16,0.18);
    border-radius: 16px;
    box-shadow: 0 6px 20px rgba(107,70,16,0.06);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .side-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.7;
    color: rgba(25,24,23,0.68);
    margin: 0;
  }

  /* ══════════════════════════════════════════════════════════════════
     RESPONSIVE
     ══════════════════════════════════════════════════════════════════ */
  @media (max-width: 1000px) {
    .leaders-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .results-grid { grid-template-columns: repeat(2, 1fr); }
    .offices-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 800px) {
    .white-story-grid { grid-template-columns: 1fr; gap: 2rem; }
    .white-story-side { padding: 1.5rem 1.5rem; }
    .compare-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 1.5rem;
    }
    .compare-divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(107,70,16,0.25), transparent);
    }
  }
  @media (max-width: 768px) {
    .hero-section { padding: 72px 20px 64px; }
    .hero-glow { width: 500px; height: 400px; }
    .section-block { padding: 68px 20px; }
    .stats-section { padding: 60px 20px; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 2.5rem 1rem; }
    .reasons-grid { grid-template-columns: 1fr; gap: 1rem; }
    .reason-card { padding: 2.25rem 1.75rem 1.75rem; }
    .result-card { padding: 1.75rem 1.4rem; }
    .brand-eyebrow, .eyebrow { font-size: 0.95rem; letter-spacing: 0.2em; }
    .hero-divider { max-width: 200px; margin-bottom: 1.5rem; }
    .hero-lede { font-size: 1rem; margin-bottom: 1.75rem; }
    .rank-badge {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      padding: 0.55rem 1rem;
    }
    /* Compare card: give it more of the viewport on mobile */
    .compare-grid { padding: 1.75rem 1.25rem; }
  }
  @media (max-width: 560px) {
    .leaders-grid { grid-template-columns: 1fr; }
    .offices-grid { grid-template-columns: 1fr; }
    .reason-title { font-size: 1.35rem; }
  }
  @media (max-width: 480px) {
    .hero-section { padding: 60px 18px 56px; }
    .hero-title { font-size: 1.9rem; line-height: 1.12; }
    .section-title { font-size: 1.75rem; line-height: 1.15; }
    .stat-value { font-size: 2.6rem; }
    .brand-eyebrow, .eyebrow { font-size: 0.85rem; letter-spacing: 0.18em; }
    .hero-lede { font-size: 0.95rem; }
    /* Stack stats vertically so 608,000+ has full column width */
    .stats-grid { grid-template-columns: 1fr; gap: 2.25rem; }
    .stat { padding: 0; }
    .stat-label { max-width: 100%; }
  }
  @media (max-width: 380px) {
    .hero-title { font-size: 1.7rem; }
    .section-title { font-size: 1.55rem; }
    .stat-value { font-size: 2.4rem; }
  }

  /* Fraunces stylistic set (softer g/a) + tabular figures on numeric data */
  .hero-title,
  .section-title,
  .stat-value,
  .result-value,
  .reason-title,
  .leader-name,
  .leader-role,
  .office-name {
    font-feature-settings: "ss01" 1, "calt" 1;
  }
</style>

</Layout>
