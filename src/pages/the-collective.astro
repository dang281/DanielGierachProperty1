---
import Layout from '../layouts/Layout.astro';

const offices = [
  { name: 'Ray White Bulimba',        phone: '(07) 3254 1022', tel: '+61732541022' },
  { name: 'Ray White New Farm',       phone: '(07) 3254 1022', tel: '+61732541022' },
  { name: 'Ray White Toowong',        phone: '(07) 3741 4922', tel: '+61737414922' },
  { name: 'Ray White Living Here',    phone: '(07) 3606 8300', tel: '+61736068300' },
  { name: 'Ray White Clayfield',      phone: '(07) 3124 9891', tel: '+61731249891' },
  { name: 'Ray White Woody Point',    phone: '(07) 3283 2277', tel: '+61732832277' },
];

const stats = [
  { value: '6',        label: 'Offices across Brisbane' },
  { value: '100+',     label: 'Agents in the network' },
  { value: '608,000+', label: 'Registered buyers in the database' },
  { value: '20%',      label: 'More buyer enquiries per campaign' },
];

const results = [
  { value: '$1.5B+', label: 'Total sales' },
  { value: '1,025',  label: 'Properties sold' },
  { value: '30,000+', label: 'Open home attendees' },
  { value: '#1',     label: 'Ray White group internationally' },
];

// ⚠️ VERIFY: Matt Lancashire external link is his Ray White New Farm
// agent page. Confirm title wording ("Principal & co-partner") with Daniel.
const leaders = [
  {
    name: 'Haesley Cush',
    role: 'CEO · Ray White Collective',
    photo: '/img/haesley-cush-headshot.jpg',
    href: '/team/haesley-cush',
    external: false,
  },
  {
    name: 'Matt Lancashire',
    role: 'Principal · Co-partner',
    photo: 'https://cdn6.ep.dynamics.net/s3/rw-media/memberphotos/e6c7f75c-1f0e-4c7f-9085-cf2c52dcfdd0.jpg?maxwidth=1280',
    href: 'https://rwnf.com.au/agents/matt-lancashire/16194',
    external: true,
  },
  {
    name: 'Peter Burgin',
    role: 'Head of Performance · Chief Auctioneer',
    photo: '/img/peter-burgin-headshot.jpg',
    href: '/team/peter-burgin',
    external: false,
  },
  {
    name: 'Nerida Conisbee',
    role: 'Chief Economist · Ray White Group',
    photo: 'https://www.raywhite.com/assets/volumes/images/People/_800x800_crop_center-center_82_none/Nerida-Conisbee-lifestyle-7.jpeg?mtime=1681964650',
    href: 'https://www.raywhite.com/people/chief-economist-nerida-conisbee',
    external: true,
  },
];

const reasons = [
  {
    title: '1 in 3 sales come from collaboration.',
    body: 'One in every three Collective sales is generated by agents working together across offices. Not from a single agent\'s contact list, but from a listing being actively shopped across the group before and during the campaign.',
  },
  {
    title: '20% more buyer enquiries.',
    body: 'A listing loaded into the Collective network attracts, on average, 20% more qualified enquiries than a comparable single-office campaign. More qualified enquiries means more genuine competition when the offers come in.',
  },
  {
    title: 'A 608,000+ buyer database.',
    body: 'Every registered buyer at every office sees your listing. Your first inspection surfaces buyers you would never have reached from a single suburb, including buyers already looking in adjacent Ray White pockets across Brisbane.',
  },
  {
    title: 'Group scale. Personal service.',
    body: 'Ray White is Australia\'s largest network, and the Collective is its #1 group internationally. You still have one agent, one strategy, one point of contact. The network sits behind them.',
  },
];
---

<Layout
  title="Ray White Collective | Six Offices, 608,000+ Buyers | Daniel Gierach"
  description="Ray White Collective is a network of six Ray White offices and over 150 agents across Brisbane, sharing a 608,000+ buyer database. What the group means for a vendor selling with Daniel Gierach."
  hideFooterCta={true}
>

<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Ray White Collective | Six Offices, 608,000+ Buyers",
  "description": "Ray White Collective is a network of six Ray White offices and over 150 agents across Brisbane. Daniel Gierach explains what the group means for a vendor.",
  "url": "https://danielgierach.com/the-collective",
  "author": { "@id": "https://danielgierach.com/#person" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://danielgierach.com" },
      { "@type": "ListItem", "position": 2, "name": "The Collective", "item": "https://danielgierach.com/the-collective" }
    ]
  }
})}</script>

<!-- ════════════════════════════════════════════
     HERO
════════════════════════════════════════════ -->
<section class="hero-section" style="background:#0a0806; color:#f0ece4; padding:120px 24px 90px;">
  <div style="max-width:920px; margin:0 auto; text-align:center;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1.25rem;">Ray White · The Collective</p>
    <h1 style="font-family:var(--font-serif); font-size:clamp(2.4rem, 5.2vw, 4.4rem); font-weight:300; line-height:1.1; letter-spacing:-0.015em; color:#f0ece4; margin-bottom:1.5rem;">
      The advantages of a big group. With personalised service.
    </h1>
    <div class="rank-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l2.9 6.9 7.1.6-5.4 4.7 1.7 7L12 17.8 5.7 21.2l1.7-7L2 9.5l7.1-.6L12 2z"/>
      </svg>
      #1 Ray White Group Internationally
    </div>
    <p style="font-family:var(--font-sans); font-size:1.05rem; font-weight:300; line-height:1.75; color:rgba(240,236,228,0.7); max-width:640px; margin:0 auto;">
      Ray White Collective is a network of over 150 agents across six Brisbane offices, sharing a database of 608,000+ registered buyers. Every listing benefits from the reach of the entire group, while you keep a single dedicated agent from start to finish.
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════════
     STATS BAND
════════════════════════════════════════════ -->
<section style="background:#1c1917; padding:60px 24px; border-top:1px solid rgba(240,236,228,0.06);">
  <div style="max-width:1200px; margin:0 auto;">
    <div class="stats-grid">
      {stats.map(s => (
        <div class="stat">
          <div class="stat-value">{s.value}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     WHAT IT IS
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-0); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:820px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem;">What Is The Collective</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.9rem, 3.6vw, 2.8rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:1.75rem;">One listing. Six offices worth of buyers.</h2>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.85; color:#4a4540; margin-bottom:1.25rem;">
      Each Collective office runs its own team, its own campaigns, and its own suburbs. What sits underneath them is shared infrastructure: one buyer database, one CRM, one auction team, and one marketing platform.
    </p>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.85; color:#4a4540;">
      For a vendor, the practical effect is straightforward. The moment your property is loaded into the system, it is visible to every registered buyer at Bulimba, New Farm, Toowong, Clayfield, Living Here and Woody Point. Not just the pool at whichever office you signed with. And you still have a single dedicated agent, running your strategy, communicating with you, and accountable for the result.
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════════
     THE SIX OFFICES
════════════════════════════════════════════ -->
<section style="background:var(--color-base); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:1200px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem; text-align:center;">The Offices</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.7rem, 3vw, 2.4rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:3rem; text-align:center;">Six offices across Brisbane.</h2>

    <div class="offices-grid">
      {offices.map(o => (
        <div class={`office-card ${o.note ? 'is-featured' : ''}`}>
          <p class="office-name">{o.name}</p>
          {o.principal && <p class="office-principal">{o.principal}</p>}
          <a href={`tel:${o.tel}`} class="office-phone">{o.phone}</a>
          {o.note && <p class="office-note">{o.note}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     WHY IT MATTERS
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-0); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:1200px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem;">Why It Matters</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.9rem, 3.6vw, 2.8rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:3rem; max-width:640px;">What the group actually does for your sale.</h2>

    <div class="reasons-grid">
      {reasons.map((r, i) => (
        <div class="reason-card">
          <div class="reason-num">{String(i + 1).padStart(2, '0')}</div>
          <p class="reason-title">{r.title}</p>
          <p class="reason-body">{r.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     2024 / 2025 RESULTS
════════════════════════════════════════════ -->
<section style="background:var(--color-base); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:1200px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem;">2024 / 2025 Results</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.7rem, 3vw, 2.4rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:2.5rem; max-width:640px;">What the Collective delivered last financial year.</h2>

    <div class="results-grid">
      {results.map(r => (
        <div class="result-card">
          <div class="result-value">{r.value}</div>
          <div class="result-label">{r.label}</div>
        </div>
      ))}
    </div>

    <p style="font-family:var(--font-sans); font-size:0.7rem; color:#78716c; margin-top:1.75rem; letter-spacing:0.02em;">
      Source: Ray White Collective, 2024/2025 group figures.
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════════
     THE WHITE STORY
════════════════════════════════════════════ -->
<section style="background:var(--color-surface-0); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:1100px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem;">The Ray White Story</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.9rem, 3.6vw, 2.8rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:2.5rem; max-width:640px;">
      Four generations, 1902 to today.
    </h2>

    <div class="white-story-grid">
      <div>
        <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.85; color:#4a4540; margin-bottom:1.25rem;">
          Ray White is a fourth-generation family-owned and family-led business. It was established in 1902 in the small Queensland country town of Crows Nest, and has grown into Australasia's most successful real estate business, with over 1,000 offices worldwide across Australia, New Zealand, Indonesia and Hong Kong.
        </p>
        <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.85; color:#4a4540;">
          Ray White today spans residential, commercial and rural property, as well as marine and other specialist businesses. A group that has thrived through many periods of volatility, and one that will provide the strongest level of support to enable its customers to make the best real estate decisions.
        </p>
      </div>

      <aside class="white-story-side">
        <p style="font-family:var(--font-sans); font-size:0.62rem; font-weight:800; letter-spacing:0.2em; text-transform:uppercase; color:#c4912a; margin-bottom:0.75rem;">Unparalleled Corporate Support</p>
        <p style="font-family:var(--font-sans); font-size:0.9rem; font-weight:300; line-height:1.75; color:#4a4540;">
          The Ray White Group is backed by the largest corporate team of any real estate group in Australasia. The group's biggest investment is always in its people, providing industry and speciality leaders across every aspect of the business.
        </p>
        <p style="font-family:var(--font-sans); font-size:0.9rem; font-weight:300; line-height:1.75; color:#4a4540; margin-top:0.8rem;">
          At any given time, Ray White corporate employs in excess of 300 support staff. Each region is backed by local market specialists supporting each business at every level.
        </p>
      </aside>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     LEADERSHIP
════════════════════════════════════════════ -->
<section style="background:var(--color-base); padding:80px 24px; border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:1200px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.28em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem; text-align:center;">Leadership</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.7rem, 3vw, 2.4rem); font-weight:300; line-height:1.2; color:#1c1917; margin-bottom:2.75rem; text-align:center;">Who sits behind the network.</h2>

    <div class="leaders-grid">
      {leaders.map(l => (
        <a href={l.href} class="leader-card"
          {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}
          data-cta={`the_collective_leader_${l.name.toLowerCase().replace(/ /g,'_')}`}>
          {l.photo
            ? <img src={l.photo} alt={l.name} class="leader-avatar" width="120" height="120" loading="lazy" />
            : <span class="leader-avatar leader-initials" aria-hidden="true">{l.initials}</span>
          }
          <p class="leader-name">{l.name}</p>
          <p class="leader-role">{l.role}</p>
          <span class="leader-cta">
            {l.external ? 'Ray White profile' : 'More info'}
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* Rank badge (under hero H1) */
  .rank-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    margin: 0 auto 1.75rem;
    background: rgba(196, 145, 42, 0.14);
    border: 1px solid rgba(196, 145, 42, 0.4);
    border-radius: 999px;
    color: #d4a23a;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .rank-badge svg { flex-shrink: 0; }

  /* Stats band */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .stat {
    text-align: center;
    padding: 0.5rem 0;
    border-left: 1px solid rgba(240,236,228,0.08);
  }
  .stat:first-child { border-left: none; }
  .stat-value {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: #c4912a;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .stat-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    color: rgba(240,236,228,0.6);
    line-height: 1.5;
    letter-spacing: 0.03em;
  }

  /* Leaders */
  .leaders-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 1000px) {
    .leaders-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .leader-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.5rem 1.5rem;
    background: var(--color-base);
    border: 1px solid rgba(28,25,23,0.1);
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .leader-card:hover {
    transform: translateY(-2px);
    border-color: rgba(196,145,42,0.35);
    box-shadow: 0 10px 28px rgba(10,8,6,0.08);
  }
  .leader-avatar {
    width: 108px; height: 108px;
    border-radius: 14px;
    object-fit: cover;
    object-position: center 22%;
    border: 1.5px solid rgba(197, 160, 60, 0.5);
    margin-bottom: 1rem;
  }
  .leader-initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1c1917 0%, #0a0806 100%);
    color: #c4912a;
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .leader-name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: #1c1917;
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }
  .leader-role {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #78716c;
    line-height: 1.4;
    margin-bottom: 1rem;
  }
  .leader-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.9rem;
    background: rgba(196,145,42,0.08);
    border: 1px solid rgba(196,145,42,0.35);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-top: auto;
  }
  .leader-card:hover .leader-cta {
    background: rgba(196,145,42,0.18);
    border-color: var(--color-gold);
  }

  /* The White Story two-column band */
  .white-story-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
  }
  .white-story-side {
    padding: 1.75rem 1.75rem;
    background: var(--color-surface-0);
    border: 1px solid rgba(196,145,42,0.22);
    border-radius: 8px;
  }
  @media (max-width: 560px) {
    .leaders-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 800px) {
    .white-story-grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* Office cards */
  .offices-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .office-card {
    background: var(--color-surface-0);
    border: 1px solid rgba(28,25,23,0.1);
    border-radius: 8px;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-height: 180px;
  }
  .office-card.is-featured {
    background: #fbf7ee;
    border-left: 3px solid #c4912a;
    padding-left: calc(1.75rem - 3px);
  }
  .office-name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: #1c1917;
    line-height: 1.3;
    margin: 0;
  }
  .office-principal {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: #78716c;
    margin: 0;
  }
  .office-phone {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    color: #c4912a;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: color 0.2s;
  }
  .office-phone:hover { color: #d4a23a; }
  .office-note {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    color: #c4912a;
    margin-top: auto;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* Reason cards */
  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .reason-card {
    background: var(--color-surface-0);
    border: 1px solid rgba(28,25,23,0.1);
    border-radius: 8px;
    padding: 2.5rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .reason-num {
    font-family: var(--font-serif);
    font-size: 0.75rem;
    font-weight: 400;
    color: #c4912a;
    letter-spacing: 0.15em;
  }
  .reason-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    color: #1c1917;
    line-height: 1.35;
    margin: 0;
  }
  .reason-body {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 300;
    color: #4a4540;
    line-height: 1.8;
    margin: 0;
  }

  /* Results grid */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .result-card {
    background: var(--color-surface-0);
    border: 1px solid rgba(28,25,23,0.1);
