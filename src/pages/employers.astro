---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';

const solutions = [
  {
    icon: 'fa-solid fa-users',
    title: 'Specialist IT Recruitment',
    description: 'We connect the brightest minds with the most challenging problems. Our specialist knowledge spans data, cloud, cyber, and software development — so you get candidates who are genuinely qualified, not just keyword matches.',
    anchor: 'recruitment',
    tags: ['Permanent Placement', 'Contract & Temp', 'Executive Search'],
  },
  {
    icon: 'fa-solid fa-handshake',
    title: 'Technology Talent Partners',
    description: 'A strategic, consultative approach to your entire talent pipeline. We embed ourselves in your organisation to understand culture, capability gaps, and growth plans — then source accordingly.',
    anchor: 'talent',
    tags: ['Talent Strategy', 'Candidate Management', 'Cultural Fit'],
  },
  {
    icon: 'fa-solid fa-diagram-project',
    title: 'Project Consulting',
    description: 'High-performing consultants who have delivered real technology projects. We recruit and deploy practitioners across programme management, business analysis, architecture, and engineering.',
    anchor: 'consulting',
    tags: ['PMO & Delivery', 'BA & Architecture', 'Programme Management'],
  },
  {
    icon: 'fa-solid fa-layer-group',
    title: 'Scalable PMO Solutions',
    description: 'Need to stand up a delivery function fast? We provide scalable project management office support — from individual PMs to full delivery teams — calibrated to your programme.',
    anchor: 'pmo',
    tags: ['Project Uplift', 'PMO Setup', 'Delivery Teams'],
  },
];

const specialisms = [
  'Program & Project Management',
  'Cyber Security',
  'Software Engineering',
  'Solutions Architecture',
  'Testing & QA',
  'Business Analysis',
  'Infrastructure & Cloud',
  'Network Administration',
  'BI & Data Engineering',
  'Product Management',
  'Machine Learning Engineering',
  'Digital Transformation',
];

const testimonials = [
  {
    quote: "Exemplary in finding us high-quality, experienced resources. Their understanding of our requirements was exceptional and their candidates consistently outperformed expectations.",
    author: "Senior Project Manager",
    company: "Enterprise Client, Queensland",
  },
  {
    quote: "Built a vast network in the IT market and is highly sought after for expertise, honesty, and reliability. A trusted long-term partner for our recruitment needs.",
    author: "Senior Manager",
    company: "Government Client, Queensland",
  },
  {
    quote: "Consistent quality candidates with genuine organisational value alignment. They've significantly reduced our time-to-hire without compromising on quality.",
    author: "Head of Technology",
    company: "Enterprise Client",
  },
];
---

<Layout title="For Employers | Cirqle Group" description="IT recruitment and technology project consulting for enterprise and government in Queensland. Specialist talent, delivered with purpose.">
  <Navbar />
  <PageHero
    badge="For Employers"
    title="Your Tech Challenge."
    titleHighlight="Our IT Excellence."
    subtitle="We deliver specialist IT recruitment and project consulting to enterprise and government organisations across Queensland — with the practitioner insight to get it right."
    cta={{ label: 'Send an Enquiry', href: '/contact-us/' }}
    ctaSecondary={{ label: 'View Our Specialisms', href: '#specialisms' }}
  />

  <!-- Solutions -->
  <section id="solutions" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 bg-[#E5F3FA] text-[#26A8FF] text-sm font-medium px-4 py-1.5 rounded-full mb-4">What We Offer</div>
        <h2 class="section-title">Recruitment & Consulting Solutions</h2>
        <p class="section-subtitle mx-auto text-center mt-4">
          Whether you need to fill a single critical role or build an entire delivery capability, we have the specialist expertise to help.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {solutions.map(s => (
          <div id={s.anchor} class="group bg-white border border-gray-100 rounded-2xl p-7 shadow-sm hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#E5F3FA] flex items-center justify-center mb-5 group-hover:bg-[#26A8FF] transition-colors duration-300">
              <i class={`${s.icon} text-[#26A8FF] text-lg group-hover:text-white transition-colors duration-300`}></i>
            </div>
            <h3 class="text-xl font-bold text-[#1F2848] mb-3">{s.title}</h3>
            <p class="text-[#383E4F] leading-relaxed mb-5">{s.description}</p>
            <div class="flex flex-wrap gap-2">
              {s.tags.map(tag => (
                <span class="bg-[#E5F3FA] text-[#26A8FF] text-xs font-medium px-3 py-1 rounded-full">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialisms -->
  <section id="specialisms" class="py-20 bg-[#1F2848]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Our Technology Specialisms</h2>
        <p class="text-white/60 max-w-xl mx-auto">Across Digital Transformation, Data & Analytics, Cloud & Infrastructure, and Software Development.</p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        {specialisms.map(s => (
          <div class="bg-white/10 border border-white/10 text-white text-sm px-4 py-2 rounded-full hover:bg-[#26A8FF] hover:border-[#26A8FF] transition-colors cursor-default">
            {s}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Cirqle -->
  <section class="py-24 bg-[#E5F3FA]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-white text-[#26A8FF] text-sm font-medium px-4 py-1.5 rounded-full mb-6 border border-[#26A8FF]/20">Why We're Different</div>
          <h2 class="section-title mb-6">We Recruit People Who Do the Thing</h2>
          <p class="text-[#383E4F] leading-relaxed mb-5">
            Most recruiters place people. We deliver projects. That means our consultants have first-hand experience running technology programmes — so when we assess a candidate, we know what "good" actually looks like in practice.
          </p>
          <p class="text-[#383E4F] leading-relaxed mb-8">
            And as a social enterprise, every engagement you make with us contributes to environmental and social causes in Queensland and beyond.
          </p>
          <a href="/contact-us/" class="btn-primary">Start a Conversation <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <div class="space-y-4">
          {[
            { icon: 'fa-solid fa-magnifying-glass', title: 'Practitioner-Led Assessment', body: 'We assess candidates with genuine delivery insight — not just keyword screening.' },
            { icon: 'fa-solid fa-clock', title: 'Reduced Time-to-Hire', body: 'Deep networks across Queensland mean we move faster without cutting corners.' },
            { icon: 'fa-solid fa-building-columns', title: 'Enterprise & Government Ready', body: 'Experienced working within complex procurement environments and panel arrangements.' },
            { icon: 'fa-solid fa-leaf', title: 'Social Enterprise Credentials', body: 'Support procurement commitments to social enterprise while getting great talent.' },
          ].map(item => (
            <div class="flex items-start gap-4 bg-white rounded-xl p-5 shadow-sm">
              <div class="w-10 h-10 rounded-lg bg-[#E5F3FA] flex items-center justify-center flex-shrink-0">
                <i class={`${item.icon} text-[#26A8FF] text-sm`}></i>
              </div>
              <div>
                <h4 class="font-semibold text-[#1F2848] mb-1 text-sm">{item.title}</h4>
                <p class="text-[#383E4F] text-sm">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-title">What Clients Say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <div class="bg-[#E5F3FA] rounded-2xl p-7 flex flex-col">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => <i class="fa-solid fa-star text-[#26A8FF] text-sm"></i>)}
            </div>
            <blockquote class="text-[#383E4F] leading-relaxed mb-6 flex-grow">"{t.quote}"</blockquote>
            <div class="border-t border-[#26A8FF]/20 pt-4">
              <div class="font-semibold text-[#1F2848] text-sm">{t.author}</div>
              <div class="text-[#26A8FF] text-xs mt-0.5">{t.company}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-br from-[#1F2848] to-[#060E23] text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Find Your Next Tech Leader?</h2>
      <p class="text-white/70 mb-8">Tell us about your requirement and we'll come back to you within one business day.</p>
      <a href="/contact-us/" class="inline-flex items-center gap-2 bg-[#26A8FF] text-white font-semibold px-8 py-4 rounded-md hover:bg-[#0090e8] transition-colors">
        Send an Enquiry <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
