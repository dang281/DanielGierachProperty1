---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | Cirqle Group" description="Reach out to Cirqle Group for IT recruitment and project consulting enquiries in Queensland.">
  <Navbar />
  <PageHero
    badge="Get in Touch"
    title="Let's Talk About"
    titleHighlight="Your Tech Requirement"
    subtitle="Whether you need to hire, consult, or just explore what's possible — we'd love to hear from you."
  />

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        <!-- Contact info -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-[#1F2848] mb-6">Contact Details</h2>
          <div class="space-y-6 mb-10">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-[#E5F3FA] flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-envelope text-[#26A8FF]"></i>
              </div>
              <div>
                <div class="font-semibold text-[#1F2848] text-sm mb-1">Email</div>
                <a href="mailto:info@cirqlegroup.com" class="text-[#383E4F] hover:text-[#26A8FF] transition-colors">info@cirqlegroup.com</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-[#E5F3FA] flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-location-dot text-[#26A8FF]"></i>
              </div>
              <div>
                <div class="font-semibold text-[#1F2848] text-sm mb-1">Location</div>
                <div class="text-[#383E4F]">Brisbane, Queensland, Australia</div>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-[#E5F3FA] flex items-center justify-center flex-shrink-0">
                <i class="fa-brands fa-linkedin text-[#26A8FF]"></i>
              </div>
              <div>
                <div class="font-semibold text-[#1F2848] text-sm mb-1">LinkedIn</div>
                <a href="https://www.linkedin.com/company/cirqlegroup" target="_blank" rel="noopener noreferrer" class="text-[#383E4F] hover:text-[#26A8FF] transition-colors">linkedin.com/company/cirqlegroup</a>
              </div>
            </div>
          </div>

          <div class="bg-[#E5F3FA] rounded-2xl p-6">
            <h3 class="font-bold text-[#1F2848] mb-3">Response Time</h3>
            <p class="text-[#383E4F] text-sm leading-relaxed">We aim to respond to all enquiries within one business day. For urgent requirements, reach us directly via email.</p>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-3">
          <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-lg">
            <h2 class="text-2xl font-bold text-[#1F2848] mb-6">Send an Enquiry</h2>
            <form name="contact" method="POST" action="/thank-you" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-[#383E4F] mb-1.5">First Name *</label>
                  <input type="text" id="first-name" name="first-name" required placeholder="Jane"
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-medium text-[#383E4F] mb-1.5">Last Name *</label>
                  <input type="text" id="last-name" name="last-name" required placeholder="Smith"
                    class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-[#383E4F] mb-1.5">Work Email *</label>
                <input type="email" id="email" name="email" required placeholder="jane@agency.gov.au"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-[#383E4F] mb-1.5">Phone</label>
                <input type="tel" id="phone" name="phone" placeholder="04XX XXX XXX"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-[#383E4F] mb-1.5">Organisation</label>
                <input type="text" id="company" name="company" placeholder="Department / Agency / Company"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition" />
              </div>
              <div>
                <label for="enquiry-type" class="block text-sm font-medium text-[#383E4F] mb-1.5">What can we help with? *</label>
                <select id="enquiry-type" name="enquiry-type" required
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-[#383E4F] focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition bg-white">
                  <option value="" disabled selected>Select an option</option>
                  <option value="recruitment">IT Recruitment</option>
                  <option value="consulting">Project Consulting</option>
                  <option value="both">Recruitment & Consulting</option>
                  <option value="job-seeker">I'm a Job Seeker</option>
                  <option value="partnership">Partnership / Social Enterprise</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-[#383E4F] mb-1.5">Tell us more</label>
                <textarea id="message" name="message" rows="5" placeholder="Describe your requirement, timeline, or anything else we should know..."
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-[#383E4F] placeholder-gray-400 focus:outline-none focus:border-[#26A8FF] focus:ring-2 focus:ring-[#26A8FF]/20 transition resize-none"></textarea>
              </div>
              <button type="submit" class="w-full bg-[#26A8FF] text-white font-semibold py-4 rounded-lg hover:bg-[#0090e8] transition-colors flex items-center justify-center gap-2">
                Send Enquiry <i class="fa-solid fa-paper-plane"></i>
              </button>
              <p class="text-xs text-gray-400 text-center">We typically respond within one business day.</p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
