---
import LandingLayout from '../layouts/LandingLayout.astro';

// Generic tools chosen for a social-media audience — work for both buyers
// and sellers without forcing intent.
const services = [
  {
    href: '/walkthrough',
    title: 'Free property report',
    desc: 'A no-obligation valuation based on recent comparable sales.',
    icon: 'report',
  },
  {
    href: '/buyers',
    title: 'Off-market & pre-market access',
    desc: 'See homes before they hit realestate.com.au.',
    icon: 'key',
  },
  {
    href: '/tools',
    title: 'All buyer & seller tools',
    desc: 'Calculators, checklists, maps, market reports.',
    icon: 'grid',
  },
];

const articles = [
  {
    href: '/insights/aml-changes-real-estate-brisbane-1-july-2026',
    title: 'New AML rules from 1 July 2026',
    desc: 'What changes for buyers and sellers.',
    icon: 'shield',
  },
  {
    href: '/insights/seller-disclosure-obligations-queensland',
    title: 'Seller disclosure obligations in Queensland',
    desc: 'What a vendor must (and should) tell a buyer.',
    icon: 'doc',
  },
];

const agents = [
  {
    name: 'Conrad Leisemann',
    slug: 'conrad-leisemann',
    photo: '/img/conrad-headshot.jpg',
    phone: '0403 978 813',
    tel: '+61403978813',
    email: 'conrad.leisemann@raywhite.com',
    handle: 'connie_leisemann',
    instagramUrl: 'https://www.instagram.com/connie_leisemann/',
    ctaKey: 'conrad',
  },
  {
    name: 'Daniel Gierach',
    slug: 'daniel-gierach',
    photo: '/img/daniel-headshot-tight.jpg',
    phone: '0412 523 821',
    tel: '+61412523821',
    email: 'daniel.gierach@raywhite.com',
    handle: 'dgierach',
    instagramUrl: 'https://www.instagram.com/dgierach/',
    ctaKey: 'daniel',
  },
];

---

<LandingLayout
  title="Your Team | Conrad Leisemann & Daniel Gierach"
  description="Conrad Leisemann and Daniel Gierach at Ray White Collective. Inner-east Brisbane buyer and seller tools, a free property report, and off-market access."
>

<style>
  :root {
    --bg: #0a0806;
    --bg-soft: #100c08;
    --card: #15110d;
    --card-hover: #1c1612;
    --line: rgba(240, 236, 228, 0.07);
    --line-strong: rgba(196, 145, 42, 0.32);
    --line-glow: rgba(196, 145, 42, 0.5);
    --text: #f2efe9;
    --text-mute: rgba(242, 239, 233, 0.5);
    --text-soft: rgba(242, 239, 233, 0.78);
    --gold: #c4912a;
    --gold-bright: #d4a23a;
    --gold-soft: rgba(196, 145, 42, 0.85);
  }

  body { background: var(--bg); color: var(--text); position: relative; }

  /* Header background photo: full-bleed, dark, fades to solid charcoal
     before the first card so it never competes with content. */
  .hero-bg {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 380px;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 92%;
    filter: grayscale(12%) brightness(0.62) contrast(1.05);
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(196,145,42,0.1) 0%, rgba(196,145,42,0) 70%),
      linear-gradient(
        180deg,
        rgba(10,8,6,0.55) 0%,
        rgba(10,8,6,0.5) 28%,
        rgba(10,8,6,0.7) 55%,
        rgba(10,8,6,0.88) 80%,
        var(--bg) 100%
      );
  }
  @media (min-width: 640px) { .hero-bg { height: 420px; } }

  .shell {
    max-width: 480px;
    margin: 0 auto;
    padding: 1.5rem 1.15rem 2.5rem;
    min-height: 100svh;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 640px) {
    .shell { padding: 2rem 1.5rem 3rem; }
  }

  /* ── Header (two-agent: Daniel + Conrad) ─────────────────────── */
  .header { text-align: center; margin-bottom: 1.5rem; }

  .agency-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.56rem; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold-soft);
    margin-bottom: 0.5rem;
  }

  .team-title {
    font-family: var(--font-serif);
    font-size: 1.25rem; font-weight: 400;
    font-style: italic;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 1.4rem;
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
  }

  .agents {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 0;
  }
  @media (min-width: 480px) { .agents { gap: 1.5rem; } }

  .agent {
    display: flex; flex-direction: column; align-items: center;
    min-width: 0;
  }

  .avatar {
    width: 76px; height: 76px;
    border-radius: 14px;
    object-fit: cover; object-position: center 35%;
    display: block;
    margin: 0 0 0.5rem;
    border: 1.5px solid rgba(197, 160, 60, 0.55);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.55), 0 0 0 4px rgba(196, 145, 42, 0.05);
  }
  @media (min-width: 480px) { .avatar { width: 88px; height: 88px; } }

  .name {
    font-family: var(--font-serif);
    font-size: 1rem; font-weight: 700;
    line-height: 1.15; letter-spacing: 0.005em;
    margin-bottom: 0.3rem;
    min-height: 2.4em;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    text-shadow: 0 1px 12px rgba(0,0,0,0.65), 0 1px 2px rgba(0,0,0,0.5);
  }
  @media (min-width: 480px) { .name { font-size: 1.15rem; min-height: 1.3em; } }

  /* Stack phone / handle / email vertically so both columns always have
     the same number of lines, keeping the two cards aligned no matter
     how long the handles or addresses are. */
  .contact-line {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.1rem;
    font-family: var(--font-sans);
    font-size: 0.7rem; font-weight: 700;
    line-height: 1.25;
    margin-bottom: 0.15rem;
    text-shadow: 0 1px 8px rgba(0,0,0,0.6), 0 1px 2px rgba(0,0,0,0.45);
  }
  @media (min-width: 480px) { .contact-line { font-size: 0.78rem; } }
  .contact-line a { color: var(--gold); text-decoration: none; transition: color 0.2s; white-space: nowrap; }
  .contact-line a:hover { color: var(--gold-bright); }
  .contact-line .sep { display: none; }
  .handle-text { color: rgba(242,239,233,0.78); font-weight: 600; }
  .handle-text a { color: rgba(242,239,233,0.78); }
  .handle-text a:hover { color: var(--gold); }

  .email {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 500;
    line-height: 1.25;
    word-break: break-all;
    text-shadow: 0 1px 6px rgba(0,0,0,0.55);
    padding: 0 0.25rem;
    margin: 0;
  }
  @media (min-width: 480px) { .email { font-size: 0.66rem; word-break: normal; } }
  .email a {
    color: rgba(242,239,233,0.85); text-decoration: none;
    transition: color 0.2s;
  }
  .email a:hover { color: var(--gold); }

  /* "More info" button under each primary agent card (links to /team/{slug}) */
  .agent-info-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.3rem;
    margin-top: 0.65rem;
    padding: 0.4rem 0.75rem;
    background: rgba(196, 145, 42, 0.08);
    border: 1px solid rgba(196, 145, 42, 0.35);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.52rem; font-weight: 800;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    white-space: nowrap;
  }
  @media (min-width: 480px) { .agent-info-btn { font-size: 0.55rem; padding: 0.45rem 0.9rem; } }
  .agent-info-btn:hover {
    background: rgba(196, 145, 42, 0.18);
    border-color: var(--gold);
    color: var(--gold-bright);
  }

  /* ── Wider team (Samantha, Haesley, Peter) ────────────────────
     Centered row of equal-width cards. align-items:stretch via flex
     gives every card the same height so the "More info" button at
     the bottom of each card lines up across the row. */
  .wider-team-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.56rem; font-weight: 800;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--text-mute);
    text-align: center;
    margin-top: 2rem; margin-bottom: 1rem;
  }
  .wider-team {
    display: flex;
    justify-content: center;
    gap: 0.7rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 480px) { .wider-team { gap: 1rem; } }
  .wt-card {
    display: flex; flex-direction: column; align-items: center;
    padding: 0.9rem 0.5rem 0.85rem;
    background: rgba(15, 11, 7, 0.55);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(196, 145, 42, 0.18);
    border-radius: 8px;
    transition: background 0.18s, border-color 0.18s;
    /* Equal width siblings; cap at 200px so the row stays compact */
    flex: 1 1 0;
    min-width: 0;
    max-width: 200px;
  }
  .wt-card:hover { background: rgba(20, 14, 9, 0.75); border-color: rgba(196, 145, 42, 0.4); }
  .wt-avatar {
    width: 60px; height: 60px;
    border-radius: 10px;
    object-fit: cover; object-position: center 22%;
    border: 1px solid rgba(197, 160, 60, 0.45);
    margin-bottom: 0.6rem;
  }
  @media (min-width: 480px) { .wt-avatar { width: 70px; height: 70px; border-radius: 12px; } }
  .wt-name {
    font-family: var(--font-serif);
    font-size: 0.78rem; font-weight: 700;
    line-height: 1.2;
    text-align: center;
    margin-bottom: 0.2rem;
    color: var(--text);
    text-shadow: 0 1px 8px rgba(0,0,0,0.55);
    /* Reserve 2 lines so cards stay the same height even if a name fits
       on one line (e.g. Peter Burgin) vs wraps (Samantha Squires) */
    min-height: 2.4em;
    display: flex; align-items: center;
  }
  @media (min-width: 480px) { .wt-name { font-size: 0.88rem; min-height: 1.2em; } }
  .wt-role {
    font-family: var(--font-sans);
    font-size: 0.5rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--gold-soft);
    text-align: center;
    margin-bottom: 0.7rem;
    line-height: 1.3;
    min-height: 2.6em;
    display: flex; align-items: center; justify-content: center;
  }
  @media (min-width: 480px) { .wt-role { font-size: 0.55rem; } }
  .wt-info-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.3rem;
    padding: 0.5rem 0.8rem;
    background: rgba(196, 145, 42, 0.08);
    border: 1px solid rgba(196, 145, 42, 0.35);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.52rem; font-weight: 800;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    margin-top: auto;
    white-space: nowrap;
  }
  @media (min-width: 480px) { .wt-info-btn { font-size: 0.55rem; padding: 0.55rem 1rem; } }
  .wt-info-btn:hover {
    background: rgba(196, 145, 42, 0.18);
    border-color: var(--gold);
    color: var(--gold-bright);
  }

  /* ── Section labels ───────────────────────────────────────────── */
  .section { margin-bottom: 1.5rem; }
  .section-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.58rem; font-weight: 800;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-mute);
    margin-bottom: 0.7rem; padding-left: 0.2rem;
  }

  /* ── Service cards (with icon) ────────────────────────────────── */
  .card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.95rem;
    background:
      linear-gradient(135deg, rgba(196,145,42,0.04) 0%, rgba(196,145,42,0) 60%),
      var(--card);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.95rem 1.05rem;
    text-decoration: none;
    color: var(--text);
    margin-bottom: 0.55rem;
    transition: background 0.2s, border-color 0.2s, transform 0.18s;
    position: relative;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px; background: var(--gold);
    opacity: 0.6;
    transition: opacity 0.2s, width 0.2s;
  }
  .card:hover, .card:focus-visible {
    background:
      linear-gradient(135deg, rgba(196,145,42,0.08) 0%, rgba(196,145,42,0.01) 60%),
      var(--card-hover);
    border-color: var(--line-strong);
    transform: translateY(-1px);
  }
  .card:hover::before { opacity: 1; width: 3px; }
  .card:active { transform: translateY(0); }

  .card-icon {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(196, 145, 42, 0.1);
    border: 1px solid rgba(196, 145, 42, 0.18);
    border-radius: 50%;
    color: var(--gold-bright);
    flex-shrink: 0;
  }

  .card-body { min-width: 0; }
  .card-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.52rem; font-weight: 800;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold);
    display: block; margin-bottom: 0.18rem;
  }
  .card-title {
    font-family: var(--font-serif);
    font-size: 1rem; font-weight: 400;
    line-height: 1.2;
    margin-bottom: 0.2rem;
  }
  .card-desc {
    font-size: 0.7rem; line-height: 1.4;
    color: var(--text-soft);
  }
  .card-arrow {
    color: var(--text-mute);
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .card:hover .card-arrow {
    color: var(--gold);
    transform: translateX(2px);
  }

  /* ── Article cards (smaller, icon-led) ────────────────────────── */
  .acard {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 0.95rem;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 4px;
    text-decoration: none;
    color: var(--text);
    margin-bottom: 0.45rem;
    transition: background 0.2s, border-color 0.2s;
  }
  .acard:hover, .acard:focus-visible {
    background: var(--bg-soft);
    border-color: var(--line-strong);
  }
  .acard-icon {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    color: var(--gold-soft);
    flex-shrink: 0;
  }
  .acard-body { min-width: 0; }
  .acard-title {
    font-family: var(--font-serif);
    font-size: 0.88rem; font-weight: 400;
    line-height: 1.25;
    margin-bottom: 0.15rem;
  }
  .acard-desc {
    font-size: 0.66rem; line-height: 1.35;
    color: var(--text-mute);
  }

  .browse-all {
    display: inline-flex; align-items: center; gap: 0.35rem;
    margin-top: 0.4rem; padding: 0.3rem 0.2rem;
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 800;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold); text-decoration: none;
    transition: color 0.18s;
  }
  .browse-all:hover { color: var(--gold-bright); }

  /* ── Final CTA panel ──────────────────────────────────────────── */
  .final {
    background:
      linear-gradient(135deg, rgba(196,145,42,0.15) 0%, rgba(196,145,42,0.04) 100%);
    border: 1px solid var(--line-strong);
    border-radius: 4px;
    padding: 1.25rem 1.25rem;
    margin-top: 1.5rem;
    text-align: center;
    position: relative;
  }
  .final-title {
    font-family: var(--font-serif);
    font-size: 0.98rem; font-weight: 400; line-height: 1.3;
    margin-bottom: 0.4rem;
  }
  .final-sub {
    font-size: 0.7rem; line-height: 1.5;
    color: var(--text-soft);
    margin-bottom: 0.9rem;
  }
  .btn-gold {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.75rem 1.25rem;
    background: var(--gold); color: var(--bg);
    font-family: var(--font-sans);
    font-size: 0.66rem; font-weight: 800;
    letter-spacing: 0.14em; text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s, transform 0.18s;
  }
  .btn-gold:hover { background: var(--gold-bright); transform: translateY(-1px); }

  /* ── Bottom row ──────────────────────────────────────────────── */
  .contact-row {
    display: flex; justify-content: center; gap: 1.25rem;
    margin-top: 1.25rem; padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
  .contact-row a {
    font-family: var(--font-sans);
    font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--text-mute); text-decoration: none;
    transition: color 0.18s;
  }
  .contact-row a:hover { color: var(--gold); }

  .legal {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.56rem; color: var(--text-mute);
    line-height: 1.5;
    opacity: 0.85;
  }
</style>

<!-- Header backdrop photo: heavily darkened, fades to solid charcoal
     so the page below stays clean and the cards do the talking. -->
<div class="hero-bg" aria-hidden="true">
  <img
    src="/_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Ff0e3-H3512351-202426677__1779329460-52623-AMY9140.jpg&w=1080&q=65"
    srcset="
      /_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Ff0e3-H3512351-202426677__1779329460-52623-AMY9140.jpg&w=640&q=65 640w,
      /_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Ff0e3-H3512351-202426677__1779329460-52623-AMY9140.jpg&w=1080&q=65 1080w,
      /_vercel/image?url=https%3A%2F%2Fcdn6.ep.dynamics.net%2Fs3%2Frw-propertyimages%2Ff0e3-H3512351-202426677__1779329460-52623-AMY9140.jpg&w=1440&q=65 1440w
    "
    sizes="(max-width: 640px) 100vw, 1440px"
    alt=""
    fetchpriority="high"
  />
</div>

<div class="shell">

  <header class="header">
    <p class="agency-eyebrow">Ray White &middot; The Collective &middot; Bulimba</p>
    <p class="team-title">Your Team</p>

    <div class="agents">
      {agents.map(a => (
        <div class="agent">
          <img src={a.photo} alt={a.name} class="avatar" width="88" height="88" loading="eager" />
          <div class="name">{a.name}</div>
          <p class="contact-line">
            <a href={`tel:${a.tel}`} data-cta={`property_tools_call_${a.ctaKey}`}>{a.phone}</a>
            <span class="sep">&middot;</span>
            <span class="handle-text"><a href={a.instagramUrl} target="_blank" rel="noopener">@{a.handle}</a></span>
          </p>
          <p class="email"><a href={`mailto:${a.email}`} data-cta={`property_tools_email_${a.ctaKey}`}>{a.email}</a></p>
          <a href={`/team/${a.slug}`} class="agent-info-btn" data-cta={`meet_team_${a.ctaKey}`}>
            More info
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </header>

  <section class="section">
    <span class="section-label">Tools &amp; services</span>
    {services.map(s => (
      <a class="card" href={s.href} data-cta={`your_team_${s.href.replace(/\//g, '_')}`}>
        <span class="card-icon">
          {s.icon === 'report' && (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
          )}
          {s.icon === 'key' && (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="4.5"/><path d="M10.7 12.3L21 2"/><path d="M16.5 6.5L19 9"/></svg>
          )}
          {s.icon === 'grid' && (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          )}
        </span>
        <div class="card-body">
          <div class="card-title">{s.title}</div>
          <p class="card-desc">{s.desc}</p>
        </div>
        <svg class="card-arrow" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    ))}
  </section>

  <section class="section">
    <span class="section-label">Latest articles</span>
    {articles.map(a => (
      <a class="acard" href={a.href} data-cta={`property_tools_article_${a.href.split('/').pop()}`}>
        <span class="acard-icon">
          {a.icon === 'shield' && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          )}
          {a.icon === 'doc' && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
          )}
        </span>
        <div class="acard-body">
          <div class="acard-title">{a.title}</div>
          <p class="acard-desc">{a.desc}</p>
        </div>
        <svg class="card-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    ))}
    <a href="/insights" class="browse-all" data-cta="property_tools_browse_all">
      Browse all articles
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>

  <div class="final">
    <p class="final-title">What is your home worth today?</p>
    <p class="final-sub">A free, no-obligation property report based on recent comparable sales in your suburb.</p>
    <a href="/walkthrough" class="btn-gold" data-cta="property_tools_to_walkthrough">
      Click here to find out
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="contact-row">
    <a href="/contact" data-cta="property_tools_contact">Contact</a>
    <a href="/tools" data-cta="property_tools_all_tools">All tools</a>
    <a href="/" data-cta="property_tools_home">Home</a>
  </div>

  <p class="legal">
    Educational information only. Always seek independent advice.
  </p>

</div>

</LandingLayout>
