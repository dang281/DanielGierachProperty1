---
import Layout from '../layouts/Layout.astro';

// Suburb name comes through as ?suburb=Indooroopilly
// We don't trust it, just display it. The form sends to Formspree.

const appraisalSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Free Property Appraisal, Brisbane",
  "description": "Request a free property appraisal anywhere across Brisbane. Daniel Gierach will follow up within 24 hours. No obligation.",
  "provider": {
    "@type": "RealEstateAgent",
    "name": "Daniel Gierach",
    "url": "https://danielgierach.com"
  },
  "areaServed": {
    "@type": "Place",
    "name": "Brisbane, Queensland"
  },
  "url": "https://danielgierach.com/get-an-appraisal",
  "serviceType": "Property Appraisal"
};
---

<Layout
  title="Request an Appraisal | Daniel Gierach Property"
  description="Request a free property appraisal anywhere across Brisbane. Daniel will follow up within 24 hours."
  preloadImage="https://cdn6.ep.dynamics.net/s3/rw-propertyimages/65cb-H3485122-195546888__1775524459-58394-AMY1219.jpg"
  hideMobileCta={true}
  schema={appraisalSchema}
>

<section class="get-appraisal-hero" style="position:relative; min-height:100svh; background:#0a0806; display:flex; align-items:center; padding:7rem 1.5rem 6rem;">
  <div style="position:absolute; inset:0; overflow:hidden;">
    <img
      src="https://cdn6.ep.dynamics.net/s3/rw-propertyimages/65cb-H3485122-195546888__1775524459-58394-AMY1219.jpg"
      alt="Brisbane property"
      style="width:100%; height:100%; object-fit:cover; filter:grayscale(20%) brightness(0.28);"
      loading="eager" decoding="async" width="1920" height="1080"
    />
    <!-- Directional overlay: heavier left for text legibility, opens up on right -->
    <div style="position:absolute; inset:0; background:linear-gradient(105deg, rgba(10,8,6,0.82) 0%, rgba(10,8,6,0.55) 45%, rgba(10,8,6,0.18) 100%);"></div>
    <!-- Bottom vignette: fades to footer's dark CTA background for seamless handoff -->
    <div style="position:absolute; bottom:0; left:0; right:0; height:260px; background:linear-gradient(to bottom, transparent 0%, #0a0806 100%);"></div>
  </div>

  <div style="position:relative; z-index:10; max-width:1200px; margin:0 auto; width:100%; display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;" class="appraisal-grid">

    <!-- Left: copy -->
    <div>
      <span class="eyebrow" style="display:block; color:rgba(240,236,228,0.6); margin-bottom:1rem;">Free Appraisal · Anywhere in Brisbane</span>
      <h1 style="font-family:var(--font-serif); font-size:clamp(2.2rem, 4vw, 3.5rem); font-weight:400; color:#f0ece4; line-height:1.1; letter-spacing:-0.02em; margin-bottom:1.25rem;">
        Request an appraisal for your Brisbane property.
      </h1>
      <p style="font-size:1rem; color:rgba(240,236,228,0.78); line-height:1.85; max-width:46ch; margin-bottom:1.5rem;">
        Every appraisal Daniel does runs the same documented method: position the property accurately, build the buyer pool, protect the result. Send a few details and he'll come back within 24 hours with comparable sales for your suburb and a frank read on what your property is worth.
      </p>
      <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.55rem;">
        <li style="font-size:0.85rem; color:rgba(240,236,228,0.7); display:flex; gap:0.6rem; align-items:flex-start;"><span style="color:#c5a03c; flex-shrink:0;">✓</span> Direct line to Daniel, no call centre</li>
        <li style="font-size:0.85rem; color:rgba(240,236,228,0.7); display:flex; gap:0.6rem; align-items:flex-start;"><span style="color:#c5a03c; flex-shrink:0;">✓</span> Comparable sales in your suburb, not a generic estimate</li>
        <li style="font-size:0.85rem; color:rgba(240,236,228,0.7); display:flex; gap:0.6rem; align-items:flex-start;"><span style="color:#c5a03c; flex-shrink:0;">✓</span> No obligation, no pressure to list</li>
      </ul>
    </div>

    <!-- Right: form card -->
    <div style="background:var(--color-surface-0); padding:2.75rem 2.5rem; position:relative; box-shadow:0 32px 80px rgba(0,0,0,0.55), 0 8px 24px rgba(0,0,0,0.3);">
      <!-- Gold top accent -->
      <div style="position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(to right, transparent 0%, rgba(196,145,42,0.9) 25%, rgba(196,145,42,0.9) 75%, transparent 100%);"></div>

      <p style="font-family:var(--font-sans); font-size:0.6rem; font-weight:700; letter-spacing:0.22em; text-transform:uppercase; color:#c4912a; margin-bottom:0.4rem;">Send a Request</p>
      <h2 style="font-family:var(--font-serif); font-size:1.55rem; font-weight:400; color:#1c1917; line-height:1.2; margin-bottom:1.5rem;">
        Daniel will respond within 24 hours.
      </h2>

      <form method="POST" action="https://formspree.io/f/xnjgedwp" style="display:flex; flex-direction:column; gap:0.85rem;"
        onsubmit="if(typeof gtag!=='undefined'){gtag('event','appraisal_form_submit',{event_category:'lead',event_label:'Get An Appraisal',form_source:'wider-brisbane'});}">
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" />
        <input type="hidden" name="_next" value="https://danielgierach.com/thank-you?from=appraisal-anywhere" />
        <input type="hidden" name="_subject" value="Appraisal request, wider Brisbane" />
        <input type="hidden" name="_source" value="get-an-appraisal" />

        <input type="text" name="name" required placeholder="Your name" autocomplete="name" aria-label="Your name"
          class="form-field"
          style="font-family:var(--font-sans); font-size:0.92rem; padding:0.8rem 1rem; border:1px solid rgba(28,25,23,0.18); background:var(--color-surface-3); color:#1c1917; outline:none; box-sizing:border-box;" />
        <input type="email" name="email" required placeholder="Email address" autocomplete="email" aria-label="Email address"
          class="form-field"
          style="font-family:var(--font-sans); font-size:0.92rem; padding:0.8rem 1rem; border:1px solid rgba(28,25,23,0.18); background:var(--color-surface-3); color:#1c1917; outline:none; box-sizing:border-box;" />
        <input type="tel" name="phone" placeholder="Phone (optional)" autocomplete="tel" aria-label="Phone, optional"
          class="form-field"
          style="font-family:var(--font-sans); font-size:0.92rem; padding:0.8rem 1rem; border:1px solid rgba(28,25,23,0.18); background:var(--color-surface-3); color:#1c1917; outline:none; box-sizing:border-box;" />
        <input id="appraisal-suburb" type="text" name="suburb" required placeholder="Suburb" aria-label="Suburb"
          class="form-field"
          style="font-family:var(--font-sans); font-size:0.92rem; padding:0.8rem 1rem; border:1px solid rgba(28,25,23,0.18); background:var(--color-surface-3); color:#1c1917; outline:none; box-sizing:border-box;" />
        <input type="text" name="property_address" required placeholder="Property address (street + number)" aria-label="Property address"
          class="form-field"
          style="font-family:var(--font-sans); font-size:0.92rem; padding:0.8rem 1rem; border:1px solid rgba(28,25,23,0.18); background:var(--color-surface-3); color:#1c1917; outline:none; box-sizing:border-box;" />
        <textarea name="notes" rows="3" placeholder="Anything Daniel should know? (timing, situation, target price)" aria-label="Notes, timing, situation, target price"
          class="form-field"
          style="font-family:var(--font-sans); font-size:0.92rem; padding:0.8rem 1rem; border:1px solid rgba(28,25,23,0.18); background:var(--color-surface-3); color:#1c1917; outline:none; box-sizing:border-box; resize:vertical;"></textarea>

        <button type="submit" class="btn-gold" style="margin-top:0.5rem; justify-content:center;">
          Request appraisal
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
        <p style="font-size:0.7rem; color:var(--color-text-muted); margin-top:0.4rem;">
          No obligation. Daniel calls back personally within 24 hours.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  @media (max-width: 880px) {
    .appraisal-grid { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
  }
</style>

<script>
  // Pre-fill the suburb input from the ?suburb= query param.
  (() => {
    const params = new URLSearchParams(window.location.search);
    const suburb = params.get('suburb');
    if (suburb) {
      const input = document.querySelector<HTMLInputElement>('#appraisal-suburb');
      if (input) input.value = suburb;
    }
  })();
</script>

<!-- Fire Meta Pixel Lead + GA4 generate_lead on appraisal form submit -->
<script is:inline>
  (function() {
    function attachLead() {
      var form = document.querySelector('form[action*="formspree.io"]');
      if (!form) return;
      form.addEventListener('submit', function() {
        try { if (typeof fbq === 'function') fbq('track', 'Lead', { content_name: 'appraisal' }); } catch (e) {}
        try { if (typeof gtag === 'function') gtag('event', 'generate_lead', { content_name: 'appraisal' }); } catch (e) {}
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', attachLead);
    } else {
      attachLead();
    }
  })();
</script>

</Layout>
