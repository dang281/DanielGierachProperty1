<!-- ═══════════════════════════════════════════════
     SECTION 4: HOW I CAN HELP YOU SELL
════════════════════════════════════════════════ -->
<section style="background:var(--color-base, #f2efe9); padding:80px 24px;">
  <div style="max-width:800px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#c4912a; margin-bottom:1rem;">Selling in Teneriffe</p>
