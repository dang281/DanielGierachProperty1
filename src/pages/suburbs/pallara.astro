<!-- CROSS-LINK TO SELLING GUIDE -->
<section style="background:var(--color-surface-0);padding:3rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:800px;margin:0 auto;padding:0 24px;text-align:center;">
