<!-- ═══════════════════════════════════════════════
     SECTION 2: WHY THIS AREA
════════════════════════════════════════════════ -->
<section style="background:var(--color-base, #f2ead4); padding:80px 24px;">
  <div style="max-width:800px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1rem;">Local Expertise</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.8rem, 3.5vw, 2.8rem); font-weight:300; line-height:1.2; color:#191817; margin-bottom:1.75rem;">A practical inner north suburb with strong owner-occupier fundamentals.</h2>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.8; color:#4a4540; margin-bottom:1.25rem;">
      Stafford sits about six kilometres north of the CBD, between Gordon Park to the south and Everton Park to the north. It is an honest suburb: predominantly post-war housing on reasonable blocks, a high proportion of owner-occupiers who have stayed for decades, and the kind of quiet residential streetscape that families consistently discover after they have been outbid in Gordon Park or Kedron.
    </p>
<!-- APPRAISAL FORM -->
<div style="background:#fff; border-left:4px solid #b98229; padding:2rem 2rem 1.75rem; margin:2rem 0;">
  <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#b98229; margin-bottom:0.5rem;">Free Appraisal</p>
