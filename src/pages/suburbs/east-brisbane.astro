    {
      "@type": "Place",
      "name": "East Brisbane QLD 4169"
    },
    {
      "@type": "Place",
      "name": "Kangaroo Point QLD"
    },
    {
      "@type": "Place",
      "name": "Woolloongabba QLD"
    },
    {
      "@type": "Place",
      "name": "Coorparoo QLD"
    },
    {
      "@type": "Place",
      "name": "Norman Park QLD"
    }
  ],
  "knowsAbout": [
    "East Brisbane real estate",
    "East Brisbane terrace homes",
    "inner-city character homes Brisbane",
    "East Brisbane property values"
  ],
  "sameAs": [
    "https://share.google/WipmgyJnjC5nkhGwx"
  ]
})}</script>


<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the median house price in East Brisbane?",
      "acceptedAnswer": { "@type": "Answer", "text": "East Brisbane property values vary by block size, position and condition. The suburb's inner-city location, walkable streetscapes and mix of character homes and contemporary residences drive consistently strong buyer demand." }
    },
    {
      "@type": "Question",
      "name": "How long does it take to sell a home in East Brisbane?",
      "acceptedAnswer": { "@type": "Answer", "text": "Well-priced East Brisbane properties typically sell within 20 to 35 days. Proximity to the CBD, the Gabba and Mowbray Park creates strong buyer urgency for properties in good positions." }
    },
    {
      "@type": "Question",
      "name": "What types of properties are available in East Brisbane?",
      "acceptedAnswer": { "@type": "Answer", "text": "East Brisbane has a diverse mix of pre-war character homes, post-war houses, contemporary townhouses and apartment complexes. The suburb's inner-city density means block sizes are smaller than outer suburbs, but location premiums reflect the trade-off buyers are willing to make." }
    },
    {
      "@type": "Question",
      "name": "Is East Brisbane a good suburb to buy in right now?",
      "acceptedAnswer": { "@type": "Answer", "text": "East Brisbane benefits from its position between the CBD and the inner-east lifestyle corridor. With the Gabba Stadium redevelopment planned for the 2032 Olympics, the area's profile and infrastructure investment are set to increase further, which many buyers and investors factor into their decision." }
    }
  ]
})}</script>

