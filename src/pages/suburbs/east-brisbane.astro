  "@type": "WebPage",
  "name": "Real Estate Agent East Brisbane",
  "description": "Daniel Gierach is a specialist real estate agent in East Brisbane, serving the inner-city corridor.",
  "url": "https://danielgierach.com/suburbs/east-brisbane",
  "breadcrumb": {
    "@type": "BreadcrumbList",
