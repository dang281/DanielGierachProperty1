      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Unit 6, 57-59 Oxford Street',
        addressLocality: 'Bulimba',
        addressRegion: 'QLD',
        postalCode: '4171',
        addressCountry: 'AU',
