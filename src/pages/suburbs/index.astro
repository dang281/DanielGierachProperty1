  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['LocalBusiness', 'RealEstateAgent'],
      name: 'Daniel Gierach, Ray White Bulimba',
      description: 'Specialist real estate agent covering Brisbane\'s inner east, inner south and surrounding suburbs. Serving over 30 suburbs across the greater Brisbane area.',
