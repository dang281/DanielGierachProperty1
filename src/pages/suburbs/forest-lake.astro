<!-- ═══════════════════════════════════════════════
     SECTION 2: WHY THIS AREA
════════════════════════════════════════════════ -->
<section style="background:var(--color-base, #f2ead4); padding:80px 24px;">
  <div style="max-width:800px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1rem;">Local Expertise</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.8rem, 3.5vw, 2.8rem); font-weight:400; font-variation-settings:'opsz' 32; line-height:1.2; color:#191817; margin-bottom:1.75rem;">Brisbane's largest planned estate, built for families.</h2>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.8; color:#4a4540; margin-bottom:1.25rem;">
      Forest Lake was developed from the late 1990s as one of the most ambitious planned residential estates in Queensland. The result is a suburb with consistent streetscapes, generous family-sized blocks, a complete community infrastructure network, and a central lake reserve that gives the suburb its identity. It draws a large, loyal family buyer pool who are choosing Forest Lake deliberately.
    </p>
<!-- APPRAISAL FORM -->
<div style="background:#fff; border-left:4px solid #b98229; padding:2rem 2rem 1.75rem; margin:2rem 0; border-radius:16px;">
  <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#b98229; margin-bottom:0.5rem;">Free Appraisal</p>
  <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:300; color:#191817; margin-bottom:1.25rem; line-height:1.25;">Find out what your Forest Lake home is worth.</h3>
