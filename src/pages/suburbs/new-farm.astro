  "@type": "WebPage",
  "name": "Real Estate Agent New Farm Brisbane",
  "description": "Daniel Gierach is a specialist real estate agent in New Farm Brisbane, serving the premium inner-city riverside corridor.",
  "url": "https://www.danielgierach.com/suburbs/new-farm",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.danielgierach.com" },
      { "@type": "ListItem", "position": 2, "name": "New Farm", "item": "https://www.danielgierach.com/suburbs/new-farm" }
    ]
  }
})}</script>
<script type="application/ld+json">{JSON.stringify({
