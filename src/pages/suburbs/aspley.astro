<!-- ═══════════════════════════════════════════════
     SECTION 2: WHY THIS AREA
════════════════════════════════════════════════ -->
<section style="background:var(--color-base, #f2ead4); padding:80px 24px;">
  <div style="max-width:800px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1rem;">Local Expertise</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.8rem, 3.5vw, 2.8rem); font-weight:300; line-height:1.2; color:#191817; margin-bottom:1.75rem;">An established northern suburb with strong school catchments and genuine land content.</h2>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.8; color:#4a4540; margin-bottom:1.25rem;">
      Aspley sits approximately 12 kilometres north of the CBD, bounded by Gympie Road to the east and connected to the broader northern corridor via Albany Creek Road. It is an honest, family-oriented suburb: predominantly post-war and early contemporary housing on generous blocks, a loyal long-term owner-occupier base, and the kind of established streetscape that families consistently discover after comparing Wavell Heights or Kedron and deciding that Aspley offers better value for what they actually need.
    </p>
<!-- APPRAISAL FORM -->
<div style="background:#fff; border-left:4px solid #b98229; padding:2rem 2rem 1.75rem; margin:2rem 0;">
