<!-- HERO -->
<section style="background:#f2ead4; color:#191817; padding: 100px 24px 80px;">
  <div style="max-width:800px; margin:0 auto; text-align:center;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1.25rem;">Kelvin Grove</p>
    <h1 style="font-family:var(--font-serif); font-size:clamp(2.4rem, 5vw, 4rem); font-weight:300; line-height:1.15; margin-bottom:1.5rem; color:#191817;">
      Selling in Kelvin Grove, Brisbane.
    </h1>
    <p style="font-family:var(--font-sans); font-size:1.05rem; font-weight:300; line-height:1.7; color:rgba(25,24,23,0.72); max-width:580px; margin:0 auto 2.5rem;">
      Property sales in Kelvin Grove and Inner Brisbane.
    </p>
    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
      <a href="/listings" class="btn-gold" style="font-family:var(--font-sans); font-size:0.85rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; background:#b98229; color:#ffffff; padding:0.85rem 2rem; text-decoration:none; display:inline-block; border-radius:10px;">View Current Listings</a>
      <a href="/property-worth" class="btn-gold" style="font-family:var(--font-sans); font-size:0.85rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; background:#b98229; color:#ffffff; padding:0.85rem 2rem; text-decoration:none; display:inline-block; border-radius:10px;">What's your property worth?</a>
    </div>
  </div>
</section>

<!-- WHY THIS AREA -->
<section style="background:var(--color-base, #f2ead4); padding:80px 24px;">
  <div style="max-width:800px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1rem;">Local Expertise</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.8rem, 3.5vw, 2.8rem); font-weight:300; line-height:1.2; color:#191817; margin-bottom:1.75rem;">QUT campus suburb with character homes and urban village living.</h2>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.8; color:#4a4540; margin-bottom:1.25rem;">
      Kelvin Grove is one of inner Brisbane's most layered suburbs. The QUT Kelvin Grove campus and the adjoining Creative Industries Precinct bring a steady professional and academic population to the area, while the older residential streets to the north hold some of the suburb's most sought-after character homes. Victoria Park forms the southern boundary, giving residents a direct off-road connection to the CBD and the inner-city parkland network.
    </p>
<!-- APPRAISAL FORM -->
<div style="background:#fff; border-left:4px solid #b98229; padding:2rem 2rem 1.75rem; margin:2rem 0; border-radius:16px;">
  <p style="font-family:var(--font-sans); font-size:0.72rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#b98229; margin-bottom:0.5rem;">Free Appraisal</p>
  <h3 style="font-family:var(--font-serif); font-size:1.4rem; font-weight:300; color:#191817; margin-bottom:1.25rem; line-height:1.25;">Find out what your Kelvin Grove home is worth.</h3>
  <form method="POST" action="https://formspree.io/f/xnjgedwp" style="display:flex; flex-direction:column; gap:0.75rem;">
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" />
    <input type="hidden" name="_next" value="https://danielgierach.com/thank-you?from=suburb-appraisal" />
    <input type="hidden" name="_subject" value="Appraisal enquiry: Kelvin Grove" />
    <input type="hidden" name="_source" value="kelvin-grove" />
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;" class="suburb-form-grid">
      <input type="text" name="name" required placeholder="Your name" autocomplete="name"
        style="font-family:var(--font-sans); font-size:0.88rem; padding:0.7rem 0.9rem; border:1px solid rgba(28,25,23,0.18); background:#faf9f7; color:#191817; outline:none; width:100%; box-sizing:border-box;" />
      <input type="email" name="email" required placeholder="Email address" autocomplete="email"
        style="font-family:var(--font-sans); font-size:0.88rem; padding:0.7rem 0.9rem; border:1px solid rgba(28,25,23,0.18); background:#faf9f7; color:#191817; outline:none; width:100%; box-sizing:border-box;" />
    </div>
    <input type="text" name="property_address" required placeholder="Your Kelvin Grove address (street + number)"
      style="font-family:var(--font-sans); font-size:0.88rem; padding:0.7rem 0.9rem; border:1px solid rgba(28,25,23,0.18); background:#faf9f7; color:#191817; outline:none; width:100%; box-sizing:border-box;" />
    <div style="display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
      <button type="submit"
        style="font-family:var(--font-sans); font-size:0.78rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; background:#b98229; color:#191817; padding:0.75rem 1.75rem; border:none; cursor:pointer; white-space:nowrap;border-radius:8px;">
        Request my free appraisal
      </button>
      <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:300; color:#78716c; margin:0; line-height:1.5;">Daniel will be in touch promptly. No pressure.</p>
    </div>
  </form>
</div>
<style>
  @media (max-width: 540px) {
    .suburb-form-grid { grid-template-columns: 1fr !important; }
  }
</style>
<!-- END APPRAISAL FORM -->
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.8; color:#4a4540; margin-bottom:1.25rem;">
      The Kelvin Grove Urban Village, developed from the early 2000s, fundamentally changed the suburb's composition. Townhouses, terraces and contemporary apartments now sit alongside older character streets, creating a suburb that attracts both the professional buyer looking for a quality apartment close to the CBD and the buyer who wants an original character home with genuine heritage presence. The two segments trade differently and require different campaign strategies.
    </p>
    <div style="display:flex; gap:1.5rem; flex-wrap:wrap;">
      <div style="flex:1; min-width:200px; background:#fff; padding:1.75rem; border-left:3px solid #b98229; border-radius:16px;">
        <p style="font-family:var(--font-serif); font-size:1.1rem; font-weight:400; color:#191817; margin-bottom:0.4rem;">Kelvin Grove Specialist</p>
        <p style="font-family:var(--font-sans); font-size:0.85rem; font-weight:300; color:#6b6560;">Inner Brisbane</p>
      </div>
      <div style="flex:1; min-width:200px; background:#fff; padding:1.75rem; border-left:3px solid #b98229; border-radius:16px;">
        <p style="font-family:var(--font-serif); font-size:1.1rem; font-weight:400; color:#191817; margin-bottom:0.4rem;">Character Homes and Urban Village</p>
        <p style="font-family:var(--font-sans); font-size:0.85rem; font-weight:300; color:#6b6560;">QUT precinct, Victoria Park corridor</p>
      </div>
    </div>
    <p style="font-size:0.82rem;color:#78716c;margin-top:2rem;">Also selling in: <a href="/suburbs/spring-hill" style="color:#b98229;">Spring Hill</a>, <a href="/suburbs/red-hill" style="color:#b98229;">Red Hill</a>, <a href="/suburbs/paddington" style="color:#b98229;">Paddington</a>, <a href="/suburbs/lutwyche" style="color:#b98229;">Lutwyche</a>, <a href="/suburbs/bowen-hills" style="color:#b98229;">Bowen Hills</a>.</p>
  </div>
</section>

<!-- FAQ -->
<section style="background:var(--color-base, #f2ead4); padding:40px 24px 80px;">
  <div style="max-width:800px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1rem;">FAQ</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.8rem, 3.5vw, 2.8rem); font-weight:300; line-height:1.2; color:#191817; margin-bottom:2.5rem;">Common questions about Kelvin Grove.</h2>
    <div style="display:flex; flex-direction:column;">
      <details style="border-bottom:1px solid rgba(72,72,72,0.15); padding:1.25rem 0;">
        <summary style="font-family:var(--font-serif); font-size:1.05rem; cursor:pointer; color:#191817; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          What drives property values in Kelvin Grove Brisbane?
          <span style="color:#b98229; font-size:1.4rem; flex-shrink:0;">+</span>
        </summary>
        <p style="font-family:var(--font-sans); font-size:0.9rem; line-height:1.75; color:#4a4540; margin-top:0.75rem; padding-right:2rem;">Kelvin Grove's character home market and modern apartment sector trade at quite different price points. Heritage cottages and renovated Queenslanders in the upper parts of the suburb attract strong competition from buyers who have specifically chosen the suburb for its character and CBD proximity. Contact Daniel for a current appraisal on your specific property.</p>
      </details>
      <details style="border-bottom:1px solid rgba(72,72,72,0.15); padding:1.25rem 0;">
        <summary style="font-family:var(--font-serif); font-size:1.05rem; cursor:pointer; color:#191817; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          How long does it take to sell a home in Kelvin Grove?
          <span style="color:#b98229; font-size:1.4rem; flex-shrink:0;">+</span>
        </summary>
        <p style="font-family:var(--font-sans); font-size:0.9rem; line-height:1.75; color:#4a4540; margin-top:0.75rem; padding-right:2rem;">Well-presented character homes in Kelvin Grove typically sell within 25 to 40 days when priced on recent comparable evidence. The urban village apartment market is more varied, tracking 30 to 55 days depending on the building, floor plan and amenity offering.</p>
      </details>
      <details style="border-bottom:1px solid rgba(72,72,72,0.15); padding:1.25rem 0;">
        <summary style="font-family:var(--font-serif); font-size:1.05rem; cursor:pointer; color:#191817; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          What is the lifestyle like in Kelvin Grove Brisbane?
          <span style="color:#b98229; font-size:1.4rem; flex-shrink:0;">+</span>
        </summary>
        <p style="font-family:var(--font-sans); font-size:0.9rem; line-height:1.75; color:#4a4540; margin-top:0.75rem; padding-right:2rem;">Kelvin Grove offers a rare combination of inner-city proximity and genuine neighbourhood character. Victoria Park sits to the south, connecting the suburb to the CBD precinct on foot or by bike. The QUT Creative Industries campus brings consistent energy to the area, and the urban village precinct has created a walkable hub that older parts of the suburb lacked.</p>
      </details>
      <details style="padding:1.25rem 0;">
        <summary style="font-family:var(--font-serif); font-size:1.05rem; cursor:pointer; color:#191817; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          What types of homes are in Kelvin Grove?
          <span style="color:#b98229; font-size:1.4rem; flex-shrink:0;">+</span>
        </summary>
        <p style="font-family:var(--font-sans); font-size:0.9rem; line-height:1.75; color:#4a4540; margin-top:0.75rem; padding-right:2rem;">Kelvin Grove has two distinct housing layers. The older, established parts of the suburb contain workers cottages, Queenslanders and character homes from the early to mid twentieth century. The Kelvin Grove Urban Village introduced a significant volume of townhouses, terraces and apartments from the early 2000s. These two markets attract different buyer profiles and are priced and campaigned differently.</p>
      </details>
    </div>
  </div>
</section>

