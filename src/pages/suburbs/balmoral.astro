  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the median house price in Balmoral?",
      "acceptedAnswer": { "@type": "Answer", "text": "Balmoral's median house price is approximately $1.9 million as of early 2026, making it one of Brisbane's most prestigious inner-east addresses. Clifftop and riverfront properties at the top end regularly command multiples of the median." }
    },
    {
      "@type": "Question",
      "name": "How long does it take to sell a home in Balmoral?",
      "acceptedAnswer": { "@type": "Answer", "text": "Well-priced Balmoral properties typically sell within 20 to 35 days. The suburb's limited turnover and consistently high buyer demand mean well-presented homes attract serious, qualified buyers relatively quickly." }
    },
    {
      "@type": "Question",
      "name": "What is the buyer profile for Balmoral?",
      "acceptedAnswer": { "@type": "Answer", "text": "Balmoral attracts primarily owner-occupier families drawn by the Balmoral State School catchment, the Wynnum Road dining strip and the elevated lifestyle. A significant portion of buyers are upsizing from nearby suburbs such as Hawthorne and Morningside." }
    },
    {
      "@type": "Question",
      "name": "Is Balmoral good value compared to neighbouring suburbs?",
      "acceptedAnswer": { "@type": "Answer", "text": "Balmoral sits at a premium to most surrounding suburbs, reflecting its hillside position, views and school catchment desirability. Buyers who prioritise long-term capital growth and lifestyle tend to view that premium as justified given the suburb's consistent performance." }
    }
  ]
})}</script>

