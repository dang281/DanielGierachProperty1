<!-- ═══════════════════════════════════════════════
     SECTION 2: WHY THIS AREA
════════════════════════════════════════════════ -->
<section style="background:var(--color-base, #f2ead4); padding:80px 24px;">
  <div style="max-width:800px; margin:0 auto;">
    <p style="font-family:var(--font-sans); font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#b98229; margin-bottom:1rem;">Local Expertise</p>
    <h2 style="font-family:var(--font-serif); font-size:clamp(1.8rem, 3.5vw, 2.8rem); font-weight:300; line-height:1.2; color:#191817; margin-bottom:1.75rem;">Family living on the Chelmer corridor.</h2>
    <p style="font-family:var(--font-sans); font-size:1rem; font-weight:300; line-height:1.8; color:#4a4540; margin-bottom:1.25rem;">
      Graceville sits roughly seven kilometres south-west of the CBD on the inner corridor between Chelmer and Sherwood. It is a suburb built on a genuine family identity: good state schools, a direct rail connection, and a housing stock of pre-war character homes on blocks that are generous by inner-Brisbane standards. It trades at a meaningful discount to Chelmer, which makes it the natural target for buyers who want the inner south-west lifestyle at a more accessible entry point.
    </p>
<!-- APPRAISAL FORM -->
<div style="background:#fff; border-left:4px solid #b98229; padding:2rem 2rem 1.75rem; margin:2rem 0; border-radius:16px;">
