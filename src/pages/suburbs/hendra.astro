<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What drives property values in Hendra?",
      "acceptedAnswer": { "@type": "Answer", "text": "Hendra property values are driven by its position in Brisbane's inner-north prestige corridor, the quality of its character housing stock, and the buyer overflow from Ascot and Hamilton. Homes on elevated or corner blocks with character features consistently outperform. The suburb's school catchment and proximity to Eagle Farm and Doomben racecourses give it a distinct identity within the northern prestige market." }
    },
    {
      "@type": "Question",
      "name": "How long does it take to sell a home in Hendra?",
      "acceptedAnswer": { "@type": "Answer", "text": "Well-presented Hendra homes typically sell within 22 to 35 days. The suburb benefits from Ascot and Hamilton buyer overflow, with buyers who have been active in those markets for months arriving at Hendra with strong purchase intent and pre-approved finance." }
    },
    {
      "@type": "Question",
      "name": "What is the lifestyle like in Hendra?",
