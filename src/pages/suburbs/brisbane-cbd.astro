<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the median apartment price in Brisbane CBD?",
      "acceptedAnswer": { "@type": "Answer", "text": "Brisbane CBD property values vary by block size, position and condition, reflecting the predominantly apartment-based market. Prices vary widely depending on floor level, views, building quality and whether the property has a car park." }
    },
    {
      "@type": "Question",
      "name": "How long does it take to sell a CBD apartment in Brisbane?",
      "acceptedAnswer": { "@type": "Answer", "text": "Well-priced Brisbane CBD apartments typically sell within 25 to 45 days. Unique floor plans, higher floors and views tend to attract faster interest, while standard mid-rise stock may take longer to find the right buyer." }
    },
    {
      "@type": "Question",
      "name": "What is the rental demand like in Brisbane CBD?",
      "acceptedAnswer": { "@type": "Answer", "text": "Brisbane CBD continues to see strong rental demand from professionals, international students and short-stay tenants ahead of the 2032 Olympics. Vacancy rates have remained low, supporting investor confidence in the precinct." }
    },
    {
      "@type": "Question",
      "name": "Is buying in Brisbane CBD a good investment right now?",
      "acceptedAnswer": { "@type": "Answer", "text": "CBD apartments offer attractive rental yields compared to houses in the inner east, and upcoming infrastructure investment tied to the 2032 Games is expected to support ongoing demand. Buyers should assess body corporate costs, building age and supply levels in their chosen precinct carefully." }
    }
  ]
})}</script>

