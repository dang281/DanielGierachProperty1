        <p style="font-family:var(--font-sans); font-size:0.85rem; font-weight:300; color:#6b6560;">Inner South Riverside</p>
      </div>
      <div style="flex:1; min-width:200px; background:#fff; padding:1.75rem; border-left:3px solid #b98229;">
