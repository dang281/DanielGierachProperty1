  "description": "Daniel Gierach is a real estate agent serving Bowen Hills and Inner Brisbane.",
  "url": "https://danielgierach.com/suburbs/bowen-hills",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://danielgierach.com" },
      { "@type": "ListItem", "position": 2, "name": "Bowen Hills", "item": "https://danielgierach.com/suburbs/bowen-hills" }
    ]
  }
})}</script>
<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "RealEstateAgent"],
  "name": "Daniel Gierach, Ray White The Collective",
  "description": "Real estate agent serving Bowen Hills and Inner Brisbane. Apartment-led growth precinct anchored by the showgrounds and the train.",
  "url": "https://danielgierach.com/suburbs/bowen-hills",
  "telephone": "+61412523821",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bowen Hills",
    "addressRegion": "QLD",
    "postalCode": "4006",
    "addressCountry": "AU"
