  "areaServed": [{"@type":"Place","name":"Corinda QLD 4075"}],
  "knowsAbout": ["Corinda real estate","Inner Brisbane property values","Corinda home values"],
  "sameAs": ["https://www.raywhite.com/agents/agent/daniel-gierach-88889915", "https://www.realestate.com.au/agent/daniel-gierach-3819232"]
