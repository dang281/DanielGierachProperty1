      { "@type": "ListItem", "position": 2, "name": "Corinda", "item": "https://danielgierach.com/suburbs/corinda" }
    ]
  }
})}</script>
<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "RealEstateAgent"],
  "@id": "https://danielgierach.com/#business",
  "name": "Daniel Gierach, Ray White Bulimba",
  "description": "Real estate agent serving Corinda and Inner Brisbane. Character family suburb on the inner south-west corridor bordering Chelmer and Graceville.",
  "url": "https://danielgierach.com/suburbs/corinda",
  "telephone": "+61412523821",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Corinda",
    "addressRegion": "QLD",
    "postalCode": "4075",
    "addressCountry": "AU"
