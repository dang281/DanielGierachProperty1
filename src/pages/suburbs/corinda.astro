<Method suburb="Corinda" />

<!-- CROSS-LINK TO SELLING GUIDE -->
<section style="background:var(--color-surface-0);padding:3rem 0;border-top:1px solid rgba(28,25,23,0.08);">
  <div style="max-width:800px;margin:0 auto;padding:0 24px;text-align:center;">
    <p style="font-family:var(--font-sans);font-size:0.88rem;font-weight:300;line-height:1.7;color:#6b6560;">
      Planning to sell? Read the full guide:
      <a href="/insights/selling-in-corinda" style="color:#c4912a;font-weight:600;">How to Sell Your Home in Corinda &rarr;</a>
    </p>
    <p style="font-family:var(--font-sans);font-size:0.88rem;font-weight:300;line-height:1.7;color:#6b6560;margin-top:0.75rem;">
      Want a starting-point estimate?
      <a href="/tools/valuation" style="color:#c4912a;font-weight:600;">Get an instant property valuation &rarr;</a>
    </p>
    <div style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid rgba(72,72,72,0.1);">
      <p style="font-family:var(--font-sans);font-size:0.72rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#78716c;margin-bottom:0.5rem;">Free seller tools</p>
      <p style="font-family:var(--font-sans);font-size:0.88rem;font-weight:300;line-height:1.8;color:#6b6560;">
        <a href="/tools/selling-costs" style="color:#c4912a;font-weight:600;">Selling costs calculator</a> &middot;
        <a href="/tools/cgt-timing" style="color:#c4912a;font-weight:600;">CGT timing calculator</a> &middot;
        <a href="/tools/settlement-date" style="color:#c4912a;font-weight:600;">Settlement date calculator</a>
      </p>
