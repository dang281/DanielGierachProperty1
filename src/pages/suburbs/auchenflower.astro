      { "@type": "ListItem", "position": 2, "name": "Auchenflower", "item": "https://danielgierach.com/suburbs/auchenflower" }
    ]
  }
})}</script>
<script type="application/ld+json">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "RealEstateAgent"],
  "name": "Daniel Gierach, Ray White The Collective",
  "description": "Real estate agent serving Auchenflower and Inner West Brisbane. Hospital-precinct family suburb with strong school catchments.",
