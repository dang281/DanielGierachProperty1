---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';

const episodes = [
  { id: 'ZNs4fe4cvso', title: 'Designing an Impact Driven Life', guest: 'Tom Allen', org: 'Impact Boom', description: 'Industrial design founder on aligning business with purpose and building sustainable communities.' },
  { id: 'tBk3eT3AFNM', title: 'Rebuilding Lives After Domestic Violence', guest: 'Annie', org: 'Lovewell Foundation', description: 'Survivor turned advocate on empowering vulnerable women through community and empathy.' },
  { id: 'qIc32Wdlfe0', title: 'Safe Spaces for Homelessness', guest: 'Norm', org: 'Beddown', description: 'Converting unused spaces into shelters and launching Queensland expansion through Change 47.' },
  { id: 'u-9B-us1CQk', title: "Mental Health Expert Discusses 'Good'", guest: 'Tina', org: 'Career Development Center', description: '30+ years of workplace mental health experience focused on self-compassion and wellbeing.' },
  { id: '2QzqzchA7Jc', title: "Following 'Good' Throughout History", guest: 'Paul Baker', org: '', description: 'History educator on how historians shape our understanding of goodness across time.' },
  { id: 'YR0OrmKj1Is', title: 'Why Love is the Next Disruptor', guest: 'Yas Grigaliunas', org: 'Circonomy', description: 'Circular economy pioneer on prioritising people, planet, and purpose in business.' },
  { id: '', title: 'Changing the Stigma Around Mental Health', guest: 'Ed & Dan', org: 'Trademutt / TIACS', description: 'Mental health advocates on normalising conversations in male-dominated industries.' },
  { id: '', title: 'Washing Clothes & Connecting Communities', guest: 'Nic Marchesi', org: 'Orange Sky', description: 'Social enterprise founder on building trust and connection through free laundry services.' },
  { id: '', title: 'Empathy Masterclass', guest: 'Leanne Butterworth', org: 'Empathy First', description: 'Exploring emotional, cognitive, and healthy types of empathy in leadership and life.' },
  { id: '', title: 'Social Justice, Measuring Impact & Stoicism', guest: 'Mike Davis', org: 'Humans of Purpose', description: 'Impact strategy and Stoic principles — on persistence, purpose, and measuring what matters.' },
  { id: '', title: 'Creating a Mental Health Revolution', guest: 'Cooper Chapman', org: '', description: 'Former professional surfer on advocating mental wellness through kindness and community.' },
  { id: '', title: 'Balancing Impact and Financial Return', guest: 'Alex Debney', org: 'Conscious Investments', description: 'Impact investment, addressing greenwashing, and building transparent purpose-driven portfolios.' },
  { id: '', title: 'Empowering Underrepresented Groups', guest: 'Tanya Andrews', org: '', description: 'Multi-entrepreneur on supporting underrepresented populations through enterprise and advocacy.' },
  { id: '', title: 'Breathwork for Physical and Mental Wellbeing', guest: 'Rory Warnock', org: '', description: 'Breathwork specialist on conscious breathing as a tool for mental and physical health.' },
  { id: '', title: 'Using AI to Shift from Fear to Love', guest: 'Nicole Gibson', org: 'Love Out Loud', description: 'Mental health advocacy through emotional intelligence and technology.' },
  { id: '', title: 'Lifelong Pursuit of Social Impact', guest: 'Tom Dawkins', org: 'StartSomeGood', description: 'Purpose-driven entrepreneurship and bridging funding gaps for social ventures.' },
  { id: '', title: 'Exploring Science, Spirituality & Wellness', guest: 'Nicholas Van Dam', org: 'University of Melbourne', description: 'Contemplative studies director on mental health through reflection and mindfulness.' },
  { id: '', title: 'Revolutionising Health with Digital Solutions', guest: 'Matt Davey', org: 'Mend', description: 'Health platform founder on consumer-focused digital health innovation.' },
  { id: '', title: 'Cultivating Confidence on Gender Equity', guest: 'Fiona Pearman', org: 'Quantum Impact Group', description: 'Women in leadership — empowerment, systemic bias, and building inclusive organisations.' },
];
---

<Layout title="Chasing Good Podcast | Cirqle Group" description="Inspiring conversations with social entrepreneurs, scientists, and leaders working to make a difference. The Chasing Good podcast from Cirqle Group.">
  <Navbar />
  <PageHero
    badge="Chasing Good Podcast"
    title="Inspiring Stories"
    titleHighlight="That Matter"
    subtitle="Conversations with social entrepreneurs, historians, scientists, and experts showcasing how incredible work is making a difference in communities."
    cta={{ label: 'Watch on YouTube', href: 'https://www.youtube.com/@CirqleGroup/videos' }}
  />

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {episodes.map(ep => (
          <div class={`group rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 flex flex-col ${ep.id ? 'cursor-pointer' : ''}`}>
            {ep.id ? (
              <a href={`https://www.youtube.com/watch?v=${ep.id}`} target="_blank" rel="noopener noreferrer" class="block">
                <div class="aspect-video relative overflow-hidden bg-[#1F2848]">
                  <img
                    src={`https://img.youtube.com/vi/${ep.id}/hqdefault.jpg`}
                    alt={ep.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-black/30 flex items-center justify-center group-hover:bg-black/20 transition-colors">
                    <div class="w-12 h-12 rounded-full bg-[#26A8FF] flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg">
                      <i class="fa-solid fa-play text-white pl-0.5"></i>
                    </div>
                  </div>
                </div>
              </a>
            ) : (
              <div class="aspect-video bg-gradient-to-br from-[#1F2848] to-[#203B63] flex items-center justify-center">
                <i class="fa-solid fa-podcast text-white/20 text-5xl"></i>
              </div>
            )}
            <div class="p-5 flex flex-col flex-grow">
              <h3 class="font-bold text-[#1F2848] mb-2 leading-snug">{ep.title}</h3>
              <p class="text-[#26A8FF] text-xs font-medium mb-3">{ep.guest}{ep.org ? ` · ${ep.org}` : ''}</p>
              <p class="text-[#383E4F] text-sm leading-relaxed flex-grow">{ep.description}</p>
              {ep.id && (
                <a href={`https://www.youtube.com/watch?v=${ep.id}`} target="_blank" rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-1.5 text-[#26A8FF] text-sm font-medium hover:gap-2.5 transition-all">
                  Watch Episode <i class="fa-solid fa-arrow-right text-xs"></i>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-14">
        <a href="https://www.youtube.com/@CirqleGroup/videos" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#060E23] text-white font-semibold px-8 py-4 rounded-md hover:bg-[#1F2848] transition-colors">
          <i class="fa-brands fa-youtube text-red-500"></i>
          All Episodes on YouTube
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
