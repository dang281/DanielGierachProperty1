---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | Daniel Gierach Property" description="Thank you for getting in touch. Daniel will be in touch within 2 hours.">

<style>
  @keyframes checkDraw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes ringPulse {
    0%   { transform: scale(1);   opacity: 0.6; }
    60%  { transform: scale(1.6); opacity: 0; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position: 400px 0; }
  }

  .ty-hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0806;
    padding: 7rem 2rem 5rem;
  }
  .ty-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(15%) brightness(0.28);
  }
  .ty-bg-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 40%, rgba(197,160,60,0.09) 0%, transparent 65%),
                linear-gradient(to bottom, rgba(10,8,6,0.3) 0%, rgba(10,8,6,0.55) 100%);
  }
  .ty-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 640px;
  }

  /* Check animation */
  .check-wrap {
    position: relative;
    width: 72px;
    height: 72px;
    margin: 0 auto 2.25rem;
  }
  .check-ring-pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(197,160,60,0.5);
    animation: ringPulse 1.8s ease-out 0.3s forwards;
  }
  .check-ring-pulse-2 {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(197,160,60,0.3);
    animation: ringPulse 1.8s ease-out 0.6s forwards;
  }
  .check-circle {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(197,160,60,0.1);
    border: 1.5px solid rgba(197,160,60,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .check-svg polyline {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: checkDraw 0.5s cubic-bezier(0.4,0,0.2,1) 0.2s forwards;
  }

  .ty-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #c5a03c;
    display: block;
    margin-bottom: 1.25rem;
    animation: fadeUp 0.6s ease 0.5s both;
  }
  .ty-h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 400;
    color: #f0ece4;
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s ease 0.65s both;
  }
  .ty-h1 em { font-style: italic; color: #c5a03c; }
  .ty-sub {
    font-size: 1rem;
    color: rgba(240,236,228,0.7);
    line-height: 1.85;
    max-width: 44ch;
    margin: 0 auto 2.75rem;
    animation: fadeUp 0.6s ease 0.8s both;
  }
  .ty-sub a {
    color: #c5a03c;
    text-decoration: none;
    font-weight: 600;
  }

  /* Gold shimmer divider */
  .ty-divider {
    width: 60px;
    height: 1px;
    margin: 0 auto 2.75rem;
    background: linear-gradient(90deg, transparent, #c5a03c, transparent);
    background-size: 200% 100%;
    animation: fadeUp 0.6s ease 0.95s both, shimmer 2.5s ease 1.5s infinite;
  }

  /* Commitment badge */
  .ty-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1.25rem;
    border: 1px solid rgba(197,160,60,0.25);
    background: rgba(197,160,60,0.06);
    animation: fadeUp 0.6s ease 1s both;
  }
  .ty-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #c5a03c;
    animation: ringPulse 2s ease-in-out 1.5s infinite;
  }
  .ty-badge span {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(240,236,228,0.75);
  }

  /* What happens next */
  .ty-next {
    background: var(--color-base);
    padding: 6rem 2rem;
  }
  .ty-next-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 1px;
    background: rgba(28,25,23,0.1);
    max-width: 900px;
    margin: 3.5rem auto 0;
  }
  .ty-next-item {
    background: var(--color-base);
    padding: 2.5rem 2rem;
    position: relative;
  }
  .ty-next-num {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 300;
    color: #c5a03c;
    opacity: 0.2;
    line-height: 1;
    margin-bottom: 1.25rem;
  }
  .ty-next-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: #1c1917;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }
  .ty-next-body {
    font-size: 0.82rem;
    color: #78716c;
    line-height: 1.75;
  }

  /* Quote */
  .ty-quote {
    background: #1c1917;
    padding: 5rem 2rem;
    text-align: center;
  }
  .ty-quote-text {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2.5vw, 1.55rem);
    font-weight: 300;
    font-style: italic;
    color: rgba(240,236,228,0.88);
    line-height: 1.7;
    max-width: 52ch;
    margin: 0 auto 2rem;
  }
  .ty-quote-attr {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #c5a03c;
  }

  /* Explore */
  .ty-explore {
    background: var(--color-surface-0);
    padding: 5.5rem 2rem;
    border-top: 1px solid rgba(28,25,23,0.08);
  }
  .ty-explore-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 1rem;
    max-width: 900px;
    margin: 3rem auto 0;
  }
  .ty-explore-card {
    background: #fff;
    padding: 1.75rem;
    text-decoration: none;
    display: block;
    border: 1px solid rgba(28,25,23,0.08);
    transition: border-color 0.2s, transform 0.2s;
  }
  .ty-explore-card:hover {
    border-color: #c5a03c;
    transform: translateY(-2px);
  }
  .ty-explore-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c5a03c;
    margin-bottom: 0.5rem;
  }
  .ty-explore-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: #1c1917;
    margin-bottom: 0.4rem;
  }
  .ty-explore-desc {
    font-size: 0.78rem;
    color: #78716c;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .ty-next-grid, .ty-explore-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- ══════════════════════════════════
     HERO
══════════════════════════════════ -->
<section class="ty-hero">

  <img
    src="https://images.unsplash.com/photo-1560185007-c5ca9d2c014d?w=1440&q=60&fm=webp&auto=format"
    alt=""
    class="ty-bg-img"
    aria-hidden="true"
    fetchpriority="high"
  />
  <div class="ty-bg-gradient"></div>

  <div class="ty-content">

    <!-- Animated check -->
    <div class="check-wrap">
      <div class="check-ring-pulse"></div>
      <div class="check-ring-pulse-2"></div>
      <div class="check-circle">
        <svg class="check-svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#c5a03c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
    </div>

    <p class="ty-notified" style="font-family:var(--font-sans);font-size:0.72rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(197,160,60,0.7);margin-bottom:0.75rem;">Daniel has been notified.</p>

    <span class="ty-eyebrow">Message Received</span>

    <h1 class="ty-h1">
      Good move.<br/>
      <em>Daniel will be in touch shortly.</em>
    </h1>

    <p class="ty-sub">
      Daniel personally reviews every enquiry. No call centres, no auto-replies. Expect to hear from him within 2 hours, or call directly on <a href="tel:+61412523821">0412 523 821</a>.
    </p>

    <div class="ty-divider"></div>

    <div class="ty-badge">
      <div class="ty-badge-dot"></div>
      <span>Typically responds within 2 hours &nbsp;·&nbsp; 7 days a week</span>
    </div>

  </div>
</section>


<!-- ══════════════════════════════════
     QUOTE (above next steps)
══════════════════════════════════ -->
<section class="ty-quote">
  <p class="ty-quote-text">
    "Dan's professionalism and genuine approach stood out immediately. He explained every step clearly, set expectations up front, and kept me updated without me ever having to chase. The result went well above and beyond expectations."
  </p>
  <p class="ty-quote-attr">Past Seller &nbsp;·&nbsp; Brisbane Inner East</p>
</section>

<!-- ══════════════════════════════════
     WHAT HAPPENS NEXT
══════════════════════════════════ -->
<section class="ty-next">
  <div style="max-width:900px;margin:0 auto;text-align:center;">
    <p style="font-family:var(--font-sans);font-size:0.72rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#c5a03c;margin-bottom:0.75rem;">What Happens Next</p>
    <h2 style="font-family:var(--font-serif);font-size:clamp(1.7rem,3vw,2.5rem);font-weight:400;color:#1c1917;line-height:1.15;">You're in good hands.</h2>
  </div>

  <div class="ty-next-grid">

    <div class="ty-next-item">
      <div class="ty-next-num">1</div>
      <p class="ty-next-title">Daniel reads your message</p>
      <p class="ty-next-body">Every enquiry lands directly with Daniel. No filtering, no delegation. He reads it himself.</p>
    </div>

    <div class="ty-next-item">
      <div class="ty-next-num">2</div>
      <p class="ty-next-title">He'll be in touch within 2 hours</p>
      <p class="ty-next-body">Available 7 days. If it's urgent, call <a href="tel:+61412523821" style="color:#c5a03c;text-decoration:none;font-weight:600;">0412 523 821</a> directly.</p>
    </div>

    <div class="ty-next-item">
      <div class="ty-next-num">3</div>
      <p class="ty-next-title">You get a clear, honest number for your home</p>
      <p class="ty-next-body">A frank, well-researched opinion of what your property could achieve. No fluff, no pressure.</p>
    </div>

  </div>
</section>


<!-- ══════════════════════════════════
     EXPLORE WHILE YOU WAIT
══════════════════════════════════ -->
<section class="ty-explore">
  <div style="max-width:900px;margin:0 auto;text-align:center;">
    <p style="font-family:var(--font-sans);font-size:0.72rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#c5a03c;margin-bottom:0.75rem;">While You Wait</p>
    <h2 style="font-family:var(--font-serif);font-size:clamp(1.4rem,2.5vw,2rem);font-weight:400;color:#1c1917;line-height:1.2;">Explore the site</h2>
  </div>

  <div class="ty-explore-grid">

    <a href="/tools/selling-costs" class="ty-explore-card">
      <p class="ty-explore-label">Seller Tool</p>
      <p class="ty-explore-title">What will selling actually cost?</p>
      <p class="ty-explore-desc">See your estimated net proceeds after agent fees, marketing and other selling costs.</p>
    </a>

    <a href="/listings" class="ty-explore-card">
      <p class="ty-explore-label">Listings</p>
      <p class="ty-explore-title">View Current Properties</p>
      <p class="ty-explore-desc">Properties currently for sale and recently sold in your area.</p>
    </a>

    <a href="/tools" class="ty-explore-card">
      <p class="ty-explore-label">Tools</p>
      <p class="ty-explore-title">Free Property Calculators</p>
      <p class="ty-explore-desc">Selling costs, stamp duty, mortgage repayments and more.</p>
    </a>

  </div>
</section>

<script>
  document.body.classList.add('thankyou-page');

  (function() {
    const from = new URLSearchParams(window.location.search).get('from');
    if (from === 'report') {
      const eyebrow = document.querySelector('.ty-eyebrow');
      const h1 = document.querySelector('.ty-h1');
      const sub = document.querySelector('.ty-sub');
      const badge = document.querySelector('.ty-badge span');
      const next1title = document.querySelectorAll('.ty-next-title')[0];
      const next1body = document.querySelectorAll('.ty-next-body')[0];
      const next2title = document.querySelectorAll('.ty-next-title')[1];
      const next2body = document.querySelectorAll('.ty-next-body')[1];
      const next3title = document.querySelectorAll('.ty-next-title')[2];
      const next3body = document.querySelectorAll('.ty-next-body')[2];

      if (eyebrow) eyebrow.textContent = 'Report on Its Way';
      const notified = document.querySelector('.ty-notified') as HTMLElement;
      if (notified) notified.textContent = 'Daniel has been notified.';
      if (h1) h1.innerHTML = 'Good move.<br/><em>Your report will be in your inbox shortly.</em>';
      if (sub) sub.innerHTML = 'Your report is being created and will be in your inbox shortly. If you have any questions, call Daniel on <a href="tel:+61412523821">0412 523 821</a>.';
      if (badge) badge.textContent = 'Report typically sent within a few hours · 7 days a week';
      if (next1title) next1title.textContent = 'Daniel reviews your property';
      if (next1body) next1body.textContent = 'He looks at your address, property type, and comparable recent sales to build an accurate picture.';
      if (next2title) next2title.textContent = 'He prepares your report';
      if (next2body) next2body.innerHTML = 'A personalised value range based on recent sales in your area. Usually ready within a few hours. If it\'s urgent, call <a href="tel:+61412523821" style="color:#c5a03c;text-decoration:none;font-weight:600;">0412 523 821</a>.';
      if (next3title) next3title.textContent = 'You receive honest advice';
      if (next3body) next3body.textContent = 'A clear, frank assessment of what your property could achieve. No fluff, no pressure.';
    }

    if (from === 'appraisal') {
      const eyebrow = document.querySelector('.ty-eyebrow');
      const h1 = document.querySelector('.ty-h1');
      const sub = document.querySelector('.ty-sub');
      const badge = document.querySelector('.ty-badge span');
      const next1title = document.querySelectorAll('.ty-next-title')[0];
      const next1body = document.querySelectorAll('.ty-next-body')[0];
      const next2title = document.querySelectorAll('.ty-next-title')[1];
      const next2body = document.querySelectorAll('.ty-next-body')[1];
      const next3title = document.querySelectorAll('.ty-next-title')[2];
      const next3body = document.querySelectorAll('.ty-next-body')[2];

      if (eyebrow) eyebrow.textContent = 'Walk Through Requested';
      const notifiedEl = document.querySelector('.ty-notified') as HTMLElement;
      if (notifiedEl) notifiedEl.textContent = 'Daniel has been notified.';
      if (h1) h1.innerHTML = 'Good move.<br/><em>Daniel will confirm your time shortly.</em>';
      if (sub) sub.innerHTML = 'Daniel will confirm the exact time with you shortly. If you need to reach him sooner, call directly on <a href="tel:+61412523821">0412 523 821</a>.';
      if (badge) badge.textContent = 'Confirmation sent shortly · 7 days a week';
      if (next1title) next1title.textContent = 'Daniel reviews your request';
      if (next1body) next1body.textContent = 'He checks your preferred date and time to make sure it works, and confirms availability.';
      if (next2title) next2title.textContent = 'He\'ll confirm the exact time';
      if (next2body) next2body.innerHTML = 'Expect a call or message from Daniel shortly to lock in the details. Or reach him directly on <a href="tel:+61412523821" style="color:#c5a03c;text-decoration:none;font-weight:600;">0412 523 821</a>.';
      if (next3title) next3title.textContent = 'An honest, in-person assessment';
      if (next3body) next3body.textContent = 'Daniel walks through your home and gives you a frank, well-researched opinion of value. Free, no obligation.';
    }
  })();
</script>

</Layout>
