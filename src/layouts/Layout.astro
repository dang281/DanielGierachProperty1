---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import GieMannTheme from '../components/GieMannTheme.astro';
import scheduleData from '../data/seo-schedule.json';
import { GLOBAL_SCHEMA_JSON } from '../data/site-schema.js';

interface Props {
  title?: string;
  description?: string;
  schema?: any;
  preloadImage?: string;
  /** Must match the hero <img> sizes attribute so the preload and the img pick the
      same srcset candidate (a mismatch makes the browser download the hero twice). */
  preloadImageSizes?: string;
  ogImage?: string;
  hideMobileCta?: boolean;
  hideFooterCta?: boolean;
  hideBreadcrumbs?: boolean;
  hideNav?: boolean;
  /** Always-on magazine footer for pages Daniel shares 1:1: hides the sticky
      Message/Call bar + full footer, shows the team contact tiles instead
      (same treatment nav-off applies funnel-wide, but baked into the page). */
  magazineFooter?: boolean;
  draft?: boolean;
  manifest?: string;
  appleTouchIcon?: string;
  faviconSvg?: string;
  appleWebAppTitle?: string;
  canonicalOverride?: string;
}

const {
  title = "Daniel Gierach | Real Estate Agent Brisbane",
  description = 'Brisbane real estate agent at Ray White Bulimba. A documented method for selling homes across Brisbane, with deep local roots in the inner east and south.',
  schema,
  preloadImage,
  preloadImageSizes = '100vw',
  ogImage,
  hideMobileCta = false,
  hideFooterCta = false,
  hideBreadcrumbs = false,
  hideNav = false,
  magazineFooter = false,
  draft = false,
  manifest = '/site.webmanifest',
  appleTouchIcon = '/apple-touch-icon.png?v=4',
  faviconSvg = '/favicon.svg?v=4',
  appleWebAppTitle = 'Daniel Gierach',
  canonicalOverride,
} = Astro.props;

// Social share image: explicit ogImage wins, then preloadImage (resized to 1200w),
// then the default headshot fallback.
const _socialImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `https://danielgierach.com${ogImage}`)
  : (preloadImage
      ? preloadImage.replace(/w=\d+/, 'w=1200').replace(/h=\d+&?/, '').replace(/q=\d+/, 'q=80')
      : 'https://danielgierach.com/img/daniel-headshot.jpg');

// Vercel serves static pages at /path/ (trailing slash). Normalise so the canonical
// always matches the actual served URL, the sitemap, and Google's chosen canonical.
const _rawPath = Astro.url.pathname;
const _canonPath = _rawPath === '/' ? '/' : (_rawPath.endsWith('/') ? _rawPath : `${_rawPath}/`);
// canonicalOverride lets near-duplicate conversion pages (get-an-appraisal,
// property-report, report) consolidate ranking signal onto /property-worth
// while staying fully functional as ad/funnel endpoints.
const canonicalURL = canonicalOverride ?? new URL(_canonPath, 'https://danielgierach.com').href;

// Breadcrumb computation (moved out of template to avoid IIFE/JSX issues)
const _bPath = Astro.url.pathname.replace(/\/$/, '');
const _bParts = _bPath.split('/').filter(Boolean);
const _bSectionLabels: Record<string, string> = {
  suburbs: 'Suburbs', insights: 'Insights', tools: 'Tools',
  listings: 'Listings', contact: 'Contact', walkthrough: 'Book a Walk Through', 'property-worth': 'Property Worth',
};
const breadcrumbs: { label: string; href: string }[] = [{ label: 'Home', href: '/' }];
if (_bParts.length >= 1 && _bSectionLabels[_bParts[0]]) {
  breadcrumbs.push({ label: _bSectionLabels[_bParts[0]], href: `/${_bParts[0]}` });
}
if (_bParts.length >= 2) {
  const _bLabel = _bParts[1].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  breadcrumbs.push({ label: _bLabel, href: _bPath });
}
const showBreadcrumbs = !hideBreadcrumbs && breadcrumbs.length > 1;

// Suburb → Insight linking (#8)
const _suburbMatch = _bPath.match(/^\/suburbs\/(.+)$/);
const _suburbSlug  = _suburbMatch ? _suburbMatch[1] : null;
const _suburbName  = _suburbSlug ? _suburbSlug.replace(/-/g,' ').replace(/\b\w/g,(c:string)=>c.toUpperCase()) : null;

// Insight → Suburb + CTA cross-link (#11)
// Only link when the suburb page actually exists: some selling-in-* slugs
// are not suburbs (selling-in-winter-brisbane, selling-in-brisbane-suburbs).
const _suburbPageFiles = import.meta.glob('../pages/suburbs/*.astro');
const _validSuburbSlugs = new Set(Object.keys(_suburbPageFiles).map(p => p.split('/').pop()!.replace('.astro', '')));
const _insightMatch      = _bPath.match(/^\/insights\/selling-in-(.+)$/);
const _insightSuburbSlug = _insightMatch && _validSuburbSlugs.has(_insightMatch[1]) ? _insightMatch[1] : null;
const _insightSuburbName = _insightSuburbSlug ? _insightSuburbSlug.replace(/-/g,' ').replace(/\b\w/g,(c:string)=>c.toUpperCase()) : null;

// Hub pages pass schema with @type CollectionPage -- exclude from article treatment
const _isHubPage = schema?.["@type"] === "CollectionPage";
// Email capture: show on all insights article pages (not the index or hub pages)
const _isInsightsArticle = _bParts[0] === 'insights' && _bParts.length >= 2 && !_isHubPage;

// Look up publish date from seo-schedule for Article JSON-LD datePublished.
// The file existing under src/pages/insights/ is the source of truth for "published";
// the schedule's `draft` flag is an editorial planning state, not a publish gate.
// Match by slug regardless of the draft flag so every scheduled article gets datePublished.
const _articleSlug = _bParts[1] ?? null;
const _scheduleEntry = _isInsightsArticle && _articleSlug
  ? (scheduleData as any).articles.find((a: any) => a.slug === _articleSlug)
  : null;
const _datePublished: string | null = _scheduleEntry?.publishDate ?? null;

// PERF-010 + LSEO-004: globalSchema lives in src/data/site-schema.js,
// pre-stringified once at module load. See GLOBAL_SCHEMA_JSON import above.
// LSEO-004 also added aggregateRating (5.0/10) and the realestate.com.au
// sameAs entry to that file. The inline copy that previously lived here
// has been removed entirely.
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={faviconSvg} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=4" />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon} />
    <link rel="manifest" href={manifest} />
    <meta name="theme-color" content="#e6d9bd" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={appleWebAppTitle} />
    <link rel="alternate" type="text/plain" href="/llms.txt" />
    <!-- Identity verification for AI systems and search engines -->
    <link rel="me" href="https://www.raywhite.com/agents/agent/daniel-gierach-88889915" />
    <link rel="me" href="https://www.realestate.com.au/agent/daniel-gierach-3819232" />
    <link rel="me" href="https://www.linkedin.com/in/danielgierach" />
    <meta name="description" content={description} />
    <meta name="author" content="Daniel Gierach" />
    <meta name="robots" content={draft ? "noindex, nofollow" : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    {preloadImage && <link rel="preload" as="image" href={preloadImage} imagesrcset={`${preloadImage.replace(/w=\d+/, 'w=640')} 640w, ${preloadImage.replace(/w=\d+/, 'w=1200')} 1200w, ${preloadImage.replace(/w=\d+/, 'w=1440')} 1440w`} imagesizes={preloadImageSizes} fetchpriority="high" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn6.ep.dynamics.net" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://connect.facebook.net" />
    <link rel="preconnect" href="https://unpkg.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Manrope:wght@300;400;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Manrope:wght@300;400;600;700&display=swap" rel="stylesheet" />
    </noscript>
    <!-- Open Graph -->
    <meta property="og:type" content={_isInsightsArticle ? "article" : "website"} />
    <meta property="og:site_name" content="Daniel Gierach Property" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={_socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title}, Daniel Gierach, Real Estate Agent Brisbane Inner East`} />
    <!-- Open Graph article namespace (insights pages only) -->
    {_isInsightsArticle && <meta property="article:author" content="Daniel Gierach" />}
    {_isInsightsArticle && <meta property="article:section" content="Real Estate" />}
    {_isInsightsArticle && _datePublished && <meta property="article:published_time" content={`${_datePublished}T00:00:00+10:00`} />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={_socialImage} />
    <!-- Geo -->
    <meta name="geo.region" content="AU-QLD" />
    <meta name="geo.placename" content="Brisbane" />
    <meta name="geo.position" content="-27.4568;153.0523" />
    <meta name="ICBM" content="-27.4568, 153.0523" />
    <!-- Per-page WebPage JSON-LD with speakable for AI/voice assistants. author + publisher
         reference the canonical Daniel Gierach Person and Ray White Bulimba business so every
         page on the site reinforces the same entity graph. -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": canonicalURL,
      "url": canonicalURL,
      "name": title,
      "description": description,
      "inLanguage": "en-AU",
      "isPartOf": { "@id": "https://danielgierach.com/#website" },
      "author": { "@id": "https://danielgierach.com/#person" },
      "publisher": { "@id": "https://danielgierach.com/#business" },
      ...(preloadImage ? { "primaryImageOfPage": preloadImage.replace(/w=\d+/, 'w=1200').replace(/q=\d+/, 'q=80') } : {}),
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".eyebrow", "title"]
      }
    })} />
    <!-- Global JSON-LD (pre-stringified at module load, see PERF-010) -->
    <script type="application/ld+json" set:html={GLOBAL_SCHEMA_JSON} />
    <!-- Page-level JSON-LD (optional) -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    <!-- Article JSON-LD for all insights articles. author/publisher use @id refs into the
         global graph so AI crawlers resolve every article to the canonical Daniel Gierach
         Person + Ray White Bulimba business entity, not floating duplicates. -->
    {_isInsightsArticle && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "@id": `${canonicalURL}#article`,
        "headline": title,
        "description": description,
        "author": { "@id": "https://danielgierach.com/#person" },
        "publisher": { "@id": "https://danielgierach.com/#business" },
        "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
        "url": canonicalURL,
        "inLanguage": "en-AU",
        "isAccessibleForFree": true,
        "articleSection": "Brisbane Real Estate",
        "image": preloadImage
          ? preloadImage.replace(/w=\d+/, 'w=1200').replace(/q=\d+/, 'q=80')
          : 'https://danielgierach.com/img/daniel-headshot.jpg',
        "about": { "@id": "https://danielgierach.com/#person" },
        ...(_datePublished ? { "datePublished": _datePublished } : {}),
        ...(_datePublished ? { "dateModified": _scheduleEntry?.modifiedDate ?? _datePublished } : {})
      })} />
    )}
    <!-- BreadcrumbList JSON-LD, generated automatically from URL path -->
    {showBreadcrumbs && <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbs.map((crumb, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": crumb.label,
        "item": `https://danielgierach.com${crumb.href}`
      }))
    })} />}
    <!-- GA4: stub defined synchronously so inline onclick="gtag(...)" handlers never fire before gtag exists -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
    </script>
    <!-- Funnel/magazine mode: ?nav=off hides the site header + breadcrumb, then
         persists for the whole session so clicking deeper stays chrome-free.
         ?nav=on clears it. Set by /meet-your-team outbound links. -->
    <script is:inline>
      (function () {
        var p = new URLSearchParams(location.search);
        var mode = p.get('nav');
        try {
          if (mode === 'off') sessionStorage.setItem('navOff', '1');
          else if (mode === 'on') sessionStorage.removeItem('navOff');
        } catch (e) {}
        var on = mode === 'off';
        try { on = on || sessionStorage.getItem('navOff') === '1'; } catch (e) {}
        if (on) document.documentElement.classList.add('nav-off');
      })();
    </script>
    <style is:global>
      html.nav-off #site-header { display: none !important; }
      /* Funnel arrivals read like a clean magazine: no header, no breadcrumb.
         Covers both the standard breadcrumb and the tool-page breadcrumb. */
      html.nav-off nav[aria-label="Breadcrumb"],
      html.nav-off .tool-breadcrumb { display: none !important; }
      /* With the header gone, collapse the top gap it used to clear. Targets
         each page type's first hero block (articles, report/contact, collective,
         listings) plus the tool header. Works desktop and mobile. */
      html.nav-off [style*="padding:8rem 0 3rem"],
      html.nav-off [style*="padding:8rem 0 3.5rem"],
      html.nav-off [style*="padding:8rem 4rem 4rem"],
      html.nav-off .hero-section,
      html.nav-off .listings-hero-pad,
      html.nav-off .pt-32.pb-16 { padding-top: 2.5rem !important; }
      html.nav-off .tool-header { padding-top: 1.25rem !important; }
      /* Heroes that reserve viewport-height leave a gap once the header is gone. */
      html.nav-off .min-h-\[40vh\] { min-height: 0 !important; }
      /* Magazine footer: drop the sticky Message/Call bar and the full footer
         (CTA strip, link lists, socials), show just the team contact tiles
         that Footer.astro keeps hidden for normal visitors. Applies in
         nav-off (funnel) AND on pages that bake it in via magazineFooter. */
      html.nav-off .mobile-call-bar,
      body.mag-footer .mobile-call-bar { display: none !important; }
      html.nav-off footer > *:not(.magazine-footer),
      body.mag-footer footer > *:not(.magazine-footer) { display: none !important; }
      html.nav-off footer .magazine-footer,
      body.mag-footer footer .magazine-footer { display: block !important; }
    </style>
  </head>
  <body class={magazineFooter ? 'mag-footer' : undefined}>
    <a href="#main" class="skip-link">Skip to main content</a>
    <GieMannTheme />
    {!hideNav && <Nav />}
    {showBreadcrumbs && (
      <nav aria-label="Breadcrumb" style="background:#1c1917;padding:calc(76px + 0.6rem) 1.5rem 0.6rem;border-bottom:1px solid rgba(196,145,42,0.1);">
        <ol style="display:flex;align-items:center;gap:0.4rem;list-style:none;margin:0;padding:0;max-width:1280px;margin:0 auto;flex-wrap:wrap;">
          {breadcrumbs.map((crumb, i) => (
            <li style="display:flex;align-items:center;gap:0.4rem;">
              {i < breadcrumbs.length - 1 ? (
                <Fragment>
                  <a href={crumb.href} style="font-family:var(--font-sans);font-size:0.65rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(196,145,42,0.7);text-decoration:none;">{crumb.label}</a>
                  <span style="font-size:0.6rem;color:rgba(242,239,233,0.2);" aria-hidden="true">›</span>
                </Fragment>
              ) : (
                <span style="font-family:var(--font-sans);font-size:0.65rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(242,239,233,0.45);" aria-current="page">{crumb.label}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}
    <main id="main">
      <slot />
    </main>

    {/* Article enhancements: progress bar, sticky ToC, back-to-top. All insights articles. */}
    {_isInsightsArticle && (
      <Fragment>
        <div id="article-progress" aria-hidden="true" style="position:fixed;top:0;left:0;right:0;height:3px;background:rgba(255,255,255,0.06);z-index:10001;pointer-events:none;">
          <div id="article-progress-fill" style="height:100%;width:0;background:var(--color-gold);transition:width 0.05s linear;"></div>
        </div>

        <aside id="article-toc" aria-label="In this article" hidden style="position:fixed;top:50%;right:1.5rem;transform:translateY(-50%);width:220px;max-height:70vh;overflow-y:auto;padding:1rem 1.25rem;background:rgba(240,236,228,0.92);backdrop-filter:blur(6px);border:1px solid rgba(28,25,23,0.08);border-radius:8px;z-index:40;">
          <p style="font-family:var(--font-sans);font-size:0.55rem;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);margin:0 0 0.75rem;">In this article</p>
          <ol id="article-toc-list" style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.5rem;"></ol>
        </aside>

        <button id="article-back-to-top" type="button" aria-label="Back to top" hidden style="position:fixed;bottom:1.5rem;right:1.5rem;width:44px;height:44px;border:none;border-radius:50%;background:#0a0806;color:#f0ece4;cursor:pointer;z-index:50;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 14px rgba(0,0,0,0.18);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
        </button>

        <style>
          #article-toc-list a { font-family: var(--font-sans); font-size: 0.78rem; line-height: 1.4; color: var(--color-text-secondary); text-decoration: none; display: block; padding-left: 0.6rem; border-left: 2px solid transparent; transition: color 0.15s, border-color 0.15s; }
          #article-toc-list a:hover { color: var(--color-text-primary); }
          #article-toc-list a.is-active { color: var(--color-text-primary); border-left-color: var(--color-gold); font-weight: 600; }
          @media (max-width: 1279px) { #article-toc { display: none !important; } }
        </style>

        <script is:inline>
          (function () {
            var main = document.getElementById('main');
            if (!main) return;

            // Reading progress
            var fill = document.getElementById('article-progress-fill');
            function updateProgress() {
              var rect = main.getBoundingClientRect();
              var scrolled = -rect.top;
              var total = rect.height - window.innerHeight;
              var pct = total > 0 ? Math.max(0, Math.min(1, scrolled / total)) : 0;
              if (fill) fill.style.width = (pct * 100).toFixed(1) + '%';
            }

            // Back-to-top
            var btn = document.getElementById('article-back-to-top');
            function updateBackToTop() {
              if (!btn) return;
              if (window.scrollY > 600) btn.hidden = false; else btn.hidden = true;
            }
            if (btn) btn.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: 'smooth' }); });

            // Build ToC from h2s inside main
            var headings = Array.prototype.slice.call(main.querySelectorAll('h2'));
            var toc = document.getElementById('article-toc');
            var list = document.getElementById('article-toc-list');
            var links = [];
            if (headings.length >= 3 && toc && list) {
              headings.forEach(function (h, i) {
                if (!h.id) {
                  var slug = (h.textContent || '').trim().toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').slice(0, 60) || ('section-' + i);
                  h.id = slug;
                }
                var li = document.createElement('li');
                var a = document.createElement('a');
                a.href = '#' + h.id;
                a.textContent = h.textContent || '';
                a.dataset.target = h.id;
                li.appendChild(a);
                list.appendChild(li);
                links.push(a);
              });
              toc.hidden = false;

              var obs = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                  if (entry.isIntersecting) {
                    var id = entry.target.id;
                    links.forEach(function (l) { l.classList.toggle('is-active', l.dataset.target === id); });
                  }
                });
              }, { rootMargin: '-30% 0px -60% 0px' });
              headings.forEach(function (h) { obs.observe(h); });
            }

            function onScroll() { updateProgress(); updateBackToTop(); }
            window.addEventListener('scroll', onScroll, { passive: true });
            window.addEventListener('resize', updateProgress, { passive: true });
            onScroll();
          })();
        </script>
      </Fragment>
    )}

    {/* Email capture, all insights articles */}
    {_isInsightsArticle && (
      <section style="background:var(--color-surface-1);padding:3.5rem 0;border-top:1px solid rgba(28,25,23,0.08);">
        <div class="max-w-[640px] mx-auto px-8 text-center">
          <p style="font-family:var(--font-sans);font-size:0.6rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">Brisbane Inner East Market</p>
          <h2 style="font-family:var(--font-serif);font-size:clamp(1.3rem,3vw,1.75rem);font-weight:400;color:var(--color-text-primary);line-height:1.2;margin-bottom:0.75rem;">
            Stay across what is happening in your suburb
          </h2>
          <p style="font-size:0.875rem;color:var(--color-text-secondary);line-height:1.8;margin-bottom:1.75rem;max-width:44ch;margin-left:auto;margin-right:auto;">
            One email per quarter. What sold, what it sold for, and what it means for your property's value. No spam.
          </p>
          <form
            method="POST" action="https://formspree.io/f/xnjgedwp"
            style="display:flex;gap:0.6rem;max-width:480px;margin:0 auto;flex-wrap:wrap;"
          >
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" />
            <input type="hidden" name="_subject" value="Market update signup - insights article" />
            <input type="hidden" name="form_type" value="insights_market_update_signup" />
            {/* Invisible context: which article they signed up from is the
                best lead signal we have (a "selling in X" slug names their
                suburb). Costs the reader nothing. */}
            <input type="hidden" name="article" value={_bPath} />
            <input type="hidden" name="page_title" value={title} />
            <input
              type="text" name="first_name" required placeholder="First name" autocomplete="given-name"
              style="flex:1 1 34%;min-width:120px;font-family:var(--font-sans);font-size:0.875rem;padding:0.85rem 1.1rem;border:1px solid rgba(28,25,23,0.2);background:var(--color-surface-0);color:var(--color-text-primary);outline:none;"
            />
            <input
              type="text" name="suburb" required placeholder="Your suburb" autocomplete="address-level2"
              style="flex:1 1 44%;min-width:150px;font-family:var(--font-sans);font-size:0.875rem;padding:0.85rem 1.1rem;border:1px solid rgba(28,25,23,0.2);background:var(--color-surface-0);color:var(--color-text-primary);outline:none;"
            />
            <input
              type="email" name="email" required placeholder="Your email address" autocomplete="email"
              style="flex:1 1 55%;min-width:200px;font-family:var(--font-sans);font-size:0.875rem;padding:0.85rem 1.1rem;border:1px solid rgba(28,25,23,0.2);background:var(--color-surface-0);color:var(--color-text-primary);outline:none;"
            />
            <button type="submit" class="btn-gold" style="white-space:nowrap;"
              onclick="gtag('event', 'email_signup_click', { event_category: 'lead', event_label: 'Insights Article' })"
            >
              Subscribe
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </form>
          <p style="font-size:0.7rem;color:var(--color-text-muted);margin-top:0.875rem;">
            Free. Unsubscribe at any time. <a href="/privacy" style="color:var(--color-gold);text-decoration:underline;">Privacy Policy</a>
          </p>
        </div>
      </section>
    )}

    {/* Related articles, all insights article pages */}
    {_isInsightsArticle && _bParts[1] && (
      <RelatedArticles slug={_bParts[1]} />
    )}

    {/* #8, Suburb → Insight selling guide link */}
    {_suburbSlug && (
      <div style="background:var(--color-surface-1);padding:3rem 0;border-top:1px solid rgba(28,25,23,0.08);">
        <div class="max-w-[1400px] mx-auto px-8 lg:px-12" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:2rem;">
          <div>
            <span class="eyebrow mb-2" style="display:block;">Seller Guide</span>
            <h2 style="font-family:var(--font-serif);font-size:clamp(1.3rem,2.5vw,1.75rem);font-weight:400;color:var(--color-text-primary);margin-bottom:0.6rem;line-height:1.2;">
              Thinking of selling in {_suburbName}?
            </h2>
            <p style="font-size:0.85rem;color:var(--color-text-secondary);max-width:50ch;line-height:1.75;">
              Read Daniel's complete selling guide, what buyers look for, recent comparable sales, and how to prepare for the best result.
            </p>
          </div>
          {/* Text link, not a gold button: the footer walkthrough CTA below
              is the page's ONE hard CTA (Daniel's rule, 2026-07-19). */}
          <a href={`/insights/selling-in-${_suburbSlug}`} style="flex-shrink:0;display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-gold);text-decoration:underline;text-underline-offset:4px;transition:color 0.2s;" onmouseover="this.style.color='#6b4610'" onmouseout="this.style.color='var(--color-gold)'">
            Read the {_suburbName} Selling Guide →
          </a>
        </div>
      </div>
    )}

    {/* #11, Insight → Suburb cross-link + CTA */}
    {_insightSuburbSlug && (
      <div style="background:var(--color-surface-1);padding:3rem 0;border-top:1px solid rgba(28,25,23,0.08);">
        <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;">
            <a href={`/suburbs/${_insightSuburbSlug}`} style="display:flex;flex-direction:column;gap:0.5rem;padding:1.75rem 2rem;background:var(--color-surface-0);border:1px solid rgba(28,25,23,0.1);text-decoration:none;transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(196,145,42,0.4)'" onmouseout="this.style.borderColor='rgba(28,25,23,0.1)'">
              <span class="eyebrow" style="display:block;">Suburb Profile</span>
              <span style="font-family:var(--font-serif);font-size:1.1rem;color:var(--color-text-primary);">{_insightSuburbName}, market data, prices & trends →</span>
            </a>
            <div style="padding:1.75rem 2rem;background:var(--color-gold-muted);border:1px solid rgba(196,145,42,0.2);border-radius:12px;">
              <p style="font-family:var(--font-serif);font-style:italic;font-size:1rem;color:var(--color-text-primary);margin-bottom:0.6rem;">Want to know what your {_insightSuburbName} home could sell for?</p>
              <p style="font-size:0.8rem;color:var(--color-text-secondary);margin-bottom:1.25rem;line-height:1.7;">Daniel walks through your property and reviews recent sold results in your street. Free, no obligation.</p>
              {/* Text link, not a button: the footer CTA below is the one
                  hard CTA per page (Daniel's rule, 2026-07-19). */}
              <a href="/walkthrough" style="display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-sans);font-size:0.78rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-gold);text-decoration:underline;text-underline-offset:4px;transition:color 0.2s;" onmouseover="this.style.color='#6b4610'" onmouseout="this.style.color='var(--color-gold)'">Book a Free Walk Through →</a>
            </div>
          </div>
        </div>
      </div>
    )}

    <Footer hideFooterCta={hideFooterCta} />

    <!-- Mobile sticky call bar -->
    <div class={`mobile-call-bar${hideMobileCta ? ' hidden-by-page' : ''}`}>
<a href="sms:+61412523821" class="mobile-call-btn" onclick="gtag('event', 'mobile_sms_click', { event_category: 'contact', event_label: 'Mobile Call Bar' })">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        Message
      </a>
      <a href="tel:+61412523821" class="mobile-call-btn primary" onclick="gtag('event', 'mobile_call_click', { event_category: 'contact', event_label: 'Mobile Call Bar' })">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 5.92 5.92l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.21 16z"/>
        </svg>
        Call
      </a>
    </div>

    <!-- Meta Pixel · deferred to after load so it never blocks first paint -->
    <script>
      window.addEventListener('load', function() {
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '1493183205636761');
        fbq('track', 'PageView');
      });
    </script>
    <noscript>
      <img height="1" width="1" style="display:none" alt=""
        src="https://www.facebook.com/tr?id=1493183205636761&ev=PageView&noscript=1"/>
    </noscript>

    <!-- Google Analytics 4, measurement script deferred so it never blocks paint -->
    <script is:inline defer src="https://www.googletagmanager.com/gtag/js?id=G-K1P37GL73K"></script>
    <script is:inline>
      gtag('js', new Date());
      gtag('config', 'G-K1P37GL73K');
    </script>
    <!-- Web Vitals → GA4 (bundled locally, no unpkg DNS cost) -->
    <script>
      import {onCLS,onINP,onLCP,onFCP,onTTFB} from 'web-vitals';
      function sendVital({name,value,rating}:{name:string,value:number,rating:string}){
        if(typeof gtag==='undefined')return;
        gtag('event',name,{value:Math.round(name==='CLS'?value*1000:value),metric_rating:rating,non_interaction:true});
      }
      onCLS(sendVital);onINP(sendVital);onLCP(sendVital);onFCP(sendVital);onTTFB(sendVital);
    </script>

    <!-- GA4 Enhanced Event Tracking -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('a').forEach(function(link) {
          link.addEventListener('click', function() {
            const href = link.getAttribute('href') || '';
            if (href.startsWith('tel:')) {
              gtag('event', 'phone_click', { event_category: 'contact', event_label: href.replace('tel:', '') });
            }
            if (href.startsWith('mailto:')) {
              gtag('event', 'email_click', { event_category: 'contact', event_label: href.replace('mailto:', '') });
            }
            if (href.startsWith('http') && !href.includes('danielgierach.com')) {
              gtag('event', 'outbound_click', { event_category: 'outbound', event_label: href });
            }
          });
        });
      });
    </script>
    <!-- Global CTA click tracking, ANLY-003 -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var link = e.target.closest('[data-cta]');
        if (!link) return;
        var ctaName = link.getAttribute('data-cta');
        var linkUrl = link.getAttribute('href') || null;
        var pagePath = location.pathname;
        if (typeof fbq === 'function') {
          fbq('trackCustom', 'CTAClick', { cta_name: ctaName, page_path: pagePath });
        }
        if (typeof gtag === 'function') {
          // Generic event so all CTA clicks roll up under one report line
          gtag('event', 'cta_click', { cta_name: ctaName, page_path: pagePath, link_url: linkUrl });
          // Also fire the cta_name as its own event so it shows up discretely
          // in GA4 Events report without needing to drill into cta_click params
          gtag('event', ctaName, { event_category: 'cta', page_path: pagePath, link_url: linkUrl });
        }
      });
    </script>
    <!-- Formspree → /thank-you redirect -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('form[action*="formspree.io"]').forEach(function(form) {
          form.addEventListener('submit', function(e) {
            e.preventDefault();
            fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { 'Accept': 'application/json' }
            }).finally(function() {
              const nextInput = form.querySelector('input[name="_next"]');
              window.location.href = nextInput ? nextInput.value : '/thank-you';
            });
          });
        });
      });
    </script>
    <!-- Global form field validation tick · targets any .form-field input/textarea -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll<HTMLElement>('.form-field').forEach(field => {
          // Skip if already wrapped (e.g. contact/walkthrough pages add their own)
          if (field.parentElement?.classList.contains('field-wrap')) return;

          const wrap = document.createElement('div');
          wrap.className = 'field-wrap';
          field.parentNode!.insertBefore(wrap, field);
          wrap.appendChild(field);

          const tick = document.createElement('span');
          tick.className = 'field-tick';
          tick.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
          wrap.appendChild(tick);

          function check() {
            const el = field as HTMLInputElement;
            const valid = el.value.trim() !== '' && (!el.checkValidity || el.checkValidity());
            field.classList.toggle('valid', valid);
            tick.classList.toggle('show', valid);
          }

          field.addEventListener('blur', check);
          field.addEventListener('focus', () => {
            field.classList.remove('valid');
            tick.classList.remove('show');
          });
        });
      });
    </script>

    <!-- Global scroll reveal -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .card-reveal').forEach((el, i) => {
        const delay = el.getAttribute('data-delay') || '0';
        (el as HTMLElement).style.transitionDelay = `${delay}ms`;
        observer.observe(el);
      });

      // ── FAQ details/summary toggle icon ──
      document.querySelectorAll('details').forEach(details => {
        const summary = details.querySelector('summary');
        const icon = summary?.querySelector('span:last-child');
        if (!icon) return;
        details.addEventListener('toggle', () => {
          icon.textContent = details.open ? '×' : '+';
          (icon as HTMLElement).style.transform = details.open ? 'rotate(0deg)' : '';
        });
      });
    </script>

  </body>
</html>
