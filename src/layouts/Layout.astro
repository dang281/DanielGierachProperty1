---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  schema?: any;
  preloadImage?: string;
  hideMobileCta?: boolean;
}

const {
  title = "Daniel Gierach | Real Estate Agent Brisbane Inner East",
  description = 'Data-driven campaigns and exceptional outcomes across Brisbane\'s inner east and south. Serving Bulimba, Balmoral, Hawthorne, Norman Park, Morningside and surrounds.',
  schema,
  preloadImage,
  hideMobileCta = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://danielgierach.com').href;

// Breadcrumb computation (moved out of template to avoid IIFE/JSX issues)
const _bPath = Astro.url.pathname.replace(/\/$/, '');
const _bParts = _bPath.split('/').filter(Boolean);
const _bSectionLabels: Record<string, string> = {
  suburbs: 'Suburbs', insights: 'Insights', tools: 'Tools',
  listings: 'Listings', contact: 'Contact', walkthrough: 'Free Appraisal', 'property-worth': 'Property Worth',
};
const breadcrumbs: { label: string; href: string }[] = [{ label: 'Home', href: '/' }];
if (_bParts.length >= 1 && _bSectionLabels[_bParts[0]]) {
  breadcrumbs.push({ label: _bSectionLabels[_bParts[0]], href: `/${_bParts[0]}` });
}
if (_bParts.length >= 2) {
  const _bLabel = _bParts[1].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  breadcrumbs.push({ label: _bLabel, href: _bPath });
}
const showBreadcrumbs = breadcrumbs.length > 1;

const globalSchema = {
  "@context": "https://schema.org",
  "@graph": [
  {
  "@type": ["RealEstateAgent", "LocalBusiness"],
  "@id": "https://danielgierach.com/#business",
  "name": "Daniel Gierach",
  "description": "Brisbane inner-east real estate specialist at Ray White Bulimba. Expert in property sales across Camp Hill, Norman Park, Hawthorne, Balmoral, Seven Hills and surrounds.",
  "url": "https://danielgierach.com",
  "telephone": "+61412523821",
  "email": "daniel.gierach@raywhite.com",
  "image": "https://cdn6.ep.dynamics.net/s3/rw-media/memberphotos/88889915-cef5-4a5f-9c19-0cea700d7bca.jpeg",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Unit 6, 57-59 Oxford Street",
    "addressLocality": "Bulimba",
