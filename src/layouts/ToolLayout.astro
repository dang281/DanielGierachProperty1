---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  tool: string;
  phase?: string;
}

const { title, description, tool, phase = 'Seller Tools' } = Astro.props;
---

<Layout title={`${title} | Dan's Website`} description={description}>

<style is:global>
  /* Tool pages always have a light background — lock the nav into its scrolled state immediately via CSS so there is no transparent flash or backdrop-filter bleed-through on scroll */
  body.tool-page #site-header {
    background: rgba(247,245,240,0.97) !important;
    backdrop-filter: blur(24px) saturate(1.3) !important;
    -webkit-backdrop-filter: blur(24px) saturate(1.3) !important;
    border-bottom: 1px solid rgba(28,25,23,0.08) !important;
    box-shadow: 0 2px 16px rgba(28,25,23,0.06) !important;
    transition: none !important;
  }
</style>

<script>
  // Tool pages have a light background from the top — force nav into its scrolled state immediately
  (function () {
    function applyLightNav() {
      const header = document.getElementById('site-header');
      const logoName = document.getElementById('logo-name');
      const navLinks = document.querySelectorAll<HTMLElement>('#nav-links .nav-link-mono, #nav-cta .nav-link-mono');
      if (!header) return;
      // Flag tells Nav scroll handler never to revert to white text on this page
      document.body.dataset.lightNav = 'true';
      header.classList.add('glass-nav');
      header.style.boxShadow = '0 4px 24px rgba(28,25,23,0.1)';
      if (logoName) logoName.style.color = 'var(--color-text-primary)';
      navLinks.forEach(el => el.style.color = '');
    }
    document.body.classList.add('tool-page');
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyLightNav);
    } else {
      applyLightNav();
    }
  })();
</script>

  <!-- Tool header -->
  <div style="background:var(--color-surface-1);padding-top:8rem;padding-bottom:3rem;border-bottom:1px solid rgba(72,72,72,0.15);">
    <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-6" style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;">
        <a href="/" style="color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">Home</a>
        <span style="color:rgba(72,72,72,0.4);">/</span>
        <a href="/tools" style="color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">Tools</a>
        <span style="color:rgba(72,72,72,0.4);">/</span>
        <span style="color:var(--color-gold);">{tool}</span>
      </nav>
      <span class="eyebrow mb-3" style="display:block;">{phase}</span>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2rem,4vw,3rem);font-weight:400;color:var(--color-text-primary);letter-spacing:-0.01em;line-height:1.1;">
        {title}
      </h1>
      {description && (
        <p style="font-size:0.9rem;color:var(--color-text-secondary);margin-top:0.75rem;max-width:56ch;line-height:1.75;">
          {description}
        </p>
      )}
    </div>
  </div>

  <!-- Tool content -->
  <div style="background:var(--color-base);min-height:60vh;padding:3rem 0 6rem;">
    <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
      <slot />
    </div>
  </div>

  <!-- Tool CTA -->
  <div style="background:var(--color-surface-1);padding:3.5rem 0;border-top:1px solid rgba(72,72,72,0.15);">
    <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
      <div style="padding:2.5rem 3rem;background:var(--color-gold-muted);border:1px solid rgba(196,145,42,0.15);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:2rem;">
        <div>
          <p style="font-family:var(--font-serif);font-size:1.1rem;font-style:italic;color:var(--color-text-primary);margin-bottom:0.4rem;">Want to know what this means for your property?</p>
          <p style="font-size:0.82rem;color:var(--color-text-secondary);line-height:1.75;">Daniel walks through your property, reviews recent sold results in your street, and gives you a clear number. Free, no obligation.</p>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;flex-shrink:0;">
          <a href="/walkthrough" class="btn-gold">Book a Free Walk Through</a>
          <a href="tel:+61412523821" class="btn-outline-gold">Call 0412 523 821</a>
        </div>
      </div>
      <div style="margin-top:1.5rem;display:flex;align-items:center;">
        <a href="/tools" style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Back to All Tools
        </a>
      </div>
    </div>
  </div>
</Layout>
