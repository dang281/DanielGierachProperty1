---
import Layout from './Layout.astro';
import ResourceCTA from '../components/ResourceCTA.astro';

interface Props {
  title: string;
  description?: string;
  tool: string;
  phase?: string;
  resourceSlug?: string;
  manifest?: string;
  appleTouchIcon?: string;
  faviconSvg?: string;
  appleWebAppTitle?: string;
  ogImage?: string;
  draft?: boolean;
  hideToolCta?: boolean;
  hideFooterCta?: boolean;
  hideNav?: boolean;
  magazineFooter?: boolean;
}

const { title, description, tool, phase = 'Seller Tools', resourceSlug, manifest, appleTouchIcon, faviconSvg, appleWebAppTitle, ogImage, draft = false, hideToolCta = false, hideFooterCta = false, hideNav = false, magazineFooter = false } = Astro.props;
---

<Layout title={`${title} | Daniel Gierach Property`} description={description} hideBreadcrumbs={true} manifest={manifest} appleTouchIcon={appleTouchIcon} faviconSvg={faviconSvg} appleWebAppTitle={appleWebAppTitle} ogImage={ogImage} draft={draft} hideFooterCta={hideFooterCta} hideNav={hideNav} magazineFooter={magazineFooter}>

<style is:global>
  /* Tool pages lock the nav into its scrolled (dark glass) state from first paint */
  body.tool-page #site-header {
    background: rgba(10,8,6,0.94) !important;
    backdrop-filter: blur(20px) saturate(1.1) !important;
    -webkit-backdrop-filter: blur(20px) saturate(1.1) !important;
    border-bottom: 1px solid rgba(196,145,42,0.15) !important;
    box-shadow: 0 4px 32px rgba(0,0,0,0.5) !important;
    transition: none !important;
  }
  .tool-header { padding-top: 8rem; padding-bottom: 3rem; }
  .tool-title { font-size: clamp(2rem, 4vw, 3rem); }
  .tool-content { padding: 3rem 0 6rem; }
  @media (max-width: 640px) {
    .tool-header { padding-top: calc(72px + 0.75rem); padding-bottom: 1rem; }
    .tool-title { font-size: 1.4rem; }
    .tool-breadcrumb { margin-bottom: 0.5rem; }
    .tool-desc { display: none; }
    .eyebrow { display: none !important; }
    .tool-content { padding: 0.75rem 0 2rem; }
  }

  /* GieMann radius pass: tool pages build cards from per-tool classes
     (sc-card, ds-result-card, fb-card, step-panel, cg-note-box, ...) and
     the occasional inline white div. One catch-all gives every card-like
     box the standard 16px radius instead of editing 56 bespoke pages.
     Radius on non-box elements that happen to match (e.g. card titles)
     is invisible, so over-matching is harmless. */
  body.tool-page [class*="-card"],
  body.tool-page [class*="-panel"],
  body.tool-page [class*="-box"],
  body.tool-page [class*="-block"],
  body.tool-page div[style*="background:#fff"],
  body.tool-page div[style*="background:#ffffff"] {
    border-radius: 16px;
  }

  /* Print: strip site chrome so tools print as standalone documents.
     Page-specific elements use .no-print or page-level @media print rules. */
  @media print {
    @page { margin: 1.5cm 1.25cm; }
    body { background: white !important; color: #000 !important; }
    #site-header,
    #tool-sticky-cta,
    #tool-cta,
    .tool-breadcrumb,
    footer,
    .no-print { display: none !important; }
    .tool-header {
      padding: 0.25rem 0 0.75rem !important;
      border-bottom: 1px solid #000 !important;
      background: white !important;
    }
    .tool-content { padding: 0.5rem 0 0 !important; background: white !important; }
    .tool-title { font-size: 1.4rem !important; color: #000 !important; }
    .tool-desc { display: none !important; }
    .eyebrow { font-size: 0.55rem !important; color: #000 !important; }
    a { color: #000 !important; text-decoration: none !important; }
  }
</style>

<script>
  // Tool pages force nav into its scrolled (dark glass) state immediately
  (function () {
    function applyLightNav() {
      const header = document.getElementById('site-header');
      if (!header) return;
      document.body.dataset.lightNav = 'true';
      header.classList.add('glass-nav');
    }
    document.body.classList.add('tool-page');
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyLightNav);
    } else {
      applyLightNav();
    }
  })();
</script>

  <!-- Tool header -->
  <div class="tool-header" style="background:var(--color-surface-1);border-bottom:1px solid rgba(72,72,72,0.15);">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-8 lg:px-12">
      <!-- Breadcrumb -->
      <nav class="tool-breadcrumb flex items-center gap-2 mb-4" style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;">
        <a href="/" style="color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">Home</a>
        <span style="color:rgba(72,72,72,0.4);">/</span>
        <a href="/tools" style="color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">Tools</a>
        <span style="color:rgba(72,72,72,0.4);">/</span>
        <span style="color:var(--color-gold);">{tool}</span>
      </nav>
      <span class="eyebrow mb-2" style="display:block;">{phase}</span>
      <h1 class="tool-title" style="font-family:var(--font-serif);font-weight:400;color:var(--color-text-primary);letter-spacing:-0.01em;line-height:1.1;">
        {title}
      </h1>
      {description && (
        <p class="tool-desc" style="font-size:0.9rem;color:var(--color-text-secondary);margin-top:0.75rem;max-width:78ch;line-height:1.75;">
          {description}
        </p>
      )}
    </div>
  </div>

  <!-- Tool content -->
  <div class="tool-content" style="background:var(--color-base);min-height:60vh;">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-8 lg:px-12">
      <slot />
      {resourceSlug && (
        <div class="max-w-[780px] mx-auto">
          <ResourceCTA slug={resourceSlug} />
        </div>
      )}
    </div>
  </div>

  <!-- Sticky tool CTA bar, visible on mobile after 300px scroll -->
  <div id="tool-sticky-cta" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:90;background:#1c1917;border-top:1px solid rgba(196,145,42,0.3);padding:0.85rem 1.25rem;gap:0.75rem;align-items:center;justify-content:space-between;box-shadow:0 -6px 24px rgba(0,0,0,0.3);">
    <p style="font-family:var(--font-sans);font-size:0.72rem;font-weight:600;color:rgba(240,236,228,0.85);margin:0;flex:1;">Questions about these numbers?</p>
    <a href="/walkthrough" style="display:inline-flex;align-items:center;gap:0.4rem;background:#c4912a;color:#1c1917;font-family:var(--font-sans);font-size:0.65rem;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;padding:0.65rem 1.1rem;border-radius:8px;white-space:nowrap;flex-shrink:0;">
      Talk to Daniel →
    </a>
  </div>
  <script>
    (function(){
      const bar = document.getElementById('tool-sticky-cta');
      if(!bar) return;
      let shown = false;
      window.addEventListener('scroll', function(){
        if(window.scrollY > 300 && !shown){ bar.style.display='flex'; shown=true; }
        else if(window.scrollY <= 300 && shown){ bar.style.display='none'; shown=false; }
      }, {passive:true});
    })();
  </script>

  <!-- Tool CTA -->
  {!hideToolCta && (
  <div id="tool-cta" style="background:var(--color-surface-1);padding:3.5rem 0;border-top:1px solid rgba(72,72,72,0.15);">
    <div class="max-w-[1400px] mx-auto px-8 lg:px-12">
      <div style="padding:2rem 1.5rem;background:var(--color-gold-muted);border:1px solid rgba(196,145,42,0.15);border-radius:8px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1.5rem;">
        <div style="min-width:0;flex:1 1 240px;">
          <p style="font-family:var(--font-serif);font-size:1.1rem;font-style:italic;color:var(--color-text-primary);margin-bottom:0.4rem;">Want to know what this means for your property?</p>
          <p style="font-size:0.82rem;color:var(--color-text-secondary);line-height:1.75;">Daniel walks through your property, reviews recent sold results in your street, and gives you a clear number. Free, no obligation.</p>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;flex:1 1 auto;">
          <a href="/walkthrough" class="btn-gold" style="flex:1 1 auto;text-align:center;min-width:160px;">Book a Free Walk Through</a>
          <a href="tel:+61412523821" class="btn-outline-gold" style="flex:1 1 auto;text-align:center;min-width:140px;">Call 0412 523 821</a>
        </div>
      </div>
      <div style="margin-top:1.5rem;display:flex;align-items:center;">
        <a href="/tools" style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.65rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-text-muted)'">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Back to All Tools
        </a>
      </div>
    </div>
  </div>
  )}
</Layout>
