---
// Stripped layout for paid ad landing pages, no nav, no footer, no distractions.
// `manifest`, `appleTouchIcon`, `faviconSvg` let individual pages override the
// default DG branding — used by Conrad-first pages so the "Add to Home Screen"
// PWA icon is CL instead of DG.
interface Props {
  title?: string;
  description?: string;
  manifest?: string;
  appleTouchIcon?: string;
  faviconSvg?: string;
  appleWebAppTitle?: string;
}

const {
  title = "Free Property Report | Daniel Gierach Property",
  description = "Find out what your home is worth. Free report based on recent comparable sales. No obligation.",
  manifest = '/site.webmanifest',
  // Keep the ?v cache-bust in step with Layout.astro or landing pages
  // serve the stale pre-refresh favicon (head drift, 2026-07-13).
  appleTouchIcon = '/apple-touch-icon.png?v=3',
  faviconSvg = '/favicon.svg?v=3',
  appleWebAppTitle = 'Daniel Gierach',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://danielgierach.com').href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#e6d9bd" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={faviconSvg} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon} />
    <link rel="manifest" href={manifest} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={appleWebAppTitle} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..700&family=Manrope:wght@300;400;600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..700&family=Manrope:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Meta Pixel -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1493183205636761');
      fbq('track', 'PageView');
</script>
    <noscript>
      <img height="1" width="1" style="display:none" alt=""
        src="https://www.facebook.com/tr?id=1493183205636761&ev=PageView&noscript=1"/>
    </noscript>

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --gold: #b98229;
        --gold-light: #6b4610;
        --dark: #e6d9bd;
        --cream: #191817;
        --font-serif: 'Fraunces', Georgia, serif;
        --font-sans: 'Manrope', system-ui, sans-serif;
      }
      html { scroll-behavior: smooth; }
      body { background: var(--dark); color: var(--cream); font-family: var(--font-sans); }
      *:focus-visible { outline: 3px solid var(--gold); outline-offset: 2px; }
      .skip-link {
        position: absolute; top: -40px; left: 0; background: #000; color: #fff;
        padding: 8px 12px; z-index: 100; text-decoration: none;
        font-family: var(--font-sans); font-size: 0.8rem; font-weight: 700;
      }
      .skip-link:focus { top: 0; }
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <main id="main">
      <slot />
    </main>

    <!-- Google Analytics 4 -->
    <script is:inline defer src="https://www.googletagmanager.com/gtag/js?id=G-K1P37GL73K"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-K1P37GL73K');
    </script>

    <!-- Global CTA click tracking (mirrors Layout.astro for LandingLayout pages). -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var link = e.target.closest('[data-cta]');
        if (!link) return;
        var ctaName = link.getAttribute('data-cta');
        var linkUrl = link.getAttribute('href') || null;
        var pagePath = location.pathname;
        if (typeof fbq === 'function') {
          fbq('trackCustom', 'CTAClick', { cta_name: ctaName, page_path: pagePath });
        }
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', { cta_name: ctaName, page_path: pagePath, link_url: linkUrl });
          gtag('event', ctaName, { event_category: 'cta', page_path: pagePath, link_url: linkUrl });
        }
      });
    </script>
  </body>
</html>
