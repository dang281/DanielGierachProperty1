{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "images": {
    "sizes": [96, 128, 256, 640, 750, 1080, 1200, 1440, 1920, 2048],
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 2592000,
    "remotePatterns": [
      { "protocol": "https", "hostname": "cdn6.ep.dynamics.net" }
    ]
  },
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/lib/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.danielgierach.com" }],
      "destination": "https://danielgierach.com/:path*",
      "permanent": true
    },
    {
      "source": "/appraisal",
      "destination": "/walkthrough",
      "permanent": true
    },
    {
      "source": "/property-tools",
      "destination": "/helpingyoubuyandsell",
      "permanent": true
    },
    {
      "source": "/property-tools-collective",
      "destination": "/helpingyoubuyandsell",
      "permanent": true
    },
    {
      "source": "/helpingyoubuyandsell-collective",
      "destination": "/helpingyoubuyandsell",
      "permanent": true
    },
    {
      "source": "/meet-the-team-dash",
      "destination": "/meet-the-team",
      "permanent": true
    },
    {
      "source": "/about-us",
      "destination": "/meet-the-team",
      "permanent": true
    },
    {
      "source": "/ig",
      "destination": "/helpingyoubuyandsell/?utm_source=instagram&utm_medium=social&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/ig-team",
      "destination": "/helpingyoubuyandsell/?utm_source=instagram&utm_medium=social&utm_campaign=bio-team",
      "permanent": false
    },
    {
      "source": "/fb",
      "destination": "/helpingyoubuyandsell/?utm_source=facebook&utm_medium=social&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/linkedin",
      "destination": "/helpingyoubuyandsell/?utm_source=linkedin&utm_medium=social&utm_campaign=bio",
      "permanent": false
    }
  ]
}
